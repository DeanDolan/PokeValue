<%#
References:
- Rails Action View helpers:
  https://guides.rubyonrails.org/action_view_helpers.html
- Bootstrap modals and buttons:
  https://getbootstrap.com/docs/5.3/components/modal/
  https://getbootstrap.com/docs/5.3/components/buttons/
%>

<%
listing = @listing
seller = listing.seller
seller_name = marketplace_seller_name(seller, listing.seller_id)
stats = @seller_stats || { avg: 0.0, count: 0 }
era = marketplace_era(listing.set_slug)
display_product = marketplace_display_product(listing)
seller_badges = marketplace_badges_for(seller)
admin_can_delete = @admin_can_delete
is_seller = @is_seller
can_offer = @can_offer
my_offers = @my_offers || []
seller_offers = @seller_offers || []
reviews = @recent_reviews || []
can_edit_listing = current_user && (is_seller || admin_can_delete) && listing.status.to_s == "active"
confirmed_paid_buyer =
  current_user &&
  !is_seller &&
  MarketplaceOffer.where(
    marketplace_listing_id: listing.id,
    seller_id: listing.seller_id,
    buyer_id: current_user.id,
    status: "confirmed_paid"
  ).exists?
already_reviewed_seller =
  current_user &&
  Review.where(seller_id: listing.seller_id, reviewer_id: current_user.id).exists?
can_review_seller = confirmed_paid_buyer && !already_reviewed_seller
review_form_id = "ml-review-form-#{listing.id}"
%>

<div id="marketplace-listing-show" class="container py-4">
  <style>
    .ml-wrap{display:flex;gap:18px;align-items:flex-start;flex-wrap:wrap}
    .ml-left{flex:1;min-width:320px}
    .ml-block,.ml-section{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.08)}
    .ml-section{margin-top:14px}
    .ml-title{font-size:1.2rem;margin:0 0 6px}
    .ml-sub{color:#6b7280;font-size:.85rem;margin:0 0 14px}
    .ml-line{font-size:.88rem;margin:6px 0}
    .ml-actions{margin-top:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .ml-badges{display:inline-flex;gap:6px;align-items:center;flex-wrap:wrap}
    .ml-badges img{height:22px;width:22px;object-fit:contain}
    .pv-rating-stars{display:inline-flex;gap:1px;white-space:nowrap;color:#d4a017;line-height:1}
    .pv-rating-star,.pv-rating-half{display:inline-block;color:#d4a017;line-height:1;font-weight:900}
    .ml-offer-grid{display:grid;grid-template-columns:1fr;gap:10px}
    .ml-offer-card,.ml-review-card{border:1px solid #e5e7eb;border-radius:12px;padding:12px;background:#fafafa}
    .ml-offer-top,.ml-review-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;flex-wrap:wrap}
    .ml-offer-name,.ml-review-name{font-weight:800;color:#111827;font-size:.9rem}
    .ml-offer-meta,.ml-review-meta{color:#6b7280;font-size:.78rem}
    .ml-offer-amount{font-weight:900;color:#111827}
    .ml-offer-status{display:inline-flex;border-radius:999px;padding:.22rem .55rem;font-size:.68rem;font-weight:900;border:1px solid #d1d5db;background:#fff;color:#111827}
    .ml-offer-pending{background:#fffbeb;border-color:#fcd34d;color:#92400e}
    .ml-offer-accepted{background:#eff6ff;border-color:#93c5fd;color:#1d4ed8}
    .ml-offer-paid{background:#f0fdf4;border-color:#86efac;color:#166534}
    .ml-offer-confirmed{background:#ecfdf5;border-color:#34d399;color:#065f46}
    .ml-offer-rejected{background:#fef2f2;border-color:#fca5a5;color:#991b1b}
    .ml-tag-hidden{display:inline-block;background:#111827;color:#111827;border-radius:6px;padding:.15rem .55rem;min-width:120px;user-select:none}
    .ml-tag-value{font-weight:800;color:#111827}
    .ml-review-body{margin-top:6px;color:#111827;font-size:.9rem;white-space:pre-wrap}
    .ml-confirm-overlay{position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,.55)}
    .ml-confirm-box{width:100%;max-width:430px;border-radius:18px;border:1px solid #000;background:#fff;color:#000;box-shadow:0 24px 70px rgba(0,0,0,.32);padding:20px;text-align:center}
    .ml-confirm-title{font-size:1.05rem;font-weight:900;margin-bottom:8px}
    .ml-confirm-text{font-size:.96rem;font-weight:800;line-height:1.45;margin-bottom:18px}
    .ml-confirm-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
    .ml-confirm-yes,.ml-confirm-no{min-width:86px;border-radius:999px;font-weight:800;font-size:.86rem;padding:.42rem .9rem;border:1px solid #000!important}
    .ml-confirm-yes{background:#000!important;color:#fff!important}
    .ml-confirm-no{background:#fff!important;color:#000!important}
    .ml-confirm-yes:hover,.ml-confirm-no:hover{background:#d4af37!important;color:#000!important;border-color:#d4af37!important}
  </style>

  <div class="mb-3">
    <%= link_to "← Back to Marketplace", marketplace_path, class: "btn btn-link p-0" %>
  </div>

  <div class="ml-wrap">
    <div class="ml-left">
      <div class="ml-block">
        <h1 class="ml-title">Listing Information:</h1>
        <p class="ml-sub"><%= [era.presence, listing.set_name.presence, display_product.presence].compact.join(" · ") %></p>

        <div class="ml-line"><strong>Seller:</strong> <%= link_to seller_name, user_path(listing.seller_id), class: "text-decoration-none" %></div>
        <div class="ml-line"><strong>Location:</strong> <span title="<%= country_name(listing.country_code) %>"><%= flag_emoji(listing.country_code) %></span></div>
        <div class="ml-line"><strong>Reviews:</strong> <%= marketplace_stars(stats[:avg]) %> (<%= stats[:count] %>)</div>

        <div class="ml-line">
          <strong>Badges:</strong>
          <% if seller_badges.any? %>
            <span class="ml-badges">
              <% seller_badges.each do |badge| %>
                <%= image_tag badge, alt: "" %>
              <% end %>
            </span>
          <% else %>
            <span class="text-muted">None</span>
          <% end %>
        </div>

        <div class="ml-line"><strong>Product Type:</strong> <%= display_product %></div>
        <div class="ml-line"><strong>Condition:</strong> <%= listing.condition %></div>
        <div class="ml-line"><strong>Asking Price:</strong> <%= number_to_currency(listing.price_cents.to_i / 100.0, unit: "€") %></div>
        <div class="ml-line"><strong>Available:</strong> <%= listing.quantity %></div>
        <div class="ml-line"><strong>Status:</strong> <%= listing.status.to_s.titleize %></div>

        <div class="ml-actions">
          <% if current_user.blank? %>
            <button type="button" class="btn btn-secondary btn-sm" disabled>Log in to send offer</button>
          <% elsif is_seller %>
            <span class="text-muted small">This is your listing.</span>
          <% elsif listing.status.to_s != "active" %>
            <button type="button" class="btn btn-secondary btn-sm" disabled>Listing not active</button>
          <% end %>

          <% if can_edit_listing %>
            <%= link_to "Edit Listing", edit_marketplace_listing_path(listing), class: "btn btn-outline-primary btn-sm" %>
          <% end %>

          <% if current_user && current_user.id == listing.seller_id && listing.status == "active" %>
            <%= button_to "Delete Listing", cancel_marketplace_listing_path(listing), method: :post, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline ml-confirm-form", data: { hide_confirm_title: "true", confirm_text: "Are you sure you want to delete this listing?", turbo: "false" } } %>
          <% end %>

          <% if admin_can_delete %>
            <%= button_to "Delete Listing", marketplace_listing_path(listing), method: :delete, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline ml-confirm-form", data: { hide_confirm_title: "true", confirm_text: "Are you sure you want to delete this listing?", turbo: "false" } } %>
          <% end %>
        </div>
      </div>

      <% if can_offer %>
        <div class="ml-section">
          <h2 class="h6 mb-3">Send Offer</h2>

          <%= form_with url: create_offer_marketplace_listing_path(listing), method: :post, local: true, html: { class: "ml-confirm-form", data: { confirm_title: "Confirm Offer", confirm_text: "Do you want to confirm this offer?" } } do %>
            <div class="mb-3">
              <label class="form-label">Offer Amount (€)</label>
              <%= text_field_tag :offer_amount, "", class: "form-control", inputmode: "decimal", placeholder: "e.g. 340", required: true %>
            </div>

            <%= submit_tag "Confirm Offer", class: "btn btn-primary btn-sm" %>
          <% end %>
        </div>
      <% end %>

      <% if my_offers.any? %>
        <div class="ml-section">
          <h2 class="h6 mb-3">Your Offers</h2>

          <div class="ml-offer-grid">
            <% my_offers.each do |offer| %>
              <div class="ml-offer-card">
                <div class="ml-offer-top">
                  <div>
                    <div class="ml-offer-name"><%= current_user.username %></div>
                    <div class="ml-offer-meta">Sent <%= time_ago_in_words(offer.created_at) %> ago</div>
                  </div>

                  <div class="text-end">
                    <div class="ml-offer-amount"><%= number_to_currency(offer.offer_cents.to_i / 100.0, unit: "€") %></div>
                    <span class="ml-offer-status <%= marketplace_offer_status_class(offer.status) %>"><%= marketplace_offer_status_label(offer.status) %></span>
                  </div>
                </div>

                <% if offer.accepted? %>
                  <div class="mt-3">
                    <%= link_to "Pay", pay_marketplace_listing_path(listing, offer_id: offer.id), class: "btn btn-success btn-sm" %>
                  </div>
                <% elsif offer.paid? %>
                  <div class="mt-3 text-muted small">Payment marked as sent. Waiting for seller to confirm payment.</div>
                <% elsif offer.confirmed_paid? %>
                  <div class="mt-3 text-success small fw-semibold">Seller confirmed payment.</div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if is_seller %>
        <div class="ml-section">
          <h2 class="h6 mb-3">Offers</h2>

          <% if seller_offers.any? %>
            <div class="ml-offer-grid">
              <% seller_offers.each do |offer| %>
                <% buyer = offer.buyer %>
                <% buyer_name = marketplace_seller_name(buyer, offer.buyer_id) %>
                <% tag_id = "buyer_tag_#{offer.id}" %>
                <% hidden_id = "buyer_tag_hidden_#{offer.id}" %>
                <% buyer_tag = offer.buyer_revolut_tag.to_s %>

                <div class="ml-offer-card">
                  <div class="ml-offer-top">
                    <div>
                      <div class="ml-offer-name"><%= buyer_name %></div>
                      <div class="ml-offer-meta">Sent <%= time_ago_in_words(offer.created_at) %> ago</div>
                    </div>

                    <div class="text-end">
                      <div class="ml-offer-amount"><%= number_to_currency(offer.offer_cents.to_i / 100.0, unit: "€") %></div>
                      <span class="ml-offer-status <%= marketplace_offer_status_class(offer.status) %>"><%= marketplace_offer_status_label(offer.status) %></span>
                    </div>
                  </div>

                  <% if buyer_tag.present? %>
                    <div class="mt-3">
                      <strong>Buyer Revolut Tag:</strong>
                      <span class="ml-tag-hidden" id="<%= hidden_id %>">Hidden</span>
                      <span class="ml-tag-value" id="<%= tag_id %>" style="display:none;"><%= buyer_tag %></span>
                      <button type="button" class="btn btn-sm btn-outline-dark ms-2 ml-reveal-tag-btn" data-hidden-id="<%= hidden_id %>" data-value-id="<%= tag_id %>">Reveal</button>
                    </div>
                  <% end %>

                  <div class="ml-actions">
                    <% if offer.pending? && listing.status == "active" %>
                      <%= button_to "Accept", accept_offer_marketplace_listing_path(listing, offer_id: offer.id), method: :post, class: "btn btn-primary btn-sm", form: { class: "d-inline ml-confirm-form", data: { confirm_title: "Accept Offer", confirm_text: "Do you want to accept this offer?" } } %>
                    <% end %>

                    <% if offer.paid? && listing.status == "active" %>
                      <%= button_to "Confirm Paid", confirm_paid_marketplace_listing_path(listing, offer_id: offer.id), method: :post, class: "btn btn-success btn-sm", form: { class: "d-inline ml-confirm-form", data: { confirm_title: "Confirm Payment", confirm_text: "Do you want to confirm that this buyer paid?" } } %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-muted">No offers yet.</div>
          <% end %>
        </div>
      <% end %>

      <div class="ml-section">
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
          <h3 class="h6 m-0">Reviews</h3>

          <% if can_review_seller %>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="document.getElementById('<%= review_form_id %>').classList.toggle('d-none')">
              Give Review
            </button>
          <% end %>
        </div>

        <% if can_review_seller %>
          <div class="ml-review-card mb-2">
            <strong>Leave a Review</strong>

            <div id="<%= review_form_id %>" class="mt-2 d-none">
              <%= form_with url: reviews_path, method: :post, local: true do %>
                <%= hidden_field_tag "review[seller_id]", listing.seller_id %>

                <div class="mb-2">
                  <label class="form-label mb-1 small">Rating (0 to 5)</label>
                  <%= number_field_tag "review[rating]", "", min: 0, max: 5, step: 0.1, class: "form-control form-control-sm", required: true %>
                </div>

                <div class="mb-2">
                  <label class="form-label mb-1 small">Comment</label>
                  <%= text_area_tag "review[comment]", "", class: "form-control form-control-sm", rows: 3, maxlength: 1000 %>
                </div>

                <div class="d-flex justify-content-end">
                  <%= submit_tag "Submit Review", class: "btn btn-primary btn-sm" %>
                </div>
              <% end %>
            </div>
          </div>
        <% elsif confirmed_paid_buyer && already_reviewed_seller %>
          <div class="text-muted small mb-2">You have already reviewed this seller.</div>
        <% end %>

        <% if reviews.any? %>
          <% reviews.each do |review| %>
            <% reviewer_name = marketplace_seller_name(review.reviewer, review.reviewer_id) %>

            <div class="ml-review-card mb-2">
              <div class="ml-review-top">
                <div>
                  <div class="ml-review-name"><%= reviewer_name %></div>
                  <div><%= marketplace_stars(review.rating) %> <strong><%= number_with_precision(review.rating.to_f, precision: 1) %>/5</strong></div>
                </div>

                <div class="ml-review-meta"><%= review.created_at.strftime("%d %b %Y") %></div>
              </div>

              <div class="ml-review-body"><%= review.comment.to_s.presence || "No comment left." %></div>
            </div>
          <% end %>
        <% else %>
          <div class="text-muted">No reviews yet.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="ml-confirm-overlay" id="mlConfirmOverlay" aria-hidden="true">
    <div class="ml-confirm-box">
      <div class="ml-confirm-title" id="mlConfirmTitle">Confirm</div>
      <div class="ml-confirm-text" id="mlConfirmText">Do you want to continue?</div>
      <div class="ml-confirm-actions">
        <button type="button" class="ml-confirm-yes" id="mlConfirmYes">Yes</button>
        <button type="button" class="ml-confirm-no" id="mlConfirmNo">No</button>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    document.querySelectorAll(".ml-reveal-tag-btn").forEach((button) => {
      button.addEventListener("click", () => {
        const hidden = document.getElementById(button.dataset.hiddenId)
        const value = document.getElementById(button.dataset.valueId)
        if (!hidden || !value) return

        const showing = value.style.display !== "none" && value.style.display !== ""

        hidden.style.display = showing ? "inline-block" : "none"
        value.style.display = showing ? "none" : "inline"
        button.textContent = showing ? "Reveal" : "Hide"
      })
    })

    let pendingForm = null
    let confirmed = false

    const overlay = document.getElementById("mlConfirmOverlay")
    const title = document.getElementById("mlConfirmTitle")
    const text = document.getElementById("mlConfirmText")
    const yes = document.getElementById("mlConfirmYes")
    const no = document.getElementById("mlConfirmNo")

    document.addEventListener("submit", (event) => {
      const form = event.target.closest(".ml-confirm-form")
      if (!form) return

      if (confirmed) {
        confirmed = false
        return
      }

      event.preventDefault()
      pendingForm = form

      if (title) {
        title.textContent = form.dataset.hideConfirmTitle === "true" ? "" : (form.dataset.confirmTitle || "Confirm")
        title.style.display = form.dataset.hideConfirmTitle === "true" ? "none" : ""
      }

      if (text) text.textContent = form.dataset.confirmText || "Do you want to continue?"
      if (overlay) overlay.style.display = "flex"
    })

    yes?.addEventListener("click", () => {
      if (!pendingForm) return

      const form = pendingForm
      pendingForm = null
      confirmed = true

      if (overlay) overlay.style.display = "none"

      if (form.requestSubmit) {
        form.requestSubmit()
      } else {
        form.submit()
      }
    })

    no?.addEventListener("click", () => {
      pendingForm = null
      if (overlay) overlay.style.display = "none"
    })

    overlay?.addEventListener("click", (event) => {
      if (event.target !== overlay) return
      pendingForm = null
      overlay.style.display = "none"
    })
  })()
</script>