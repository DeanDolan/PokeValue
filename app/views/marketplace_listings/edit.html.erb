<%#
References:
- Rails form helpers:
  https://guides.rubyonrails.org/form_helpers.html
- Bootstrap forms and buttons:
  https://getbootstrap.com/docs/5.3/forms/overview/
  https://getbootstrap.com/docs/5.3/components/buttons/
%>

<%
listing = @listing
current_price = listing.price_cents.to_i / 100.0
condition_options = @condition_options || marketplace_condition_options
%>

<div class="container py-4">
  <style>
    .mledit-wrap{max-width:760px;margin:0 auto}
    .mledit-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:18px;box-shadow:0 10px 25px rgba(15,23,42,.08)}
    .mledit-title{font-size:1.35rem;font-weight:900;margin:0 0 6px;color:#111827}
    .mledit-sub{font-size:.88rem;color:#6b7280;margin:0 0 16px}
    .mledit-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;margin-top:16px}
  </style>

  <div class="mledit-wrap">
    <div class="mb-3">
      <%= link_to "← Back to Listing", marketplace_listing_path(listing), class: "btn btn-link p-0" %>
    </div>

    <div class="mledit-card">
      <h1 class="mledit-title">Edit Listing</h1>
      <p class="mledit-sub">Update the price, quantity or condition. Sold, cancelled or deleted listings cannot be edited.</p>

      <%= form_with url: marketplace_listing_path(listing), method: :patch, local: true do %>
        <div class="mb-3">
          <label class="form-label" for="listing_price">Price (€)</label>
          <%= number_field_tag :price, current_price, step: "0.01", min: "0.01", class: "form-control", id: "listing_price", required: true %>
        </div>

        <div class="mb-3">
          <label class="form-label" for="listing_quantity">Quantity</label>
          <%= number_field_tag :quantity, listing.quantity.to_i, min: 1, step: 1, class: "form-control", id: "listing_quantity", required: true %>
        </div>

        <div class="mb-3">
          <label class="form-label" for="listing_condition">Condition</label>
          <%= select_tag :condition, options_for_select(condition_options, listing.condition.to_s), include_blank: "Select condition", class: "form-select", id: "listing_condition", required: true %>
        </div>

        <div class="mledit-actions">
          <%= link_to "Cancel", marketplace_listing_path(listing), class: "btn btn-outline-secondary" %>
          <%= submit_tag "Save Changes", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>