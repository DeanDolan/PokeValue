<%#
References:
- Rails Action View helpers:
  https://guides.rubyonrails.org/action_view_helpers.html
- Rails form helpers:
  https://guides.rubyonrails.org/form_helpers.html
- Bootstrap tables, forms and buttons:
  https://getbootstrap.com/docs/5.3/content/tables/
  https://getbootstrap.com/docs/5.3/forms/overview/
  https://getbootstrap.com/docs/5.3/components/buttons/
%>

<%
tab = @tab.to_s.presence || "current"
marketplace_logged_in = current_user.present?
selected_era = params[:era].to_s
selected_set = params[:set_slug].to_s
selected_country = params[:country].to_s
selected_type = params[:product_type].to_s
selected_condition = params[:condition].to_s
selected_sort = params[:sort].to_s
listing_map = @sold_listing_map || {}
%>

<div class="container py-4">
  <style>
    .mp-filters{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:12px;box-shadow:0 10px 25px rgba(15,23,42,.06)}
    .mp-table{background:#fff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;box-shadow:0 10px 25px rgba(15,23,42,.06)}
    .mp-table table{margin:0}
    .mp-table th,.mp-table td{font-size:.72rem;text-align:center;vertical-align:middle}
    .mp-actions{display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:nowrap;white-space:nowrap}
    .mp-actions .btn{padding:.12rem .35rem;font-size:.70rem;line-height:1.2}
    .mp-badges img{height:16px;width:16px;object-fit:contain}
    .mp-tab-links{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 12px}
    .mp-tab-link{font-size:.72rem;padding:.28rem .55rem;border-radius:999px;border:1px solid #e5e7eb;text-decoration:none;color:#111827;background:#fff}
    .mp-tab-link.active{border-color:#111827;font-weight:900}
    .mp-confirm-overlay{position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,.55)}
    .mp-confirm-box{width:100%;max-width:430px;border-radius:18px;border:1px solid #000;background:#fff;color:#000;box-shadow:0 24px 70px rgba(0,0,0,.32);padding:20px;text-align:center}
    .mp-confirm-text{font-size:.96rem;font-weight:800;line-height:1.45;margin-bottom:18px}
    .mp-confirm-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
    .mp-confirm-yes,.mp-confirm-no{min-width:86px;border-radius:999px;font-weight:800;font-size:.86rem;padding:.42rem .9rem;border:1px solid #000!important}
    .mp-confirm-yes{background:#000!important;color:#fff!important}
    .mp-confirm-no{background:#fff!important;color:#000!important}
    .mp-confirm-yes:hover,.mp-confirm-no:hover{background:#d4af37!important;color:#000!important;border-color:#d4af37!important}
  </style>

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h4 class="m-0">Marketplace</h4>

    <% if marketplace_logged_in %>
      <%= link_to "Create Listing", new_marketplace_listing_path, class: "btn btn-primary btn-sm" %>
    <% else %>
      <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#marketplaceCreateListingLoginModal">
        Create Listing
      </button>
    <% end %>
  </div>

  <% unless marketplace_logged_in %>
    <div class="modal fade" id="marketplaceCreateListingLoginModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Log in to create listing</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body">
            <%= form_with url: login_path, method: :post, local: true do %>
              <div class="mb-3">
                <label class="form-label">Username</label>
                <%= text_field_tag :username, nil, class: "form-control", required: true %>
              </div>

              <div class="mb-3">
                <label class="form-label">Password</label>
                <%= password_field_tag :password, nil, class: "form-control", required: true %>
              </div>

              <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Log in</button>
              </div>
            <% end %>

            <hr>

            <div class="text-center small">
              Don't have an account?
              <%= link_to "Register", register_path, class: "btn btn-link btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mp-tab-links">
    <%= link_to "Current Listings", marketplace_path(tab: "current"), class: ["mp-tab-link", ("active" if tab == "current")].compact.join(" ") %>
    <%= link_to "Sold Listings", marketplace_path(tab: "sold"), class: ["mp-tab-link", ("active" if tab == "sold")].compact.join(" ") %>
  </div>

  <%= form_with url: marketplace_path, method: :get, local: true, class: "mp-filters mb-3" do %>
    <%= hidden_field_tag :tab, tab %>

    <div class="row g-2 align-items-end">
      <div class="col-12 col-lg-5">
        <label class="form-label small mb-1">Search</label>
        <%= text_field_tag :q, params[:q], class: "form-control form-control-sm", placeholder: "Search seller, set or product..." %>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Location</label>
        <select name="country" class="form-select form-select-sm">
          <option value="">All EU Countries</option>
          <% marketplace_country_options.each do |name, code| %>
            <option value="<%= code %>" <%= "selected" if selected_country == code %>><%= "#{flag_emoji(code)} #{name}" %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Era</label>
        <select name="era" class="form-select form-select-sm" id="mp-era">
          <option value=""></option>
          <% @eras.each do |era| %>
            <option value="<%= era %>" <%= "selected" if selected_era == era %>><%= era %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-lg-3">
        <label class="form-label small mb-1">Set</label>
        <select name="set_slug" class="form-select form-select-sm" <%= selected_era.blank? ? "disabled" : "" %>>
          <option value=""></option>
          <% @sets_for_era.each do |set| %>
            <option value="<%= set["slug"] %>" <%= "selected" if selected_set == set["slug"] %>><%= set["name"] %></option>
          <% end %>
        </select>
      </div>
    </div>

    <div class="row g-2 align-items-end mt-1">
      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Product Type</label>
        <select name="product_type" class="form-select form-select-sm">
          <option value=""></option>
          <% marketplace_type_map.each do |code, label| %>
            <option value="<%= code %>" <%= "selected" if selected_type == code %>><%= label %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Condition</label>
        <select name="condition" class="form-select form-select-sm">
          <option value=""></option>
          <% marketplace_condition_options.each do |condition| %>
            <option value="<%= condition %>" <%= "selected" if selected_condition == condition %>><%= condition %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Min (€)</label>
        <%= text_field_tag :min_price, params[:min_price], class: "form-control form-control-sm", inputmode: "decimal" %>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Max (€)</label>
        <%= text_field_tag :max_price, params[:max_price], class: "form-control form-control-sm", inputmode: "decimal" %>
      </div>

      <div class="col-6 col-lg-2">
        <label class="form-label small mb-1">Sort</label>
        <select name="sort" class="form-select form-select-sm">
          <option value="" <%= "selected" if selected_sort.blank? %>>Newest</option>
          <option value="oldest" <%= "selected" if selected_sort == "oldest" %>>Oldest</option>
          <option value="price-asc" <%= "selected" if selected_sort == "price-asc" %>>Price Low → High</option>
          <option value="price-desc" <%= "selected" if selected_sort == "price-desc" %>>Price High → Low</option>
        </select>
      </div>

      <div class="col-6 col-lg-2 d-flex gap-2 justify-content-end">
        <%= submit_tag "Apply", class: "btn btn-primary btn-sm" %>
        <%= link_to "Reset", marketplace_path(tab: tab), class: "btn btn-outline-secondary btn-sm" %>
      </div>
    </div>
  <% end %>

  <div class="mp-table">
    <div class="table-responsive">
      <table class="table table-sm align-middle">
        <% if tab == "current" %>
          <thead class="table-light">
            <tr>
              <th>Seller</th>
              <th>Location</th>
              <th>Badges</th>
              <th>Era</th>
              <th>Set</th>
              <th>Product Type</th>
              <th>Condition</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if @listings.any? %>
              <% @listings.each do |listing| %>
                <% seller = listing.seller %>

                <tr>
                  <td><%= link_to marketplace_seller_name(seller, listing.seller_id), user_path(listing.seller_id), class: "text-decoration-none" %></td>
                  <td title="<%= country_name(listing.country_code) %>"><%= flag_emoji(listing.country_code) %></td>
                  <td class="mp-badges">
                    <% marketplace_badges_for(seller).each do |badge| %>
                      <%= image_tag badge, alt: "" %>
                    <% end %>
                  </td>
                  <td><%= marketplace_era(listing.set_slug).presence || "-" %></td>
                  <td><%= listing.set_name.presence || "-" %></td>
                  <td><%= marketplace_display_product(listing) %></td>
                  <td><%= listing.condition %></td>
                  <td><%= number_to_currency(listing.price_cents.to_i / 100.0, unit: "€") %></td>
                  <td><%= listing.quantity %></td>
                  <td>
                    <div class="mp-actions">
                      <%= link_to "View", marketplace_listing_path(listing), class: "btn btn-outline-primary btn-sm" %>

                      <% if current_user && current_user.id == listing.seller_id && listing.status == "active" %>
                        <%= button_to "Delete", cancel_marketplace_listing_path(listing), method: :post, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline mp-confirm-form", data: { confirm_text: "Are you sure you want to delete this listing?", turbo: "false" } } %>
                      <% end %>

                      <% if @admin_can_delete %>
                        <%= button_to "Delete", marketplace_listing_path(listing), method: :delete, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline mp-confirm-form", data: { confirm_text: "Are you sure you want to delete this listing?", turbo: "false" } } %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="10" class="text-center text-muted py-4">No listings found.</td>
              </tr>
            <% end %>
          </tbody>
        <% else %>
          <thead class="table-light">
            <tr>
              <th>Seller</th>
              <th>Location</th>
              <th>Badges</th>
              <th>Era</th>
              <th>Set</th>
              <th>Product Type</th>
              <th>Condition</th>
              <th>Price</th>
              <th>Quantity Sold</th>
              <th>Sale Date</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if @sold_rows.any? %>
              <% @sold_rows.each do |row| %>
                <% listing = marketplace_sold_listing(row, listing_map) %>
                <% seller_id = marketplace_sold_seller_id(row, listing_map) %>
                <% seller = marketplace_sold_seller(row, listing_map) %>
                <% set_slug = marketplace_sold_set_slug(row, listing_map) %>
                <% country = marketplace_sold_country(row, listing_map) %>
                <% sale_date = marketplace_sold_date(row, listing_map) %>

                <tr>
                  <td>
                    <% if seller_id.present? %>
                      <%= link_to marketplace_seller_name(seller, seller_id), user_path(seller_id), class: "text-decoration-none" %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td title="<%= country.present? ? country_name(country) : "" %>"><%= country.present? ? flag_emoji(country) : "-" %></td>
                  <td class="mp-badges">
                    <% marketplace_badges_for(seller).each do |badge| %>
                      <%= image_tag badge, alt: "" %>
                    <% end %>
                  </td>
                  <td><%= marketplace_era(set_slug).presence || "-" %></td>
                  <td><%= marketplace_sold_set_name(row, listing_map).presence || "-" %></td>
                  <td><%= marketplace_display_product(row.respond_to?(:product_name) && row.product_name.present? ? row : listing) %></td>
                  <td><%= marketplace_sold_condition(row, listing_map).presence || "-" %></td>
                  <td><%= number_to_currency(marketplace_sold_unit_cents(row, listing_map) / 100.0, unit: "€") %></td>
                  <td><%= marketplace_sold_quantity(row, listing_map) %></td>
                  <td><%= sale_date ? sale_date.strftime("%d %b %Y") : "-" %></td>
                  <td>
                    <div class="mp-actions">
                      <% if listing %>
                        <%= link_to "View", marketplace_listing_path(listing), class: "btn btn-outline-primary btn-sm" %>
                      <% else %>
                        -
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="11" class="text-center text-muted py-4">No sold listings found.</td>
              </tr>
            <% end %>
          </tbody>
        <% end %>
      </table>
    </div>
  </div>

  <div class="mp-confirm-overlay" id="mpConfirmOverlay" aria-hidden="true">
    <div class="mp-confirm-box">
      <div class="mp-confirm-text" id="mpConfirmText">Are you sure you want to continue?</div>
      <div class="mp-confirm-actions">
        <button type="button" class="mp-confirm-yes" id="mpConfirmYes">Yes</button>
        <button type="button" class="mp-confirm-no" id="mpConfirmNo">No</button>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const eraSelect = document.getElementById("mp-era")

      eraSelect?.addEventListener("change", () => {
        eraSelect.closest("form")?.submit()
      })

      let pendingForm = null
      let confirmed = false

      const overlay = document.getElementById("mpConfirmOverlay")
      const text = document.getElementById("mpConfirmText")
      const yes = document.getElementById("mpConfirmYes")
      const no = document.getElementById("mpConfirmNo")

      document.addEventListener("submit", (event) => {
        const form = event.target.closest(".mp-confirm-form")
        if (!form) return

        if (confirmed) {
          confirmed = false
          return
        }

        event.preventDefault()
        pendingForm = form

        if (text) text.textContent = form.dataset.confirmText || "Are you sure you want to continue?"
        if (overlay) overlay.style.display = "flex"
      })

      yes?.addEventListener("click", () => {
        if (!pendingForm) return

        const form = pendingForm
        pendingForm = null
        confirmed = true

        if (overlay) overlay.style.display = "none"

        if (form.requestSubmit) {
          form.requestSubmit()
        } else {
          form.submit()
        }
      })

      no?.addEventListener("click", () => {
        pendingForm = null
        if (overlay) overlay.style.display = "none"
      })

      overlay?.addEventListener("click", (event) => {
        if (event.target !== overlay) return
        pendingForm = null
        overlay.style.display = "none"
      })
    })()
  </script>
</div>