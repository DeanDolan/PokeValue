<%#
References:
- Rails form helpers and file uploads:
  https://guides.rubyonrails.org/form_helpers.html
  https://guides.rubyonrails.org/active_storage_overview.html
- Bootstrap forms and dropdowns:
  https://getbootstrap.com/docs/5.3/forms/overview/
  https://getbootstrap.com/docs/5.3/components/dropdowns/
- MDN DOM events and dataset:
  https://developer.mozilla.org/en-US/docs/Web/API/EventTarget/addEventListener
  https://developer.mozilla.org/en-US/docs/Web/API/HTMLElement/dataset
%>

<%
form = @listing_form || {}
selected_mode = form[:mode].to_s.presence || "catalog"
selected_holding_id = form[:holding_id].to_s
selected_set_slug = form[:catalog_set_slug].to_s
selected_route_type = form[:catalog_route_type].to_s
selected_condition = form[:catalog_condition].to_s
selected_price = form[:price].to_s
selected_quantity = form[:quantity].to_s.presence || "1"
catalogue = marketplace_catalogue
eras = catalogue.map { |set| set[:era] }.reject(&:blank?).uniq.sort
selected_era = catalogue.find { |set| set[:slug] == selected_set_slug }&.dig(:era).to_s
holdings = @holdings || []
selected_holding = holdings.find { |holding| holding.id.to_s == selected_holding_id }
selected_holding_option = selected_holding ? marketplace_holding_option(selected_holding) : nil
%>

<div class="container py-4">
  <style>
    .ml-wrap{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.06)}
    .ml-title{font-size:1.2rem;margin:0 0 10px}
    .ml-muted{color:#6b7280;font-size:.9rem}
    .ml-rowlabel{font-size:.85rem}
    .ml-hold-btn{display:flex;align-items:center;gap:10px;justify-content:flex-start}
    .ml-hold-btn img{width:28px;height:28px;object-fit:contain}
    .ml-hold-item{display:flex;align-items:center;gap:10px}
    .ml-hold-item img{width:34px;height:34px;object-fit:contain}
    .ml-hold-title{font-weight:600;font-size:.9rem;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ml-hold-sub{font-size:.78rem;color:#6b7280;line-height:1.2}
    .ml-img-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  </style>

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <div class="ml-title">Create Marketplace Listing</div>
      <div class="ml-muted">Choose a product, set your price, quantity and condition.</div>
    </div>

    <%= link_to "← Back to Marketplace", marketplace_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="ml-wrap">
    <%= form_with url: marketplace_listings_path, method: :post, local: true, html: { multipart: true, id: "ml-form" } do %>
      <input type="hidden" name="mode" id="ml-mode" value="<%= selected_mode %>">

      <div class="d-flex gap-3 flex-wrap mb-3">
        <label class="d-inline-flex align-items-center gap-2">
          <input type="radio" name="ml_mode_choice" value="catalog" <%= "checked" if selected_mode != "holding" %>>
          <span class="ml-rowlabel">Choose from catalogue</span>
        </label>

        <label class="d-inline-flex align-items-center gap-2">
          <input type="radio" name="ml_mode_choice" value="holding" <%= "checked" if selected_mode == "holding" %>>
          <span class="ml-rowlabel">Choose from holdings</span>
        </label>
      </div>

      <div id="ml-catalog">
        <div class="row g-2 mb-2">
          <div class="col-12 col-lg-3">
            <label class="form-label mb-1 ml-rowlabel">Era</label>
            <select class="form-select" id="ml-era" data-selected="<%= selected_era %>">
              <option value=""></option>
              <% eras.each do |era| %>
                <option value="<%= era %>" <%= "selected" if selected_era == era %>><%= era %></option>
              <% end %>
            </select>
          </div>

          <div class="col-12 col-lg-4">
            <label class="form-label mb-1 ml-rowlabel">Set</label>
            <select class="form-select" name="catalog_set_slug" id="ml-set" data-selected="<%= selected_set_slug %>">
              <option value=""></option>
            </select>
          </div>

          <div class="col-12 col-lg-5">
            <label class="form-label mb-1 ml-rowlabel">Product</label>
            <select class="form-select" name="catalog_route_type" id="ml-product" data-selected="<%= selected_route_type %>">
              <option value=""></option>
            </select>
          </div>
        </div>
      </div>

      <div id="ml-holding">
        <div class="row g-2 mb-2">
          <div class="col-12">
            <label class="form-label mb-1 ml-rowlabel">Holding</label>

            <div class="dropdown">
              <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start ml-hold-btn" type="button" data-bs-toggle="dropdown" id="ml-hold-btn">
                <% if selected_holding_option %>
                  <img src="<%= selected_holding_option[:image] %>" alt="">
                  <span class="text-truncate"><%= selected_holding_option[:label] %></span>
                <% else %>
                  Select a holding...
                <% end %>
              </button>

              <ul class="dropdown-menu w-100 p-0" style="max-height:360px;overflow:auto;">
                <% holdings.each do |holding| %>
                  <% option = marketplace_holding_option(holding) %>
                  <li>
                    <button
                      type="button"
                      class="dropdown-item py-2"
                      data-holding-id="<%= option[:id] %>"
                      data-holding-label="<%= option[:label] %>"
                      data-holding-img="<%= option[:image] %>">
                      <div class="ml-hold-item">
                        <img src="<%= option[:image] %>" alt="">
                        <div class="min-w-0">
                          <div class="ml-hold-title"><%= option[:label] %></div>
                          <div class="ml-hold-sub">Available: <%= option[:available] %></div>
                        </div>
                      </div>
                    </button>
                  </li>
                <% end %>
              </ul>

              <input type="hidden" name="holding_id" id="ml-holding-id" value="<%= selected_holding_id %>">
            </div>
          </div>
        </div>
      </div>

      <div class="row g-2 mb-2 align-items-end">
        <div class="col-12 col-lg-3">
          <label class="form-label mb-1 ml-rowlabel">Quantity</label>
          <%= number_field_tag :quantity, selected_quantity, min: 1, step: 1, class: "form-control" %>
        </div>

        <div class="col-12 col-lg-4">
          <label class="form-label mb-1 ml-rowlabel">Price per product (€)</label>
          <%= text_field_tag :price, selected_price, class: "form-control", inputmode: "decimal", placeholder: "e.g. 59.99" %>
        </div>

        <div class="col-12 col-lg-5">
          <label class="form-label mb-1 ml-rowlabel">Condition</label>
          <select class="form-select" id="ml-condition" name="catalog_condition">
            <option value=""></option>
            <% marketplace_condition_options.each do |condition| %>
              <option value="<%= condition %>" <%= "selected" if selected_condition == condition %>><%= condition %></option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label mb-1 ml-rowlabel">Images (up to 4)</label>

        <div class="ml-img-grid">
          <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
          <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
          <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
          <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
        </div>

        <div class="small text-muted mt-1">PNG/JPG only.</div>
      </div>

      <div class="d-flex gap-2 justify-content-end flex-wrap">
        <%= submit_tag "Create Listing", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <script>
    (() => {
      const catalogue = <%= raw(catalogue.to_json) %>

      const modeHidden = document.getElementById("ml-mode")
      const modeRadios = document.querySelectorAll("input[name='ml_mode_choice']")
      const catalogWrap = document.getElementById("ml-catalog")
      const holdingWrap = document.getElementById("ml-holding")
      const conditionSelect = document.getElementById("ml-condition")
      const eraSelect = document.getElementById("ml-era")
      const setSelect = document.getElementById("ml-set")
      const productSelect = document.getElementById("ml-product")
      const holdButton = document.getElementById("ml-hold-btn")
      const holdInput = document.getElementById("ml-holding-id")

      function setMode(mode) {
        const holding = mode === "holding"

        modeHidden.value = holding ? "holding" : "catalog"
        catalogWrap.style.display = holding ? "none" : ""
        holdingWrap.style.display = holding ? "" : "none"
        conditionSelect.name = holding ? "holding_condition" : "catalog_condition"
      }

      function optionHtml(value, label, selected) {
        return `<option value="${value}" ${String(value) === String(selected || "") ? "selected" : ""}>${label}</option>`
      }

      function rebuildSets() {
        const era = eraSelect.value
        const selected = setSelect.dataset.selected || setSelect.value || ""
        const sets = catalogue.filter((set) => set.era === era).sort((a, b) => a.name.localeCompare(b.name))

        setSelect.innerHTML = `<option value=""></option>` + sets.map((set) => optionHtml(set.slug, set.name, selected)).join("")
        setSelect.disabled = sets.length === 0
        setSelect.dataset.selected = ""

        rebuildProducts()
      }

      function rebuildProducts() {
        const selectedSet = catalogue.find((set) => set.slug === setSelect.value)
        const selected = productSelect.dataset.selected || productSelect.value || ""
        const products = selectedSet ? selectedSet.products : []

        productSelect.innerHTML = `<option value=""></option>` + products.map((product) => optionHtml(product.route_type, product.name, selected)).join("")
        productSelect.disabled = products.length === 0
        productSelect.dataset.selected = ""
      }

      modeRadios.forEach((radio) => {
        radio.addEventListener("change", () => setMode(radio.value))
      })

      eraSelect?.addEventListener("change", () => {
        setSelect.dataset.selected = ""
        productSelect.dataset.selected = ""
        rebuildSets()
      })

      setSelect?.addEventListener("change", () => {
        productSelect.dataset.selected = ""
        rebuildProducts()
      })

      document.addEventListener("click", (event) => {
        const item = event.target.closest(".dropdown-item[data-holding-id]")
        if (!item) return

        holdInput.value = item.dataset.holdingId || ""

        holdButton.innerHTML = `
          <img src="${item.dataset.holdingImg || ""}" alt="">
          <span class="text-truncate">${item.dataset.holdingLabel || ""}</span>
        `
      })

      setMode("<%= selected_mode == "holding" ? "holding" : "catalog" %>")
      rebuildSets()
    })()
  </script>
</div>