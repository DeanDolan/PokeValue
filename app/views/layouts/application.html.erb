      :root[data-pv-theme="light"] section.rf-section.active{
        background:#ffffff !important;
        color:#000000 !important;
      }

      :root[data-pv-theme="dark"] .rf-section.active,
      :root[data-pv-theme="dark"] section.rf-section.active{
        background:#000000 !important;
        color:#d4af37 !important;
      }

      .pv-tab-locked,
      .pv-tab-locked:hover,
      .pv-tab-locked:focus,
      .pv-tab-locked:active,
      .pv-tab-button.active,
      .pv-tab-button.active:hover,
      .pv-tab-button.active:focus,
      .pv-tab-button.active:active,
      .rf-tabbar button.active,
      .rf-tabbar button.active:hover,
      .rf-tabbar button.active:focus,
      .rf-tabbar button.active:active,
      [aria-pressed="true"],
      [aria-pressed="true"]:hover,
      [aria-pressed="true"]:focus,
      [aria-pressed="true"]:active{
        background:var(--pv-active-bg) !important;
        background-color:var(--pv-active-bg) !important;
        color:var(--pv-active-text) !important;
        border-color:var(--pv-active-border) !important;
        box-shadow:none !important;
        filter:none !important;
        opacity:1 !important;
      }

      .pv-tab-locked *,
      .pv-tab-locked:hover *,
      .pv-tab-locked:focus *,
      .pv-tab-locked:active *,
      .pv-tab-button.active *,
      .pv-tab-button.active:hover *,
      .rf-tabbar button.active *,
      .rf-tabbar button.active:hover *,
      [aria-pressed="true"] *,
      [aria-pressed="true"]:hover *{
        color:inherit !important;
        background:transparent !important;
        box-shadow:none !important;
        filter:none !important;
      }

      :root[data-pv-theme="dark"] .pv-tab-locked,
      :root[data-pv-theme="dark"] .pv-tab-locked:hover,
      :root[data-pv-theme="dark"] .pv-tab-locked:focus,
      :root[data-pv-theme="dark"] .pv-tab-locked:active,
      :root[data-pv-theme="dark"] .pv-tab-button.active,
      :root[data-pv-theme="dark"] .pv-tab-button.active:hover,
      :root[data-pv-theme="dark"] .pv-tab-button.active:focus,
      :root[data-pv-theme="dark"] .pv-tab-button.active:active,
      :root[data-pv-theme="dark"] .rf-tabbar button.active,
      :root[data-pv-theme="dark"] .rf-tabbar button.active:hover,
      :root[data-pv-theme="dark"] .rf-tabbar button.active:focus,
      :root[data-pv-theme="dark"] .rf-tabbar button.active:active,
      :root[data-pv-theme="dark"] [aria-pressed="true"],
      :root[data-pv-theme="dark"] [aria-pressed="true"]:hover,
      :root[data-pv-theme="dark"] [aria-pressed="true"]:focus,
      :root[data-pv-theme="dark"] [aria-pressed="true"]:active{
        background:#d4af37 !important;
        background-color:#d4af37 !important;
        color:#000000 !important;
        border-color:#d4af37 !important;
        box-shadow:none !important;
        filter:none !important;
        opacity:1 !important;
      }

      :root[data-pv-theme="dark"] .pv-tab-locked *,
      :root[data-pv-theme="dark"] .pv-tab-locked:hover *,
      :root[data-pv-theme="dark"] .pv-tab-locked:focus *,
      :root[data-pv-theme="dark"] .pv-tab-locked:active *,
      :root[data-pv-theme="dark"] .pv-tab-button.active *,
      :root[data-pv-theme="dark"] .pv-tab-button.active:hover *,
      :root[data-pv-theme="dark"] .rf-tabbar button.active *,
      :root[data-pv-theme="dark"] .rf-tabbar button.active:hover *,
      :root[data-pv-theme="dark"] [aria-pressed="true"] *,
      :root[data-pv-theme="dark"] [aria-pressed="true"]:hover *{
        color:#000000 !important;
        background:transparent !important;
        box-shadow:none !important;
        filter:none !important;
      }

      .navbar .nav-link,
      .navbar .dropdown-toggle{
        border:0 !important;
        border-radius:999px !important;
        outline:0 !important;
        box-shadow:none !important;
      }

      .navbar .nav-link:hover,
      .navbar .dropdown-toggle:hover,
      .navbar .nav-link:focus,
      .navbar .dropdown-toggle:focus,
      .navbar .nav-link:focus-visible,
      .navbar .dropdown-toggle:focus-visible{
        border:0 !important;
        border-radius:999px !important;
        outline:0 !important;
        box-shadow:none !important;
        background:var(--pv-button-hover-bg) !important;
        color:var(--pv-button-hover-text) !important;
      }

      .navbar .nav-link.fw-bold,
      .navbar .nav-link.active,
      .navbar .dropdown-toggle.fw-bold,
      .navbar .dropdown-toggle.active,
      .navbar .nav-link.fw-bold:hover,
      .navbar .nav-link.active:hover,
      .navbar .dropdown-toggle.fw-bold:hover,
      .navbar .dropdown-toggle.active:hover,
      .navbar .nav-link.fw-bold:focus,
      .navbar .nav-link.active:focus,
      .navbar .dropdown-toggle.fw-bold:focus,
      .navbar .dropdown-toggle.active:focus,
      .navbar .nav-link.fw-bold:focus-visible,
      .navbar .nav-link.active:focus-visible,
      .navbar .dropdown-toggle.fw-bold:focus-visible,
      .navbar .dropdown-toggle.active:focus-visible{
        border:0 !important;
        border-radius:999px !important;
        outline:0 !important;
        box-shadow:none !important;
        background:var(--pv-active-bg) !important;
        color:var(--pv-active-text) !important;
      }

      .navbar .nav-link *,
      .navbar .dropdown-toggle *,
      .navbar .nav-link:hover *,
      .navbar .dropdown-toggle:hover *,
      .navbar .nav-link:focus *,
      .navbar .dropdown-toggle:focus *,
      .navbar .nav-link:focus-visible *,
      .navbar .dropdown-toggle:focus-visible *{
        color:inherit !important;
        background:transparent !important;
        border:0 !important;
        outline:0 !important;
        box-shadow:none !important;
        filter:none !important;
      }

      .modal-backdrop{
        background-color:#000000 !important;
      }
    </style>
  </head>

  <body>
    <%= render "shared/navbar" %>

    <div class="container mt-3">
      <% flash.each do |type, msg| %>
        <% bs = (type.to_s == "alert" ? "danger" : type.to_s == "notice" ? "success" : "info") %>
        <div class="alert alert-<%= bs %> alert-dismissible fade show mb-3 position-relative pe-5" role="alert">
          <div><%= msg %></div>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <div class="container mt-2">
      <%= yield %>
    </div>

    <%= render "shared/footer" %>

    <div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h1 class="modal-title fs-5" id="authModalLabel">Welcome</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancel"></button>
          </div>

          <div class="modal-body">
            <ul class="nav nav-tabs" id="authTab" role="tablist">
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link active"
                  id="login-tab"
                  data-bs-toggle="tab"
                  data-bs-target="#login-pane"
                  type="button"
                  role="tab"
                  aria-controls="login-pane"
                  aria-selected="true">
                  Login
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button
                  class="nav-link"
                  id="register-tab"
                  data-bs-toggle="tab"
                  data-bs-target="#register-pane"
                  type="button"
                  role="tab"
                  aria-controls="register-pane"
                  aria-selected="false">
                  Register
                </button>
              </li>
            </ul>

            <div class="tab-content pt-3">
              <div
                class="tab-pane fade show active"
                id="login-pane"
                role="tabpanel"
                aria-labelledby="login-tab"
                tabindex="0">
                <%= render "sessions/form" %>
              </div>

              <div
                class="tab-pane fade"
                id="register-pane"
                role="tabpanel"
                aria-labelledby="register-tab"
                tabindex="0">
                <%= render "registrations/form" %>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
      (function(){
        function forceDarkTheme(){
          document.documentElement.setAttribute("data-pv-theme", "dark");
          localStorage.setItem("pokevalue_theme", "dark");
        }

        function cssVar(name){
          return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        }

        function forceColours(el, active){
          if(!el) return;

          const bg = active ? (cssVar("--pv-active-bg") || cssVar("--pv-button-hover-bg")) : (cssVar("--pv-button-bg") || "#ffffff");
          const text = active ? (cssVar("--pv-active-text") || cssVar("--pv-button-hover-text")) : (cssVar("--pv-button-text") || "#000000");
          const border = active ? (cssVar("--pv-active-border") || cssVar("--pv-button-hover-border")) : (cssVar("--pv-button-border") || "#000000");

          el.style.setProperty("background", bg, "important");
          el.style.setProperty("background-color", bg, "important");
          el.style.setProperty("color", text, "important");
          el.style.setProperty("border-color", border, "important");
          el.style.setProperty("box-shadow", "none", "important");
          el.style.setProperty("filter", "none", "important");

          el.querySelectorAll("*").forEach(function(child){
            child.style.setProperty("color", "inherit", "important");
            child.style.setProperty("background", "transparent", "important");
            child.style.setProperty("box-shadow", "none", "important");
            child.style.setProperty("filter", "none", "important");
          });
        }

        function normalizeTabText(value){
          return String(value || "")
            .toLowerCase()
            .replace(/\s+/g, " ")
            .trim();
        }

        function isMarketplaceTabText(text){
          return [
            "current listings",
            "current listing",
            "current",
            "sold listings",
            "sold listing",
            "sold"
          ].includes(text);
        }

        function isAuctionTabText(text){
          return [
            "current auctions",
            "current auction",
            "current",
            "ended auctions",
            "ended auction",
            "ended",
            "sold auctions",
            "sold auction",
            "sold"
          ].includes(text);
        }

        function isRaffleTabText(text){
          return [
            "raffles",
            "mini raffles",
            "completed",
            "incompleted"
          ].includes(text);
        }

        function isTabLike(el){
          if(!el) return false;

          const text = normalizeTabText(el.textContent);
          const href = el.getAttribute("href") || "";
          const cls = el.className ? String(el.className) : "";

          if(el.matches("[data-marketplace-tab], [data-auction-tab], [data-marketplace-tab-target], [data-auction-tab-target], [data-rf-tab-target]")) return true;
          if(cls.match(/marketplace.*tab|auction.*tab|raffle.*tab|rf-tabbar|mp-tab|au-tab|tabbar|tabs/i)) return true;
          if(href.includes("/marketplace") || href.includes("/auction") || href.includes("/raffles")) return true;
          if(isMarketplaceTabText(text) || isAuctionTabText(text) || isRaffleTabText(text)) return true;

          return false;
        }

        function setTabState(el, active){
          if(!isTabLike(el)) return;

          el.classList.add("pv-tab-button");

          if(active){
            el.classList.add("pv-tab-locked", "active");
            el.setAttribute("aria-pressed", "true");
            forceColours(el, true);
          }else{
            el.classList.remove("pv-tab-locked");
            el.setAttribute("aria-pressed", "false");
            forceColours(el, false);
          }
        }

        function marketplaceTabForElement(el){
          const text = normalizeTabText(el.textContent);
          const href = el.getAttribute("href") || "";
          const data = [
            el.getAttribute("data-marketplace-tab"),
            el.getAttribute("data-marketplace-tab-target"),
            el.getAttribute("data-tab"),
            el.getAttribute("data-tab-target")
          ].filter(Boolean).join(" ").toLowerCase();

          if(href.includes("tab=sold") || data.includes("sold") || text.includes("sold")) return "sold";
          if(href.includes("tab=current") || data.includes("current") || text.includes("current")) return "current";
          return "";
        }

        function auctionTabForElement(el){
          const text = normalizeTabText(el.textContent);
          const href = el.getAttribute("href") || "";
          const data = [
            el.getAttribute("data-auction-tab"),
            el.getAttribute("data-auction-tab-target"),
            el.getAttribute("data-tab"),
            el.getAttribute("data-tab-target")
          ].filter(Boolean).join(" ").toLowerCase();

          if(href.includes("auction_tab=sold") || href.includes("tab=sold") || data.includes("sold") || text.includes("sold")) return "sold";
          if(href.includes("auction_tab=ended") || href.includes("tab=ended") || data.includes("ended") || text.includes("ended")) return "ended";
          if(href.includes("auction_tab=current") || href.includes("tab=current") || data.includes("current") || text.includes("current")) return "current";
          return "";
        }

        function raffleTabForElement(el){
          const text = normalizeTabText(el.textContent);
          const data = [
            el.getAttribute("data-rf-tab-target"),
            el.getAttribute("data-tab"),
            el.getAttribute("data-tab-target")
          ].filter(Boolean).join(" ").toLowerCase();

          if(data.includes("mini") || text === "mini raffles") return "mini_raffles";
          if(data.includes("completed") || text === "completed") return "completed";
          if(data.includes("incompleted") || text === "incompleted") return "incompleted";
          if(data.includes("raffles") || text === "raffles") return "raffles";
          return "";
        }

        function initMarketplaceTabs(){
          const path = window.location.pathname;
          if(!(path === "/marketplace" || path.startsWith("/marketplace"))) return;

          const params = new URLSearchParams(window.location.search);
          const currentTab = params.get("tab") === "sold" ? "sold" : "current";

          document.querySelectorAll("a, button").forEach(function(el){
            const tab = marketplaceTabForElement(el);
            if(!tab) return;
            setTabState(el, tab === currentTab);
          });
        }

        function initAuctionTabs(){
          const path = window.location.pathname;
          if(!(path === "/auction" || path.startsWith("/auction"))) return;

          const params = new URLSearchParams(window.location.search);
          const raw = params.get("auction_tab") || params.get("tab") || "current";
          const currentTab = ["sold", "ended"].includes(raw) ? raw : "current";

          document.querySelectorAll("a, button").forEach(function(el){
            const tab = auctionTabForElement(el);
            if(!tab) return;
            setTabState(el, tab === currentTab);
          });
        }

        function initRaffleTabs(){
          const path = window.location.pathname;
          if(!(path === "/raffles" || path.startsWith("/raffles") || path === "/raffle")) return;

          const buttons = Array.from(document.querySelectorAll("[data-rf-tab-target], .rf-tabbar button"));

          if(!buttons.length) return;

          buttons.forEach(function(button){
            button.classList.add("pv-tab-button");

            if(button.dataset.pvRaffleTabBound !== "1"){
              button.dataset.pvRaffleTabBound = "1";

              button.addEventListener("click", function(){
                setTimeout(function(){
                  buttons.forEach(function(btn){
                    const active = btn.classList.contains("active");
                    setTabState(btn, active);
                  });
                }, 0);
              });
            }

            setTabState(button, button.classList.contains("active"));
          });
        }

        function removeRaffleFiltersHeading(){
          const path = window.location.pathname;
          if(!(path === "/raffles" || path.startsWith("/raffles") || path === "/raffle")) return;

          document.querySelectorAll("h1,h2,h3,h4,h5,h6,.rf-filter-title,.raffle-filter-title,.filter-title,.fw-semibold").forEach(function(el){
            const text = normalizeTabText(el.textContent);
            if(text !== "filters") return;

            const parent = el.parentElement;
            const parentClass = parent && parent.className ? String(parent.className).toLowerCase() : "";
            const nearby = parent ? parent.querySelector("input,select,button,form") : null;

            if(parentClass.includes("filter") || nearby){
              el.style.setProperty("display", "none", "important");
            }
          });
        }

        function initMarketplaceAuctionRaffleTabs(){
          initMarketplaceTabs();
          initAuctionTabs();
          initRaffleTabs();
          removeRaffleFiltersHeading();
        }

        function initAllThemeBehaviour(){
          forceDarkTheme();
          initMarketplaceAuctionRaffleTabs();
        }

        document.addEventListener("DOMContentLoaded", initAllThemeBehaviour);
        document.addEventListener("turbo:load", initAllThemeBehaviour);
        document.addEventListener("click", function(){
          setTimeout(initMarketplaceAuctionRaffleTabs, 0);
        });
      })();
    </script>
  </body>
</html>