<!DOCTYPE html>
<html data-pv-theme="dark">
  <head>
    <title>PokeValueApp</title>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-cache-control" content="no-cache">

    <script>
      (function(){
        document.documentElement.setAttribute("data-pv-theme", "dark");
        localStorage.setItem("pokevalue_theme", "dark");
      })();
    </script>

    <%= javascript_importmap_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">

    <style>
      :root[data-pv-theme="light"]{
        --pv-bg:#ffffff;
        --pv-surface:#ffffff;
        --pv-surface-2:#ffffff;
        --pv-surface-3:#f8f9fa;
        --pv-text:#000000;
        --pv-muted:#555555;
        --pv-border:#000000;
        --pv-button-bg:#ffffff;
        --pv-button-text:#000000;
        --pv-button-border:#000000;
        --pv-button-hover-bg:#000000;
        --pv-button-hover-text:#ffffff;
        --pv-button-hover-border:#000000;
        --pv-active-bg:#000000;
        --pv-active-text:#ffffff;
        --pv-active-border:#000000;
        --pv-link:#000000;
        --pv-shadow:0 10px 25px rgba(0,0,0,.08);
        --pv-input-bg:#ffffff;
        --pv-input-text:#000000;
        --pv-table-head:#f3f4f6;
      }

      :root[data-pv-theme="dark"]{
        --pv-bg:#000000;
        --pv-surface:#000000;
        --pv-surface-2:#000000;
        --pv-surface-3:#000000;
        --pv-text:#d4af37;
        --pv-muted:#d4af37;
        --pv-border:#d4af37;
        --pv-button-bg:#000000;
        --pv-button-text:#d4af37;
        --pv-button-border:#d4af37;
        --pv-button-hover-bg:#d4af37;
        --pv-button-hover-text:#000000;
        --pv-button-hover-border:#d4af37;
        --pv-active-bg:#d4af37;
        --pv-active-text:#000000;
        --pv-active-border:#d4af37;
        --pv-link:#d4af37;
        --pv-shadow:none;
        --pv-input-bg:#000000;
        --pv-input-text:#d4af37;
        --pv-table-head:#000000;
      }

      html,
      body{
        background:var(--pv-bg) !important;
        color:var(--pv-text) !important;
        min-height:100vh;
      }

      body,
      p,
      span,
      div,
      label,
      small,
      strong,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      li,
      td,
      th,
      tr,
      tbody,
      thead,
      table{
        color:var(--pv-text) !important;
      }

      a{
        color:var(--pv-link) !important;
      }

      a:hover{
        color:var(--pv-link) !important;
      }

      .text-muted,
      .small.text-muted,
      .text-secondary,
      .form-label,
      .col-form-label,
      .community-subtitle,
      .community-hint,
      .community-file-status,
      .community-time,
      .community-login-copy p,
      .rf-sub,
      .rf-muted,
      .co-sub,
      .ml-muted,
      .au-show-sub,
      .au-show-review-meta{
        color:var(--pv-muted) !important;
      }

      .navbar{
        background:var(--pv-surface-2) !important;
        border-bottom:1px solid var(--pv-border) !important;
      }

      .navbar .nav-link,
      .navbar .navbar-text,
      .navbar .navbar-brand,
      .navbar .dropdown-toggle,
      .navbar a,
      .dropdown-item{
        color:var(--pv-text) !important;
      }

      .navbar .nav-link,
      .navbar .dropdown-toggle{
        border:0 !important;
        border-radius:999px !important;
        background:transparent !important;
        box-shadow:none !important;
        outline:0 !important;
        padding-left:.75rem !important;
        padding-right:.75rem !important;
      }

      .navbar .nav-link:hover,
      .navbar .dropdown-toggle:hover,
      .navbar .nav-link:focus,
      .navbar .dropdown-toggle:focus,
      .navbar .nav-link:focus-visible,
      .navbar .dropdown-toggle:focus-visible{
        color:var(--pv-button-hover-text) !important;
        background:var(--pv-button-hover-bg) !important;
        border:0 !important;
        border-radius:999px !important;
        box-shadow:none !important;
        outline:0 !important;
      }

      .navbar .nav-link.fw-bold,
      .navbar .nav-link.active,
      .navbar .dropdown-toggle.fw-bold,
      .navbar .dropdown-toggle.active,
      .navbar .nav-link.fw-bold:hover,
      .navbar .nav-link.active:hover,
      .navbar .dropdown-toggle.fw-bold:hover,
      .navbar .dropdown-toggle.active:hover,
      .navbar .nav-link.fw-bold:focus,
      .navbar .nav-link.active:focus,
      .navbar .dropdown-toggle.fw-bold:focus,
      .navbar .dropdown-toggle.active:focus,
      .navbar .nav-link.fw-bold:focus-visible,
      .navbar .nav-link.active:focus-visible,
      .navbar .dropdown-toggle.fw-bold:focus-visible,
      .navbar .dropdown-toggle.active:focus-visible{
        color:var(--pv-active-text) !important;
        background:var(--pv-active-bg) !important;
        border:0 !important;
        border-radius:999px !important;
        box-shadow:none !important;
        outline:0 !important;
        padding-left:.75rem !important;
        padding-right:.75rem !important;
      }

      .navbar .nav-link *,
      .navbar .dropdown-toggle *,
      .navbar .nav-link:hover *,
      .navbar .dropdown-toggle:hover *,
      .navbar .nav-link:focus *,
      .navbar .dropdown-toggle:focus *,
      .navbar .nav-link:focus-visible *,
      .navbar .dropdown-toggle:focus-visible *,
      .navbar .nav-link.fw-bold *,
      .navbar .nav-link.active *,
      .navbar .dropdown-toggle.fw-bold *,
      .navbar .dropdown-toggle.active *{
        color:inherit !important;
        background:transparent !important;
        border:0 !important;
        box-shadow:none !important;
        outline:0 !important;
        filter:none !important;
      }

      .navbar-toggler{
        border-color:var(--pv-border) !important;
        background:var(--pv-surface) !important;
      }

      .dropdown-menu{
        background:var(--pv-surface) !important;
        border:1px solid var(--pv-border) !important;
        box-shadow:var(--pv-shadow) !important;
      }

      .dropdown-item{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
      }

      .dropdown-item.active,
      .dropdown-item.fw-bold{
        background:var(--pv-active-bg) !important;
        color:var(--pv-active-text) !important;
      }

      .card,
      .modal-content,
      .list-group-item,
      .community-card,
      .rf-card,
      .rf-table-card,
      .au-show-block,
      .co-block,
      .ml-wrap,
      .admin-sets-card,
      .community-post-card,
      .community-comment-card,
      .community-reaction-person,
      .rf-stat,
      .rf-tag-card,
      .au-pay-box,
      .equal-tile,
      .era-card,
      .set-card,
      .sets-card,
      .sets-era-card,
      .set-era-card,
      .auction-card,
      .marketplace-card,
      .raffle-card{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border:1px solid var(--pv-border) !important;
        border-radius:16px !important;
        box-shadow:var(--pv-shadow) !important;
        background-clip:border-box !important;
        overflow:hidden !important;
      }

      .modal-content{
        position:relative !important;
        border:1px solid var(--pv-border) !important;
        border-radius:16px !important;
        overflow:hidden !important;
        background-clip:border-box !important;
        box-shadow:var(--pv-shadow) !important;
      }

      .modal-content::after{
        content:"";
        position:absolute;
        inset:0;
        border:1px solid var(--pv-border);
        border-radius:16px;
        pointer-events:none;
        z-index:5;
      }

      .modal-header{
        border-top-left-radius:15px !important;
        border-top-right-radius:15px !important;
      }

      .modal-footer{
        border-bottom-left-radius:15px !important;
        border-bottom-right-radius:15px !important;
      }

      .card-body,
      .card-header,
      .card-footer,
      .modal-header,
      .modal-body,
      .modal-footer{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      a.text-decoration-none:hover .card,
      a:hover .card,
      a:hover .set-card,
      a:hover .sets-card,
      a:hover .sets-era-card,
      a:hover .set-era-card,
      a:hover .era-card,
      a:hover .equal-tile{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      a.text-decoration-none:hover .card *,
      a:hover .card *,
      a:hover .set-card *,
      a:hover .sets-card *,
      a:hover .sets-era-card *,
      a:hover .set-era-card *,
      a:hover .era-card *,
      a:hover .equal-tile *{
        color:var(--pv-text) !important;
        background:transparent !important;
      }

      .table-responsive,
      .rf-table-wrap,
      .au-table-wrap,
      .marketplace-table-wrap,
      .holdings-table-wrap,
      .admin-table-wrap{
        border:1px solid var(--pv-border) !important;
        border-radius:16px !important;
        overflow:auto !important;
        background:var(--pv-surface) !important;
        box-shadow:var(--pv-shadow) !important;
        background-clip:border-box !important;
      }

      .table,
      table,
      .rf-table,
      .au-table,
      .marketplace-table,
      .holdings-table,
      .admin-table,
      .admin-sets-table{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border:0 !important;
        border-collapse:separate !important;
        border-spacing:0 !important;
        margin-bottom:0 !important;
        overflow:hidden !important;
      }

      .table thead,
      .table thead tr,
      .table thead th,
      thead,
      thead tr,
      thead th,
      .table-light,
      .rf-table thead th,
      .au-table thead th,
      .marketplace-table thead th,
      .holdings-table thead th,
      .admin-table thead th,
      .admin-sets-table thead th,
      .admin-sets-card .card-head{
        background:var(--pv-table-head) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      .table tbody,
      .table tbody tr,
      .table tbody td,
      tbody,
      tbody tr,
      tbody td,
      .rf-table tbody td,
      .au-table tbody td,
      .marketplace-table tbody td,
      .holdings-table tbody td,
      .admin-table tbody td,
      .admin-sets-table tbody td{
        background:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      .table > :not(caption) > * > *,
      .table-bordered > :not(caption) > * > *,
      .rf-table th,
      .rf-table td,
      .au-table th,
      .au-table td,
      .marketplace-table th,
      .marketplace-table td,
      .holdings-table th,
      .holdings-table td,
      .admin-table th,
      .admin-table td,
      .admin-sets-table th,
      .admin-sets-table td{
        background-color:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
        border-top:0 !important;
        border-left:0 !important;
      }

      .table thead th,
      .rf-table thead th,
      .au-table thead th,
      .marketplace-table thead th,
      .holdings-table thead th,
      .admin-table thead th,
      .admin-sets-table thead th{
        background:var(--pv-table-head) !important;
        color:var(--pv-text) !important;
        border-bottom:1px solid var(--pv-border) !important;
      }

      .table th:not(:last-child),
      .table td:not(:last-child),
      .rf-table th:not(:last-child),
      .rf-table td:not(:last-child),
      .au-table th:not(:last-child),
      .au-table td:not(:last-child),
      .marketplace-table th:not(:last-child),
      .marketplace-table td:not(:last-child),
      .holdings-table th:not(:last-child),
      .holdings-table td:not(:last-child),
      .admin-table th:not(:last-child),
      .admin-table td:not(:last-child),
      .admin-sets-table th:not(:last-child),
      .admin-sets-table td:not(:last-child){
        border-right:1px solid var(--pv-border) !important;
      }

      .table tr:not(:last-child) td,
      .rf-table tr:not(:last-child) td,
      .au-table tr:not(:last-child) td,
      .marketplace-table tr:not(:last-child) td,
      .holdings-table tr:not(:last-child) td,
      .admin-table tr:not(:last-child) td,
      .admin-sets-table tr:not(:last-child) td{
        border-bottom:1px solid var(--pv-border) !important;
      }

      .table thead tr:first-child th:first-child,
      .rf-table thead tr:first-child th:first-child,
      .au-table thead tr:first-child th:first-child,
      .marketplace-table thead tr:first-child th:first-child,
      .holdings-table thead tr:first-child th:first-child,
      .admin-table thead tr:first-child th:first-child,
      .admin-sets-table thead tr:first-child th:first-child{
        border-top-left-radius:15px !important;
      }

      .table thead tr:first-child th:last-child,
      .rf-table thead tr:first-child th:last-child,
      .au-table thead tr:first-child th:last-child,
      .marketplace-table thead tr:first-child th:last-child,
      .holdings-table thead tr:first-child th:last-child,
      .admin-table thead tr:first-child th:last-child,
      .admin-sets-table thead tr:first-child th:last-child{
        border-top-right-radius:15px !important;
      }

      .table tbody tr:last-child td:first-child,
      .rf-table tbody tr:last-child td:first-child,
      .au-table tbody tr:last-child td:first-child,
      .marketplace-table tbody tr:last-child td:first-child,
      .holdings-table tbody tr:last-child td:first-child,
      .admin-table tbody tr:last-child td:first-child,
      .admin-sets-table tbody tr:last-child td:first-child{
        border-bottom-left-radius:15px !important;
      }

      .table tbody tr:last-child td:last-child,
      .rf-table tbody tr:last-child td:last-child,
      .au-table tbody tr:last-child td:last-child,
      .marketplace-table tbody tr:last-child td:last-child,
      .holdings-table tbody tr:last-child td:last-child,
      .admin-table tbody tr:last-child td:last-child,
      .admin-sets-table tbody tr:last-child td:last-child{
        border-bottom-right-radius:15px !important;
      }

      .table-striped > tbody > tr:nth-of-type(odd) > *,
      .table-hover > tbody > tr:hover > *{
        background-color:var(--pv-surface) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      .table-light > *,
      .table-light > * > *{
        background:var(--pv-table-head) !important;
        color:var(--pv-text) !important;
      }

      .form-control,
      .form-select,
      textarea,
      input,
      select,
      option{
        background-color:var(--pv-input-bg) !important;
        color:var(--pv-input-text) !important;
        border-color:var(--pv-border) !important;
      }

      input[type="file"],
      .form-control[type="file"]{
        background-color:var(--pv-input-bg) !important;
        color:var(--pv-input-text) !important;
        border-color:var(--pv-border) !important;
      }

      input[type="file"]::file-selector-button,
      .form-control[type="file"]::file-selector-button{
        background:var(--pv-button-bg) !important;
        background-color:var(--pv-button-bg) !important;
        color:var(--pv-button-text) !important;
        border:0 !important;
        border-right:1px solid var(--pv-button-border) !important;
        box-shadow:none !important;
        filter:none !important;
      }

      input[type="file"]::-webkit-file-upload-button,
      .form-control[type="file"]::-webkit-file-upload-button{
        background:var(--pv-button-bg) !important;
        background-color:var(--pv-button-bg) !important;
        color:var(--pv-button-text) !important;
        border:0 !important;
        border-right:1px solid var(--pv-button-border) !important;
        box-shadow:none !important;
        filter:none !important;
      }

      input[type="file"]::file-selector-button:hover,
      .form-control[type="file"]::file-selector-button:hover,
      input[type="file"]::-webkit-file-upload-button:hover,
      .form-control[type="file"]::-webkit-file-upload-button:hover{
        background:var(--pv-button-hover-bg) !important;
        background-color:var(--pv-button-hover-bg) !important;
        color:var(--pv-button-hover-text) !important;
        border-color:var(--pv-button-hover-border) !important;
      }

      :root[data-pv-theme="dark"] input[type="file"]::file-selector-button,
      :root[data-pv-theme="dark"] .form-control[type="file"]::file-selector-button,
      :root[data-pv-theme="dark"] input[type="file"]::-webkit-file-upload-button,
      :root[data-pv-theme="dark"] .form-control[type="file"]::-webkit-file-upload-button{
        background:#000000 !important;
        background-color:#000000 !important;
        color:#d4af37 !important;
        border-color:#d4af37 !important;
      }

      :root[data-pv-theme="dark"] input[type="file"]::file-selector-button:hover,
      :root[data-pv-theme="dark"] .form-control[type="file"]::file-selector-button:hover,
      :root[data-pv-theme="dark"] input[type="file"]::-webkit-file-upload-button:hover,
      :root[data-pv-theme="dark"] .form-control[type="file"]::-webkit-file-upload-button:hover{
        background:#d4af37 !important;
        background-color:#d4af37 !important;
        color:#000000 !important;
        border-color:#d4af37 !important;
      }

      .form-control:focus,
      .form-select:focus,
      textarea:focus,
      input:focus,
      select:focus{
        background-color:var(--pv-input-bg) !important;
        color:var(--pv-input-text) !important;
        border-color:var(--pv-border) !important;
        box-shadow:0 0 0 .18rem rgba(212,175,55,.18) !important;
      }

      .form-control::placeholder,
      textarea::placeholder,
      input::placeholder{
        color:var(--pv-muted) !important;
        opacity:.75 !important;
      }

      .input-group-text{
        background:var(--pv-surface-3) !important;
        color:var(--pv-text) !important;
        border-color:var(--pv-border) !important;
      }

      .btn,
      input[type="submit"],
      .community-file-trigger,
      .community-channel-pill,
      .rf-tabbar button,
      .community-reactions-filter,
      .rf-number-chip,
      .rf-ticket-option,
      .nav-tabs .nav-link,
      .page-link,
      .pv-tab-button,
      .marketplace-tab,
      .marketplace-tabs a,
      .marketplace-tabs button,
      .marketplace-tabbar a,
      .marketplace-tabbar button,
      .mp-tab,
      .auction-tab,
      .auction-tabs a,
      .auction-tabs button,
      .auction-tabbar a,
      .auction-tabbar button,
      .au-tab,
      [data-marketplace-tab],
      [data-auction-tab],
      [data-marketplace-tab-target],
      [data-auction-tab-target]{
        background:var(--pv-button-bg) !important;
        color:var(--pv-button-text) !important;
        border:1px solid var(--pv-button-border) !important;
        transition:background-color .15s ease,color .15s ease,border-color .15s ease !important;
        box-shadow:none !important;
        filter:none !important;
      }

      .btn *,
      button *,
      input[type="submit"] *,
      .community-file-trigger *,
      .community-channel-pill *,
      .rf-tabbar button *,
      .community-reactions-filter *,
      .nav-tabs .nav-link *,
      .page-link *,
      .pv-tab-button *,
      .marketplace-tab *,
      .marketplace-tabs a *,
      .marketplace-tabs button *,
      .marketplace-tabbar a *,
      .marketplace-tabbar button *,
      .mp-tab *,
      .auction-tab *,
      .auction-tabs a *,
      .auction-tabs button *,
      .auction-tabbar a *,
      .auction-tabbar button *,
      .au-tab *{
        color:inherit !important;
        background:transparent !important;
        border-color:inherit !important;
        box-shadow:none !important;
      }

      .btn-primary,
      .btn-dark,
      .btn-success,
      .btn-secondary,
      .btn-danger,
      .btn-warning,
      .btn-info,
      .btn-outline-primary,
      .btn-outline-dark,
      .btn-outline-secondary,
      .btn-outline-success,
      .btn-outline-danger,
      .btn-outline-warning,
      .btn-outline-info{
        background:var(--pv-button-bg) !important;
        border:1px solid var(--pv-button-border) !important;
        color:var(--pv-button-text) !important;
      }

      .btn:not(.active):not(.pv-tab-locked):not(.disabled):not(:disabled):not([aria-disabled="true"]):hover,
      input[type="submit"]:not(:disabled):hover,
      .community-file-trigger:hover,
      .community-channel-pill:not(.active):hover,
      .rf-tabbar button:not(.active):hover,
      .community-reactions-filter:not(.active):hover,
      .rf-number-chip:not(.active):hover,
      .rf-ticket-option:not(.is-selected):hover,
      .nav-tabs .nav-link:not(.active):hover,
      .page-link:hover,
      .navbar .nav-link:not(.fw-bold):not(.active):hover,
      .navbar .dropdown-toggle:not(.fw-bold):not(.active):hover,
      .dropdown-item:not(.active):not(.fw-bold):hover,
      .pv-tab-button:not(.active):not(.pv-tab-locked):hover,
      .marketplace-tab:not(.active):not(.pv-tab-locked):hover,
      .marketplace-tabs a:not(.active):not(.pv-tab-locked):hover,
      .marketplace-tabs button:not(.active):not(.pv-tab-locked):hover,
      .marketplace-tabbar a:not(.active):not(.pv-tab-locked):hover,
      .marketplace-tabbar button:not(.active):not(.pv-tab-locked):hover,
      .mp-tab:not(.active):not(.pv-tab-locked):hover,
      .auction-tab:not(.active):not(.pv-tab-locked):hover,
      .auction-tabs a:not(.active):not(.pv-tab-locked):hover,
      .auction-tabs button:not(.active):not(.pv-tab-locked):hover,
      .auction-tabbar a:not(.active):not(.pv-tab-locked):hover,
      .auction-tabbar button:not(.active):not(.pv-tab-locked):hover,
      .au-tab:not(.active):not(.pv-tab-locked):hover,
      [data-marketplace-tab]:not(.active):not(.pv-tab-locked):hover,
      [data-auction-tab]:not(.active):not(.pv-tab-locked):hover,
