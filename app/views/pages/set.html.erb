<div class="container py-3">
  <style>
    .equal-tile{min-height:120px;overflow:visible}
    .tile-logo{max-height:60px;max-width:100%;height:auto;width:auto;object-fit:contain}
    .equal-tile .small.text-muted{font-size:.70rem;line-height:1.2;white-space:nowrap}
    .equal-tile .fw-semibold{font-size:.80rem;line-height:1.35;margin-top:2px;padding:0 3px;text-align:center}
    .product-card-img{aspect-ratio:4/3;object-fit:contain;background:#ffffff;padding:.5rem}
    .urgency-tile.urgency-green{background-color:#16a34a;color:#ffffff}
    .urgency-tile.urgency-orange{background-color:#f97316;color:#ffffff}
    .urgency-tile.urgency-red{background-color:#ef4444;color:#ffffff}
    .urgency-tile.urgency-dark-red{background-color:#7f1d1d;color:#ffffff}
    .urgency-tile.urgency-black{background-color:#000000;color:#ffffff}
    .urgency-tile.urgency-unknown{background-color:#e5e7eb;color:#111827}
    .urgency-tile .small.text-muted{color:inherit!important;opacity:.85}
    .urgency-tile .fw-semibold{font-size:.72rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  </style>

  <div class="mb-3">
    <%= link_to "← Back to sets", sets_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <%# Admin-only edit panel for updating set value and card totals %>
  <% if defined?(admin_signed_in?) && admin_signed_in? %>
    <div class="mb-3">
      <div class="card">
        <div class="card-body">
          <%= form_with url: admin_set_path(slug: @set_slug), method: :patch, local: true do %>
            <div class="row g-2 align-items-end">
              <div class="col-12 col-md-4">
                <label class="form-label mb-1">Total Set Value (€)</label>
                <%= number_field_tag :total_value, @total_value, step: "0.01", min: 0, class: "form-control" %>
              </div>

              <div class="col-6 col-md-3">
                <label class="form-label mb-1">Cards</label>
                <%= number_field_tag :cards, @cards, step: 1, min: 0, class: "form-control" %>
              </div>

              <div class="col-6 col-md-3">
                <label class="form-label mb-1">Secret</label>
                <%= number_field_tag :secret_cards, @secret, step: 1, min: 0, class: "form-control" %>
              </div>

              <div class="col-12 col-md-2 d-grid">
                <button class="btn btn-primary" type="submit">Update</button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Top information tiles for logo, era, release date, value, card count and urgency %>
  <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 mb-4">
    <div class="col">
      <div class="card h-100 equal-tile d-flex align-items-center justify-content-center text-center p-3">
        <%= image_tag @set_logo_url, alt: @set_name, class: "tile-logo" %>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Era</div>
        <div class="fw-semibold"><%= @era %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Release Date</div>
        <div class="fw-semibold"><%= @release_date %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Total Set Value</div>
        <div class="fw-semibold">
          <%= @total_value.present? ? number_to_currency(@total_value, unit: "€") : "€0.00" %>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Cards/Secret</div>
        <div class="fw-semibold"><%= @cards.to_i %>/<%= @secret.to_i %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile urgency-tile d-flex flex-column align-items-center justify-content-center text-center p-3 <%= @urgency_class %>">
        <div class="small text-muted">Urgency Level</div>
        <div class="fw-semibold"><%= @urgency_label %></div>

        <% if @urgency_subtitle.present? %>
          <div class="small text-muted mt-1"><%= @urgency_subtitle %></div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Product cards for the selected set %>
  <div class="row">
    <div class="col-12">
      <% if @products.present? %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
          <% @products.each do |product| %>
            <div class="col">
              <%= link_to product[:link], class: "text-decoration-none" do %>
                <div class="card h-100">
                  <%= image_tag product[:img_url], alt: product[:name], class: "card-img-top product-card-img" %>

                  <div class="card-body py-2 text-center">
                    <div class="fw-semibold small m-0 text-truncate"><%= product[:name] %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-muted">No products listed for this set.</div>
      <% end %>
    </div>
  </div>
</div>