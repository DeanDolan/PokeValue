<%
  require "base64"

  # Product names that should not be shown on the set page
  hidden_exact = []

  # Normalises names so comparisons work even with different apostrophes or capital letters
  def normalize_name(s)
    s.to_s.strip.downcase.gsub("’", "'")
  end

  # Safely parses the release date stored for the set
  def parse_set_date(value)
    Date.parse(value.to_s)
  rescue
    nil
  end

  # Returns the number of days in a specific month
  def days_in_month(year, month)
    Date.new(year, month, -1).day
  end

  # Breaks the time between two dates into years, months and days
  def date_parts_between(from_date, to_date)
    return [0, 0, 0] if to_date <= from_date

    years = to_date.year - from_date.year
    months = to_date.month - from_date.month
    days = to_date.day - from_date.day

    if days < 0
      months -= 1
      previous_month = to_date.month - 1
      previous_year = to_date.year

      if previous_month == 0
        previous_month = 12
        previous_year -= 1
      end

      days += days_in_month(previous_year, previous_month)
    end

    if months < 0
      years -= 1
      months += 12
    end

    [years, months, days]
  end

  today = Date.current
  set_name_normalized = normalize_name(@set_name)
  era_normalized = normalize_name(@era)
  release_date = parse_set_date(@release_date)

  raw_set_logo_path = (defined?(@set_logo_url) && @set_logo_url.present?) ? @set_logo_url.to_s : ""
  cleaned_set_logo_path = raw_set_logo_path.sub(/\A\//, "").sub(/\Aimages\//, "")
  logo_file_name = File.basename(cleaned_set_logo_path.presence || "#{@set_slug}logo.png")

  logo_disk_candidates = [
    Rails.root.join("app", "assets", "images", cleaned_set_logo_path),
    Rails.root.join("app", "assets", "images", "sets", logo_file_name),
    Rails.root.join("app", "assets", "images", "images", "sets", logo_file_name),
    Rails.root.join("public", "assets", "sets", logo_file_name),
    Rails.root.join("public", "images", "sets", logo_file_name)
  ].uniq

  found_logo_path = logo_disk_candidates.find { |path| path.to_s.present? && File.file?(path) }

  set_logo_image_path =
    if found_logo_path
      ext = File.extname(found_logo_path.to_s).downcase
      mime = ext == ".jpg" || ext == ".jpeg" ? "image/jpeg" : "image/png"
      "data:#{mime};base64,#{Base64.strict_encode64(File.binread(found_logo_path.to_s))}"
    elsif raw_set_logo_path.start_with?("http://", "https://", "/assets/", "/rails/")
      raw_set_logo_path
    else
      "pokevaluelogo.png"
    end

  out_of_print_now = false
  out_of_print_date = nil

  # Sets that are already treated as out of print
  scarlet_violet_out_of_print = [
    "scarlet & violet base",
    "paldea evolved",
    "obsidian flames",
    "151",
    "paradox rift",
    "paldean fates"
  ]

  # Sets expected to become out of print by April 2027
  april_2027_out_of_print = [
    "temporal forces",
    "twilight masquerade",
    "shrouded fable",
    "stellar crown",
    "surging sparks",
    "prismatic evolutions"
  ]

  # Sets expected to become out of print by April 2028
  april_2028_out_of_print = [
    "journey together",
    "destined rivals",
    "black bolt",
    "white flare",
    "mega evolution base",
    "phantasmal flames",
    "ascended heroes"
  ]

  # Sets expected to become out of print by April 2029
  april_2029_out_of_print = [
    "perfect order"
  ]

  # Calculates whether the set is already out of print or when it is expected to be out of print
  if era_normalized == "sword & shield"
    out_of_print_now = true
  elsif scarlet_violet_out_of_print.include?(set_name_normalized)
    out_of_print_now = true
  elsif april_2027_out_of_print.include?(set_name_normalized)
    out_of_print_date = Date.new(2027, 4, 30)
  elsif april_2028_out_of_print.include?(set_name_normalized)
    out_of_print_date = Date.new(2028, 4, 30)
  elsif april_2029_out_of_print.include?(set_name_normalized)
    out_of_print_date = Date.new(2029, 4, 30)
  elsif release_date.present?
    out_of_print_date = Date.new(release_date.year + 3, 4, 30)
    out_of_print_date = Date.new(release_date.year + 4, 4, 30) if out_of_print_date <= release_date
  end

  out_of_print_now = true if out_of_print_date.present? && out_of_print_date <= today

  # Creates the urgency label and colour class shown in the urgency tile
  if out_of_print_now
    urgency_label = "Out of Print"
    urgency_class = "urgency-black"
  elsif out_of_print_date.present?
    years_left, months_left, days_left = date_parts_between(today, out_of_print_date)
    urgency_label = "#{years_left} Years #{months_left} Months #{days_left} Days"

    days_until_out_of_print = (out_of_print_date - today).to_i
    age_days = release_date.present? ? (today - release_date).to_i : nil

    urgency_class =
      if days_until_out_of_print <= 183
        "urgency-dark-red"
      elsif days_until_out_of_print <= 365
        "urgency-red"
      elsif age_days.present? && age_days < 183
        "urgency-green"
      else
        "urgency-orange"
      end
  else
    urgency_label = "Unknown"
    urgency_class = "urgency-unknown"
  end
%>

<div class="container py-3">
  <style>
    .equal-tile{min-height:120px;overflow:visible;}
    .tile-logo{max-height:60px;max-width:100%;height:auto;width:auto;object-fit:contain;}
    .tile-logo-dark{display:none;}
    html[data-pv-theme="dark"] .tile-logo-light{display:none;}
    html[data-pv-theme="dark"] .tile-logo-dark{display:block;}
    .equal-tile .small.text-muted{font-size:0.70rem;line-height:1.2;white-space:nowrap;}
    .equal-tile .fw-semibold{font-size:0.80rem;line-height:1.35;margin-top:2px;padding:0 3px;text-align:center;}

    .product-card-img{aspect-ratio:4/3;object-fit:contain;background:#ffffff;padding:0.5rem;}

    .urgency-tile.urgency-green{background-color:#16a34a;color:#ffffff;}
    .urgency-tile.urgency-orange{background-color:#f97316;color:#ffffff;}
    .urgency-tile.urgency-red{background-color:#ef4444;color:#ffffff;}
    .urgency-tile.urgency-dark-red{background-color:#7f1d1d;color:#ffffff;}
    .urgency-tile.urgency-black{background-color:#000000;color:#ffffff;}
    .urgency-tile.urgency-unknown{background-color:#e5e7eb;color:#111827;}

    .urgency-tile .small.text-muted{color:inherit !important;opacity:.85;}
    .urgency-tile .fw-semibold{font-size:0.72rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  </style>

  <div class="mb-3">
    <%= link_to "← Back to sets", sets_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <%# Admin-only edit panel for updating set value and card totals %>
  <% if defined?(admin_signed_in?) && admin_signed_in? %>
    <div class="mb-3">
      <div class="card">
        <div class="card-body">
          <%= form_with url: admin_set_path(slug: @set_slug), method: :patch, local: true do %>
            <div class="row g-2 align-items-end">
              <div class="col-12 col-md-4">
                <label class="form-label mb-1">Total Set Value (€)</label>
                <%= number_field_tag :total_value, @total_value, step: "0.01", min: 0, class: "form-control" %>
              </div>
              <div class="col-6 col-md-3">
                <label class="form-label mb-1">Cards</label>
                <%= number_field_tag :cards, @cards, step: 1, min: 0, class: "form-control" %>
              </div>
              <div class="col-6 col-md-3">
                <label class="form-label mb-1">Secret</label>
                <%= number_field_tag :secret_cards, @secret, step: 1, min: 0, class: "form-control" %>
              </div>
              <div class="col-12 col-md-2 d-grid">
                <button class="btn btn-primary" type="submit">Update</button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Top information tiles for logo, era, release date, value, card count and urgency %>
  <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3 mb-4">
    <div class="col">
      <div class="card h-100 equal-tile d-flex align-items-center justify-content-center text-center p-3">
        <%= image_tag set_logo_image_path, alt: @set_name, class: "tile-logo" %>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Era</div>
        <div class="fw-semibold"><%= @era %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Release Date</div>
        <div class="fw-semibold"><%= @release_date %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Total Set Value</div>
        <div class="fw-semibold">
          <%= @total_value.present? ? number_to_currency(@total_value, unit: "€") : "€0.00" %>
        </div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile d-flex flex-column align-items-center justify-content-center text-center p-3">
        <div class="small text-muted">Cards/Secret</div>
        <div class="fw-semibold"><%= (@cards || 0) %>/<%= (@secret || 0) %></div>
      </div>
    </div>

    <div class="col">
      <div class="card h-100 equal-tile urgency-tile d-flex flex-column align-items-center justify-content-center text-center p-3 <%= urgency_class %>">
        <div class="small text-muted">Urgency Level</div>
        <div class="fw-semibold"><%= urgency_label %></div>

        <% unless urgency_label == "Out of Print" %>
          <div class="small text-muted mt-1">Until Out of Print</div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Product cards for the selected set %>
  <div class="row">
    <div class="col-12">
      <% if @products.present? %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
          <% @products.each do |p| %>
            <%
              n = p[:name].to_s

              # Skips hidden products so they do not appear as clickable product cards
              next if hidden_exact.any? { |x| normalize_name(x) == normalize_name(n) }
            %>

            <div class="col">
              <a href="<%= p[:link] %>" class="text-decoration-none">
                <div class="card h-100">
                  <%= image_tag p[:img_url], alt: p[:name], class: "card-img-top product-card-img" %>
                  <div class="card-body py-2 text-center">
                    <div class="fw-semibold small m-0 text-truncate"><%= p[:name] %></div>
                  </div>
                </div>
              </a>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-muted">No products listed for this set.</div>
      <% end %>
    </div>
  </div>
</div>