<div class="container py-3 sets-layout">
  <div class="row g-3">
    <%# Era filter sidebar %>
    <aside class="col-12 col-lg-3">
      <div class="border rounded-3 p-3 bg-white">
        <h3 class="h6 mb-3">Era</h3>

        <ul class="list-unstyled d-flex flex-column gap-2 mb-0" id="era-list">
          <% @eras.each_with_index do |era, i| %>
            <li>
              <button
                type="button"
                class="btn w-100 text-start era-item <%= i.zero? ? 'active selected pv-tab-locked' : '' %>"
                data-era="<%= era %>"
                aria-pressed="<%= i.zero? ? 'true' : 'false' %>">
                <%= era %>
              </button>
            </li>
          <% end %>
        </ul>
      </div>
    </aside>

    <%# Main sets grid and search area %>
    <section class="col-12 col-lg-9">
      <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-3">
        <div class="d-flex align-items-center gap-3">
          <%= image_tag @era_badges[@eras.first], id: "era-badge", class: "era-badge", alt: @eras.first %>
          <span class="text-muted small" id="result-count"></span>
        </div>

        <div class="w-100" style="max-width:340px;">
          <input id="sets-search" class="form-control" type="search" placeholder="Search sets...">
        </div>
      </div>

      <%# Each set card stores its era and name for the JavaScript filters below %>
      <div id="sets-grid" class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3">
        <% @sets.each do |s| %>
          <div class="col set-card" data-era="<%= s[:era] %>" data-name="<%= s[:name].downcase %>">
            <%= link_to set_path(slug: s[:slug]), class: "text-decoration-none text-reset" do %>
              <div class="card h-100">
                <%= image_tag s[:image_url], alt: s[:name], class: "card-img-top", style: "aspect-ratio:4/3;object-fit:cover;" %>
                <div class="card-body py-2 text-center">
                  <div class="fw-semibold small"><%= s[:name] %></div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div id="sets-empty" class="text-center text-muted border border-2 border-dashed rounded-3 py-5 mt-3 d-none">
        No sets match your filters.
      </div>
    </section>
  </div>
</div>

<style>
  .era-badge{max-height:56px;object-fit:contain}
  .era-badge.is-mega{max-height:96px}
  .era-badge.is-sv-small{max-height:44px}
  .era-badge.is-ss-smaller{max-height:36px}
  #era-list .era-item{
    border-radius:999px !important;
    font-weight:800 !important;
    transition:background-color .15s ease,color .15s ease,border-color .15s ease !important;
  }
  .border-dashed{border-style:dashed}
</style>

<script>
  (() => {
    const eraList = document.getElementById("era-list");
    const grid = document.getElementById("sets-grid");
    const empty = document.getElementById("sets-empty");
    const search = document.getElementById("sets-search");
    const badge = document.getElementById("era-badge");
    const count = document.getElementById("result-count");

    if (!eraList || !grid) return;

    // Maps each era to its badge image
    const eraToBadge = {
      "Mega Evolution": "<%= @era_badges['Mega Evolution'] %>",
      "Scarlet & Violet": "<%= @era_badges['Scarlet & Violet'] %>",
      "Sword & Shield": "<%= @era_badges['Sword & Shield'] %>"
    };

    // Reads theme colour variables from the page
    function cssVar(name) {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    // Colours used for inactive era buttons
    function normalColours() {
      return {
        bg: cssVar("--pv-button-bg") || "#ffffff",
        text: cssVar("--pv-button-text") || "#000000",
        border: cssVar("--pv-button-border") || "#000000"
      };
    }

    // Colours used for the selected era button
    function lockedColours() {
      return {
        bg: cssVar("--pv-button-hover-bg") || cssVar("--pv-active-bg") || "#000000",
        text: cssVar("--pv-button-hover-text") || cssVar("--pv-active-text") || "#ffffff",
        border: cssVar("--pv-button-hover-border") || cssVar("--pv-active-border") || "#000000"
      };
    }

    // Forces button colours so the selected era keeps the correct theme styling
    function forceButtonColour(button, colours) {
      button.style.setProperty("background", colours.bg, "important");
      button.style.setProperty("background-color", colours.bg, "important");
      button.style.setProperty("color", colours.text, "important");
      button.style.setProperty("border-color", colours.border, "important");
      button.style.setProperty("box-shadow", "none", "important");
    }

    // Changes the era badge size depending on the selected era logo
    function sizeClassForEra(era) {
      if (era === "Mega Evolution") return "is-mega";
      if (era === "Scarlet & Violet") return "is-sv-small";
      if (era === "Sword & Shield") return "is-ss-smaller";
      return "";
    }

    const firstEra = "<%= @eras.first %>";
    const buttons = Array.from(eraList.querySelectorAll("button[data-era]"));
    let storedEra = null;

    // Restores the last selected era when the user returns to the page
    try {
      storedEra = window.localStorage.getItem("setsActiveEra");
    } catch (_) {}

    let activeEra = firstEra;

    if (storedEra && buttons.some((button) => button.getAttribute("data-era") === storedEra)) {
      activeEra = storedEra;
    }

    // Applies active and inactive styles to all era buttons
    function applyEraButtonStyles() {
      const normal = normalColours();
      const locked = lockedColours();

      buttons.forEach((button) => {
        const era = button.getAttribute("data-era");
        const active = era === activeEra;

        button.classList.remove("active", "selected", "pv-tab-locked", "btn-primary", "btn-outline-secondary");

        if (active) {
          button.classList.add("active", "selected", "pv-tab-locked");
          button.setAttribute("aria-pressed", "true");
          forceButtonColour(button, locked);
        } else {
          button.classList.add("btn-outline-secondary");
          button.setAttribute("aria-pressed", "false");
          forceButtonColour(button, normal);
        }
      });
    }

    // Updates the era logo image beside the search bar
    function updateBadge() {
      const src = eraToBadge[activeEra] || "";

      if (src && badge) {
        badge.src = src;
        badge.alt = activeEra;
      }

      if (badge) {
        badge.classList.remove("is-mega", "is-sv-small", "is-ss-smaller");
        const cls = sizeClassForEra(activeEra);
        if (cls) badge.classList.add(cls);
      }
    }

    let storedSearch = "";

    // Restores the last search text when the user comes back to the sets page
    try {
      storedSearch = window.localStorage.getItem("setsSearch") || "";
    } catch (_) {}

    if (search) search.value = storedSearch;

    // Filters set cards by selected era and search text
    function apply() {
      const q = (search && search.value ? search.value : "").trim().toLowerCase();
      const cards = Array.from(grid.querySelectorAll(".set-card"));
      let shown = 0;

      cards.forEach((card) => {
        const era = card.getAttribute("data-era");
        const name = card.getAttribute("data-name") || "";
        const visible = era === activeEra && (!q || name.includes(q));

        card.classList.toggle("d-none", !visible);
        if (visible) shown += 1;
      });

      if (empty) empty.classList.toggle("d-none", shown > 0);
      if (count) count.textContent = shown + (shown === 1 ? " set" : " sets");
    }

    // Handles era button hover and click behaviour
    buttons.forEach((button) => {
      button.addEventListener("mouseenter", () => {
        forceButtonColour(button, lockedColours());
      });

      button.addEventListener("mouseleave", () => {
        const era = button.getAttribute("data-era");
        forceButtonColour(button, era === activeEra ? lockedColours() : normalColours());
      });

      button.addEventListener("click", () => {
        const newEra = button.getAttribute("data-era");
        if (!newEra) return;

        activeEra = newEra;

        try {
          window.localStorage.setItem("setsActiveEra", activeEra);
        } catch (_) {}

        applyEraButtonStyles();
        updateBadge();
        apply();
      });
    });

    // Saves the search text and reapplies filtering as the user types
    if (search) {
      search.addEventListener("input", () => {
        try {
          window.localStorage.setItem("setsSearch", search.value.trim());
        } catch (_) {}

        apply();
      });
    }

    // Reapplies button colours when the light/dark theme changes
    const observer = new MutationObserver(() => {
      applyEraButtonStyles();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-pv-theme"]
    });

    applyEraButtonStyles();
    updateBadge();
    apply();
  })();
</script>