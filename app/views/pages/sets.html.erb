<%= stylesheet_link_tag "sets", "data-turbo-track": "reload" %>

<div class="container py-3">
  <div class="row g-3">
    <%# Era filter sidebar %>
    <aside class="col-12 col-lg-3">
      <div class="border rounded-3 p-3 bg-white">
        <h3 class="h6 mb-3">Era</h3>

        <ul class="list-unstyled d-flex flex-column gap-2 mb-0" id="era-list">
          <% @eras.each_with_index do |era, index| %>
            <li>
              <button
                type="button"
                class="btn w-100 text-start era-item <%= index.zero? ? 'active selected pv-tab-locked' : 'btn-outline-secondary' %>"
                data-era="<%= era %>"
                aria-pressed="<%= index.zero? ? 'true' : 'false' %>">
                <%= era %>
              </button>
            </li>
          <% end %>
        </ul>
      </div>
    </aside>

    <%# Main set grid and search area %>
    <section class="col-12 col-lg-9">
      <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3 mb-3">
        <div class="d-flex align-items-center gap-3">
          <%= image_tag @era_badges[@eras.first], id: "era-badge", class: "era-badge", alt: @eras.first %>
          <span class="text-muted small" id="result-count"></span>
        </div>

        <div class="w-100" style="max-width:340px;">
          <input id="sets-search" class="form-control" type="search" placeholder="Search sets..." autocomplete="off">
        </div>
      </div>

      <%# Each set card stores its era and name so JavaScript can filter without another request %>
      <div id="sets-grid" class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3">
        <% @sets.each do |set| %>
          <div class="col set-card" data-era="<%= set[:era] %>" data-name="<%= set[:name].downcase %>">
            <%= link_to set_path(slug: set[:slug]), class: "text-decoration-none text-reset" do %>
              <div class="card h-100">
                <%= image_tag set[:image_url], alt: set[:name], class: "card-img-top sets-card-img" %>

                <div class="card-body py-2 text-center">
                  <div class="fw-semibold small"><%= set[:name] %></div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>

<script>
  (() => {
    const eraList = document.getElementById("era-list")
    const grid = document.getElementById("sets-grid")
    const empty = document.getElementById("sets-empty")
    const search = document.getElementById("sets-search")
    const badge = document.getElementById("era-badge")
    const count = document.getElementById("result-count")

    if (!eraList || !grid) return

    // Maps each era to its badge image.
    const badges = {
      "Mega Evolution": "<%= @era_badges['Mega Evolution'] %>",
      "Scarlet & Violet": "<%= @era_badges['Scarlet & Violet'] %>",
      "Sword & Shield": "<%= @era_badges['Sword & Shield'] %>"
    }

    const firstEra = "<%= @eras.first %>"
    const buttons = Array.from(eraList.querySelectorAll("[data-era]"))
    const cards = Array.from(grid.querySelectorAll(".set-card"))

    let activeEra = firstEra

    if (!buttons.some((button) => button.dataset.era === activeEra)) activeEra = firstEra

    // Reads one design CSS variable.
    function cssVar(name) {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim()
    }

    // Applies design colours directly so the active button stays correct.
    function paintButton(button, active) {
      const bg = active ? cssVar("--pv-active-bg") : cssVar("--pv-button-bg")
      const text = active ? cssVar("--pv-active-text") : cssVar("--pv-button-text")
      const border = active ? cssVar("--pv-active-border") : cssVar("--pv-button-border")

      button.style.setProperty("background", bg, "important")
      button.style.setProperty("background-color", bg, "important")
      button.style.setProperty("color", text, "important")
      button.style.setProperty("border-color", border, "important")
      button.style.setProperty("box-shadow", "none", "important")
    }

    // Changes the badge height class for different era logos.
    function badgeClass(era) {
      if (era === "Mega Evolution") return "is-mega"
      if (era === "Scarlet & Violet") return "is-sv-small"
      if (era === "Sword & Shield") return "is-ss-smaller"
      return ""
    }

    // Updates active era buttons.
    function syncButtons() {
      buttons.forEach((button) => {
        const active = button.dataset.era === activeEra

        button.classList.toggle("active", active)
        button.classList.toggle("selected", active)
        button.classList.toggle("pv-tab-locked", active)
        button.classList.toggle("btn-outline-secondary", !active)
        button.setAttribute("aria-pressed", active ? "true" : "false")

        paintButton(button, active)
      })
    }

    // Updates the era badge image.
    function syncBadge() {
      badge.src = badges[activeEra] || ""
      badge.alt = activeEra
      badge.classList.remove("is-mega", "is-sv-small", "is-ss-smaller")

      const extraClass = badgeClass(activeEra)
      if (extraClass) badge.classList.add(extraClass)
    }

    // Filters set cards by era and search text.
    function applyFilter() {
      const text = (search ? search.value : "").trim().toLowerCase()
      let shown = 0

      cards.forEach((card) => {
        const visible = card.dataset.era === activeEra && (!text || card.dataset.name.includes(text))

        card.classList.toggle("d-none", !visible)
        if (visible) shown += 1
      })

      if (empty) empty.classList.toggle("d-none", shown > 0)
      if (count) count.textContent = shown + (shown === 1 ? " set" : " sets")
    }

    // Runs all visual updates together.
    function render() {
      syncButtons()
      syncBadge()
      applyFilter()
    }

    // Handles era button clicks.
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        activeEra = button.dataset.era
        render()
      })

      button.addEventListener("mouseenter", () => paintButton(button, true))
      button.addEventListener("mouseleave", () => paintButton(button, button.dataset.era === activeEra))
    })

    // Handles set search input.
    if (search) {
      search.addEventListener("input", () => {
        applyFilter()
      })
    }

    render()
  })()
</script>