<%# Shows either an add or remove watchlist button depending on the current user's watchlist state %>
<% if user_signed_in? %>
  <% if @watchlisted %>
    <%# Sends a DELETE request to remove this product from the user's watchlist and then returns to the same page %>
    <%= button_to "Remove from Watchlist",
                  watchlist_remove_path(slug: @watchlist_slug, type: @watchlist_type),
                  method: :delete,
                  params: { return_to: request.fullpath },
                  class: "btn btn-outline-danger btn-sm" %>
  <% else %>
    <%# Sends a POST request to add this product to the user's watchlist and then returns to the same page %>
    <%= button_to "Add to Watchlist",
                  watchlist_add_path(slug: @watchlist_slug, type: @watchlist_type),
                  method: :post,
                  params: { return_to: request.fullpath },
                  class: "btn btn-outline-primary btn-sm" %>
  <% end %>
<% else %>
  <%# Sends logged-out users back to the home/auth flow instead of trying to create a watchlist record %>
  <%= link_to "Add to Watchlist", root_path, class: "btn btn-outline-primary btn-sm" %>
<% end %>