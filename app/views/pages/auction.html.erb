      font-size:.7rem;
      padding:.28rem .55rem;
      border-radius:999px;
      border:1px solid #d1d5db;
      text-decoration:none;
      color:#111827;
      background:#ffffff;
    }
    .au-tabbar a.active{
      border-color:#111827;
      font-weight:700;
    }
    .au-filters-card{
      background:#ffffff;
      border-radius:1rem;
      border:1px solid #d4d4d8;
      padding:10px;
      box-shadow:0 10px 25px rgba(15,23,42,0.08);
      margin-bottom:12px;
    }
    .au-filters-card,
    .au-filters-card:hover,
    .au-filters-card:focus,
    .au-filters-card:focus-within{
      background:var(--pv-surface) !important;
      background-color:var(--pv-surface) !important;
      color:var(--pv-text) !important;
      border-color:var(--pv-border) !important;
      box-shadow:var(--pv-shadow) !important;
      filter:none !important;
    }
    .au-filters-card *,
    .au-filters-card:hover *,
    .au-filters-card:focus *,
    .au-filters-card:focus-within *{
      box-shadow:none;
      filter:none !important;
    }
    .au-filters-card label,
    .au-filters-card .au-field-label,
    .au-filters-card:hover label,
    .au-filters-card:hover .au-field-label{
      background:transparent !important;
      color:var(--pv-muted) !important;
    }
    .au-filters-card .form-control,
    .au-filters-card .form-select,
    .au-filters-card input,
    .au-filters-card select,
    .au-filters-card textarea,
    .au-filters-card .form-control:hover,
    .au-filters-card .form-select:hover,
    .au-filters-card input:hover,
    .au-filters-card select:hover,
    .au-filters-card textarea:hover{
      background-color:var(--pv-input-bg) !important;
      color:var(--pv-input-text) !important;
      border-color:var(--pv-border) !important;
