    .au-table th:nth-child(7), .au-table td:nth-child(7){width:11%}
    .au-table th:nth-child(8), .au-table td:nth-child(8){width:4%}
    .au-table th:nth-child(9), .au-table td:nth-child(9){width:8%}
    .au-table th:nth-child(10), .au-table td:nth-child(10){width:7%}
    .au-table th:nth-child(11), .au-table td:nth-child(11){width:9%}
    .au-table th:nth-child(12), .au-table td:nth-child(12){width:7%}
