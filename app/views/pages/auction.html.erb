<%#
References:
- Rails Action View helpers:
  https://guides.rubyonrails.org/action_view_helpers.html
- Bootstrap tables, forms, buttons and modals:
  https://getbootstrap.com/docs/5.3/content/tables/
  https://getbootstrap.com/docs/5.3/forms/overview/
  https://getbootstrap.com/docs/5.3/components/buttons/
  https://getbootstrap.com/docs/5.3/components/modal/
- MDN DOM events, dataset and timers:
  https://developer.mozilla.org/en-US/docs/Web/API/EventTarget/addEventListener
  https://developer.mozilla.org/en-US/docs/Web/API/HTMLElement/dataset
  https://developer.mozilla.org/en-US/docs/Web/API/setInterval
%>

<%
# Refreshes auction statuses before showing the auction table.
if defined?(Auction)
  begin
    Auction.refresh_all_statuses!
  rescue
  end
end

# Loads auctions with seller and bids so the table does not repeatedly query them.
all_auctions =
  begin
    defined?(Auction) ? Auction.includes(:seller, :auction_bids).order(created_at: :desc).to_a : []
  rescue
    []
  end

# Controls which auction tab is shown.
view_tab = params[:auction_tab].to_s
view_tab = "current" unless %w[current ended sold].include?(view_tab)

# Filters auctions into the selected tab.
auctions = all_auctions.select { |auction| auction_status_key(auction) == (view_tab == "current" ? "running" : view_tab) }

# Pulls seller review stats for the visible auctions.
seller_ids = auctions.map(&:seller_id).compact.uniq
review_stats = auction_review_stats_for_ids(seller_ids)

auction_logged_in = current_user.present?
auction_admin_can_delete = auction_admin_user?(current_user)

empty_label =
  case view_tab
  when "ended"
    "No ended auctions."
  when "sold"
    "No sold auctions."
  else
    "No current auctions."
  end
%>

<div class="container py-3">
  <style>
    .au-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:12px 0 14px}
    .au-title{margin:0;font-size:1.4rem;line-height:1.1}
    .au-sub{margin:2px 0 0;font-size:.85rem;color:#6b7280}
    .au-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
    .au-tabs a{font-size:.7rem;padding:.28rem .55rem;border-radius:999px;border:1px solid #d1d5db;text-decoration:none;color:#111827;background:#fff}
    .au-tabs a.active{border-color:#111827;font-weight:700}
    .au-card{background:#fff;border:1px solid #d4d4d8;border-radius:1rem;box-shadow:0 10px 25px rgba(15,23,42,.08)}
    .au-filters{padding:10px;margin-bottom:12px}
    .au-label{font-size:.68rem;color:#4b5563;margin-bottom:2px}
    .au-table-wrap{overflow-x:visible;min-height:220px}
    .au-table{width:100%;border-collapse:collapse;table-layout:fixed;font-size:.72rem}
    .au-table th,.au-table td{text-align:center;vertical-align:middle;border-bottom:1px solid #f1f5f9;padding:4px 3px;font-size:.64rem}
    .au-table th{background:#f9fafb;font-weight:900;color:#374151;white-space:nowrap}
    .au-table th:nth-child(1),.au-table td:nth-child(1){width:9%}
    .au-table th:nth-child(2),.au-table td:nth-child(2){width:6%}
    .au-table th:nth-child(3),.au-table td:nth-child(3){width:8%}
    .au-table th:nth-child(4),.au-table td:nth-child(4){width:6%}
    .au-table th:nth-child(5),.au-table td:nth-child(5){width:24%}
    .au-table th:nth-child(6),.au-table td:nth-child(6){width:11%}
    .au-table th:nth-child(7),.au-table td:nth-child(7){width:5%}
    .au-table th:nth-child(8),.au-table td:nth-child(8){width:9%}
    .au-table th:nth-child(9),.au-table td:nth-child(9){width:7%}
    .au-table th:nth-child(10),.au-table td:nth-child(10){width:9%}
    .au-table th:nth-child(11),.au-table td:nth-child(11){width:6%}
    .au-empty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;color:#6b7280;font-size:.8rem}
    .au-table-card{position:relative;overflow:visible}
    .au-link{font-weight:600;text-decoration:none}
    .au-muted{color:#6b7280}
    .au-desc{text-align:left}
    .au-desc-text{display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;line-clamp:2;overflow:hidden;text-overflow:ellipsis;line-height:1.2;max-height:2.4em;word-break:break-word}
    .au-actions{display:flex;gap:3px;justify-content:center;align-items:center;flex-wrap:wrap;white-space:nowrap}
    .au-actions .btn{font-size:.52rem;padding:.1rem .2rem;line-height:1}
    .au-actions form{margin:0}
    .au-time{white-space:nowrap;font-variant-numeric:tabular-nums}
    .pv-au-table-stars{display:inline-flex;align-items:center;gap:1px;white-space:nowrap;color:#d4a017;line-height:1}
    .pv-au-table-star,.pv-au-table-half{display:inline-block;color:#d4a017;line-height:1}
    .pv-au-table-half{font-weight:900;font-size:.8em}
    .au-badges{display:flex;justify-content:center;align-items:center;gap:3px;flex-wrap:wrap}
    .au-badges img{height:14px;width:14px;object-fit:contain}
    .au-confirm{position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,.55)}
    .au-confirm-box{width:100%;max-width:430px;border-radius:18px;border:1px solid #000;background:#fff;color:#000;box-shadow:0 24px 70px rgba(0,0,0,.32);padding:20px;text-align:center}
    .au-confirm-text{font-size:.96rem;font-weight:800;line-height:1.45;margin-bottom:18px}
    .au-confirm-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
    .au-confirm-yes,.au-confirm-no{min-width:86px;border-radius:999px;font-weight:800;font-size:.86rem;padding:.42rem .9rem;border:1px solid #000}
    .au-confirm-yes{background:#000;color:#fff}
    .au-confirm-no{background:#fff;color:#000}
    .au-confirm-yes:hover,.au-confirm-no:hover{background:#d4af37;color:#000;border-color:#d4af37}
  </style>

  <div class="au-head">
    <div>
      <h1 class="au-title">Auction</h1>
      <p class="au-sub">Bid on live auctions and browse ended or sold auctions.</p>
    </div>

    <% if auction_logged_in %>
      <%= link_to "Create Auction", new_auction_path, class: "btn btn-success btn-sm" %>
    <% else %>
      <%# Logged-out users get a login pop-up instead of the protected create-auction route. %>
      <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#auctionLoginModal">Create Auction</button>
    <% end %>
  </div>

  <% unless auction_logged_in %>
    <div class="modal fade" id="auctionLoginModal" tabindex="-1" aria-labelledby="auctionLoginModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="auctionLoginModalLabel">Log in to create auction</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancel"></button>
          </div>

          <div class="modal-body">
            <%= form_with url: login_path, method: :post, local: true do %>
              <div class="mb-3">
                <label class="form-label" for="auction_login_username">Username</label>
                <%= text_field_tag :username, nil, class: "form-control", id: "auction_login_username", required: true, autocomplete: "username" %>
              </div>

              <div class="mb-3">
                <label class="form-label" for="auction_login_password">Password</label>
                <%= password_field_tag :password, nil, class: "form-control", id: "auction_login_password", required: true, autocomplete: "current-password" %>
              </div>

              <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <%= submit_tag "Log in", class: "btn btn-primary" %>
              </div>
            <% end %>

            <hr class="my-3">

            <div class="text-center small">
              Don't have an account?
              <%= link_to "Register", register_path, class: "btn btn-link btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="au-tabs">
    <%= link_to "Current Auctions", auction_path(auction_tab: "current"), class: (view_tab == "current" ? "active" : nil) %>
    <%= link_to "Ended Auctions", auction_path(auction_tab: "ended"), class: (view_tab == "ended" ? "active" : nil) %>
    <%= link_to "Sold Auctions", auction_path(auction_tab: "sold"), class: (view_tab == "sold" ? "active" : nil) %>
  </div>

  <%# Client-side filters keep the auction table responsive without extra routes. %>
  <section class="au-card au-filters" data-auction-tab="<%= view_tab %>">
    <div class="row g-2 mb-2">
      <div class="col-12">
        <label for="au-search" class="au-label">Search</label>
        <input id="au-search" type="search" class="form-control form-control-sm" placeholder="Search seller, auction description, condition...">
      </div>
    </div>

    <div class="row g-2">
      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-location" class="au-label">Location</label>
        <select id="au-location" class="form-select form-select-sm">
          <option value="">All EU Countries</option>
          <% auction_country_options.each do |code, label| %>
            <option value="<%= code %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-condition" class="au-label">Condition</label>
        <select id="au-condition" class="form-select form-select-sm">
          <option value="">Any</option>
          <% auction_conditions.each do |condition| %>
            <option value="<%= condition %>"><%= condition %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-min-bids" class="au-label">Min Bids</label>
        <input id="au-min-bids" type="number" min="0" step="1" class="form-control form-control-sm" placeholder="0">
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-max-bids" class="au-label">Max Bids</label>
        <input id="au-max-bids" type="number" min="0" step="1" class="form-control form-control-sm" placeholder="0">
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-reserve" class="au-label">Reserve Status</label>
        <select id="au-reserve" class="form-select form-select-sm">
          <option value="">Any</option>
          <option value="reserve">Reserve</option>
          <option value="no reserve">No Reserve</option>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-sort" class="au-label">Sort by</label>
        <select id="au-sort" class="form-select form-select-sm">
          <option value="ending-soonest" <%= "selected" if view_tab == "current" %>>Ending Soonest</option>
          <option value="newest" <%= "selected" if view_tab != "current" %>>Newest</option>
          <option value="oldest">Oldest</option>
        </select>
      </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-2 flex-wrap">
      <button type="button" id="au-clear-filters" class="btn btn-outline-secondary btn-sm">Clear</button>
      <button type="button" id="au-apply-filters" class="btn btn-primary btn-sm">Apply Filters</button>
    </div>
  </section>

  <section class="au-card au-table-card">
    <div class="au-table-wrap">
      <table class="au-table" aria-label="Auction Listings">
        <thead>
          <tr>
            <th>Seller</th>
            <th>Location</th>
            <th>Reviews</th>
            <th>Badges</th>
            <th>Description</th>
            <th>Condition</th>
            <th>Bids</th>
            <th>Reserve Status</th>
            <th>Length</th>
            <th>Time Remaining</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody id="au-table-body">
          <% auctions.each do |auction| %>
            <%
              seller = auction.seller
              seller_id = auction.seller_id
              seller_name = seller&.username.to_s.presence || "User ##{seller_id}"
              country_code = seller&.country_code.to_s.upcase
              stats = review_stats[seller_id] || { avg: 0.0, count: 0 }
              status_key = auction_status_key(auction)
              payment_waiting = auction_payment_waiting_status?(auction.status)
              end_timestamp = auction.ends_at.present? ? (auction.ends_at.to_f * 1000).to_i : 0
              created_timestamp = auction.created_at.present? ? (auction.created_at.to_f * 1000).to_i : 0
              description = auction.auction_description.to_s.presence || "-"
              condition = auction.condition.to_s.presence || "-"
              reserve_label = auction.no_reserve? ? "No Reserve" : "Reserve"
              reserve_key = reserve_label.downcase
              length_label = auction_length_label(auction)
              owner_can_end = current_user && auction.can_end_early_by?(current_user)
            %>

            <tr
              data-auction-row="true"
              data-seller="<%= seller_name.downcase %>"
              data-description="<%= description.downcase %>"
              data-condition="<%= condition.downcase %>"
              data-location="<%= country_code.downcase %>"
              data-bids="<%= auction.bids_count.to_i %>"
              data-reserve="<%= reserve_key %>"
              data-status="<%= status_key %>"
              data-payment-waiting="<%= payment_waiting ? "true" : "false" %>"
              data-length-text="<%= length_label %>"
              data-end-timestamp="<%= end_timestamp %>"
              data-created-timestamp="<%= created_timestamp %>"
            >
              <td><%= link_to seller_name, user_path(seller_id), class: "au-link" %></td>

              <td>
                <% if country_code.present? %>
                  <span title="<%= auction_country_name(country_code) %>"><%= auction_flag(country_code) %></span>
                <% else %>
                  <span class="au-muted">-</span>
                <% end %>
              </td>

              <td title="<%= "#{stats[:avg].round(1)}/5 (#{stats[:count]})" %>">
                <%= auction_star_rating(stats[:avg], prefix: "pv-au-table") %> (<%= stats[:count] %>)
              </td>

              <td>
                <div class="au-badges">
                  <% badges = auction_badges_for(seller) %>
                  <% if badges.any? %>
                    <% badges.each do |badge| %>
                      <%= image_tag badge, alt: "Badge" %>
                    <% end %>
                  <% else %>
                    <span class="au-muted">None</span>
                  <% end %>
                </div>
              </td>

              <td class="au-desc">
                <div class="au-desc-text" title="<%= description %>"><%= description %></div>
              </td>

              <td><%= condition %></td>
              <td><%= auction.bids_count.to_i %></td>
              <td><%= reserve_label %></td>
              <td data-auction-length="true"><%= length_label %></td>
              <td class="au-time-remaining au-time"><%= auction_time_left_text(auction) %></td>

              <td>
                <div class="au-actions">
                  <%= link_to "View", auction_listing_path(auction), class: "btn btn-outline-primary btn-sm" %>

                  <% if status_key == "running" && auction.running? && !payment_waiting %>
                    <%= link_to "Bid", bid_auction_path(auction), class: "btn btn-primary btn-sm" %>
                  <% end %>

                  <% if owner_can_end %>
                    <%= button_to "End",
                                  end_auction_path(auction),
                                  method: :post,
                                  class: "btn btn-outline-danger btn-sm",
                                  form: { data: { auction_confirm: "true", message: "Are you sure you want to end this auction?", turbo: "false" } } %>
                  <% end %>

                  <% if auction_admin_can_delete %>
                    <%= button_to "Delete",
                                  delete_auction_path(auction),
                                  method: :delete,
                                  class: "btn btn-outline-danger btn-sm",
                                  form: { data: { auction_confirm: "true", message: "Are you sure you want to delete this auction?", turbo: "false" } } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div id="au-empty-state" class="au-empty" <%= 'style="display:none;"'.html_safe if auctions.any? %>>
      <%= empty_label %>
    </div>
  </section>

  <%# Custom confirmation overlay used before ending or deleting auctions. %>
  <div class="au-confirm" id="auctionConfirm" aria-hidden="true">
    <div class="au-confirm-box">
      <div class="au-confirm-text" id="auctionConfirmText">Are you sure you want to continue?</div>
      <div class="au-confirm-actions">
        <button type="button" class="au-confirm-yes" id="auctionConfirmYes">Yes</button>
        <button type="button" class="au-confirm-no" id="auctionConfirmNo">No</button>
      </div>
    </div>
  </div>

  <script>
    (() => {
      let pendingForm = null

      function formatRemaining(ms) {
        if (ms <= 0) return "Ended"

        const total = Math.floor(ms / 1000)
        const days = Math.floor(total / 86400)
        const hours = Math.floor((total % 86400) / 3600)
        const minutes = Math.floor((total % 3600) / 60)
        const seconds = total % 60

        if (days > 0) return `${days}d ${hours}h ${minutes}m`
        if (hours > 0) return `${hours}h ${minutes}m ${seconds}s`
        return `${minutes}m ${seconds}s`
      }

      function initAuctionConfirm() {
        const overlay = document.getElementById("auctionConfirm")
        const text = document.getElementById("auctionConfirmText")
        const yes = document.getElementById("auctionConfirmYes")
        const no = document.getElementById("auctionConfirmNo")

        if (!overlay || overlay.dataset.bound === "1") return
        overlay.dataset.bound = "1"

        document.addEventListener("submit", (event) => {
          const form = event.target.closest("form[data-auction-confirm='true']")
          if (!form || form.dataset.confirmed === "true") return

          event.preventDefault()
          pendingForm = form
          if (text) text.textContent = form.dataset.message || "Are you sure you want to continue?"
          overlay.style.display = "flex"
          overlay.setAttribute("aria-hidden", "false")
        })

        no?.addEventListener("click", () => {
          pendingForm = null
          overlay.style.display = "none"
          overlay.setAttribute("aria-hidden", "true")
        })

        yes?.addEventListener("click", () => {
          if (!pendingForm) return

          const form = pendingForm
          pendingForm = null
          overlay.style.display = "none"
          overlay.setAttribute("aria-hidden", "true")
          form.dataset.confirmed = "true"
          form.submit()
        })

        overlay.addEventListener("click", (event) => {
          if (event.target !== overlay) return

          pendingForm = null
          overlay.style.display = "none"
          overlay.setAttribute("aria-hidden", "true")
        })
      }

      function initAuctionTable() {
        initAuctionConfirm()

        const tbody = document.getElementById("au-table-body")
        if (!tbody) return

        const rows = Array.from(tbody.querySelectorAll("tr[data-auction-row='true']"))
        const empty = document.getElementById("au-empty-state")
        const tab = document.querySelector(".au-filters")?.dataset.auctionTab || "current"
        const search = document.getElementById("au-search")
        const location = document.getElementById("au-location")
        const condition = document.getElementById("au-condition")
        const minBids = document.getElementById("au-min-bids")
        const maxBids = document.getElementById("au-max-bids")
        const reserve = document.getElementById("au-reserve")
        const sort = document.getElementById("au-sort")
        const clear = document.getElementById("au-clear-filters")
        const apply = document.getElementById("au-apply-filters")

        const normalize = (value) => String(value || "").trim().toLowerCase()
        const numberOrNull = (value) => value === "" || value == null ? null : (Number.isNaN(parseInt(value, 10)) ? null : parseInt(value, 10))

        function updateTimers() {
          const now = Date.now()

          rows.forEach((row) => {
            const cell = row.querySelector(".au-time-remaining")
            if (!cell) return

            const end = parseInt(row.dataset.endTimestamp || "0", 10)

            if (!end || row.dataset.status !== "running" || row.dataset.paymentWaiting === "true") {
              cell.textContent = row.dataset.lengthText || "-"
              return
            }

            const left = end - now

            if (left <= 0) {
              cell.textContent = row.dataset.lengthText || "Ended"
              row.dataset.status = "ended"
            } else {
              cell.textContent = formatRemaining(left)
            }
          })
        }

        function applyFilters() {
          updateTimers()

          const q = normalize(search?.value)
          const loc = normalize(location?.value)
          const cond = normalize(condition?.value)
          const min = numberOrNull(minBids?.value)
          const max = numberOrNull(maxBids?.value)
          const res = normalize(reserve?.value)
          const sortBy = normalize(sort?.value)

          rows.forEach((row) => {
            const blob = [row.dataset.seller, row.dataset.description, row.dataset.condition].join(" ")
            const bids = parseInt(row.dataset.bids || "0", 10)
            let visible = true

            if (tab === "current" && row.dataset.status !== "running") visible = false
            if (tab === "ended" && row.dataset.status !== "ended") visible = false
            if (tab === "sold" && row.dataset.status !== "sold") visible = false
            if (q && !blob.includes(q)) visible = false
            if (loc && normalize(row.dataset.location) !== loc) visible = false
            if (cond && normalize(row.dataset.condition) !== cond) visible = false
            if (min !== null && bids < min) visible = false
            if (max !== null && bids > max) visible = false
            if (res && normalize(row.dataset.reserve) !== res) visible = false

            row.style.display = visible ? "" : "none"
          })

          rows.slice().sort((a, b) => {
            const aEnd = parseInt(a.dataset.endTimestamp || "0", 10)
            const bEnd = parseInt(b.dataset.endTimestamp || "0", 10)
            const aCreated = parseInt(a.dataset.createdTimestamp || "0", 10)
            const bCreated = parseInt(b.dataset.createdTimestamp || "0", 10)

            if (sortBy === "oldest") return aCreated - bCreated
            if (sortBy === "newest") return bCreated - aCreated
            return aEnd - bEnd
          }).forEach((row) => tbody.appendChild(row))

          if (empty) {
            const visibleRows = rows.filter((row) => row.style.display !== "none").length
            empty.style.display = visibleRows === 0 ? "flex" : "none"
          }
        }

        function clearFilters() {
          if (search) search.value = ""
          if (location) location.value = ""
          if (condition) condition.value = ""
          if (minBids) minBids.value = ""
          if (maxBids) maxBids.value = ""
          if (reserve) reserve.value = ""
          if (sort) sort.value = tab === "current" ? "ending-soonest" : "newest"
          applyFilters()
        }

        apply?.addEventListener("click", applyFilters)
        clear?.addEventListener("click", clearFilters)
        ;[search, minBids, maxBids].forEach((el) => el?.addEventListener("input", applyFilters))
        ;[location, condition, reserve, sort].forEach((el) => el?.addEventListener("change", applyFilters))

        if (window.auctionTimerId) clearInterval(window.auctionTimerId)
        applyFilters()
        window.auctionTimerId = setInterval(applyFilters, 1000)
      }

      document.addEventListener("DOMContentLoaded", initAuctionTable)
      document.addEventListener("turbo:load", initAuctionTable)
    })()
  </script>
</div>