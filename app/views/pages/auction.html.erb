    .au-field-label{
      font-size:.68rem;
      color:#4b5563;
      margin-bottom:2px;
    }
    .au-table-card{
      position:relative;
      background:#ffffff;
      border-radius:1rem;
      border:1px solid #d4d4d8;
      box-shadow:0 10px 25px rgba(15,23,42,0.08);
      overflow:visible;
    }
    .au-table-wrap{
      overflow-x:visible;
      min-height:220px;
    }
    .au-table{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      font-size:.72rem;
    }
    .au-table thead th{
      background:#f9fafb;
      font-weight:900;
      text-align:center;
      font-size:.64rem;
      color:#374151;
      padding:4px 3px;
      border-bottom:1px solid #e5e7eb;
      white-space:nowrap;
    }
    .au-table tbody td{
      padding:4px 3px;
      border-bottom:1px solid #f1f5f9;
      font-size:.64rem;
      vertical-align:middle;
      text-align:center;
    }
    .au-table th:nth-child(1), .au-table td:nth-child(1){width:8%}
    .au-table th:nth-child(2), .au-table td:nth-child(2){width:6%}
    .au-table th:nth-child(3), .au-table td:nth-child(3){width:8%}
    .au-table th:nth-child(4), .au-table td:nth-child(4){width:5%}
    .au-table th:nth-child(5), .au-table td:nth-child(5){width:6%}
