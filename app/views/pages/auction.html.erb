      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      pointer-events:none;
      padding:16px;
      color:#6b7280;
      font-size:.8rem;
    }
    .au-seller-link{
      font-weight:600;
      text-decoration:none;
    }
    .au-flag{
      font-size:.85rem;
      line-height:1;
    }
    .au-stars{
      display:inline-flex;
      align-items:center;
      gap:1px;
      white-space:nowrap;
      vertical-align:middle;
      line-height:1;
    }
    .au-star{
      position:relative;
      display:inline-block;
      width:.95em;
      height:1em;
      line-height:1;
      vertical-align:middle;
    }
    .au-star-base{
      position:absolute;
      left:0;
      top:0;
      color:#d1d5db;
      line-height:1;
    }
    .au-star-fill{
      position:absolute;
      left:0;
      top:0;
      overflow:hidden;
      color:#d4a017;
      line-height:1;
      white-space:nowrap;
    }
    .au-badges{
      display:flex;
      justify-content:center;
      align-items:center;
      gap:3px;
      flex-wrap:wrap;
    }
    .au-badges img{
      height:14px;
      width:14px;
      object-fit:contain;
      display:inline-block;
      vertical-align:middle;
    }
    .au-image-cell{
      position:relative;
      overflow:visible;
    }
    .au-camera-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:22px;
      height:22px;
      border-radius:999px;
      background:#2563eb;
      color:#ffffff;
      font-size:.72rem;
      line-height:1;
      border:1px solid #1d4ed8;
      cursor:default;
      user-select:none;
    }
    .au-image-preview{
      position:fixed;
      top:50%;
      left:50%;
      transform:translate(-50%, -50%);
      z-index:9999;
      display:none;
      width:min(760px, 82vw);
      max-height:88vh;
      overflow:auto;
      padding:12px;
      background:#ffffff;
      border:1px solid #d1d5db;
      border-radius:16px;
      box-shadow:0 24px 60px rgba(15,23,42,0.28);
    }
    .au-image-cell:hover .au-image-preview,
    .au-image-cell:focus-within .au-image-preview{
      display:block;
    }
    .au-image-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }
    .au-image-grid img{
      width:100%;
      height:180px;
      object-fit:cover;
      border-radius:12px;
      border:1px solid #e5e7eb;
    }
    .au-description{
      text-align:left;
    }
    .au-description-text{
      display:-webkit-box;
      -webkit-box-orient:vertical;
      -webkit-line-clamp:2;
      line-clamp:2;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:normal;
      word-break:break-word;
      line-height:1.2;
      max-height:2.4em;
    }
    .au-actions{
      display:flex;
      gap:3px;
      justify-content:center;
      align-items:center;
      flex-wrap:nowrap;
      white-space:nowrap;
    }
    .au-actions .btn{
      font-size:.52rem;
      padding:.1rem .2rem;
      line-height:1;
      flex:0 0 auto;
    }
    .au-actions form{
      margin:0;
      flex:0 0 auto;
    }
    .au-muted{
      color:#6b7280;
    }
    .au-time{
      white-space:nowrap;
      font-variant-numeric:tabular-nums;
    }
    .au-review-wrap{
      display:inline-flex;
      align-items:center;
      gap:3px;
      white-space:nowrap;
    }
  </style>

  <div class="au-page-header">
    <div>
      <h1 class="au-page-title">Auction</h1>
      <p class="au-subtitle mb-0">Bid on live auctions and browse ended or sold auctions.</p>
    </div>

    <% if defined?(current_user) && current_user %>
      <%= link_to "Create Auction", new_auction_path, class: "btn btn-success btn-sm" %>
    <% else %>
      <%= link_to "Log in to Create Auction", login_path, class: "btn btn-outline-secondary btn-sm" %>
    <% end %>
  </div>

  <div class="au-tabbar">
    <%= link_to "Current Auctions", auction_path(auction_tab: "current"), class: (view_tab == "current" ? "active" : nil) %>
    <%= link_to "Ended Auctions", auction_path(auction_tab: "ended"), class: (view_tab == "ended" ? "active" : nil) %>
    <%= link_to "Sold Auctions", auction_path(auction_tab: "sold"), class: (view_tab == "sold" ? "active" : nil) %>
  </div>

  <section class="au-filters-card" data-auction-view-tab="<%= view_tab %>">
    <div class="row g-2 mb-2">
      <div class="col-12">
        <label for="au-search" class="au-field-label">Search</label>
        <input id="au-search" type="search" class="form-control form-control-sm" placeholder="Search seller, auction description, condition...">
      </div>
    </div>

    <div class="row g-2">
      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-location" class="au-field-label">Location</label>
        <select id="au-location" class="form-select form-select-sm">
          <option value="">All EU Countries</option>
          <% eu_countries.each do |code, label| %>
            <option value="<%= code %>"><%= label %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-condition" class="au-field-label">Condition</label>
        <select id="au-condition" class="form-select form-select-sm">
          <option value="">Any</option>
          <% auction_conditions.each do |condition| %>
            <option value="<%= condition %>"><%= condition %></option>
          <% end %>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-min-bids" class="au-field-label">Min Bids</label>
        <input id="au-min-bids" type="number" min="0" step="1" class="form-control form-control-sm" placeholder="0">
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-max-bids" class="au-field-label">Max Bids</label>
        <input id="au-max-bids" type="number" min="0" step="1" class="form-control form-control-sm" placeholder="0">
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-reserve" class="au-field-label">Reserve Status</label>
        <select id="au-reserve" class="form-select form-select-sm">
          <option value="">Any</option>
          <option value="reserve">Reserve</option>
          <option value="no reserve">No Reserve</option>
        </select>
      </div>

      <div class="col-6 col-md-4 col-lg-2">
        <label for="au-sort" class="au-field-label">Sort by</label>
        <select id="au-sort" class="form-select form-select-sm">
          <option value="ending-soonest" <%= "selected" if view_tab == "current" %>>Ending Soonest</option>
          <option value="newest" <%= "selected" if view_tab != "current" %>>Newest</option>
          <option value="oldest">Oldest</option>
        </select>
      </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-2 flex-wrap">
      <button type="button" id="au-clear-filters" class="btn btn-outline-secondary btn-sm">Clear</button>
      <button type="button" id="au-apply-filters" class="btn btn-primary btn-sm">Apply Filters</button>
    </div>
  </section>

  <section class="au-table-card">
    <div class="au-table-wrap">
      <table class="au-table" aria-label="Auction Listings">
        <thead>
          <tr>
            <th>Seller</th>
            <th>Location</th>
            <th>Reviews</th>
            <th>Badges</th>
            <th>Image(s)</th>
            <th>Description</th>
            <th>Condition</th>
            <th>Bids</th>
            <th>Reserve Status</th>
            <th>Length</th>
            <th>Time Remaining</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="au-table-body">
          <% auctions.each do |auction| %>
            <%
            seller = auction.respond_to?(:seller) ? auction.seller : nil
            seller_id = seller&.id || auction.seller_id

            seller_name =
              if seller&.respond_to?(:username) && seller.username.present?
                seller.username
              elsif seller_id.present?
                "User ##{seller_id}"
              else
                "-"
              end

            seller_path = seller_id.present? ? user_path(seller_id) : "#"

            country_code =
              if seller&.respond_to?(:country_code) && seller.country_code.present?
                seller.country_code.to_s.upcase
              else
                ""
              end

            avg_rating = review_averages[seller_id].to_f
            count_rating = review_counts[seller_id].to_i

            is_admin =
              seller && (
                (seller.respond_to?(:admin?) && seller.admin?) ||
                (seller.respond_to?(:admin) && !!seller.admin)
              )

            description_text = auction.auction_description.to_s.presence || "-"
            condition_text = auction.condition.to_s.presence || "-"
            reserve_label = auction.reserve_status.to_s.downcase.include?("no") ? "No Reserve" : "Reserve"
            reserve_key = reserve_label.downcase
            bids_count = auction.bids_count.to_i
            end_time = auction.ends_at
            status_key = status_key_for.call(auction)
            explicit_status = auction.respond_to?(:status) ? auction.status.to_s.downcase : ""
            payment_waiting = payment_waiting_statuses.include?(explicit_status)
            end_timestamp = end_time.present? ? (end_time.to_f * 1000).to_i : 0
            created_timestamp = auction.respond_to?(:created_at) && auction.created_at.present? ? (auction.created_at.to_f * 1000).to_i : 0
            length_text = length_label_for.call(auction)
            initial_time_text =
              if status_key == "running" && end_time.present? && end_time > Time.current && !payment_waiting
                remaining_text_for.call(end_time)
              else
                length_text
              end
            owner_can_end = defined?(current_user) && current_user && auction.can_end_early_by?(current_user)
            auction_images = auction.photos.attached? ? auction.photos.first(4) : []
            %>

            <tr
              data-auction-row="true"
              data-seller="<%= seller_name.to_s.downcase %>"
              data-description="<%= description_text.to_s.downcase %>"
              data-condition="<%= condition_text.to_s.downcase %>"
              data-location="<%= country_code.to_s.downcase %>"
              data-bids="<%= bids_count %>"
              data-reserve="<%= reserve_key %>"
              data-status="<%= status_key %>"
              data-payment-waiting="<%= payment_waiting ? "true" : "false" %>"
              data-end-timestamp="<%= end_timestamp %>"
              data-created-timestamp="<%= created_timestamp %>"
            >
              <td><%= link_to seller_name, seller_path, class: "au-seller-link" %></td>
              <td>
                <% if country_code.present? %>
                  <span class="au-flag" title="<%= country_code %>"><%= flag_for.call(country_code) %></span>
                <% else %>
                  <span class="au-muted">-</span>
                <% end %>
              </td>
              <td>
                <span class="au-review-wrap" title="<%= "#{avg_rating.round(1)}/5 (#{count_rating})" %>">
                  <%= stars.call(avg_rating) %>
                  <span>(<%= count_rating %>)</span>
                </span>
              </td>
              <td>
                <div class="au-badges">
                  <% if is_admin %>
                    <span title="Admin"><%= image_tag admin_badge_asset, alt: "Admin" %></span>
                  <% else %>
                    <span class="au-muted">None</span>
                  <% end %>
                </div>
              </td>
              <td class="au-image-cell">
                <% if auction_images.any? %>
                  <span class="au-camera-btn" tabindex="0">📷</span>
                  <div class="au-image-preview">
                    <div class="au-image-grid">
                      <% auction_images.each do |img| %>
                        <%= image_tag url_for(img), alt: "" %>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <span class="au-muted">N/A</span>
                <% end %>
              </td>
              <td class="au-description"><div class="au-description-text" title="<%= description_text %>"><%= description_text %></div></td>
              <td><%= condition_text %></td>
              <td><%= bids_count %></td>
              <td><%= reserve_label %></td>
              <td data-auction-length="true"><%= length_text %></td>
              <td class="au-time-remaining au-time"><%= initial_time_text %></td>
              <td>
                <div class="au-actions">
                  <%= link_to "View", auction_listing_path(auction), class: "btn btn-outline-primary btn-sm" %>
                  <% if status_key == "running" && end_time.present? && end_time > Time.current && !payment_waiting %>
                    <%= link_to "Bid", bid_auction_path(auction), class: "btn btn-primary btn-sm" %>
                  <% end %>
                  <% if owner_can_end %>
                    <%= button_to "End", end_auction_path(auction), method: :post, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline", data: { turbo_confirm: "Are you sure you want to end this auction?" } } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div id="au-empty-state" class="au-empty-state" <%= 'style="display:none;"'.html_safe if auctions.any? %>>
      <%= empty_label %>
    </div>
  </section>

  <script>
    (function () {
      function initAuctionPage() {
        const tbody = document.getElementById("au-table-body");
        if (!tbody) return;

        const rows = Array.from(tbody.querySelectorAll("tr[data-auction-row='true']"));
        const emptyState = document.getElementById("au-empty-state");
        const filtersCard = document.querySelector(".au-filters-card");
        const defaultTab = filtersCard ? (filtersCard.getAttribute("data-auction-view-tab") || "current") : "current";

        const searchInput = document.getElementById("au-search");
        const locationSelect = document.getElementById("au-location");
        const conditionSelect = document.getElementById("au-condition");
        const minBidsInput = document.getElementById("au-min-bids");
        const maxBidsInput = document.getElementById("au-max-bids");
        const reserveSelect = document.getElementById("au-reserve");
        const sortSelect = document.getElementById("au-sort");
        const clearButton = document.getElementById("au-clear-filters");
        const applyButton = document.getElementById("au-apply-filters");

        const normalize = function (value) {
          return (value || "").toString().trim().toLowerCase();
        };

        const toNumber = function (value) {
          if (value === null || value === undefined || value === "") return null;
          const parsed = parseInt(value, 10);
          return Number.isNaN(parsed) ? null : parsed;
        };

        const formatRemaining = function (milliseconds) {
          if (milliseconds <= 0) return "Ended";

          const totalSeconds = Math.floor(milliseconds / 1000);
          const days = Math.floor(totalSeconds / 86400);
          const hours = Math.floor((totalSeconds % 86400) / 3600);
          const minutes = Math.floor((totalSeconds % 3600) / 60);
          const seconds = totalSeconds % 60;

          if (days > 0) {
            return days + "d " + hours + "h " + minutes + "m";
          }

          if (hours > 0) {
            return hours + "h " + minutes + "m " + seconds + "s";
          }

          return minutes + "m " + seconds + "s";
        };

        const rowLengthText = function (row) {
          const lengthCell = row.querySelector("[data-auction-length='true']");
          return lengthCell ? lengthCell.textContent.trim() : "-";
        };

        const updateTimers = function () {
          const now = Date.now();

          rows.forEach(function (row) {
            const timeCell = row.querySelector(".au-time-remaining");
            const endTimestamp = parseInt(row.dataset.endTimestamp || "0", 10);

            if (!timeCell) return;

            if (!endTimestamp || row.dataset.status === "sold" || row.dataset.status === "ended" || row.dataset.paymentWaiting === "true") {
              timeCell.textContent = rowLengthText(row);
              return;
            }

            const remaining = endTimestamp - now;

            if (remaining <= 0) {
              timeCell.textContent = rowLengthText(row);
              if (row.dataset.status === "running") {
                row.dataset.status = "ended";
              }
            } else {
              timeCell.textContent = formatRemaining(remaining);
            }
          });
        };

        const applyFilters = function () {
          updateTimers();

          const searchValue = normalize(searchInput ? searchInput.value : "");
          const locationValue = normalize(locationSelect ? locationSelect.value : "");
          const conditionValue = normalize(conditionSelect ? conditionSelect.value : "");
          const minBidsValue = toNumber(minBidsInput ? minBidsInput.value : "");
          const maxBidsValue = toNumber(maxBidsInput ? maxBidsInput.value : "");
          const reserveValue = normalize(reserveSelect ? reserveSelect.value : "");
          const sortValue = normalize(sortSelect ? sortSelect.value : "");

          rows.forEach(function (row) {
            const searchBlob = [row.dataset.seller, row.dataset.description, row.dataset.condition].join(" ");
            const rowBids = parseInt(row.dataset.bids || "0", 10);
            const rowLocation = normalize(row.dataset.location);
            const rowCondition = normalize(row.dataset.condition);
            const rowReserve = normalize(row.dataset.reserve);
            const rowStatus = normalize(row.dataset.status);

            let visible = true;

            if (defaultTab === "current" && rowStatus !== "running") visible = false;
            if (defaultTab === "ended" && rowStatus !== "ended") visible = false;
            if (defaultTab === "sold" && rowStatus !== "sold") visible = false;
            if (searchValue && !searchBlob.includes(searchValue)) visible = false;
            if (locationValue && rowLocation !== locationValue) visible = false;
            if (conditionValue && rowCondition !== conditionValue) visible = false;
            if (minBidsValue !== null && rowBids < minBidsValue) visible = false;
            if (maxBidsValue !== null && rowBids > maxBidsValue) visible = false;
            if (reserveValue && rowReserve !== reserveValue) visible = false;

            row.style.display = visible ? "" : "none";
          });

          rows.slice().sort(function (a, b) {
            const aStatus = normalize(a.dataset.status);
            const bStatus = normalize(b.dataset.status);
            const aEnd = parseInt(a.dataset.endTimestamp || "0", 10);
            const bEnd = parseInt(b.dataset.endTimestamp || "0", 10);
            const aCreated = parseInt(a.dataset.createdTimestamp || "0", 10);
            const bCreated = parseInt(b.dataset.createdTimestamp || "0", 10);

            if (sortValue === "ending-soonest" || sortValue === "") {
              const aBucket = aStatus === "running" ? 0 : 1;
              const bBucket = bStatus === "running" ? 0 : 1;

              if (aBucket !== bBucket) return aBucket - bBucket;
              return aEnd - bEnd;
            }

            if (sortValue === "oldest") {
              return aCreated - bCreated;
            }

            return bCreated - aCreated;
          }).forEach(function (row) {
            tbody.appendChild(row);
          });

          const visibleRows = rows.filter(function (row) {
            return row.style.display !== "none";
          }).length;

          if (emptyState) {
            emptyState.style.display = visibleRows === 0 ? "flex" : "none";
          }
        };

        const clearFilters = function () {
          if (searchInput) searchInput.value = "";
          if (locationSelect) locationSelect.value = "";
          if (conditionSelect) conditionSelect.value = "";
          if (minBidsInput) minBidsInput.value = "";
          if (maxBidsInput) maxBidsInput.value = "";
          if (reserveSelect) reserveSelect.value = "";
          if (sortSelect) sortSelect.value = defaultTab === "current" ? "ending-soonest" : "newest";
          applyFilters();
        };

        if (applyButton) applyButton.addEventListener("click", applyFilters);
        if (clearButton) clearButton.addEventListener("click", clearFilters);

        [searchInput, minBidsInput, maxBidsInput].forEach(function (input) {
          if (input) input.addEventListener("input", applyFilters);
        });

        [locationSelect, conditionSelect, reserveSelect, sortSelect].forEach(function (select) {
          if (select) select.addEventListener("change", applyFilters);
        });

        if (window.auctionPageTimerId) clearInterval(window.auctionPageTimerId);

        applyFilters();
        window.auctionPageTimerId = setInterval(applyFilters, 1000);
      }

      document.addEventListener("DOMContentLoaded", initAuctionPage);
      document.addEventListener("turbo:load", initAuctionPage);
    })();
  </script>
</div>