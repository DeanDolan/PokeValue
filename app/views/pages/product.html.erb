<% require "base64" %>

<%# Product display values used by the page and modal buttons %>
<% display_product_name = params[:product_name].presence || @product_name.presence || @product_type_name %>
<% display_product_img_url = params[:image_url].presence || @product_img_url %>

<%
raw_set_logo_path =
  if defined?(@set_logo_url) && @set_logo_url.present?
    @set_logo_url.to_s
  elsif defined?(@set_logo_path) && @set_logo_path.present?
    @set_logo_path.to_s
  elsif defined?(@set_logo) && @set_logo.present?
    @set_logo.to_s
  else
    ""
  end

cleaned_set_logo_path = raw_set_logo_path.sub(/\A\//, "").sub(/\Aimages\//, "")
set_slug_for_logo = @set_slug.to_s.strip
set_name_for_logo = @set_name.to_s.downcase.gsub(/[^a-z0-9]/, "")
logo_file_name = File.basename(cleaned_set_logo_path.presence || "#{set_slug_for_logo}logo.png")

asset_image_root = Rails.root.join("app", "assets", "images")

logo_disk_candidates = [
  asset_image_root.join(cleaned_set_logo_path),
  asset_image_root.join("sets", logo_file_name),
  asset_image_root.join("sets", "#{set_slug_for_logo}logo.png"),
  asset_image_root.join("sets", "#{set_name_for_logo}logo.png"),
  Rails.root.join("public", "assets", "sets", logo_file_name),
  Rails.root.join("public", "images", "sets", logo_file_name)
].uniq

found_logo_path = logo_disk_candidates.find { |path| path.to_s.present? && File.file?(path) }

if found_logo_path.blank?
  logo_names = [
    logo_file_name,
    "#{set_slug_for_logo}logo.png",
    "#{set_name_for_logo}logo.png"
  ].map(&:to_s).map(&:downcase).uniq

  found_logo_path =
    Dir.glob(asset_image_root.join("**", "*").to_s).find do |path|
      File.file?(path) && logo_names.include?(File.basename(path).downcase)
    end
end

set_logo_image_path =
  if found_logo_path
    ext = File.extname(found_logo_path.to_s).downcase
    mime =
      if ext == ".jpg" || ext == ".jpeg"
        "image/jpeg"
      elsif ext == ".webp"
        "image/webp"
      else
        "image/png"
      end

    "data:#{mime};base64,#{Base64.strict_encode64(File.binread(found_logo_path.to_s))}"
  elsif raw_set_logo_path.start_with?("http://", "https://", "/assets/", "/rails/")
    raw_set_logo_path
  else
    "pokevaluelogo.png"
  end
%>

<%# Forecast metadata inferred from the product name if it was not passed directly %>
<% derived_variant = params[:product_variant].presence || (display_product_name.to_s[/\(([^)]+)\)/, 1].to_s.strip.presence || "") %>
<% derived_origin =
  params[:origin].presence ||
  (display_product_name.to_s.downcase.include?("pokemon center") ? "Pokemon Center" : "")
%>

<%# Current product identifiers used for watchlist and marketplace lookups %>
<% current_route_type = params[:type].presence || @product_type %>
<% watchlist_sku = "#{@set_slug}:#{current_route_type}" %>
<% marketplace_listing_quantity =
  begin
    if defined?(MarketplaceListing)
      quantity = MarketplaceListing.active.where(set_slug: @set_slug.to_s, route_type: current_route_type.to_s).sum(:quantity).to_i

      if quantity.zero?
        quantity = MarketplaceListing.active.where(product_sku: "#{@set_slug}:#{current_route_type}").sum(:quantity).to_i
      end

      if quantity.zero?
        quantity = MarketplaceListing.active.where(product_sku: "#{@set_slug}--#{current_route_type}").sum(:quantity).to_i
      end

      if quantity.zero?
        quantity = MarketplaceListing.active.where(set_slug: @set_slug.to_s, product_type_name: display_product_name.to_s).sum(:quantity).to_i
      end

      if quantity.zero?
        quantity = MarketplaceListing.active.where(set_slug: @set_slug.to_s, product_type_name: @product_type_name.to_s).sum(:quantity).to_i
      end

      quantity
    else
      0
    end
  rescue
    0
  end
%>

<%# Checks whether this product is already in the current user's watchlist %>
<% is_watchlisted =
  (defined?(user_signed_in?) && user_signed_in?) &&
  current_user &&
  current_user.watchlists.exists?(product_sku: watchlist_sku)
%>

<%# Counts how many of this product the current user already has in holdings %>
<% holdings_qty =
  if defined?(user_signed_in?) && user_signed_in? && defined?(@holdings) && @holdings.respond_to?(:sum)
    @holdings.sum { |h| h.quantity.to_i }
  else
    0
  end
%>

<%# Product condition options used by the Add to Portfolio form %>
<%
condition_options = [
  "Loosely Sealed",
  "Mini Tear/Hole (<2cm)",
  "Unsealed",
  "Small Tear (>2cm)",
  "Big Tear (>1 inch)",
  "Small Imperfections",
  "Big Imperfections",
  "Pressure Marks",
  "Slightly Dented",
  "Heavy Dented",
  "Damaged",
  "Box Only",
  "Contents Only"
]

condition_options = ((@conditions || []) + condition_options).map(&:to_s).reject(&:blank?).uniq
condition_options = condition_options.reject { |c| ["Mint Condition", "Small Tear", "Big Tear", "Small Tear (<1 inch)"].include?(c.to_s.strip) }
%>

<div class="container py-4">
  <div class="mb-3">
    <%= link_to "← Back to set", set_path(slug: @set_slug), class: "btn btn-link p-0" %>
  </div>

  <div class="row g-4 align-items-stretch">
    <div class="col-12 col-lg-5">
      <div class="card h-100">
        <div class="card-body d-flex align-items-center justify-content-center">
          <%= image_tag display_product_img_url,
                        alt: display_product_name,
                        class: "img-fluid",
                        style: "max-height:320px;object-fit:contain;" %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="text-center mb-3">
        <%= image_tag set_logo_image_path,
                      alt: @set_name,
                      class: "mb-2",
                      style: "max-height:60px;object-fit:contain;" %>

        <h3 class="mb-0"><%= display_product_name %></h3>

        <div class="text-muted small">
          <%= [@era, @set_name, @product_type_name].compact.join(" · ") %>
        </div>

        <% if holdings_qty.to_i > 0 %>
          <div class="mt-2">
            <span class="badge text-bg-danger"><%= "#{holdings_qty} in holdings" %></span>
          </div>
        <% end %>

        <% if is_watchlisted %>
          <div class="mt-2">
            <span class="badge text-bg-success">On your watchlist</span>
          </div>
        <% end %>
      </div>

      <%# Product information cards %>
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Set</div>
              <div class="fw-semibold"><%= @set_name %></div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Era</div>
              <div class="fw-semibold"><%= @era %></div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Release Date</div>
              <div class="fw-semibold"><%= @release_date %></div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Product Type</div>
              <div class="fw-semibold"><%= @product_type_name %></div>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Estimated Value</div>
              <div class="fw-semibold">
                <%= @product_value.present? ? number_to_currency(@product_value, unit: "€") : "€0.00" %>
              </div>

              <%# Admin-only value update form %>
              <% if defined?(admin_signed_in?) && admin_signed_in? %>
                <div class="mt-2">
                  <%= form_with url: admin_product_value_path(sku: @admin_value_sku), method: :patch, local: true do %>
                    <%= hidden_field_tag :return_to, request.fullpath %>
                    <%= hidden_field_tag :name, display_product_name %>
                    <%= hidden_field_tag :set_name, @set_name %>
                    <%= hidden_field_tag :era, @era %>
                    <%= hidden_field_tag :product_type_name, @product_type_name %>
                    <%= hidden_field_tag :image_url, display_product_img_url %>
                    <div class="input-group input-group-sm">
                      <%= number_field_tag :value, @product_value, step: "0.01", min: 0, class: "form-control", required: true %>
                      <button class="btn btn-outline-primary" type="submit">Update</button>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="col-6 col-md-4">
          <div class="card h-100">
            <div class="card-body text-center py-3">
              <div class="small text-muted">Listings</div>
              <div class="fw-semibold"><%= marketplace_listing_quantity %></div>
            </div>
          </div>
        </div>
      </div>

      <%# Product action buttons %>
      <div class="d-flex flex-wrap gap-2 justify-content-center">
        <% if defined?(user_signed_in?) && user_signed_in? %>
          <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addHoldingModal">
            Add to Portfolio
          </button>
        <% else %>
          <%# Logged-out users see the login modal with an Add to Portfolio-specific title %>
          <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-title="Log in to add to portfolio">
            Add to Portfolio
          </button>
        <% end %>

        <% if defined?(user_signed_in?) && user_signed_in? %>
          <% if is_watchlisted %>
            <%= button_to "Remove from Watchlist",
                          remove_watchlist_path(sku: watchlist_sku),
                          method: :delete,
                          form: { class: "d-inline" },
                          params: { return_to: request.fullpath },
                          class: "btn btn-outline-danger" %>
          <% else %>
            <%= button_to "Add to Watchlist",
                          watchlist_path(sku: watchlist_sku),
                          method: :post,
                          form: { class: "d-inline" },
                          params: { return_to: request.fullpath },
                          class: "btn btn-outline-secondary" %>
          <% end %>
        <% else %>
          <%# Logged-out users see the login modal with an Add to Watchlist-specific title %>
          <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-title="Log in to add to watchlist">
            Add to Watchlist
          </button>
        <% end %>

        <%# Forecast button passes product data into the forecast Stimulus controller %>
        <% if defined?(user_signed_in?) && user_signed_in? %>
          <button
            class="btn btn-outline-primary"
            data-bs-toggle="modal"
            data-bs-target="#forecastModal"
            data-forecast-set-name="<%= @set_name %>"
            data-forecast-product-name="<%= display_product_name %>"
            data-forecast-product-variant="<%= derived_variant %>"
            data-forecast-origin="<%= derived_origin %>">
            Future Projections
          </button>
        <% else %>
          <%# Logged-out users see the login modal instead of loading the Future Projections modal %>
          <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-title="Log in to see future projections">
            Future Projections
          </button>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Future projections modal %>
<% if defined?(user_signed_in?) && user_signed_in? %>
  <div class="modal fade" id="forecastModal" tabindex="-1"
       data-controller="forecast"
       data-forecast-endpoint-value="/forecast">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Future Projections</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div class="alert alert-warning small mb-3">
            <strong>Warning:</strong>
            Future projections are estimates only. They are based on available historical data and trend-based modelling, so they are not guaranteed to be accurate. These projections should not be treated as financial advice or relied on as the only reason to buy, sell, or hold a product. Product values can rise or fall, and PokeValue is not liable for any loss, missed profit, or financial decision made using these projections.
          </div>

          <div class="d-flex gap-2 mb-3">
            <button class="btn btn-outline-primary btn-sm" data-forecast-target="hbtn" data-horizon="6m" data-action="click->forecast#changeHorizon">6m</button>
            <button class="btn btn-outline-primary btn-sm" data-forecast-target="hbtn" data-horizon="1y" data-action="click->forecast#changeHorizon">1y</button>
            <button class="btn btn-outline-primary btn-sm" data-forecast-target="hbtn" data-horizon="3y" data-action="click->forecast#changeHorizon">3y</button>
            <button class="btn btn-outline-primary btn-sm" data-forecast-target="hbtn" data-horizon="5y" data-action="click->forecast#changeHorizon">5y</button>

            <div class="ms-auto small text-muted">
              As of: <span data-forecast-target="asof">—</span>
            </div>
          </div>

          <div class="small text-muted mb-2" data-forecast-target="status">Loading…</div>

          <div style="height:360px;">
            <canvas data-forecast-target="canvas"></canvas>
          </div>

          <hr>

          <%# Forecast milestone values %>
          <div class="row g-2 text-center">
            <div class="col-6 col-lg-3">
              <div class="card">
                <div class="card-body">
                  <div class="small text-muted">6m</div>
                  <div class="fw-semibold" data-forecast-target="m6">—</div>
                </div>
              </div>
            </div>

            <div class="col-6 col-lg-3">
              <div class="card">
                <div class="card-body">
                  <div class="small text-muted">1y</div>
                  <div class="fw-semibold" data-forecast-target="m1y">—</div>
                </div>
              </div>
            </div>

            <div class="col-6 col-lg-3">
              <div class="card">
                <div class="card-body">
                  <div class="small text-muted">3y</div>
                  <div class="fw-semibold" data-forecast-target="m3y">—</div>
                </div>
              </div>
            </div>

            <div class="col-6 col-lg-3">
              <div class="card">
                <div class="card-body">
                  <div class="small text-muted">5y</div>
                  <div class="fw-semibold" data-forecast-target="m5y">—</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# Login modal shown when a logged-out user tries to add a product %>
<%# The same login modal is reused for portfolio, watchlist and future projections, with the title changed depending on which button was clicked %>
<% if !(defined?(user_signed_in?) && user_signed_in?) %>
  <div class="modal fade" id="authModal" tabindex="-1" aria-labelledby="authModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="authModalLabel">Log in to add to portfolio</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body">
          <%= form_with url: login_path, method: :post, local: true do %>
            <div class="mb-3">
              <label class="form-label" for="login_username">Username</label>
              <%= text_field_tag :username, nil, class: "form-control", id: "login_username", required: true %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="login_password">Password</label>
              <%= password_field_tag :password, nil, class: "form-control", id: "login_password", required: true %>
            </div>

            <div class="d-flex justify-content-end gap-2">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary">Log in</button>
            </div>
          <% end %>

          <hr class="my-3">

          <div class="text-center small">
            Don't have an account?
            <%= link_to "Register", register_path, class: "btn btn-link btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (() => {
      function initAuthModalTitle() {
        const authModal = document.getElementById("authModal")
        const title = document.getElementById("authModalLabel")

        if (!authModal || !title) return
        if (authModal.dataset.bound === "1") return
        authModal.dataset.bound = "1"

        authModal.addEventListener("show.bs.modal", event => {
          const button = event.relatedTarget
          const nextTitle = button ? button.getAttribute("data-auth-title") : null
          title.textContent = nextTitle || "Log in"
        })
      }

      document.addEventListener("DOMContentLoaded", initAuthModalTitle)
      document.addEventListener("turbo:load", initAuthModalTitle)
    })()
  </script>
<% end %>

<%# Add to Portfolio modal shown only for logged-in users %>
<% if defined?(user_signed_in?) && user_signed_in? %>
  <div class="modal fade" id="addHoldingModal" tabindex="-1" aria-labelledby="addHoldingModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addHoldingModalLabel">Add to Portfolio</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div class="mb-3 small text-muted text-center">
            <div><strong><%= display_product_name %></strong></div>
            <div><%= @set_name %> · <%= @era %></div>
          </div>

          <%= form_with url: holdings_path, scope: :holding, method: :post, local: true do %>
            <%= hidden_field_tag "holding[set_slug]", @set_slug %>
            <%= hidden_field_tag "holding[type_code]", current_route_type %>
            <%= hidden_field_tag "holding[image_url]", display_product_img_url %>

            <%= hidden_field_tag "holding[era]", @era %>
            <%= hidden_field_tag "holding[set_name]", @set_name %>
            <%= hidden_field_tag "holding[product_type]", display_product_name %>

            <div class="mb-3">
              <label class="form-label" for="holding_value_input">Estimated value / unit (€)</label>
              <%= number_field_tag "holding[value]",
                                   @product_value,
                                   step: "0.01",
                                   min: 0,
                                   class: "form-control",
                                   id: "holding_value_input",
                                   required: true,
                                   readonly: true,
                                   data: { base_value: @product_value.to_f } %>
              <div class="form-text" id="holding_condition_note"></div>
            </div>

            <div class="mb-3">
              <label class="form-label" for="holding_quantity">Quantity</label>
              <%= number_field_tag "holding[quantity]", 1, min: 1, class: "form-control", id: "holding_quantity", required: true %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="holding_cost_per_unit">Cost per unit (€)</label>
              <%= number_field_tag "holding[cost_per_unit]",
                                   @product_value,
                                   step: "0.01",
                                   min: 0,
                                   class: "form-control",
                                   id: "holding_cost_per_unit",
                                   required: true %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="holding_purchase_date">Purchase date</label>
              <%= date_field_tag "holding[purchase_date]", Date.today, class: "form-control", id: "holding_purchase_date" %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="holding_condition">Condition</label>
              <%= select_tag "holding[condition]",
                             options_for_select(condition_options),
                             include_blank: "Select condition",
                             class: "form-select",
                             id: "holding_condition" %>
            </div>

            <div class="d-flex justify-content-end gap-2">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-success">Save to Portfolio</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <script>
    (() => {
      // Updates estimated value when the user selects a condition
      function initHoldingConditionValue() {
        const conditionSelect = document.getElementById("holding_condition")
        const valueInput = document.getElementById("holding_value_input")
        const note = document.getElementById("holding_condition_note")

        if (!conditionSelect || !valueInput) return
        if (conditionSelect.dataset.bound === "1") return
        conditionSelect.dataset.bound = "1"

        const baseValue = parseFloat(valueInput.dataset.baseValue || "0") || 0

        const naConditions = [
          "unsealed",
          "damaged",
          "box only",
          "contents only"
        ]

        const tenPercent = [
          "loosely sealed",
          "mini tear/hole (<2cm)",
          "mini tear/hole (1cm)",
          "pressure marks",
          "small imperfections"
        ]

        const fifteenPercent = [
          "big imperfections",
          "small tear (>2cm)"
        ]

        const twentyPercent = [
          "big tear (>1 inch)",
          "big tear (>inch)",
          "slightly dented"
        ]

        const thirtyPercent = [
          "heavy dented"
        ]

        function normalize(value) {
          return String(value || "").trim().toLowerCase().replace(/\s+/g, " ")
        }

        function syncValue() {
          const condition = normalize(conditionSelect.value)
          let adjusted = baseValue
          let noteText = ""

          if (naConditions.includes(condition)) {
            valueInput.readOnly = false
            valueInput.classList.remove("bg-light")
            if (!valueInput.value || parseFloat(valueInput.value) === 0) {
              valueInput.value = baseValue.toFixed(2)
            }
            if (note) note.textContent = "This condition is marked as N/A for estimated value."
            return
          }

          valueInput.readOnly = true
          valueInput.classList.add("bg-light")

          if (tenPercent.includes(condition)) {
            adjusted = baseValue * 0.9
            noteText = "10% condition reduction applied."
          } else if (fifteenPercent.includes(condition)) {
            adjusted = baseValue * 0.85
            noteText = "15% condition reduction applied."
          } else if (twentyPercent.includes(condition)) {
            adjusted = baseValue * 0.8
            noteText = "20% condition reduction applied."
          } else if (thirtyPercent.includes(condition)) {
            adjusted = baseValue * 0.7
            noteText = "30% condition reduction applied."
          }

          adjusted = Math.round(adjusted * 100) / 100
          valueInput.value = adjusted.toFixed(2)
          if (note) note.textContent = noteText
        }

        conditionSelect.addEventListener("change", syncValue)
        syncValue()
      }

      document.addEventListener("DOMContentLoaded", initHoldingConditionValue)
      document.addEventListener("turbo:load", initHoldingConditionValue)
    })()
  </script>
<% end %>