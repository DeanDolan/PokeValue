<%
  # Splits the community channel buttons into two rows so the layout stays neat
  second_row_channel_values = %w[card_shows content_creators app_suggestions application_problems]
  selected_channel_value = @selected_channel.presence || "general"
  first_row_channels = @community_channels.reject { |_, value| second_row_channel_values.include?(value) }
  second_row_channels = @community_channels.select { |_, value| second_row_channel_values.include?(value) }
%>

<div class="community-page py-3">
  <style>
    .community-page{max-width:920px;margin:0 auto}
    .community-card{background:#fff;border:1px solid #e5e7eb;border-radius:1.25rem;box-shadow:0 12px 30px rgba(15,23,42,.06)}
    .community-header{margin-bottom:1rem}
    .community-title{margin:0;font-size:1.7rem;line-height:1.05;font-weight:800}
    .community-subtitle{margin:.35rem 0 0;color:#6b7280;font-size:.95rem}
    .community-channel-groups{display:grid;gap:.45rem;margin-bottom:1.15rem}
    .community-channels-top{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:.35rem}
    .community-channels-bottom{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.35rem}
    .community-page .community-channel-pill{display:flex!important;align-items:center!important;justify-content:center!important;min-width:0!important;min-height:30px!important;padding:.32rem .42rem!important;border-radius:999px!important;background:var(--pv-button-bg)!important;background-color:var(--pv-button-bg)!important;border:1px solid var(--pv-button-border)!important;color:var(--pv-button-text)!important;text-decoration:none!important;font-size:.7rem!important;font-weight:700!important;white-space:nowrap!important;line-height:1!important;box-shadow:none!important;filter:none!important;outline:0!important}
    .community-page .community-channel-pill:not(.active),.community-page .community-channel-pill:not(.active):hover,.community-page .community-channel-pill:not(.active):focus,.community-page .community-channel-pill:not(.active):focus-visible,.community-page .community-channel-pill:not(.active):active{background:var(--pv-button-bg)!important;background-color:var(--pv-button-bg)!important;border-color:var(--pv-button-border)!important;color:var(--pv-button-text)!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    .community-page .community-channel-pill.active,.community-page .community-channel-pill.active:hover,.community-page .community-channel-pill.active:focus,.community-page .community-channel-pill.active:focus-visible,.community-page .community-channel-pill.active:active{background:var(--pv-active-bg)!important;background-color:var(--pv-active-bg)!important;border-color:var(--pv-active-border)!important;color:var(--pv-active-text)!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    :root[data-pv-theme="dark"] body .community-page .community-channel-pill{background:#000000!important;background-color:#000000!important;border-color:#d4af37!important;color:#d4af37!important;box-shadow:none!important;filter:none!important;outline:0!important}
    :root[data-pv-theme="dark"] body .community-page .community-channel-pill:not(.active),:root[data-pv-theme="dark"] body .community-page .community-channel-pill:not(.active):hover,:root[data-pv-theme="dark"] body .community-page .community-channel-pill:not(.active):focus,:root[data-pv-theme="dark"] body .community-page .community-channel-pill:not(.active):focus-visible,:root[data-pv-theme="dark"] body .community-page .community-channel-pill:not(.active):active{background:#000000!important;background-color:#000000!important;border-color:#d4af37!important;color:#d4af37!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    :root[data-pv-theme="dark"] body .community-page .community-channel-pill.active,:root[data-pv-theme="dark"] body .community-page .community-channel-pill.active:hover,:root[data-pv-theme="dark"] body .community-page .community-channel-pill.active:focus,:root[data-pv-theme="dark"] body .community-page .community-channel-pill.active:focus-visible,:root[data-pv-theme="dark"] body .community-page .community-channel-pill.active:active{background:#d4af37!important;background-color:#d4af37!important;border-color:#d4af37!important;color:#000000!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    :root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active),:root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active):hover,:root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active):focus,:root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active):focus-visible,:root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active):active{background:#ffffff!important;background-color:#ffffff!important;border-color:#000000!important;color:#000000!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    :root[data-pv-theme="light"] body .community-page .community-channel-pill.active,:root[data-pv-theme="light"] body .community-page .community-channel-pill.active:hover,:root[data-pv-theme="light"] body .community-page .community-channel-pill.active:focus,:root[data-pv-theme="light"] body .community-page .community-channel-pill.active:focus-visible,:root[data-pv-theme="light"] body .community-page .community-channel-pill.active:active{background:#000000!important;background-color:#000000!important;border-color:#000000!important;color:#ffffff!important;box-shadow:none!important;filter:none!important;outline:0!important;text-decoration:none!important}
    .community-create-card{padding:1rem;margin-bottom:1rem}
    .community-create-label{font-size:.8rem;font-weight:700;color:#4b5563;margin-bottom:.45rem}
    .community-create-textarea{width:100%;min-height:120px;border:1px solid #d1d5db;border-radius:1rem;padding:.9rem 1rem;font-size:.98rem;resize:vertical;outline:none}
    .community-create-textarea:focus{border-color:#111827;box-shadow:0 0 0 3px rgba(17,24,39,.08)}
    .community-create-bottom{display:flex;gap:1rem;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;margin-top:.9rem}
    .community-file-wrap{flex:1 1 320px}
    .community-file-control{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap}
    .community-file-input{position:absolute;opacity:0;pointer-events:none;width:0;height:0}
    .community-file-trigger{display:inline-flex;align-items:center;justify-content:center;height:42px;padding:0 1rem;border:1px solid #d1d5db;border-radius:1rem;background:#fff;color:#111827;font-size:.9rem;font-weight:700;cursor:pointer}
    .community-file-trigger:hover{background:#f9fafb}
    .community-file-status{font-size:.88rem;color:#6b7280}
    .community-hint{font-size:.78rem;color:#6b7280;margin-top:.4rem;line-height:1.35}
    .community-selected-files{display:none;margin-top:.8rem}
    .community-selected-files.active{display:block}
    .community-selected-files-top{display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:.55rem}
    .community-selected-files-title{font-size:.8rem;font-weight:800;color:#374151}
    .community-selected-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));gap:.55rem}
    .community-selected-item{position:relative;border:1px solid #e5e7eb;border-radius:1rem;overflow:hidden;background:#f8fafc;aspect-ratio:1 / 1}
    .community-selected-thumb{width:100%;height:100%;object-fit:cover;display:block}
    .community-selected-remove{position:absolute;top:.35rem;right:.35rem;width:28px;height:28px;border:none;border-radius:999px;background:rgba(17,24,39,.75);color:#fff;font-size:1rem;line-height:1}
    .community-post-action{display:flex;align-items:flex-start}
    .community-post-btn{width:150px;height:42px;min-width:150px;max-width:150px;border-radius:1rem;font-weight:800;padding:0 1.25rem;display:inline-flex;align-items:center;justify-content:center;flex:0 0 150px}
    .community-login-prompt{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .community-login-copy h2{margin:0 0 .25rem;font-size:1.1rem}
    .community-login-copy p{margin:0;color:#6b7280}
    .community-empty{padding:1.3rem;text-align:center;color:#6b7280}
    .community-feed{display:grid;gap:1rem}
    .community-viewer-stage{position:relative;height:min(78vh,900px);overflow:hidden;background:#05070b;border-radius:1rem;touch-action:none;cursor:grab}
    .community-viewer-stage.dragging{cursor:grabbing}
    .community-viewer-image{position:absolute;top:50%;left:50%;max-width:none;max-height:none;transform-origin:center center;will-change:transform;user-select:none;-webkit-user-drag:none}
    .community-viewer-toolbar{display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;margin-bottom:.85rem}
    .community-viewer-controls{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
    .community-viewer-counter{color:#e5e7eb;font-weight:700}
    .community-viewer-btn{border-radius:999px}
    .community-viewer-nav{position:absolute;top:50%;transform:translateY(-50%);z-index:4}
    .community-viewer-prev{left:.75rem}
    .community-viewer-next{right:.75rem}
    @media (max-width:900px){
      .community-channels-top{grid-template-columns:repeat(4,minmax(0,1fr))}
      .community-channels-bottom{grid-template-columns:repeat(4,minmax(0,1fr))}
    }
    @media (max-width:640px){
      .community-create-bottom{align-items:stretch}
      .community-post-action{width:100%}
      .community-post-btn{width:100%;max-width:none;flex:1 1 auto}
      .community-viewer-stage{height:70vh}
      .community-channels-top,.community-channels-bottom{grid-template-columns:repeat(2,minmax(0,1fr));gap:.5rem}
    }
  </style>

  <div class="community-header">
    <h1 class="community-title">Community Channels</h1>
    <p class="community-subtitle">Post in channels, share images, react, and comment on posts (without spamming).</p>
  </div>

  <%# Channel navigation keeps the selected channel highlighted %>
  <div class="community-channel-groups">
    <div class="community-channels-top">
      <% first_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", (selected_channel_value == value ? "active" : nil)].compact.join(" ") %>
      <% end %>
    </div>

    <div class="community-channels-bottom">
      <% second_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", (selected_channel_value == value ? "active" : nil)].compact.join(" ") %>
      <% end %>
    </div>
  </div>

  <%# Post creation card shown only to logged-in users %>
  <section class="community-card community-create-card">
    <% if current_user %>
      <%= form_with model: @community_post, url: community_posts_path, local: true do |f| %>
        <%= f.hidden_field :channel, value: selected_channel_value %>

        <div class="community-create-label">
          Post in <%= CommunityPost.channel_label(selected_channel_value) %>
        </div>

        <%= f.text_area :body,
              class: "community-create-textarea",
              placeholder: "Write your post for #{CommunityPost.channel_label(selected_channel_value)}...",
              maxlength: CommunityPost::MAX_BODY_LENGTH,
              rows: 5 %>

        <div class="community-create-bottom">
          <div class="community-file-wrap">
            <div class="community-file-control">
              <label for="community-post-images-input" class="community-file-trigger">Browse</label>
              <span id="community-post-images-status" class="community-file-status">No images selected.</span>
              <%= f.file_field :images,
                    multiple: true,
                    accept: "image/png,image/jpeg,image/jpg,image/webp,image/gif",
                    class: "community-file-input",
                    id: "community-post-images-input" %>
            </div>

            <div class="community-hint">You can keep selecting more images and they will be added. Up to 10 images. Max 2000 characters.</div>

            <%# Client-side image preview area for selected post images %>
            <div id="community-selected-files" class="community-selected-files">
              <div class="community-selected-files-top">
                <div id="community-selected-files-title" class="community-selected-files-title"></div>
                <button id="community-clear-selected-files" type="button" class="btn btn-sm btn-outline-secondary">Clear images</button>
              </div>
              <div id="community-selected-grid" class="community-selected-grid"></div>
            </div>
          </div>

          <div class="community-post-action">
            <%= f.submit "Post", class: "btn btn-dark community-post-btn" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <%# Logged-out users are prompted to open the login/register modal %>
      <div class="community-login-prompt">
        <div class="community-login-copy">
          <h2>Join the conversation</h2>
          <p>Log in to create posts, react, and comment in the community channels.</p>
        </div>
        <button class="btn btn-dark" type="button" data-bs-toggle="modal" data-bs-target="#authModal">
          Login / Register
        </button>
      </div>
    <% end %>
  </section>

  <%# Main community feed for the selected channel %>
  <section class="community-feed">
    <% if @community_posts.any? %>
      <%= render partial: "community_posts/post", collection: @community_posts, as: :post, locals: { selected_channel: selected_channel_value } %>
    <% else %>
      <div class="community-card community-empty">
        No posts yet in <strong><%= CommunityPost.channel_label(selected_channel_value) %></strong>.
      </div>
    <% end %>
  </section>
</div>

<%# Full-screen image viewer used when users click post images %>
<div class="modal fade" id="communityImageViewerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen-sm-down modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content bg-dark text-white border-0">
      <div class="modal-header border-0 pb-0">
        <div class="community-viewer-toolbar w-100">
          <div id="community-image-viewer-counter" class="community-viewer-counter">1 / 1</div>
          <div class="community-viewer-controls">
            <button id="community-image-zoom-out" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">-</button>
            <button id="community-image-zoom-reset" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">Reset</button>
            <button id="community-image-zoom-in" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">+</button>
            <button type="button" class="btn btn-outline-light btn-sm community-viewer-btn" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
      <div class="modal-body pt-2">
        <div id="community-image-viewer-stage" class="community-viewer-stage">
          <button id="community-image-prev" type="button" class="btn btn-outline-light community-viewer-nav community-viewer-prev">‹</button>
          <img id="community-image-viewer-image" class="community-viewer-image" src="" alt="Post image" draggable="false">
          <button id="community-image-next" type="button" class="btn btn-outline-light community-viewer-nav community-viewer-next">›</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    // Creates a stable key so the same selected file is not added twice
    function keyForFile(file){
      return [file.name, file.size, file.lastModified].join("__");
    }

    // Escapes dynamic text before inserting it into HTML strings
    function escapeHtml(value){
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    // Converts a two-letter country code into a flag emoji
    function flagEmoji(countryCode){
      const code = (countryCode || "").toUpperCase();
      if(!/^[A-Z]{2}$/.test(code)) return "";
      return code.replace(/./g, function(char){
        return String.fromCodePoint(127397 + char.charCodeAt(0));
      });
    }

    // Builds the badge HTML used inside the reaction modal rows
    function badgeHtml(badge){
      const klass = badge === "Admin" ? "community-badge community-badge-admin" : "community-badge community-badge-default";
      return '<span class="' + klass + '">' + escapeHtml(badge) + '</span>';
    }

    // Builds one person row for a post or comment reaction modal
    function reactorRowHtml(reactor, emoji, label){
      const badges = (reactor.badges || []).map(badgeHtml).join("");
      const flag = flagEmoji(reactor.country_code);
      return '' +
        '<div class="community-reaction-person" data-kind="' + escapeHtml(reactor.kind) + '">' +
          '<div class="community-reaction-person-left">' +
            '<span class="community-reaction-person-name">' + escapeHtml(reactor.username) + '</span>' +
            (flag ? '<span class="community-flag">' + flag + '</span>' : '') +
            badges +
          '</div>' +
          '<div class="community-reaction-kind">' +
            '<span>' + escapeHtml(emoji) + '</span>' +
            '<span>' + escapeHtml(label) + '</span>' +
          '</div>' +
        '</div>';
    }

    // Handles image selection, previews, duplicate prevention, and clearing selected files
    function initCommunityCreateForm(){
      const input = document.getElementById("community-post-images-input");
      const status = document.getElementById("community-post-images-status");
      const wrap = document.getElementById("community-selected-files");
      const title = document.getElementById("community-selected-files-title");
      const grid = document.getElementById("community-selected-grid");
      const clearButton = document.getElementById("community-clear-selected-files");

      if(!input || !status || !wrap || !title || !grid || !clearButton) return;
      if(input.dataset.communityImagesReady === "true") return;
      input.dataset.communityImagesReady = "true";

      let storedFiles = [];

      function syncInput(){
        const dt = new DataTransfer();
        storedFiles.forEach(function(file){ dt.items.add(file); });
        input.files = dt.files;
      }

      function render(){
        grid.innerHTML = "";

        if(storedFiles.length === 0){
          wrap.classList.remove("active");
          title.textContent = "";
          status.textContent = "No images selected.";
          return;
        }

        wrap.classList.add("active");
        title.textContent = storedFiles.length + " image" + (storedFiles.length === 1 ? "" : "s") + " selected";
        status.textContent = storedFiles.length + " image" + (storedFiles.length === 1 ? "" : "s") + " selected";

        storedFiles.forEach(function(file){
          const item = document.createElement("div");
          item.className = "community-selected-item";
          item.dataset.fileKey = keyForFile(file);

          const img = document.createElement("img");
          img.className = "community-selected-thumb";
          img.alt = file.name;
          img.src = URL.createObjectURL(file);

          const remove = document.createElement("button");
          remove.type = "button";
          remove.className = "community-selected-remove";
          remove.dataset.fileKey = keyForFile(file);
          remove.textContent = "×";

          item.appendChild(img);
          item.appendChild(remove);
          grid.appendChild(item);
        });
      }

      input.addEventListener("change", function(){
        const incoming = Array.from(input.files || []);
        if(incoming.length === 0) return;

        const map = new Map(storedFiles.map(function(file){ return [keyForFile(file), file]; }));
        incoming.forEach(function(file){
          map.set(keyForFile(file), file);
        });

        storedFiles = Array.from(map.values()).slice(0, 10);
        syncInput();
        render();
      });

      grid.addEventListener("click", function(event){
        const button = event.target.closest(".community-selected-remove");
        if(!button) return;

        const fileKey = button.dataset.fileKey;
        storedFiles = storedFiles.filter(function(file){
          return keyForFile(file) !== fileKey;
        });

        syncInput();
        render();
      });

      clearButton.addEventListener("click", function(){
        storedFiles = [];
        syncInput();
        render();
      });

      render();
    }

    // Allows users to filter reaction modals by reaction type
    function initReactionModals(){
      document.addEventListener("click", function(event){
        const filterButton = event.target.closest(".community-reactions-filter");
        if(!filterButton) return;

        const modalBody = filterButton.closest(".community-reactions-modal-body");
        if(!modalBody) return;

        const kind = filterButton.dataset.kind || "all";

        modalBody.querySelectorAll(".community-reactions-filter").forEach(function(button){
          button.classList.remove("active");
        });
        filterButton.classList.add("active");

        modalBody.querySelectorAll(".community-reaction-person").forEach(function(row){
          const rowKind = row.dataset.kind;
          row.style.display = (kind === "all" || rowKind === kind) ? "" : "none";
        });

        const emptyState = modalBody.querySelector(".community-reactions-empty-filter");
        if(emptyState){
          const visibleRows = Array.from(modalBody.querySelectorAll(".community-reaction-person")).filter(function(row){
            return row.style.display !== "none";
          });
          emptyState.style.display = visibleRows.length === 0 ? "" : "none";
        }
      }, { passive: true });
    }

    // Reveals hidden comments in batches when a More Comments button is used
    function initViewMoreComments(){
      if(document.body.dataset.communityViewMoreReady === "true") return;
      document.body.dataset.communityViewMoreReady = "true";

      document.addEventListener("click", function(event){
        const button = event.target.closest("[data-community-more-comments-toggle]");
        if(!button) return;

        const postId = button.dataset.communityMoreCommentsToggle;
        const container = document.querySelector('[data-community-comments-container][data-post-id="' + postId + '"]');
        if(!container) return;

        const hiddenComments = Array.from(container.querySelectorAll('[data-community-hidden-comment="true"].d-none')).slice(0, 10);
        hiddenComments.forEach(function(comment){
          comment.classList.remove("d-none");
        });

        const remaining = container.querySelectorAll('[data-community-hidden-comment="true"].d-none').length;
        if(remaining === 0){
          button.remove();
        }
      });
    }

    // Updates all visible reaction counts and modal content after a post reaction is submitted by AJAX
    function updatePostReactionUi(postId, counts, totalReactions, currentReaction, reactors){
      document.querySelectorAll('.community-post-react-form[data-community-post-id="' + postId + '"]').forEach(function(form){
        const button = form.querySelector("[data-post-reaction-kind]");
        if(!button) return;

        const kind = button.dataset.postReactionKind;
        const count = Number(counts[kind] || 0);
        const countSpan = button.querySelector("[data-post-reaction-count]");
        button.classList.toggle("active", currentReaction === kind);
        if(countSpan){
          countSpan.textContent = count > 0 ? String(count) : "";
        }
      });

      const totalLink = document.querySelector('[data-community-post-total-reactions][data-post-id="' + postId + '"]');
      if(totalLink){
        totalLink.textContent = "Reactions (" + totalReactions + ")";
      }

      const pillsWrap = document.querySelector('[data-community-post-summary-emojis][data-post-id="' + postId + '"]');
      if(pillsWrap){
        pillsWrap.innerHTML = "";
        document.querySelectorAll('.community-post-react-form[data-community-post-id="' + postId + '"]').forEach(function(form){
          const button = form.querySelector("[data-post-reaction-kind]");
          if(!button) return;

          const kind = button.dataset.postReactionKind;
          const count = Number(counts[kind] || 0);
          if(count <= 0) return;

          const pill = document.createElement("span");
          pill.className = "community-social-emoji-pill";
          pill.textContent = button.dataset.postReactionEmoji + " " + count;
          pillsWrap.appendChild(pill);
        });
      }

      const modalBody = document.querySelector('.community-reactions-modal-body[data-community-post-id="' + postId + '"]');
      if(modalBody){
        modalBody.querySelectorAll(".community-reactions-filter").forEach(function(filter){
          const kind = filter.dataset.kind || "all";
          if(kind === "all"){
            filter.textContent = "All (" + totalReactions + ")";
          } else {
            filter.textContent = (filter.dataset.emoji || "") + " " + Number(counts[kind] || 0);
          }
        });

        const list = modalBody.querySelector("[data-community-reactor-list]");
        if(list){
          list.innerHTML = "";
          if((reactors || []).length === 0){
            list.innerHTML = '<div class="text-muted">No reactions yet.</div>';
          } else {
            reactors.forEach(function(reactor){
              const sourceButton = document.querySelector('.community-post-react-form[data-community-post-id="' + postId + '"] [data-post-reaction-kind="' + reactor.kind + '"]');
              const emoji = sourceButton ? sourceButton.dataset.postReactionEmoji : "";
              const label = sourceButton ? sourceButton.dataset.postReactionLabel : reactor.kind;
              list.insertAdjacentHTML("beforeend", reactorRowHtml(reactor, emoji, label));
            });
          }
        }

        const active = modalBody.querySelector(".community-reactions-filter.active");
        if(active) active.click();
      }
    }

    // Updates all visible reaction counts and modal content after a comment reaction is submitted by AJAX
    function updateCommentReactionUi(commentId, counts, totalReactions, currentReaction, reactors){
      document.querySelectorAll('.community-comment-react-form[data-community-comment-id="' + commentId + '"]').forEach(function(form){
        const button = form.querySelector("[data-comment-reaction-kind]");
        if(!button) return;

        const kind = button.dataset.commentReactionKind;
        const count = Number(counts[kind] || 0);
        const countSpan = button.querySelector("[data-comment-reaction-count]");
        button.classList.toggle("active", currentReaction === kind);
        if(countSpan){
          countSpan.textContent = count > 0 ? String(count) : "";
        }
      });

      const totalLink = document.querySelector('[data-community-comment-total-reactions][data-comment-id="' + commentId + '"]');
      if(totalLink){
        totalLink.textContent = "👍 " + totalReactions;
      }

      const modalBody = document.querySelector('.community-reactions-modal-body[data-community-comment-id="' + commentId + '"]');
      if(modalBody){
        modalBody.querySelectorAll(".community-reactions-filter").forEach(function(filter){
          const kind = filter.dataset.kind || "all";
          if(kind === "all"){
            filter.textContent = "All (" + totalReactions + ")";
          } else {
            filter.textContent = (filter.dataset.emoji || "") + " " + Number(counts[kind] || 0);
          }
        });

        const list = modalBody.querySelector("[data-community-comment-reactor-list]");
        if(list){
          list.innerHTML = "";
          if((reactors || []).length === 0){
            list.innerHTML = '<div class="text-muted">No reactions yet.</div>';
          } else {
            reactors.forEach(function(reactor){
              const sourceButton = document.querySelector('.community-comment-react-form[data-community-comment-id="' + commentId + '"] [data-comment-reaction-kind="' + reactor.kind + '"]');
              const emoji = sourceButton ? sourceButton.dataset.commentReactionEmoji : "";
              const label = sourceButton ? sourceButton.dataset.commentReactionLabel : reactor.kind;
              list.insertAdjacentHTML("beforeend", reactorRowHtml(reactor, emoji, label));
            });
          }
        }

        const active = modalBody.querySelector(".community-reactions-filter.active");
        if(active) active.click();
      }
    }

    // Sends reaction forms with fetch so the page does not need a full reload
    function submitReactionForm(form, onSuccess){
      const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content");
      const submitButton = form.querySelector("button[type='submit']");
      if(submitButton) submitButton.disabled = true;

      fetch(form.action, {
        method: "POST",
        headers: {
          "Accept": "application/json",
          "X-CSRF-Token": token
        },
        body: new FormData(form),
        credentials: "same-origin"
      }).then(function(response){
        if(!response.ok) throw new Error("Request failed");
        return response.json();
      }).then(function(data){
        onSuccess(data);
      }).catch(function(){
      }).finally(function(){
        if(submitButton) submitButton.disabled = false;
      });
    }

    // Intercepts post and comment reaction forms and updates the UI from JSON responses
    function initAjaxReactionForms(){
      if(document.body.dataset.communityAjaxReactionReady === "true") return;
      document.body.dataset.communityAjaxReactionReady = "true";

      document.addEventListener("submit", function(event){
        const postForm = event.target.closest(".community-post-react-form");
        if(postForm){
          event.preventDefault();
          submitReactionForm(postForm, function(data){
            updatePostReactionUi(data.post_id, data.counts || {}, Number(data.total_reactions || 0), data.current_reaction || null, data.reactors || []);
          });
          return;
        }

        const commentForm = event.target.closest(".community-comment-react-form");
        if(commentForm){
          event.preventDefault();
          submitReactionForm(commentForm, function(data){
            updateCommentReactionUi(data.comment_id, data.counts || {}, Number(data.total_reactions || 0), data.current_reaction || null, data.reactors || []);
          });
        }
      });
    }

    // Sets up the image viewer modal with zoom, drag, touch pinch, and next/previous controls
    function initImageViewer(){
      const modalEl = document.getElementById("communityImageViewerModal");
      const stage = document.getElementById("community-image-viewer-stage");
      const image = document.getElementById("community-image-viewer-image");
      const counter = document.getElementById("community-image-viewer-counter");
      const prevButton = document.getElementById("community-image-prev");
      const nextButton = document.getElementById("community-image-next");
      const zoomInButton = document.getElementById("community-image-zoom-in");
      const zoomOutButton = document.getElementById("community-image-zoom-out");
      const zoomResetButton = document.getElementById("community-image-zoom-reset");

      if(!modalEl || !stage || !image || !counter || !prevButton || !nextButton || !zoomInButton || !zoomOutButton || !zoomResetButton) return;
      if(modalEl.dataset.communityViewerReady === "true") return;
      modalEl.dataset.communityViewerReady = "true";

      let images = [];
      let index = 0;
      let scale = 1;
      let translateX = 0;
      let translateY = 0;
      let dragging = false;
      let lastPointerX = 0;
      let lastPointerY = 0;
      let pinchStartDistance = null;
      let pinchStartScale = 1;

      function clampScale(value){
        return Math.max(1, Math.min(6, value));
      }

      function applyTransform(){
        image.style.transform = "translate(" + translateX + "px, " + translateY + "px) translate(-50%, -50%) scale(" + scale + ")";
        prevButton.style.display = images.length > 1 ? "" : "none";
        nextButton.style.display = images.length > 1 ? "" : "none";
        counter.textContent = images.length ? (index + 1) + " / " + images.length : "0 / 0";
      }

      function resetTransform(){
        scale = 1;
        translateX = 0;
        translateY = 0;
        applyTransform();
      }

      function renderImage(){
        if(!images.length) return;
        image.src = images[index];
        resetTransform();
      }

      function openFromTrigger(trigger){
        const joined = trigger.dataset.imageUrls || "";
        images = joined ? joined.split("||") : [];
        index = parseInt(trigger.dataset.imageIndex || "0", 10);
        if(Number.isNaN(index) || index < 0) index = 0;
        if(index > images.length - 1) index = images.length - 1;
        renderImage();
      }

      function nextImage(){
        if(index >= images.length - 1) return;
        index += 1;
        renderImage();
      }

      function prevImage(){
        if(index <= 0) return;
        index -= 1;
        renderImage();
      }

      function zoomBy(step){
        scale = clampScale(scale + step);
        if(scale === 1){
          translateX = 0;
          translateY = 0;
        }
        applyTransform();
      }

      function distanceBetweenTouches(touchA, touchB){
        const dx = touchA.clientX - touchB.clientX;
        const dy = touchA.clientY - touchB.clientY;
        return Math.sqrt(dx * dx + dy * dy);
      }

      document.addEventListener("click", function(event){
        const trigger = event.target.closest("[data-community-image-viewer]");
        if(!trigger) return;
        openFromTrigger(trigger);
      }, { passive: true });

      prevButton.addEventListener("click", prevImage);
      nextButton.addEventListener("click", nextImage);
      zoomInButton.addEventListener("click", function(){ zoomBy(0.25); });
      zoomOutButton.addEventListener("click", function(){ zoomBy(-0.25); });
      zoomResetButton.addEventListener("click", resetTransform);

      stage.addEventListener("wheel", function(event){
        event.preventDefault();
        zoomBy(event.deltaY < 0 ? 0.2 : -0.2);
      }, { passive: false });

      stage.addEventListener("mousedown", function(event){
        if(scale <= 1) return;
        dragging = true;
        stage.classList.add("dragging");
        lastPointerX = event.clientX;
        lastPointerY = event.clientY;
      });

      window.addEventListener("mousemove", function(event){
        if(!dragging || scale <= 1) return;
        translateX += event.clientX - lastPointerX;
        translateY += event.clientY - lastPointerY;
        lastPointerX = event.clientX;
        lastPointerY = event.clientY;
        applyTransform();
      });

      window.addEventListener("mouseup", function(){
        dragging = false;
        stage.classList.remove("dragging");
      });

      stage.addEventListener("touchstart", function(event){
        if(event.touches.length === 1){
          lastPointerX = event.touches[0].clientX;
          lastPointerY = event.touches[0].clientY;
        } else if(event.touches.length === 2){
          pinchStartDistance = distanceBetweenTouches(event.touches[0], event.touches[1]);
          pinchStartScale = scale;
        }
      }, { passive: true });

      stage.addEventListener("touchmove", function(event){
        if(event.touches.length === 2){
          event.preventDefault();
          const newDistance = distanceBetweenTouches(event.touches[0], event.touches[1]);
          if(pinchStartDistance){
            scale = clampScale((newDistance / pinchStartDistance) * pinchStartScale);
            if(scale === 1){
              translateX = 0;
              translateY = 0;
            }
            applyTransform();
          }
        } else if(event.touches.length === 1 && scale > 1){
          event.preventDefault();
          const touch = event.touches[0];
          translateX += touch.clientX - lastPointerX;
          translateY += touch.clientY - lastPointerY;
          lastPointerX = touch.clientX;
          lastPointerY = touch.clientY;
          applyTransform();
        }
      }, { passive: false });

      stage.addEventListener("touchend", function(event){
        if(event.touches.length < 2){
          pinchStartDistance = null;
        }
        if(event.touches.length === 1){
          lastPointerX = event.touches[0].clientX;
          lastPointerY = event.touches[0].clientY;
        }
      }, { passive: true });

      modalEl.addEventListener("hidden.bs.modal", function(){
        images = [];
        index = 0;
        image.src = "";
        resetTransform();
      });
    }

    // Runs all community page JavaScript after the normal page load or Turbo navigation
    function initCommunityPage(){
      initCommunityCreateForm();
      initReactionModals();
      initViewMoreComments();
      initAjaxReactionForms();
      initImageViewer();
    }

    document.addEventListener("turbo:load", initCommunityPage);
    document.addEventListener("DOMContentLoaded", initCommunityPage);
  })();
</script>