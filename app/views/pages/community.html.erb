<%
second_row_channel_values = %w[card_shows content_creators app_suggestions application_problems]
selected_channel_value = @selected_channel.presence || "general"
first_row_channels = @community_channels.reject { |_, value| second_row_channel_values.include?(value) }
second_row_channels = @community_channels.select { |_, value| second_row_channel_values.include?(value) }
%>

<div class="community-page py-3">
  <style>
    .community-page{max-width:920px;margin:0 auto}.community-card{background:#fff;border:1px solid #e5e7eb;border-radius:1.25rem;box-shadow:0 12px 30px rgba(15,23,42,.06)}.community-header{margin-bottom:1rem}.community-title{margin:0;font-size:1.7rem;line-height:1.05;font-weight:800}.community-subtitle{margin:.35rem 0 0;color:#6b7280;font-size:.95rem}.community-channel-groups{display:grid;gap:.45rem;margin-bottom:1.15rem}.community-channels-top{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:.35rem}.community-channels-bottom{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.35rem}.community-page .community-channel-pill{display:flex!important;align-items:center!important;justify-content:center!important;min-width:0!important;min-height:30px!important;padding:.32rem .42rem!important;border-radius:999px!important;background:var(--pv-button-bg)!important;border:1px solid var(--pv-button-border)!important;color:var(--pv-button-text)!important;text-decoration:none!important;font-size:.7rem!important;font-weight:700!important;white-space:nowrap!important;line-height:1!important;box-shadow:none!important;filter:none!important;outline:0!important}.community-page .community-channel-pill:not(.active),.community-page .community-channel-pill:not(.active):hover,.community-page .community-channel-pill:not(.active):focus,.community-page .community-channel-pill:not(.active):active{background:var(--pv-button-bg)!important;border-color:var(--pv-button-border)!important;color:var(--pv-button-text)!important}.community-page .community-channel-pill.active,.community-page .community-channel-pill.active:hover,.community-page .community-channel-pill.active:focus,.community-page .community-channel-pill.active:active{background:var(--pv-active-bg)!important;border-color:var(--pv-active-border)!important;color:var(--pv-active-text)!important}:root[data-pv-theme="dark"] body .community-page .community-channel-pill{background:#000!important;border-color:#d4af37!impor