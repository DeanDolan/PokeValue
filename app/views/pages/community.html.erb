lex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;margin-bottom:.85rem}.community-viewer-controls{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}.community-viewer-counter{color:#e5e7eb;font-weight:700}.community-viewer-btn{border-radius:999px}.community-viewer-nav{position:absolute;top:50%;transform:translateY(-50%);z-index:4}.community-viewer-prev{left:.75rem}.community-viewer-next{right:.75rem}@media(max-width:900px){.community-channels-top,.community-channels-bottom{grid-template-columns:repeat(4,minmax(0,1fr))}}@media(max-width:640px){.community-create-bottom{align-items:stretch}.community-post-action,.community-post-btn{width:100%}.community-post-btn{max-width:none;flex:1 1 auto}.community-viewer-stage{height:70vh}.community-channels-top,.community-channels-bottom{grid-template-columns:repeat(2,minmax(0,1fr));gap:.5rem}.community-post-head{flex-direction:column}.community-post-actions{width:100%;justify-content:flex-start}.community-media-grid-2,.community-media-grid-4{grid-template-columns:1fr}.community-media-grid-3{grid-template-columns:1fr;grid-template-rows:none}.community-media-grid-3 .community-media-item-1{grid-row:auto;height:220px}.community-media-grid-1 .community-media-item,.community-media-grid-2 .community-media-item,.community-media-grid-3 .community-media-item,.community-media-grid-4 .community-media-item{height:220px}.community-comment-form{flex-direction:column;align-items:stretch}.community-reaction-person{align-items:flex-start;flex-direction:column}}
  </style>

  <div class="community-header">
    <h1 class="community-title">Community Channels</h1>
    <p class="community-subtitle">Post in channels, share images, react, and comment on posts (without spamming).</p>
  </div>

  <div class="community-channel-groups">
    <div class="community-channels-top">
      <% first_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", ("active" if selected_channel_value == value)].compact.join(" ") %>
      <% end %>
    </div>
    <div class="community-channels-bottom">
      <% second_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", ("active" if selected_channel_value == value)].compact.join(" ") %>
      <% end %>
    </div>
  </div>

  <section class="community-card community-create-card">
    <% if current_user %>
      <%= form_with model: @community_post, url: community_posts_path, local: true do |f| %>
        <%= f.hidden_field :channel, value: selected_channel_value %>
        <div class="community-create-label">Post in <%= CommunityPost.channel_label(selected_channel_value) %></div>
        <%= f.text_area :body, class: "community-create-textarea", placeholder: "Write your post for #{CommunityPost.channel_label(selected_channel_value)}...", maxlength: CommunityPost::MAX_BODY_LENGTH, rows: 5 %>

        <div class="community-create-bottom">
          <div class="community-file-wrap">
            <div class="community-file-control">
              <label for="community-post-images-input" class="community-file-trigger">Browse</label>
              <span id="community-post-images-status" class="community-file-status">No images selected.</span>
              <%= f.file_field :images, multiple: true, accept: "image/png,image/jpeg,image/jpg,image/webp,image/gif", class: "community-file-input", id: "community-post-images-input" %>
            </div>

            <div class="community-hint">You can keep selecting more images and they will be added. Up to 10 images. Max 2000 characters.</div>

            <div id="community-selected-files" class="community-selected-files">
              <div class="community-selected-files-top">
                <div id="community-selected-files-title" class="community-selected-files-title"></div>
                <button id="community-clear-selected-files" type="button" class="btn btn-sm btn-outline-secondary">Clear images</button>
              </div>
              <div id="community-selected-grid" class="community-selected-grid"></div>
            </div>
          </div>

          <div class="community-post-action">
            <%= f.submit "Post", class: "btn btn-dark community-post-btn" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="community-login-prompt">
        <div class="community-login-copy">
          <h2>Join the conversation</h2>
          <p>Log in to create posts, react, and comment in the community channels.</p>
        </div>
        <button class="btn btn-dark" type="button" data-bs-toggle="modal" data-bs-target="#authModal">Login / Register</button>
      </div>
    <% end %>
  </section>

  <section class="community-feed">
    <% if @community_posts.any? %>
      <%= render partial: "community_posts/post", collection: @community_posts, as: :post, locals: { selected_channel: selected_channel_value } %>
    <% else %>
      <div class="community-card community-empty">No posts yet in <strong><%= CommunityPost.channel_label(selected_channel_value) %></strong>.</div>
    <% end %>
  </section>
</div>

<div class="modal fade" id="communityImageViewerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen-sm-down modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content bg-dark text-white border-0">
      <div class="modal-header border-0 pb-0">
        <div class="community-viewer-toolbar w-100">
          <div id="community-image-viewer-counter" class="community-viewer-counter">1 / 1</div>
          <div class="community-viewer-controls">
            <button id="community-image-zoom-out" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">-</button>
            <button id="community-image-zoom-reset" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">Reset</button>
            <button id="community-image-zoom-in" type="button" class="btn btn-outline-light btn-sm community-viewer-btn">+</button>
            <button type="button" class="btn btn-outline-light btn-sm community-viewer-btn" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
      <div class="modal-body pt-2">
        <div id="community-image-viewer-stage" class="community-viewer-stage">
          <button id="community-image-prev" type="button" class="btn btn-outline-light community-viewer-nav community-viewer-prev">‹</button>
          <img id="community-image-viewer-image" class="community-viewer-image" src="" alt="Post image" draggable="false">
          <button id="community-image-next" type="button" class="btn btn-outline-light community-viewer-nav community-viewer-next">›</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    function keyForFile(file){return [file.name,file.size,file.lastModified].join("__")}
    function escapeHtml(value){return String(value||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;")}
    function flagEmoji(countryCode){const code=(countryCode||"").toUpperCase();if(!/^[A-Z]{2}$/.test(code))return "";return code.replace(/./g,function(char){return String.fromCodePoint(127397+char.charCodeAt(0))})}
    function badgeHtml(badge){return '<span class="' + (badge==="Admin" ? "community-badge community-badge-admin" : "community-badge community-badge-default") + '">' + escapeHtml(badge) + '</span>'}
    function reactorRowHtml(reactor,emoji,label){const badges=(reactor.badges||[]).map(badgeHtml).join("");const flag=flagEmoji(reactor.country_code);return '<div class="community-reaction-person" data-kind="'+escapeHtml(reactor.kind)+'"><div class="community-reaction-person-left"><span class="community-reaction-person-name">'+escapeHtml(reactor.username)+'</span>'+(flag?'<span class="community-flag">'+flag+'</span>':'')+badges+'</div><div class="community-reaction-kind"><span>'+escapeHtml(emoji)+'</span><span>'+escapeHtml(label)+'</span></div></div>'}

    function initCommunityCreateForm(){
      const input=document.getElementById("community-post-images-input"),status=document.getElementById("community-post-images-status"),wrap=document.getElementById("community-selected-files"),title=document.getElementById("community-selected-files-title"),grid=document.getElementById("community-selected-grid"),clearButton=document.getElementById("community-clear-selected-files")
      if(!input||!status||!wrap||!title||!grid||!clearButton||input.dataset.communityImagesReady==="true")return
      input.dataset.communityImagesReady="true"
      let storedFiles=[]
      function syncInput(){const dt=new DataTransfer();storedFiles.forEach(function(file){dt.items.add(file)});input.files=dt.files}
      function render(){
        grid.innerHTML=""
        if(storedFiles.length===0){wrap.classList.remove("active");title.textContent="";status.textContent="No images selected.";return}
        wrap.classList.add("active")
        title.textContent=storedFiles.length+" image"+(storedFiles.length===1?"":"s")+" selected"
        status.textContent=title.textContent
        storedFiles.forEach(function(file){
          const item=document.createElement("div"),img=document.createElement("img"),remove=document.createElement("button"),key=keyForFile(file)
          item.className="community-selected-item";item.dataset.fileKey=key
          img.className="community-selected-thumb";img.alt=file.name;img.src=URL.createObjectURL(file)
          remove.type="button";remove.className="community-selected-remove";remove.dataset.fileKey=key;remove.textContent="×"
          item.appendChild(img);item.appendChild(remove);grid.appendChild(item)
        })
      }
      input.addEventListener("change",function(){
        const incoming=Array.from(input.files||[])
        if(!incoming.length)return
        const map=new Map(storedFiles.map(function(file){return [keyForFile(file),file]}))
        incoming.forEach(function(file){map.set(keyForFile(file),file)})
        storedFiles=Array.from(map.values()).slice(0,10)
        syncInput();render()
      })
      grid.addEventListener("click",function(event){
        const button=event.target.closest(".community-selected-remove")
        if(!button)return
        storedFiles=storedFiles.filter(function(file){return keyForFile(file)!==button.dataset.fileKey})
        syncInput();render()
      })
      clearButton.addEventListener("click",function(){storedFiles=[];syncInput();render()})
      render()
    }

    function initReactionModals(){
      if(document.body.dataset.communityReactionModalsReady==="true")return
      document.body.dataset.communityReactionModalsReady="true"
      document.addEventListener("click",function(event){
        const filterButton=event.target.closest(".community-reactions-filter")
        if(!filterButton)return
        const modalBody=filterButton.closest(".community-reactions-modal-body")
        if(!modalBody)return
        const kind=filterButton.dataset.kind||"all"
        modalBody.querySelectorAll(".community-reactions-filter").forEach(function(button){button.classList.remove("active")})
        filterButton.classList.add("active")
        modalBody.querySelectorAll(".community-reaction-person").forEach(function(row){row.style.display=(kind==="all"||row.dataset.kind===kind)?"":"none"})
        const emptyState=modalBody.querySelector(".community-reactions-empty-filter")
        if(emptyState)emptyState.style.display=Array.from(modalBody.querySelectorAll(".community-reaction-person")).some(function(row){return row.style.display!=="none"})?"none":""
      },{passive:true})
    }

    function updatePostReactionUi(postId,counts,totalReactions,currentReaction,reactors){
      document.querySelectorAll('.community-post-react-form[data-community-post-id="'+postId+'"]').forEach(function(form){
        const button=form.querySelector("[data-post-reaction-kind]")
        if(!button)return
        const kind=button.dataset.postReactionKind,count=Number(counts[kind]||0),countSpan=button.querySelector("[data-post-reaction-count]")
        button.classList.toggle("active",currentReaction===kind)
        if(countSpan)countSpan.textContent=count>0?String(count):""
      })
      const totalLink=document.querySelector('[data-community-post-total-reactions][data-post-id="'+postId+'"]')
      if(totalLink)totalLink.textContent="Reactions ("+totalReactions+")"
      const pillsWrap=document.querySelector('[data-community-post-summary-emojis][data-post-id="'+postId+'"]')
      if(pillsWrap){
        pillsWrap.innerHTML=""
        document.querySelectorAll('.community-post-react-form[data-community-post-id="'+postId+'"]').forEach(function(form){
          const button=form.querySelector("[data-post-reaction-kind]")
          if(!button)return
          const kind=button.dataset.postReactionKind,count=Number(counts[kind]||0)
          if(count<=0)return
          const pill=document.createElement("span")
          pill.className="community-social-emoji-pill"
          pill.textContent=button.dataset.postReactionEmoji+" "+count
          pillsWrap.appendChild(pill)
        })
      }
      updateReactionModal(postId,null,counts,totalReactions,reactors,false)
    }

    function updateCommentReactionUi(commentId,counts,totalReactions,currentReaction,reactors){
      document.querySelectorAll('.community-comment-react-form[data-community-comment-id="'+commentId+'"]').forEach(function(form){
        const button=form.querySelector("[data-comment-reaction-kind]")
        if(!button)return
        const kind=button.dataset.commentReactionKind,count=Number(counts[kind]||0),countSpan=button.querySelector("[data-comment-reaction-count]")
        button.classList.toggle("active",currentReaction===kind)
        if(countSpan)countSpan.textContent=count>0?String(count):""
      })
      const totalLink=document.querySelector('[data-community-comment-total-reactions][data-comment-id="'+commentId+'"]')
      if(totalLink)totalLink.textContent="👍 "+totalReactions
      updateReactionModal(null,commentId,counts,totalReactions,reactors,true)
    }

    function updateReactionModal(postId,commentId,counts,totalReactions,reactors,isComment){
      const modalBody=document.querySelector(isComment ? '.community-reactions-modal-body[data-community-comment-id="'+commentId+'"]' : '.community-reactions-modal-body[data-community-post-id="'+postId+'"]')
      if(!modalBody)return
      modalBody.querySelectorAll(".community-reactions-filter").forEach(function(filter){
        const kind=filter.dataset.kind||"all"
        filter.textContent=kind==="all" ? "All ("+totalReactions+")" : (filter.dataset.emoji||"")+" "+Number(counts[kind]||0)
      })
      const list=modalBody.querySelector(isComment ? "[data-community-comment-reactor-list]" : "[data-community-reactor-list]")
      if(list){
        list.innerHTML=""
        if(!(reactors||[]).length){
          list.innerHTML='<div class="text-muted">No reactions yet.</div>'
        }else{
          reactors.forEach(function(reactor){
            const sourceButton=document.querySelector((isComment ? '.community-comment-react-form[data-community-comment-id="'+commentId+'"] [data-comment-reaction-kind="' : '.community-post-react-form[data-community-post-id="'+postId+'"] [data-post-reaction-kind="')+reactor.kind+'"]')
            const emoji=sourceButton ? (isComment ? sourceButton.dataset.commentReactionEmoji : sourceButton.dataset.postReactionEmoji) : ""
            const label=sourceButton ? (isComment ? sourceButton.dataset.commentReactionLabel : sourceButton.dataset.postReactionLabel) : reactor.kind
            list.insertAdjacentHTML("beforeend",reactorRowHtml(reactor,emoji,label))
          })
        }
      }
      const active=modalBody.querySelector(".community-reactions-filter.active")
      if(active)active.click()
    }

    function submitReactionForm(form,onSuccess){
      const token=document.querySelector('meta[name="csrf-token"]')?.getAttribute("content"),submitButton=form.querySelector("button[type='submit']")
      if(submitButton)submitButton.disabled=true
      fetch(form.action,{method:"POST",headers:{"Accept":"application/json","X-CSRF-Token":token},body:new FormData(form),credentials:"same-origin"})
        .then(function(response){if(!response.ok)throw new Error("Request failed");return response.json()})
        .then(onSuccess)
        .catch(function(){})
        .finally(function(){if(submitButton)submitButton.disabled=false})
    }

    function initAjaxReactionForms(){
      if(document.body.dataset.communityAjaxReactionReady==="true")return
      document.body.dataset.communityAjaxReactionReady="true"
      document.addEventListener("submit",function(event){
        const postForm=event.target.closest(".community-post-react-form"),commentForm=event.target.closest(".community-comment-react-form")
        if(postForm){
          event.preventDefault()
          submitReactionForm(postForm,function(data){updatePostReactionUi(data.post_id,data.counts||{},Number(data.total_reactions||0),data.current_reaction||null,data.reactors||[])})
        }else if(commentForm){
          event.preventDefault()
          submitReactionForm(commentForm,function(data){updateCommentReactionUi(data.comment_id,data.counts||{},Number(data.total_reactions||0),data.current_reaction||null,data.reactors||[])})
        }
      })
    }

    function visibleCommentRows(container){return Array.from(container.querySelectorAll("[data-community-hidden-comment]")).filter(function(row){return !row.classList.contains("d-none")})}
    function hiddenCommentRows(container){return Array.from(container.querySelectorAll('[data-community-hidden-comment="true"].d-none'))}
    function revealNextComments(container,amount){
      hiddenCommentRows(container).slice(0,amount).forEach(function(row){row.classList.remove("d-none")})
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.toggle("d-none",hiddenCommentRows(container).length===0)
    }
    function closeComments(container){
      container.classList.add("d-none")
      container.dataset.open="0"
      container.querySelectorAll("[data-community-hidden-comment]").forEach(function(row){row.classList.add("d-none")})
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.add("d-none")
    }
    function openComments(container){
      container.classList.remove("d-none")
      container.dataset.open="1"
      if(visibleCommentRows(container).length===0)revealNextComments(container,5)
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.toggle("d-none",hiddenCommentRows(container).length===0)
    }

    function initCommunityToggles(){
      if(document.body.dataset.communityTogglesReady==="true")return
      document.body.dataset.communityTogglesReady="true"
      document.addEventListener("click",function(event){
        const editButton=event.target.closest("[data-community-edit-toggle]"),cancelButton=event.target.closest("[data-community-edit-cancel]"),toggle=event.target.closest("[data-community-comments-toggle]"),more=event.target.closest("[data-community-comments-more]")
        if(editButton){
          const postId=editButton.dataset.communityEditToggle,form=document.querySelector('[data-community-edit-form="'+postId+'"]'),body=document.querySelector('[data-community-post-body="'+postId+'"]')
          if(!form)return
          form.classList.remove("d-none")
          if(body)body.classList.add("d-none")
          editButton.classList.add("d-none")
          return
        }
        if(cancelButton){
          const postId=cancelButton.dataset.communityEditCancel,form=document.querySelector('[data-community-edit-form="'+postId+'"]'),body=document.querySelector('[data-community-post-body="'+postId+'"]'),button=document.querySelector('[data-community-edit-toggle="'+postId+'"]')
          if(form)form.classList.add("d-none")
          if(body)body.classList.remove("d-none")
          if(button)button.classList.remove("d-none")
          return
        }
        if(toggle){
          const container=document.querySelector('[data-community-comments-container][data-post-id="'+toggle.dataset.communityCommentsToggle+'"]')
          if(container)container.dataset.open==="1"?closeComments(container):openComments(container)
          return
        }
        if(more){
          const container=document.querySelector('[data-community-comments-container][data-post-id="'+more.dataset.communityCommentsMore+'"]')
          if(container)revealNextComments(container,5)
        }
      })
    }

    function initImageViewer(){
      const modalEl=document.getElementById("communityImageViewerModal"),stage=document.getElementById("community-image-viewer-stage"),image=document.getElementById("community-image-viewer-image"),counter=document.getElementById("community-image-viewer-counter"),prevButton=document.getElementById("community-image-prev"),nextButton=document.getElementById("community-image-next"),zoomInButton=document.getElementById("community-image-zoom-in"),zoomOutButton=document.getElementById("community-image-zoom-out"),zoomResetButton=document.getElementById("community-image-zoom-reset")
      if(!modalEl||!stage||!image||!counter||!prevButton||!nextButton||!zoomInButton||!zoomOutButton||!zoomResetButton||modalEl.dataset.communityViewerReady==="true")return
      modalEl.dataset.communityViewerReady="true"
      let images=[],index=0,scale=1,translateX=0,translateY=0,dragging=false,lastPointerX=0,lastPointerY=0,pinchStartDistance=null,pinchStartScale=1
      function clampScale(value){return Math.max(1,Math.min(6,value))}
      function applyTransform(){
        image.style.transform="translate("+translateX+"px, "+translateY+"px) translate(-50%, -50%) scale("+scale+")"
        prevButton.style.display=images.length>1?"":"none"
        nextButton.style.display=images.length>1?"":"none"
        counter.textContent=images.length?(index+1)+" / "+images.length:"0 / 0"
      }
      function resetTransform(){scale=1;translateX=0;translateY=0;applyTransform()}
      function renderImage(){if(!images.length)return;image.src=images[index];resetTransform()}
      function openFromTrigger(trigger){
        images=(trigger.dataset.imageUrls||"").split("||").filter(Boolean)
        index=parseInt(trigger.dataset.imageIndex||"0",10)
        if(Number.isNaN(index)||index<0)index=0
        if(index>images.length-1)index=images.length-1
        renderImage()
      }
      function zoomBy(step){scale=clampScale(scale+step);if(scale===1){translateX=0;translateY=0}applyTransform()}
      function distanceBetweenTouches(a,b){const dx=a.clientX-b.clientX,dy=a.clientY-b.clientY;return Math.sqrt(dx*dx+dy*dy)}
      document.addEventListener("click",function(event){const trigger=event.target.closest("[data-community-image-viewer]");if(trigger)openFromTrigger(trigger)},{passive:true})
      prevButton.addEventListener("click",function(){if(index>0){index-=1;renderImage()}})
      nextButton.addEventListener("click",function(){if(index<images.length-1){index+=1;renderImage()}})
      zoomInButton.addEventListener("click",function(){zoomBy(.25)})
      zoomOutButton.addEventListener("click",function(){zoomBy(-.25)})
      zoomResetButton.addEventListener("click",resetTransform)
      stage.addEventListener("wheel",function(event){event.preventDefault();zoomBy(event.deltaY<0?.2:-.2)},{passive:false})
      stage.addEventListener("mousedown",function(event){if(scale<=1)return;dragging=true;stage.classList.add("dragging");lastPointerX=event.clientX;lastPointerY=event.clientY})
      window.addEventListener("mousemove",function(event){if(!dragging||scale<=1)return;translateX+=event.clientX-lastPointerX;translateY+=event.clientY-lastPointerY;lastPointerX=event.clientX;lastPointerY=event.clientY;applyTransform()})
      window.addEventListener("mouseup",function(){dragging=false;stage.classList.remove("dragging")})
      stage.addEventListener("touchstart",function(event){
        if(event.touches.length===1){lastPointerX=event.touches[0].clientX;lastPointerY=event.touches[0].clientY}
        if(event.touches.length===2){pinchStartDistance=distanceBetweenTouches(event.touches[0],event.touches[1]);pinchStartScale=scale}
      },{passive:true})
      stage.addEventListener("touchmove",function(event){
        if(event.touches.length===2){
          event.preventDefault()
          const newDistance=distanceBetweenTouches(event.touches[0],event.touches[1])
          if(pinchStartDistance){scale=clampScale((newDistance/pinchStartDistance)*pinchStartScale);if(scale===1){translateX=0;translateY=0}applyTransform()}
        }else if(event.touches.length===1&&scale>1){
          event.preventDefault()
          const touch=event.touches[0]
          translateX+=touch.clientX-lastPointerX
          translateY+=touch.clientY-lastPointerY
          lastPointerX=touch.clientX
          lastPointerY=touch.clientY
          applyTransform()
        }
      },{passive:false})
      stage.addEventListener("touchend",function(event){if(event.touches.length<2)pinchStartDistance=null;if(event.touches.length===1){lastPointerX=event.touches[0].clientX;lastPointerY=event.touches[0].clientY}},{passive:true})
      modalEl.addEventListener("hidden.bs.modal",function(){images=[];index=0;image.src="";resetTransform()})
    }

    function initCommunityPage(){
      initCommunityCreateForm()
      initReactionModals()
      initAjaxReactionForms()
      initCommunityToggles()
      initImageViewer()
    }

    document.addEventListener("turbo:load",initCommunityPage)
    document.addEventListener("DOMContentLoaded",initCommunityPage)
  })()
</script>