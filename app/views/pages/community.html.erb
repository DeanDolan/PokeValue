<%
second_row_channel_values = %w[card_shows content_creators app_suggestions application_problems]
selected_channel_value = @selected_channel.presence || "general"
first_row_channels = @community_channels.reject { |_, value| second_row_channel_values.include?(value) }
second_row_channels = @community_channels.select { |_, value| second_row_channel_values.include?(value) }
%>

<div class="community-page py-3">
  <style>
    .community-page{max-width:920px;margin:0 auto}.community-card{background:#fff;border:1px solid #e5e7eb;border-radius:1.25rem;box-shadow:0 12px 30px rgba(15,23,42,.06)}.community-header{margin-bottom:1rem}.community-title{margin:0;font-size:1.7rem;line-height:1.05;font-weight:800}.community-subtitle{margin:.35rem 0 0;color:#6b7280;font-size:.95rem}.community-channel-groups{display:grid;gap:.45rem;margin-bottom:1.15rem}.community-channels-top{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:.35rem}.community-channels-bottom{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.35rem}.community-page .community-channel-pill{display:flex!important;align-items:center!important;justify-content:center!important;min-width:0!important;min-height:30px!important;padding:.32rem .42rem!important;border-radius:999px!important;background:var(--pv-button-bg)!important;border:1px solid var(--pv-button-border)!important;color:var(--pv-button-text)!important;text-decoration:none!important;font-size:.7rem!important;font-weight:700!important;white-space:nowrap!important;line-height:1!important;box-shadow:none!important;filter:none!important;outline:0!important}.community-page .community-channel-pill:not(.active),.community-page .community-channel-pill:not(.active):hover,.community-page .community-channel-pill:not(.active):focus,.community-page .community-channel-pill:not(.active):active{background:var(--pv-button-bg)!important;border-color:var(--pv-button-border)!important;color:var(--pv-button-text)!important}.community-page .community-channel-pill.active,.community-page .community-channel-pill.active:hover,.community-page .community-channel-pill.active:focus,.community-page .community-channel-pill.active:active{background:var(--pv-active-bg)!important;border-color:var(--pv-active-border)!important;color:var(--pv-active-text)!important}:root[data-pv-theme="dark"] body .community-page .community-channel-pill{background:#000!important;border-color:#d4af37!important;color:#d4af37!important}:root[data-pv-theme="dark"] body .community-page .community-channel-pill.active{background:#d4af37!important;border-color:#d4af37!important;color:#000!important}:root[data-pv-theme="light"] body .community-page .community-channel-pill:not(.active){background:#fff!important;border-color:#000!important;color:#000!important}:root[data-pv-theme="light"] body .community-page .community-channel-pill.active{background:#000!important;border-color:#000!important;color:#fff!important}.community-create-card,.community-post-card{padding:1rem}.community-create-label{font-size:.8rem;font-weight:700;color:#4b5563;margin-bottom:.45rem}.community-create-textarea,.community-edit-textarea{width:100%;min-height:120px;border:1px solid #d1d5db;border-radius:1rem;padding:.9rem 1rem;font-size:.98rem;resize:vertical;outline:none;background:#fff;color:#111827}.community-create-textarea:focus,.community-edit-textarea:focus{border-color:#111827;box-shadow:0 0 0 3px rgba(17,24,39,.08)}.community-create-bottom{display:flex;gap:1rem;justify-content:flex-end;align-items:flex-start;flex-wrap:wrap;margin-top:.9rem}.community-hint,.community-empty,.community-login-copy p,.community-time,.community-comment-time,.community-login-note,.community-reactions-empty-filter{color:#6b7280}.community-hint{font-size:.78rem;margin-top:.4rem;line-height:1.35}.community-post-action{display:flex;align-items:flex-start}.community-post-btn{width:150px;height:42px;min-width:150px;max-width:150px;border-radius:1rem;font-weight:800;padding:0 1.25rem;display:inline-flex;align-items:center;justify-content:center;flex:0 0 150px}.community-login-prompt{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}.community-login-copy h2{margin:0 0 .25rem;font-size:1.1rem}.community-empty{padding:1.3rem;text-align:center}.community-feed{display:grid;gap:1rem}.community-post-head,.community-social-summary,.community-user-line,.community-post-actions,.community-reactions-row,.community-comment-social,.community-comment-reactions-row,.community-reactions-filter-row,.community-reaction-person-left,.community-reaction-kind{display:flex;align-items:center;gap:.45rem;flex-wrap:wrap}.community-post-head{align-items:flex-start;justify-content:space-between;gap:.75rem}.community-username,.community-comment-user,.community-reaction-person-name{font-weight:800;color:#111827}.community-flag{font-size:1rem;line-height:1}.community-badge{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:.18rem .5rem;font-size:.72rem;font-weight:800}.community-badge-admin{background:rgba(220,53,69,.12);border:1px solid rgba(220,53,69,.35);color:#dc3545}.community-badge-default{background:#f3f4f6;border:1px solid #e5e7eb;color:#374151}.community-time{font-size:.8rem;margin-top:.15rem}.community-post-actions{flex-wrap:nowrap}.community-edit-btn,.community-delete-btn{border-radius:999px}.community-post-body{margin-top:.8rem;color:#111827;font-size:.97rem;line-height:1.55;word-break:break-word}.community-post-body p:last-child,.community-comment-body p:last-child{margin-bottom:0}.community-edit-form-wrap{margin-top:.85rem;padding:.85rem;border:1px solid #e5e7eb;border-radius:1rem;background:#f8fafc}.community-edit-textarea{min-height:110px;font-size:.95rem;padding:.8rem .9rem}.community-edit-actions{display:flex;justify-content:flex-end;gap:.5rem;margin-top:.7rem;flex-wrap:wrap}.community-social-summary{justify-content:flex-start;gap:.9rem;margin-top:.95rem;padding-top:.85rem;border-top:1px solid #f3f4f6}.community-social-link,.community-comment-summary-link{border:none;background:none;padding:0;color:#475569;font-weight:700}.community-social-link{font-size:.9rem}.community-comment-summary-link{font-size:.82rem}.community-social-link:hover,.community-comment-summary-link:hover{color:#111827}.community-social-emojis{display:flex;align-items:center;gap:.35rem;flex-wrap:wrap}.community-social-emoji-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.28rem .55rem;border-radius:999px;background:transparent;border:1px solid #e5e7eb;font-size:.84rem;font-weight:700;color:#111827}.community-reactions-row{gap:.45rem;margin-top:.85rem}.community-post-react-form,.community-comment-react-form{display:inline-block;margin:0}.community-react-btn,.community-comment-react-btn,.community-reactions-filter{border:1px solid #d1d5db;background:transparent;color:#111827;border-radius:999px;font-weight:700;display:inline-flex;align-items:center;box-shadow:none}.community-react-btn{position:relative;padding:.45rem .75rem;font-size:.84rem;gap:.35rem}.community-comment-react-btn{position:relative;padding:.28rem .5rem;font-size:.8rem;gap:.28rem}.community-react-btn.active,.community-comment-react-btn.active{background:transparent;color:#111827;border-color:#111827;box-shadow:none}.community-react-btn:hover::after,.community-comment-react-btn:hover::after{content:attr(data-post-reaction-label);position:absolute;left:50%;bottom:calc(100% + 8px);transform:translateX(-50%);background:#111827;color:#fff;padding:.32rem .55rem;border-radius:.55rem;font-size:.74rem;font-weight:700;line-height:1;white-space:nowrap;pointer-events:none;z-index:20}.community-comment-react-btn:hover::after{content:attr(data-comment-reaction-label);font-size:.72rem}.community-comment-compose{margin-top:.85rem}.community-comment-form{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap}.community-comment-input{flex:1 1 260px;border-radius:999px}.community-comments-wrap{margin-top:.85rem;padding-top:.85rem;border-top:1px solid #f3f4f6;display:grid;gap:.75rem}.community-view-more-comments{margin-top:.15rem}.community-comment-thread.depth-1{margin-left:1.25rem;padding-left:.9rem;border-left:2px solid #e5e7eb}.community-comment-thread.depth-2{margin-left:2.25rem;padding-left:.9rem;border-left:2px solid #e5e7eb}.community-comment-card{padding:.7rem .8rem;background:#f8fafc;border:1px solid #e5e7eb;border-radius:1rem}.community-comment-line{display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;margin-bottom:.2rem}.community-comment-body{font-size:.9rem;color:#1f2937;line-height:1.45;word-break:break-word}.community-comment-social{gap:.8rem;margin-top:.5rem}.community-comment-reactions-row{gap:.4rem;margin-top:.55rem}.community-reply-form-wrap{margin-top:.65rem}.community-replies-wrap{display:grid;gap:.55rem;margin-top:.7rem}.community-login-note{margin-top:.7rem;font-size:.84rem}.community-reactions-filter-row{gap:.55rem;margin-bottom:.9rem}.community-reactions-filter{background:#fff;padding:.42rem .75rem;font-size:.84rem}.community-reactions-filter.active{background:#111827;color:#fff;border-color:#111827}.community-reaction-people{display:grid;gap:.55rem}.community-reaction-person{display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.7rem .85rem;border:1px solid #e5e7eb;border-radius:1rem;background:#f8fafc}.community-reaction-kind{font-size:.9rem;font-weight:800;color:#111827}.community-reactions-empty-filter{display:none;padding:.4rem 0}@media(max-width:900px){.community-channels-top,.community-channels-bottom{grid-template-columns:repeat(4,minmax(0,1fr))}}@media(max-width:640px){.community-create-bottom{align-items:stretch}.community-post-action,.community-post-btn{width:100%}.community-post-btn{max-width:none;flex:1 1 auto}.community-channels-top,.community-channels-bottom{grid-template-columns:repeat(2,minmax(0,1fr));gap:.5rem}.community-post-head{flex-direction:column}.community-post-actions{width:100%;justify-content:flex-start}.community-comment-form{flex-direction:column;align-items:stretch}.community-reaction-person{align-items:flex-start;flex-direction:column}}
  </style>

  <div class="community-header">
    <h1 class="community-title">Community Channels</h1>
    <p class="community-subtitle">Post in channels, react, and comment on posts without spamming.</p>
  </div>

  <div class="community-channel-groups">
    <div class="community-channels-top">
      <% first_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", ("active" if selected_channel_value == value)].compact.join(" ") %>
      <% end %>
    </div>
    <div class="community-channels-bottom">
      <% second_row_channels.each do |label, value| %>
        <%= link_to label, community_path(channel: value), class: ["community-channel-pill", ("active" if selected_channel_value == value)].compact.join(" ") %>
      <% end %>
    </div>
  </div>

  <section class="community-card community-create-card">
    <% if current_user %>
      <%= form_with model: @community_post, url: community_posts_path, local: true do |f| %>
        <%= f.hidden_field :channel, value: selected_channel_value %>
        <div class="community-create-label">Post in <%= CommunityPost.channel_label(selected_channel_value) %></div>
        <%= f.text_area :body, class: "community-create-textarea", placeholder: "Write your post for #{CommunityPost.channel_label(selected_channel_value)}...", maxlength: CommunityPost::MAX_BODY_LENGTH, rows: 5, required: true %>

        <div class="community-create-bottom">
          <div class="community-post-action">
            <%= f.submit "Post", class: "btn btn-dark community-post-btn" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="community-login-prompt">
        <div class="community-login-copy">
          <h2>Join the conversation</h2>
          <p>Log in to create posts, react, and comment in the community channels.</p>
        </div>
        <button class="btn btn-dark" type="button" data-bs-toggle="modal" data-bs-target="#authModal">Login / Register</button>
      </div>
    <% end %>
  </section>

  <section class="community-feed">
    <% if @community_posts.any? %>
      <%= render partial: "community_posts/post", collection: @community_posts, as: :post, locals: { selected_channel: selected_channel_value } %>
    <% else %>
      <div class="community-card community-empty">No posts yet in <strong><%= CommunityPost.channel_label(selected_channel_value) %></strong>.</div>
    <% end %>
  </section>
</div>

<script>
  (function(){
    function escapeHtml(value){return String(value||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;")}
    function flagEmoji(countryCode){const code=(countryCode||"").toUpperCase();if(!/^[A-Z]{2}$/.test(code))return "";return code.replace(/./g,function(char){return String.fromCodePoint(127397+char.charCodeAt(0))})}
    function badgeHtml(badge){return '<span class="' + (badge==="Admin" ? "community-badge community-badge-admin" : "community-badge community-badge-default") + '">' + escapeHtml(badge) + '</span>'}
    function reactorRowHtml(reactor,emoji,label){const badges=(reactor.badges||[]).map(badgeHtml).join("");const flag=flagEmoji(reactor.country_code);return '<div class="community-reaction-person" data-kind="'+escapeHtml(reactor.kind)+'"><div class="community-reaction-person-left"><span class="community-reaction-person-name">'+escapeHtml(reactor.username)+'</span>'+(flag?'<span class="community-flag">'+flag+'</span>':'')+badges+'</div><div class="community-reaction-kind"><span>'+escapeHtml(emoji)+'</span><span>'+escapeHtml(label)+'</span></div></div>'}

    function initReactionModals(){
      if(document.body.dataset.communityReactionModalsReady==="true")return
      document.body.dataset.communityReactionModalsReady="true"
      document.addEventListener("click",function(event){
        const filterButton=event.target.closest(".community-reactions-filter")
        if(!filterButton)return
        const modalBody=filterButton.closest(".community-reactions-modal-body")
        if(!modalBody)return
        const kind=filterButton.dataset.kind||"all"
        modalBody.querySelectorAll(".community-reactions-filter").forEach(function(button){button.classList.remove("active")})
        filterButton.classList.add("active")
        modalBody.querySelectorAll(".community-reaction-person").forEach(function(row){row.style.display=(kind==="all"||row.dataset.kind===kind)?"":"none"})
        const emptyState=modalBody.querySelector(".community-reactions-empty-filter")
        if(emptyState)emptyState.style.display=Array.from(modalBody.querySelectorAll(".community-reaction-person")).some(function(row){return row.style.display!=="none"})?"none":""
      },{passive:true})
    }

    function updatePostReactionUi(postId,counts,totalReactions,currentReaction,reactors){
      document.querySelectorAll('.community-post-react-form[data-community-post-id="'+postId+'"]').forEach(function(form){
        const button=form.querySelector("[data-post-reaction-kind]")
        if(!button)return
        const kind=button.dataset.postReactionKind,count=Number(counts[kind]||0),countSpan=button.querySelector("[data-post-reaction-count]")
        button.classList.toggle("active",currentReaction===kind)
        if(countSpan)countSpan.textContent=count>0?String(count):""
      })
      const totalLink=document.querySelector('[data-community-post-total-reactions][data-post-id="'+postId+'"]')
      if(totalLink)totalLink.textContent="Reactions ("+totalReactions+")"
      const pillsWrap=document.querySelector('[data-community-post-summary-emojis][data-post-id="'+postId+'"]')
      if(pillsWrap){
        pillsWrap.innerHTML=""
        document.querySelectorAll('.community-post-react-form[data-community-post-id="'+postId+'"]').forEach(function(form){
          const button=form.querySelector("[data-post-reaction-kind]")
          if(!button)return
          const kind=button.dataset.postReactionKind,count=Number(counts[kind]||0)
          if(count<=0)return
          const pill=document.createElement("span")
          pill.className="community-social-emoji-pill"
          pill.textContent=button.dataset.postReactionEmoji+" "+count
          pillsWrap.appendChild(pill)
        })
      }
      updateReactionModal(postId,null,counts,totalReactions,reactors,false)
    }

    function updateCommentReactionUi(commentId,counts,totalReactions,currentReaction,reactors){
      document.querySelectorAll('.community-comment-react-form[data-community-comment-id="'+commentId+'"]').forEach(function(form){
        const button=form.querySelector("[data-comment-reaction-kind]")
        if(!button)return
        const kind=button.dataset.commentReactionKind,count=Number(counts[kind]||0),countSpan=button.querySelector("[data-comment-reaction-count]")
        button.classList.toggle("active",currentReaction===kind)
        if(countSpan)countSpan.textContent=count>0?String(count):""
      })
      const totalLink=document.querySelector('[data-community-comment-total-reactions][data-comment-id="'+commentId+'"]')
      if(totalLink)totalLink.textContent="👍 "+totalReactions
      updateReactionModal(null,commentId,counts,totalReactions,reactors,true)
    }

    function updateReactionModal(postId,commentId,counts,totalReactions,reactors,isComment){
      const modalBody=document.querySelector(isComment ? '.community-reactions-modal-body[data-community-comment-id="'+commentId+'"]' : '.community-reactions-modal-body[data-community-post-id="'+postId+'"]')
      if(!modalBody)return
      modalBody.querySelectorAll(".community-reactions-filter").forEach(function(filter){
        const kind=filter.dataset.kind||"all"
        filter.textContent=kind==="all" ? "All ("+totalReactions+")" : (filter.dataset.emoji||"")+" "+Number(counts[kind]||0)
      })
      const list=modalBody.querySelector(isComment ? "[data-community-comment-reactor-list]" : "[data-community-reactor-list]")
      if(list){
        list.innerHTML=""
        if(!(reactors||[]).length){
          list.innerHTML='<div class="text-muted">No reactions yet.</div>'
        }else{
          reactors.forEach(function(reactor){
            const sourceButton=document.querySelector((isComment ? '.community-comment-react-form[data-community-comment-id="'+commentId+'"] [data-comment-reaction-kind="' : '.community-post-react-form[data-community-post-id="'+postId+'"] [data-post-reaction-kind="')+reactor.kind+'"]')
            const emoji=sourceButton ? (isComment ? sourceButton.dataset.commentReactionEmoji : sourceButton.dataset.postReactionEmoji) : ""
            const label=sourceButton ? (isComment ? sourceButton.dataset.commentReactionLabel : sourceButton.dataset.postReactionLabel) : reactor.kind
            list.insertAdjacentHTML("beforeend",reactorRowHtml(reactor,emoji,label))
          })
        }
      }
      const active=modalBody.querySelector(".community-reactions-filter.active")
      if(active)active.click()
    }

    function submitReactionForm(form,onSuccess){
      const token=document.querySelector('meta[name="csrf-token"]')?.getAttribute("content"),submitButton=form.querySelector("button[type='submit']")
      if(submitButton)submitButton.disabled=true
      fetch(form.action,{method:"POST",headers:{"Accept":"application/json","X-CSRF-Token":token},body:new FormData(form),credentials:"same-origin"})
        .then(function(response){if(!response.ok)throw new Error("Request failed");return response.json()})
        .then(onSuccess)
        .catch(function(){})
        .finally(function(){if(submitButton)submitButton.disabled=false})
    }

    function initAjaxReactionForms(){
      if(document.body.dataset.communityAjaxReactionReady==="true")return
      document.body.dataset.communityAjaxReactionReady="true"
      document.addEventListener("submit",function(event){
        const postForm=event.target.closest(".community-post-react-form"),commentForm=event.target.closest(".community-comment-react-form")
        if(postForm){
          event.preventDefault()
          submitReactionForm(postForm,function(data){updatePostReactionUi(data.post_id,data.counts||{},Number(data.total_reactions||0),data.current_reaction||null,data.reactors||[])})
        }else if(commentForm){
          event.preventDefault()
          submitReactionForm(commentForm,function(data){updateCommentReactionUi(data.comment_id,data.counts||{},Number(data.total_reactions||0),data.current_reaction||null,data.reactors||[])})
        }
      })
    }

    function visibleCommentRows(container){return Array.from(container.querySelectorAll("[data-community-hidden-comment]")).filter(function(row){return !row.classList.contains("d-none")})}
    function hiddenCommentRows(container){return Array.from(container.querySelectorAll('[data-community-hidden-comment="true"].d-none'))}
    function revealNextComments(container,amount){
      hiddenCommentRows(container).slice(0,amount).forEach(function(row){row.classList.remove("d-none")})
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.toggle("d-none",hiddenCommentRows(container).length===0)
    }
    function closeComments(container){
      container.classList.add("d-none")
      container.dataset.open="0"
      container.querySelectorAll("[data-community-hidden-comment]").forEach(function(row){row.classList.add("d-none")})
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.add("d-none")
    }
    function openComments(container){
      container.classList.remove("d-none")
      container.dataset.open="1"
      if(visibleCommentRows(container).length===0)revealNextComments(container,5)
      const moreButton=container.querySelector("[data-community-comments-more]")
      if(moreButton)moreButton.classList.toggle("d-none",hiddenCommentRows(container).length===0)
    }

    function initCommunityToggles(){
      if(document.body.dataset.communityTogglesReady==="true")return
      document.body.dataset.communityTogglesReady="true"
      document.addEventListener("click",function(event){
        const editButton=event.target.closest("[data-community-edit-toggle]"),cancelButton=event.target.closest("[data-community-edit-cancel]"),toggle=event.target.closest("[data-community-comments-toggle]"),more=event.target.closest("[data-community-comments-more]")
        if(editButton){
          const postId=editButton.dataset.communityEditToggle,form=document.querySelector('[data-community-edit-form="'+postId+'"]'),body=document.querySelector('[data-community-post-body="'+postId+'"]')
          if(!form)return
          form.classList.remove("d-none")
          if(body)body.classList.add("d-none")
          editButton.classList.add("d-none")
          return
        }
        if(cancelButton){
          const postId=cancelButton.dataset.communityEditCancel,form=document.querySelector('[data-community-edit-form="'+postId+'"]'),body=document.querySelector('[data-community-post-body="'+postId+'"]'),button=document.querySelector('[data-community-edit-toggle="'+postId+'"]')
          if(form)form.classList.add("d-none")
          if(body)body.classList.remove("d-none")
          if(button)button.classList.remove("d-none")
          return
        }
        if(toggle){
          const container=document.querySelector('[data-community-comments-container][data-post-id="'+toggle.dataset.communityCommentsToggle+'"]')
          if(container)container.dataset.open==="1"?closeComments(container):openComments(container)
          return
        }
        if(more){
          const container=document.querySelector('[data-community-comments-container][data-post-id="'+more.dataset.communityCommentsMore+'"]')
          if(container)revealNextComments(container,5)
        }
      })
    }

    function initCommunityPage(){
      initReactionModals()
      initAjaxReactionForms()
      initCommunityToggles()
    }

    document.addEventListener("turbo:load",initCommunityPage)
    document.addEventListener("DOMContentLoaded",initCommunityPage)
  })()
</script>