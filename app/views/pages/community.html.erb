ctive{display:block}.community-selected-files-top{display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:.55rem}.community-selected-files-title{font-size:.8rem;font-weight:800;color:#374151}.community-selected-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));gap:.55rem}.community-selected-item{position:relative;border:1px solid #e5e7eb;border-radius:1rem;overflow:hidden;background:#f8fafc;aspect-ratio:1/1}.community-selected-thumb{width:100%;height:100%;object-fit:cover;display:block}.community-selected-remove{position:absolute;top:.35rem;right:.35rem;width:28px;height:28px;border:none;border-radius:999px;background:rgba(17,24,39,.75);color:#fff;font-size:1rem;line-height:1}.community-post-action{display:flex;align-items:flex-start}.community-post-btn{width:150px;height:42px;min-width:150px;max-width:150px;border-radius:1rem;font-weight:800;padding:0 1.25rem;display:inline-flex;align-items:center;justify-content:center;flex:0 0 150px}.community-login-prompt{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}.community-login-copy h2{margin:0 0 .25rem;font-size:1.1rem}.community-empty{padding:1.3rem;text-align:center}.community-feed{display:grid;gap:1rem}.community-post-head,.community-social-summary,.community-user-line,.community-post-actions,.community-reactions-row,.community-comment-social,.community-comment-reactions-row,.community-reactions-filter-row,.community-reaction-person-left,.community-reaction-kind{display:flex;align-items:center;gap:.45rem;flex-wrap:wrap}.community-post-head{align-items:flex-start;justify-content:space-between;gap:.75rem}.community-username,.community-comment-user,.community-reaction-person-name{font-weight:800;color:#111827}.community-flag{font-size:1rem;line-height:1}.community-badge{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;padding:.18rem .5rem;font-size:.72rem;font-weight:800}.community-badge-admin{background:rgba(220,53,69,.12);border:1px solid rgba(220,53,69,.35);color:#dc3545}.community-badge-default{background:#f3f4f6;border:1px solid #e5e7eb;color:#374151}.community-time{font-size:.8rem;margin-top:.15rem}.community-post-actions{flex-wrap:nowrap}.community-edit-btn,.community-delete-btn{border-radius:999px}.community-post-body{margin-top:.8rem;color:#111827;font-size:.97rem;line-height:1.55;word-break:break-word}.community-post-body p:last-child,.community-comment-body p:last-child{margin-bottom:0}.community-edit-form-wrap{margin-top:.85rem;padding:.85rem;border:1px solid #e5e7eb;border-radius:1rem;background:#f8fafc}.community-edit-textarea{min-height:110px;font-size:.95rem;padding:.8rem .9rem}.community-edit-actions{display:flex;justify-content:flex-end;gap:.5rem;margin-top:.7rem;flex-wrap:wrap}.community-media-grid{display:grid;gap:.5rem;margin-top:.9rem}.community-media-grid-1{grid-template-columns:1fr}.community-media-grid-2{grid-template-columns:repeat(2,1fr)}.community-media-grid-3{grid-template-columns:1.2fr .8fr;grid-template-rows:repeat(2,165px)}.community-media-grid-4{grid-template-columns:repeat(2,1fr);grid-template-rows:repeat(2,165px)}.community-media-grid-1 .community-media-item{height:340px}.community-media-grid-2 .community-media-item{height:220px}.community-media-grid-3 .community-media-item-1{grid-row:1/span 2;height:335px}.community-media-grid-3 .community-media-item:not(.community-media-item-1),.community-media-grid-4 .community-media-item{height:165px}.community-media-item{position:relative;overflow:hidden;border-radius:1rem;background:#f3f4f6}.community-media-button{display:block;width:100%;height:100%;padding:0;border:none;background:none;position:relative}.community-media-image{width:100%;height:100%;object-fit:cover;display:block}.community-media-more{position:absolute;inset:0;background:rgba(15,23,42,.55);display:flex;align-items:center;justify-content:center;color:#fff;font-size:2rem;font-weight:800}.community-social-summary{just