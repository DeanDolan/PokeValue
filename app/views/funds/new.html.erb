<div class="container py-4" style="max-width: 720px;">
  <h2 class="mb-3">Add Funds</h2>

  <div class="card">
    <div class="card-body">
      <%= form_with url: funds_path, method: :post, local: true, html: { id: "add-funds-form" } do %>
        <div class="mb-3">
          <label class="form-label">Amount (€)</label>
          <input id="fund-amount" type="number" name="amount" class="form-control" step="0.01" min="0.01" placeholder="0.00" required>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <%= link_to "Back", account_path, class: "btn btn-outline-secondary" %>
          <button type="submit" class="btn btn-success">Add Funds</button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script type="module">
  const form = document.getElementById("add-funds-form");
  const amountInput = document.getElementById("fund-amount");

  form?.addEventListener("submit", (e) => {
    const v = parseFloat((amountInput?.value || "").trim());
    if (!Number.isFinite(v) || v <= 0) return;

    const ok = window.confirm(`Confirm adding €${v.toFixed(2)} to your account?`);
    if (!ok) e.preventDefault();
  });
</script>