<nav class="navbar navbar-expand-lg navbar-light bg-light">
  <div class="container-fluid">
    <%# Main brand logo link %>
    <%= link_to "/", class: "navbar-brand d-flex align-items-center gap-2" do %>
      <%= image_tag "logos/pokevaluelogolightmode.png", alt: "PokeValue", class: "pv-navbar-logo pv-logo-light" %>
      <%= image_tag "logos/pokevaluelogodarkmode.png", alt: "PokeValue", class: "pv-navbar-logo pv-logo-dark" %>
    <% end %>

    <%# Bootstrap mobile navbar toggle button %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <%# Main navigation links %>
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to "Portfolio", "/", class: ["nav-link", (current_page?("/") ? "fw-bold text-dark" : nil)].compact.join(" ") %>
        </li>
        <li class="nav-item"><%= link_to "Sets", sets_path, class: ["nav-link", (current_page?(sets_path) ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
        <li class="nav-item"><%= link_to "Marketplace", marketplace_path, class: ["nav-link", (current_page?(marketplace_path) ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
        <li class="nav-item"><%= link_to "Auction", auction_path, class: ["nav-link", (current_page?(auction_path) ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
        <li class="nav-item"><%= link_to "Raffle", raffles_path, class: ["nav-link", ((current_page?(raffles_path) || request.path == "/raffle") ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
        <li class="nav-item"><%= link_to "Community", community_path, class: ["nav-link", (request.path.start_with?("/community") || request.path.start_with?("/showcase") ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>

        <%# Admin dropdown is only shown when an admin is signed in %>
        <% if defined?(admin_signed_in?) && admin_signed_in? %>
          <% admin_path = request.path.to_s %>
          <% admin_active = admin_path.start_with?("/admin") %>
          <% admin_products_active = admin_path.start_with?("/admin/products") %>
          <% admin_sets_active = admin_path.start_with?("/admin/sets") %>

          <li class="nav-item dropdown">
            <a href="#" role="button" class="<%= ["nav-link dropdown-toggle pv-admin-dropdown-toggle", (admin_active ? "fw-bold text-dark" : nil)].compact.join(" ") %>" data-bs-toggle="dropdown" aria-expanded="false">
              <span>Admin</span>
              <span class="pv-admin-caret">▾</span>
            </a>
            <ul class="dropdown-menu">
              <li><%= link_to "Products", admin_products_path, class: ["dropdown-item", (admin_products_active ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
              <li><%= link_to "Sets", admin_sets_path, class: ["dropdown-item", (admin_sets_active ? "fw-bold text-dark" : nil)].compact.join(" ") %></li>
            </ul>
          </li>
        <% end %>
      </ul>

      <style>
        #global-search-results{display:none!important;position:absolute;z-index:1050}
        #global-search-results.open{display:block!important}
        .navbar{padding-top:0;padding-bottom:0;min-height:56px}
        .pv-navbar-logo{height:52px;width:auto}
        .pv-footer-logo{height:100px;width:auto}
        .pv-logo-light{display:inline-block!important}
        .pv-logo-dark{display:none!important}
        :root[data-pv-theme="dark"] .pv-logo-light{display:none!important}
        :root[data-pv-theme="dark"] .pv-logo-dark{display:inline-block!important}
        :root[data-pv-theme="light"] .pv-logo-light{display:inline-block!important}
        :root[data-pv-theme="light"] .pv-logo-dark{display:none!important}
        .pv-admin-dropdown-toggle{display:inline-flex!important;align-items:center!important;gap:.22rem!important}
        .pv-admin-dropdown-toggle::after{display:none!important}
        .pv-admin-caret{display:inline-block!important;font-size:.78rem!important;line-height:1!important;color:inherit!important;background:transparent!important;border:0!important;transform:translateY(1px)}
        .pv-search-wrap{width:250px;min-width:250px;max-width:250px;flex:0 0 250px}
        .navbar-user-wrap{display:flex;align-items:center;gap:.35rem;flex-wrap:nowrap}
        .navbar-user-text{white-space:nowrap;font-size:.85rem;max-width:220px;overflow:hidden;text-overflow:ellipsis}
        .pv-badge{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:6px;font-size:.78rem;font-weight:900;line-height:1;vertical-align:middle}
        .pv-badge-admin{background:rgba(220,53,69,.10);color:#dc3545;border:1px solid rgba(220,53,69,.45);box-shadow:0 2px 6px rgba(220,53,69,.15)}
        @media (max-width: 1199.98px){
          .pv-search-wrap{width:220px;min-width:220px;max-width:220px;flex:0 0 220px}
          .navbar-user-text{max-width:170px}
        }
        @media (max-width: 991.98px){
          .pv-search-wrap{width:100%;min-width:0;max-width:none;flex:1 1 auto;margin-top:.5rem;margin-bottom:.5rem}
          .navbar-user-wrap{margin-top:.5rem}
          .navbar-user-text{max-width:100%}
        }
      </style>

      <%# Global search input for finding sets and products from the navbar %>
      <div class="position-relative me-2 pv-search-wrap">
        <input id="global-search" class="form-control" type="search" placeholder="Search products and sets..." aria-label="Search" autocomplete="off">
        <div id="global-search-results" class="dropdown-menu w-100 mt-1 p-0" style="max-height:420px; overflow:auto;"></div>
      </div>

      <%# My Account link opens the account page for logged-in users. Logged-out users go to account_path so the controller can show a flash message. %>
      <ul class="navbar-nav mb-2 mb-lg-0 me-2">
        <li class="nav-item">
          <%= link_to "My Account", account_path, class: ["nav-link", (current_page?(account_path) ? "fw-bold text-dark" : nil)].compact.join(" ") %>
        </li>
      </ul>

      <%# Logged-in user area with logout button, otherwise show login/register button %>
      <% if current_user %>
        <div class="navbar-user-wrap">
          <span class="navbar-text navbar-user-text">
            <%= "#{current_user.username} is logged in..." %>
          </span>
          <%= button_to "Logout",
                logout_path,
                method: :delete,
                class: "btn btn-outline-danger btn-sm",
                form: { class: "d-inline mb-0" } %>
        </div>
      <% else %>
        <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#authModal">
          Login/Register
        </button>
      <% end %>
    </div>
  </div>
</nav>

<script>
  (() => {
    // Gets the search input from the navbar.
    const input = document.getElementById("global-search")

    // Gets the dropdown box where search results will be shown.
    const menu = document.getElementById("global-search-results")

    // Stops the script if the search input or results dropdown does not exist.
    if (!input || !menu) return

    // Hides and clears the dropdown menu.
    function closeSearchMenu() {
      menu.innerHTML = ""
      menu.classList.remove("open")
    }

    // Makes sure the menu is hidden when the page first loads with no search text.
    if (!input.value.trim()) closeSearchMenu()

    // Runs every time the user types into the search bar.
    input.addEventListener("input", async () => {
      // Gets the typed search text and removes extra spaces.
      const query = input.value.trim()

      // If the search box is empty, clear and hide the dropdown.
      if (!query) {
        closeSearchMenu()
        return
      }

      // Sends the typed search text to the Rails search_index route.
      const response = await fetch("/search_index.json?q=" + encodeURIComponent(query))

      // Converts the JSON response from Rails into JavaScript data.
      const data = await response.json()

      // Stops old search results from showing if the user has already cleared or changed the input.
      if (input.value.trim() !== query) return

      // Combines returned sets and products into one results list.
      const results = [...(data.sets || []), ...(data.products || [])]

      // If there are no results, clear and hide the dropdown.
      if (results.length === 0) {
        closeSearchMenu()
        return
      }

      // Builds the HTML for each search result and puts it inside the dropdown.
      menu.innerHTML = results.map((item) => `
        <a class="dropdown-item py-2" href="${item.href}">
          <div class="d-flex align-items-center">
            <img src="${item.image_url}" alt="" style="width:48px;height:48px;object-fit:contain;margin-right:10px;">
            <div class="flex-grow-1">
              <div class="fw-semibold">${item.label}</div>
              <div class="text-muted small">${item.subtitle}</div>
            </div>
          </div>
        </a>
      `).join("")

      // Shows the dropdown.
      menu.classList.add("open")
    })

    // Stops the search dropdown being remembered/open when you navigate away and come back
    document.addEventListener("turbo:before-cache", closeSearchMenu)
  })()
</script>