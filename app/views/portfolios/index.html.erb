  else
    []
  end

condition_order = [
  "Mint Sealed",
  "Loosely Sealed",
  "Mini Tear/Hole (<2cm)",
  "Unsealed",
  "Small Tear (>2cm)",
  "Big Tear (>1 inch)",
  "Small Imperfections",
  "Big Imperfections",
  "Pressure Marks",
  "Slightly Dented",
  "Heavy Dented",
  "Damaged",
  "Box Only",
  "Contents Only"
].freeze

conditions_ordered = (condition_order + (conditions_from_controller - condition_order).sort).uniq

portfolio_type_options =
  if defined?(@types) && @types.is_a?(Array) && @types.any?
    @types.map(&:to_s)
  else
    type_map.values.uniq
  end

# Normalises text for matching sets, products and product variants
def normalize_text(s)
  s.to_s.unicode_normalize(:nfkc).downcase.strip.gsub(/\s+/, " ")
end

# Normalises product type codes so they can be matched safely.
def normalize_type(t)
  x = t.to_s.strip.downcase
  x = x.tr("-", "_")
  x = x.gsub(/\s+/, "_")
  x
end

# Converts text into a URL-safe slug.
def slugify(s)
  normalize_text(s).gsub(/[^a-z0-9]+/, "-").gsub(/\A-+|-+\z/, "")
end

# Extracts bracketed variant text from product names.
def extract_variant(name)
  m = name.to_s.match(/\(([^)]+)\)/)
  m ? m[1].to_s.strip : nil
end

# Detects whether a product is a Pokemon Center product.
def infer_origin(type_key:, name:)
  t = normalize_type(type_key)
  n = normalize_text(name)
  return "Pokemon Center" if t == "pc_etb"
  return "Pokemon Center" if n.include?("pokemon center")
  nil
end

# Checks whether a product type needs the product name added to the route.
def route_needs_product_slug?(base)
  [
    "collection_box",
    "tin",
    "mini_tin",
    "mini_tin_display",
    "booster_pack",
    "blister_pack",
    "blister_pack_display",
    "half_booster_box"
  ].include?(base.to_s)
end

# Builds the product route type used by /sets/:slug/:type
def build_route_type_for_product(type_key:, name:)
  base = normalize_type(type_key)
  variant = extract_variant(name)
  origin  = infer_origin(type_key: type_key, name: name)
  out = base.dup
  out << "--v-#{slugify(variant)}" if variant.present?
  out << "--o-#{slugify(origin)}"  if origin.present?
  out << "--p-#{slugify(name)}" if route_needs_product_slug?(base) && name.to_s.present?
  out
end

# Infers a general product type from a human-readable product name
def base_type_for_name(name)
  n = normalize_text(name)
  return "Pokemon Center Elite Trainer Box" if n.include?("pokemon center elite trainer box") || (n.include?("pokemon center") && n.include?("elite trainer box"))
  return "Elite Trainer Box" if n.include?("elite trainer box")
  return "Enhanced Booster Box" if n.include?("enhanced booster box")
  return "Half Booster Box" if n.include?("half booster box")
  return "Booster Pack" if n.include?("booster pack")
  return "Booster Box" if n.include?("booster box")
  return "Booster Bundle Display" if n.include?("booster bundle display")
  return "Booster Bundle" if n.include?("booster bundle")
  return "Mini Tin Display" if n.include?("mini tin display")
  return "Mini Tin" if n.include?("mini tin")
  return "Ultra Premium Collection" if n.include?("ultra premium collection")
  return "Super Premium Collection" if n.include?("super premium collection") || n.include?("special premium collection")
  return "Collection Box" if n.include?("collection") || n.include?(" ex box") || n.include?(" poster collection") || n.include?(" pin collection")
  return "Blister Pack Display" if n.include?("blister display") || n.include?("collection display")
  return "Blister Pack" if n.include?("blister") || n.include?("tech sticker")
  return "Tin" if n.include?(" tin")
  name.to_s
end

# Converts a release date value into a Date object when possible.
def parse_release_date(v)
  begin
    Date.parse(v.to_s)
  rescue
    nil
  end
end

# Converts a value into a decimal number for money calculations.
def to_decimal(v)
  return nil if v.nil?
  return v.to_d if v.respond_to?(:to_d)
  BigDecimal(v.to_s)
rescue
  nil
end

# Builds a SKU-to-value lookup from ProductValue or Product records
def build_value_map_for(klass)
  return nil unless klass
  cols = klass.column_names
  return nil unless cols.include?("sku")

  candidates = %w[value product_value estimated_value value_eur value_cents product_value_cents estimated_value_cents]
  val_col = (candidates & cols).first
  return nil unless val_col

  col = klass.columns_hash[val_col] rescue nil
  cents = val_col.to_s.end_with?("_cents") || (col && col.type == :integer)

  raw = klass.where.not(sku: nil).pluck(:sku, val_col.to_sym)
  out = {}
  raw.each do |sku, v|
    d = to_decimal(v)
    next if d.nil?
    d = d / 100 if cents
    out[sku.to_s.downcase] = d.to_f
  end
  out
rescue
  nil
end

# Finds the first positive value from a list of possible SKU keys.
def first_nonzero(map, keys)
  keys.each do |k|
    v = map[k.to_s.downcase]
    return v if v && v.to_f > 0
  end
  nil
end

value_by_sku =
  begin
    m = nil
    m = build_value_map_for(ProductValue) if defined?(ProductValue)
    m = build_value_map_for(Product) if m.nil?
    m || {}
  rescue
    {}
  end

# Finds image and product-page URL metadata for a holding row
meta_for = lambda do |set_name, human_product_name, fallback_image = nil|
  s = sets_data.values.find { |x| x["name"].to_s == set_name.to_s }
  next nil unless s

  sealed = Array(s["products"] || s["sealed"])
  want_name = human_product_name.to_s
  want_image = fallback_image.to_s
  want_image_base = File.basename(want_image) rescue ""

  prod = sealed.find { |p| normalize_text(p["name"] || p[:name]) == normalize_text(want_name) }

  if prod.nil? && want_image_base.present?
    prod = sealed.find do |p|
      img_base = File.basename((p["img"] || p[:img]).to_s) rescue ""
      img_base.present? && normalize_text(img_base) == normalize_text(want_image_base)
    end
  end

  if prod.nil?
    base = base_type_for_name(want_name)
    type_code = inv_type_map[base] || base.to_s.downcase.gsub(/\s+/, "_")
    matching = sealed.select { |p| normalize_type(p["type"] || p[:type]) == normalize_type(type_code) } if type_code.present?

    if matching.present? && matching.length == 1
      prod = matching.first
    end
  end

  next nil unless prod

  type_code = (prod["type"] || prod[:type]).to_s
  prod_name = (prod["name"] || prod[:name]).to_s

  img_base = File.basename((prod["img"] || prod[:img]).to_s) rescue nil
  img_url =
    if img_base.present? && File.exist?(images_sealed.join(img_base))
      asset_path("sealed/#{img_base}")
    elsif want_image.present?
      want_image
    else
      asset_path("pokevaluelogo.png")
    end

  route_type = build_route_type_for_product(type_key: type_code, name: prod_name)
  href = set_product_path(slug: s["slug"], type: route_type)
  { img_url: img_url, href: href, product_name: prod_name, route_type: route_type }
end

# Creates a front-end catalogue used by the Add to Portfolio modal
sets_index =
  sets_data.values.map do |s|
    slug = (s["slug"] || s[:slug]).to_s
    name = (s["name"] || s[:name]).to_s
    era  = (s["era"]  || s[:era]).to_s
    release_raw = (s["releaseDate"] || s["release_date"] || s["release"]).to_s
    release_date = parse_release_date(release_raw)
    release_iso = release_date ? release_date.strftime("%Y-%m-%d") : ""

    sealed_entries =
      Array(s["products"] || s["sealed"]).map do |p|
        type_code = (p["type"] || p[:type]).to_s
        prod_name = (p["name"] || p[:name]).to_s

        img_base = File.basename((p["img"] || p[:img]).to_s) rescue nil
        img_url =
          if img_base.present? && File.exist?(images_sealed.join(img_base))
            asset_path("sealed/#{img_base}")
          else
            asset_path("pokevaluelogo.png")
          end

        route_type = build_route_type_for_product(type_key: type_code, name: prod_name)

        sku_a = "#{slug}:#{type_code}".downcase
        sku_b = "#{slug}:#{route_type}".downcase
        sku_c = "#{slug}--#{type_code}".downcase
        sku_d = "#{slug}--#{route_type}".downcase

        val = first_nonzero(value_by_sku, [sku_b, sku_a, sku_d, sku_c])

        if val.nil?
          json_val = (p["value"] || p[:value])
          json_val = json_val.to_f if json_val.present? rescue json_val
          val = json_val if json_val.present? && json_val.to_f > 0
        end

        {
          type_code: type_code,
          type_human: (type_map[normalize_type(type_code)] || base_type_for_name(prod_name)),
          name: prod_name,
          variant: extract_variant(prod_name),
          route_type: route_type,
          img_url: img_url,
          value: (val if val.present?)
        }
      end

    { slug: slug, name: name, era: era, release_raw: release_raw, release_iso: release_iso, sealed: sealed_entries }
  end

# Orders eras by the newest set release date
era_release =
  sets_index.group_by { |x| x[:era].to_s }.transform_values do |arr|
    arr.map { |x| parse_release_date(x[:release_iso]) }.compact.max
  end

ordered_eras =
  era_release.keys.sort_by do |e|
    d = era_release[e]
    d ? -d.jd : 0
  end

# Loads manual sold summary rows created from the portfolio Remove/Sold flow
sold_summary_entries =
  if defined?(SummaryEntry) && current_user
    SummaryEntry.where(user_id: current_user.id, action: ["SOLD", "Sold", "sold"]).order(created_at: :desc).limit(500).to_a
  else
    []
  end

# Calculates realised profit/loss from manual sold summary rows
manual_sales_total_eur =
  sold_summary_entries.sum do |entry|
    qty = entry.quantity.to_i
    cost_u = (to_decimal(entry.cost_per_unit) || BigDecimal("0")).to_f
    sell_u = (to_decimal(entry.value) || BigDecimal("0")).to_f
    (sell_u - cost_u) * qty
  end

# Calculates realised profit/loss from completed marketplace purchases
marketplace_sales_total_cents =
  if defined?(MarketplacePurchase) && current_user
    MarketplacePurchase.where(seller_id: current_user.id).sum(:realised_pl_cents).to_i
  else
    0
  end

sales_total_eur = (marketplace_sales_total_cents / 100.0) + manual_sales_total_eur

# Builds realised P/L chart data for the metrics modal
sales_series =
  begin
    labels_hash = Hash.new(0.0)

    if defined?(MarketplacePurchase) && current_user
      raw = MarketplacePurchase.where(seller_id: current_user.id).group("DATE(created_at)").sum(:realised_pl_cents)
      raw.each do |date, cents|
        labels_hash[date.to_s] += cents.to_i / 100.0
      end
    end

    sold_summary_entries.each do |entry|
      date = (entry.purchase_date || entry.created_at&.to_date || Date.current).to_s
      qty = entry.quantity.to_i
      cost_u = (to_decimal(entry.cost_per_unit) || BigDecimal("0")).to_f
      sell_u = (to_decimal(entry.value) || BigDecimal("0")).to_f
      labels_hash[date] += (sell_u - cost_u) * qty
    end

    dates = labels_hash.keys.sort
    running = 0.0
    labels = []
    values = []

    dates.each do |d|
      running += labels_hash[d].to_f
      labels << d
      values << running.round(2)
    end

    { series: { realised_pl: { labels: labels, values: values } } }
  rescue
    { series: { realised_pl: { labels: [], values: [] } } }
  end

# Loads sold rows for the portfolio summary modal
sales_rows =
  if defined?(MarketplacePurchase) && current_user
    MarketplacePurchase.where(seller_id: current_user.id).order(created_at: :desc).limit(500).to_a
  else
    []
  end

summary_rows = []

@holdings.each do |holding|
  summary_rows << {
    kind: "added",
    record: holding,
    created_at: holding.created_at
  }
end

sold_summary_entries.each do |entry|
  summary_rows << {
    kind: "manual_sold",
    record: entry,
    created_at: entry.created_at
  }
end

sales_rows.each do |purchase|
  summary_rows << {
    kind: "marketplace_sold",
    record: purchase,
    created_at: purchase.created_at
  }
end

summary_rows = summary_rows.sort_by { |row| row[:created_at] || Time.at(0) }.reverse
%>

