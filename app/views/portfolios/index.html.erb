<%= stylesheet_link_tag "portfolios", "data-turbo-track": "reload" %>

<%
portfolio_logged_in = current_user.present?
holdings = @holdings || []
summary_entries = @summary_entries || []
conditions_ordered = (@conditions || []).map(&:to_s).uniq
sets_ordered = holdings.map { |holding| holding.set_name.to_s }.reject(&:blank?).uniq.sort

holding_product_href = lambda do |holding|
  product = holding.product
  next nil unless product

  set_slug = product.respond_to?(:set_slug) ? product.set_slug.to_s : ""
  type_code = product.respond_to?(:type_code) ? product.type_code.to_s : ""

  next nil if set_slug.blank? || type_code.blank?

  set_product_path(slug: set_slug, type: type_code)
rescue
  nil
end

holding_image_path = lambda do |holding|
  holding.image.present? ? holding.image : "pokevaluelogo.png"
end

summary_image_path = lambda do |entry|
  entry.respond_to?(:image_url) && entry.image_url.present? ? entry.image_url : "pokevaluelogo.png"
end

summary_entry_type = lambda do |entry|
  action = entry.action.to_s.upcase
  action == "SOLD" ? "Sold" : "Added"
end

summary_quantity = lambda do |entry|
  quantity = entry.quantity.to_i
  quantity.positive? ? quantity : 1
end

summary_cost_per_unit = lambda do |entry|
  BigDecimal(entry.cost_per_unit.to_s)
rescue
  BigDecimal("0")
end

summary_value_per_unit = lambda do |entry|
  BigDecimal(entry.value.to_s)
rescue
  BigDecimal("0")
end

summary_total_cost = lambda do |entry|
  summary_cost_per_unit.call(entry) * summary_quantity.call(entry)
end

summary_total_value = lambda do |entry|
  summary_value_per_unit.call(entry) * summary_quantity.call(entry)
end

summary_pl = lambda do |entry|
  summary_total_value.call(entry) - summary_total_cost.call(entry)
end

summary_roi = lambda do |entry|
  total_cost = summary_total_cost.call(entry)
  return BigDecimal("0") if total_cost.zero?

  ((summary_pl.call(entry) / total_cost) * 100).round(2)
rescue
  BigDecimal("0")
end
%>

<div>
  <h4 class="mb-3">Portfolio Overview</h4>

  <div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-lg">
      <div class="card h-100">
        <div class="card-body py-2">
          <h6 class="card-title mb-1">Total Cost</h6>
          <div class="fs-4 text-secondary"><%= number_to_currency(@totals[:cost], unit: "€") %></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-lg">
      <div class="card h-100">
        <div class="card-body py-2">
          <h6 class="card-title mb-1">Total Value</h6>
          <div class="fs-4 text-secondary"><%= number_to_currency(@totals[:value], unit: "€") %></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-lg">
      <div class="card h-100">
        <div class="card-body py-2">
          <h6 class="card-title mb-1">Unrealised P/L</h6>
          <div class="fs-4 text-secondary"><%= number_to_currency(@totals[:pl], unit: "€") %></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-lg">
      <div class="card h-100">
        <div class="card-body py-2">
          <h6 class="card-title mb-1">ROI (%)</h6>
          <div class="fs-4 text-secondary"><%= "#{number_with_precision(@totals[:roi], precision: 2)}%" %></div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-6 col-lg">
      <div class="card h-100">
        <div class="card-body py-2">
          <h6 class="card-title mb-1">Realised P/L</h6>
          <div class="fs-4 text-secondary"><%= number_to_currency(@realised_pl_total, unit: "€") %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="mb-4 d-flex justify-content-center gap-2">
    <% if portfolio_logged_in %>
      <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#summaryModal">View Summary</button>
      <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#metricsModal">View Metrics</button>
    <% else %>
      <%= link_to "View Summary", portfolio_login_required_path, class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "View Metrics", portfolio_login_required_path, class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>

  <h4 class="mb-3">Holdings</h4>

  <div class="card mb-3">
    <div class="card-body">
      <div class="row g-2 align-items-end mb-2">
        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-search">Search</label>
          <input id="portfolio-filter-search" class="form-control form-control-sm" type="text" placeholder="Search..." oninput="applyFilters()">
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-era">Era</label>
          <select id="portfolio-filter-era" class="form-select form-select-sm" onchange="applyFilters()">
            <option value="">All Eras</option>
            <% (@eras || []).each do |era| %>
              <option value="<%= era %>"><%= era %></option>
            <% end %>
          </select>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-set">Set</label>
          <select id="portfolio-filter-set" class="form-select form-select-sm" onchange="applyFilters()">
            <option value="">All Sets</option>
            <% sets_ordered.each do |set_name| %>
              <option value="<%= set_name %>"><%= set_name %></option>
            <% end %>
          </select>
        </div>

        <div class="col-12 col-md-3">
          <label class="form-label small mb-1" for="portfolio-filter-type">Product Type</label>
          <select id="portfolio-filter-type" class="form-select form-select-sm" onchange="applyFilters()">
            <option value="">All Product Types</option>
            <% (@types || []).each do |type| %>
              <option value="<%= type %>"><%= type %></option>
            <% end %>
          </select>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-condition">Condition</label>
          <select id="portfolio-filter-condition" class="form-select form-select-sm" onchange="applyFilters()">
            <option value="">All Conditions</option>
            <% conditions_ordered.each do |condition| %>
              <option value="<%= condition %>"><%= condition %></option>
            <% end %>
          </select>
        </div>

        <div class="col-12 col-md-1">
          <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="document.querySelectorAll('[id^=portfolio-filter-]').forEach((input) => input.value = ''); applyFilters();">
            Clear
          </button>
        </div>
      </div>

      <div class="row g-2 align-items-end">
        <div class="col-12 col-md-2">
          <label class="form-label small mb-1">Cost Range</label>
          <div class="d-flex gap-1">
            <input id="portfolio-filter-cost-min" class="form-control form-control-sm" type="number" step="0.01" placeholder="Min" oninput="applyFilters()">
            <input id="portfolio-filter-cost-max" class="form-control form-control-sm" type="number" step="0.01" placeholder="Max" oninput="applyFilters()">
          </div>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1">Value Range</label>
          <div class="d-flex gap-1">
            <input id="portfolio-filter-value-min" class="form-control form-control-sm" type="number" step="0.01" placeholder="Min" oninput="applyFilters()">
            <input id="portfolio-filter-value-max" class="form-control form-control-sm" type="number" step="0.01" placeholder="Max" oninput="applyFilters()">
          </div>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1">P/L Range</label>
          <div class="d-flex gap-1">
            <input id="portfolio-filter-pl-min" class="form-control form-control-sm" type="number" step="0.01" placeholder="Min" oninput="applyFilters()">
            <input id="portfolio-filter-pl-max" class="form-control form-control-sm" type="number" step="0.01" placeholder="Max" oninput="applyFilters()">
          </div>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1">ROI% Range</label>
          <div class="d-flex gap-1">
            <input id="portfolio-filter-roi-min" class="form-control form-control-sm" type="number" step="0.01" placeholder="Min" oninput="applyFilters()">
            <input id="portfolio-filter-roi-max" class="form-control form-control-sm" type="number" step="0.01" placeholder="Max" oninput="applyFilters()">
          </div>
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-date-from">From</label>
          <input id="portfolio-filter-date-from" class="form-control form-control-sm" type="date" onchange="applyFilters()">
        </div>

        <div class="col-12 col-md-2">
          <label class="form-label small mb-1" for="portfolio-filter-date-to">To</label>
          <input id="portfolio-filter-date-to" class="form-control form-control-sm" type="date" onchange="applyFilters()">
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-bordered mb-0 align-middle text-center">
          <thead class="table-light">
            <tr>
              <th>Product</th>
              <th>Era</th>
              <th>Set</th>
              <th>Product Type</th>
              <th>Condition</th>
              <th>Purchase Date</th>
              <th>Quantity</th>
              <th>Cost</th>
              <th>Total Cost</th>
              <th>Value</th>
              <th>Total Value</th>
              <th>P/L</th>
              <th>ROI %</th>
              <th class="portfolio-actions-col">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if holdings.any? %>
              <% holdings.each do |holding| %>
                <% view_path = holding_product_href.call(holding) %>
                <% holding_date = holding.purchase_date || holding.created_at&.to_date %>

                <tr data-portfolio-row="true"
                    data-era="<%= holding.era.to_s.downcase %>"
                    data-set-name="<%= holding.set_name.to_s.downcase %>"
                    data-type="<%= holding.product_type.to_s.downcase %>"
                    data-condition="<%= holding.condition.to_s.downcase %>"
                    data-cost="<%= holding.cost_per_unit.to_f %>"
                    data-value="<%= holding.value.to_f %>"
                    data-pl="<%= holding.pl.to_f %>"
                    data-roi="<%= holding.roi_pct.to_f %>"
                    data-date="<%= holding_date&.strftime("%Y-%m-%d") %>"
                    data-search="<%= [holding.era, holding.set_name, holding.product_type, holding.condition].join(' ').downcase %>">
                  <td>
                    <%= image_tag holding_image_path.call(holding), alt: holding.product_type, class: "portfolio-product-thumb" %>
                  </td>

                  <td><%= holding.era %></td>
                  <td><%= holding.set_name %></td>
                  <td><%= holding.product_type %></td>
                  <td><%= holding.condition %></td>
                  <td><%= holding_date&.strftime("%d/%m/%Y") || "—" %></td>
                  <td><%= holding.quantity %></td>
                  <td><%= number_to_currency(holding.cost_per_unit, unit: "€") %></td>
                  <td><%= number_to_currency(holding.total_cost, unit: "€") %></td>
                  <td><%= number_to_currency(holding.value, unit: "€") %></td>
                  <td><%= number_to_currency(holding.total_value, unit: "€") %></td>
                  <td><%= number_to_currency(holding.pl, unit: "€") %></td>
                  <td><%= "#{number_with_precision(holding.roi_pct, precision: 2)}%" %></td>

                  <td class="portfolio-actions-col">
                    <div class="portfolio-actions">
                      <% if view_path.present? %>
                        <%= link_to "View", view_path, class: "btn btn-outline-primary" %>
                      <% else %>
                        <span class="btn btn-outline-secondary disabled">View</span>
                      <% end %>

                      <%= link_to "Edit", edit_holding_path(holding), class: "btn btn-outline-secondary" %>

                      <%= button_to "Remove",
                                    holding_path(holding),
                                    method: :delete,
                                    class: "btn btn-outline-danger",
                                    form: { class: "d-inline m-0 p-0" } %>

                      <%= link_to "Sold", sold_holding_path(holding), class: "btn btn-outline-success" %>
                    </div>
                  </td>
                </tr>
              <% end %>

              <tr id="portfolio-no-filter-results" class="d-none">
                <td colspan="14" class="text-center text-muted py-4">
                  No holdings match the selected filters.
                </td>
              </tr>
            <% else %>
              <tr>
                <td colspan="14" class="text-center text-muted py-4">
                  No products within holdings.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<% if portfolio_logged_in %>
  <div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Summary</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div class="table-responsive">
            <table class="table table-bordered text-center align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Entry Type</th>
                  <th>Product</th>
                  <th>Era</th>
                  <th>Set</th>
                  <th>Product Type</th>
                  <th>Condition</th>
                  <th>Quantity</th>
                  <th>Total Cost</th>
                  <th>Total Value</th>
                  <th>P/L</th>
                  <th>ROI %</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody>
                <% if summary_entries.any? %>
                  <% summary_entries.each do |entry| %>
                    <tr>
                      <td><%= summary_entry_type.call(entry) %></td>
                      <td>
                        <%= image_tag summary_image_path.call(entry), alt: entry.product_type, class: "portfolio-product-thumb" %>
                      </td>
                      <td><%= entry.era %></td>
                      <td><%= entry.set_name %></td>
                      <td><%= entry.product_type %></td>
                      <td><%= entry.condition %></td>
                      <td><%= summary_quantity.call(entry) %></td>
                      <td><%= number_to_currency(summary_total_cost.call(entry), unit: "€") %></td>
                      <td><%= number_to_currency(summary_total_value.call(entry), unit: "€") %></td>
                      <td><%= number_to_currency(summary_pl.call(entry), unit: "€") %></td>
                      <td><%= "#{number_with_precision(summary_roi.call(entry), precision: 2)}%" %></td>
                      <td><%= (entry.purchase_date || entry.created_at&.to_date)&.strftime("%d/%m/%Y") || "—" %></td>
                      <td>
                        <%= button_to "Remove",
                                      summary_entry_path(entry),
                                      method: :delete,
                                      class: "btn btn-outline-danger btn-sm",
                                      form: { class: "d-inline m-0 p-0" } %>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="13" class="text-center text-muted py-4">No summary entries yet.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="metricsModal" tabindex="-1" aria-hidden="true" data-controller="metrics" data-action="shown.bs.modal->metrics#onShown" data-metrics-endpoint-value="<%= portfolio_metrics_path(format: :json) %>">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Metrics</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div class="d-none" data-metrics-target="status"></div>

          <div class="d-flex flex-wrap gap-2 mb-3">
            <button class="btn btn-primary btn-sm" data-action="click->metrics#select" data-metrics-key-param="cost">Total Cost</button>
            <button class="btn btn-outline-primary btn-sm" data-action="click->metrics#select" data-metrics-key-param="value">Total Value</button>
            <button class="btn btn-outline-primary btn-sm" data-action="click->metrics#select" data-metrics-key-param="pl">Unrealised P/L</button>
            <button class="btn btn-outline-primary btn-sm" data-action="click->metrics#select" data-metrics-key-param="roi">ROI (%)</button>
            <button class="btn btn-outline-primary btn-sm" data-action="click->metrics#select" data-metrics-key-param="realised_pl">Realised P/L</button>
          </div>

          <div class="card">
            <div class="card-body">
              <div data-metrics-target="panel" data-key="cost">
                <div class="fw-semibold mb-2">Total Cost</div>
                <div style="height:360px;">
                  <canvas data-key="cost"></canvas>
                </div>
              </div>

              <div class="d-none" data-metrics-target="panel" data-key="value">
                <div class="fw-semibold mb-2">Total Value</div>
                <div style="height:360px;">
                  <canvas data-key="value"></canvas>
                </div>
              </div>

              <div class="d-none" data-metrics-target="panel" data-key="pl">
                <div class="fw-semibold mb-2">Unrealised P/L</div>
                <div style="height:360px;">
                  <canvas data-key="pl"></canvas>
                </div>
              </div>

              <div class="d-none" data-metrics-target="panel" data-key="roi">
                <div class="fw-semibold mb-2">ROI (%)</div>
                <div style="height:360px;">
                  <canvas data-key="roi"></canvas>
                </div>
              </div>

              <div class="d-none" data-metrics-target="panel" data-key="realised_pl">
                <div class="fw-semibold mb-2">Realised P/L</div>
                <div style="height:360px;">
                  <canvas data-key="realised_pl"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
  // Filters the portfolio holdings table.
  function applyFilters() {
    const search = document.getElementById("portfolio-filter-search").value.toLowerCase().trim()
    const era = document.getElementById("portfolio-filter-era").value.toLowerCase().trim()
    const setName = document.getElementById("portfolio-filter-set").value.toLowerCase().trim()
    const type = document.getElementById("portfolio-filter-type").value.toLowerCase().trim()
    const condition = document.getElementById("portfolio-filter-condition").value.toLowerCase().trim()

    const costMin = parseFloat(document.getElementById("portfolio-filter-cost-min").value)
    const costMax = parseFloat(document.getElementById("portfolio-filter-cost-max").value)
    const valueMin = parseFloat(document.getElementById("portfolio-filter-value-min").value)
    const valueMax = parseFloat(document.getElementById("portfolio-filter-value-max").value)
    const plMin = parseFloat(document.getElementById("portfolio-filter-pl-min").value)
    const plMax = parseFloat(document.getElementById("portfolio-filter-pl-max").value)
    const roiMin = parseFloat(document.getElementById("portfolio-filter-roi-min").value)
    const roiMax = parseFloat(document.getElementById("portfolio-filter-roi-max").value)

    const dateFrom = document.getElementById("portfolio-filter-date-from").value
    const dateTo = document.getElementById("portfolio-filter-date-to").value

    const rows = document.querySelectorAll("[data-portfolio-row='true']")
    const noResults = document.getElementById("portfolio-no-filter-results")
    let visibleCount = 0

    rows.forEach((row) => {
      const rowSearch = row.dataset.search || ""
      const rowEra = row.dataset.era || ""
      const rowSetName = row.dataset.setName || ""
      const rowType = row.dataset.type || ""
      const rowCondition = row.dataset.condition || ""
      const rowCost = parseFloat(row.dataset.cost || "0")
      const rowValue = parseFloat(row.dataset.value || "0")
      const rowPl = parseFloat(row.dataset.pl || "0")
      const rowRoi = parseFloat(row.dataset.roi || "0")
      const rowDate = row.dataset.date || ""

      const matchesSearch = search === "" || rowSearch.includes(search)
      const matchesEra = era === "" || rowEra === era
      const matchesSet = setName === "" || rowSetName === setName
      const matchesType = type === "" || rowType === type
      const matchesCondition = condition === "" || rowCondition === condition

      const matchesCostMin = Number.isNaN(costMin) || rowCost >= costMin
      const matchesCostMax = Number.isNaN(costMax) || rowCost <= costMax
      const matchesValueMin = Number.isNaN(valueMin) || rowValue >= valueMin
      const matchesValueMax = Number.isNaN(valueMax) || rowValue <= valueMax
      const matchesPlMin = Number.isNaN(plMin) || rowPl >= plMin
      const matchesPlMax = Number.isNaN(plMax) || rowPl <= plMax
      const matchesRoiMin = Number.isNaN(roiMin) || rowRoi >= roiMin
      const matchesRoiMax = Number.isNaN(roiMax) || rowRoi <= roiMax

      const matchesDateFrom = dateFrom === "" || rowDate >= dateFrom
      const matchesDateTo = dateTo === "" || rowDate <= dateTo

      const show =
        matchesSearch &&
        matchesEra &&
        matchesSet &&
        matchesType &&
        matchesCondition &&
        matchesCostMin &&
        matchesCostMax &&
        matchesValueMin &&
        matchesValueMax &&
        matchesPlMin &&
        matchesPlMax &&
        matchesRoiMin &&
        matchesRoiMax &&
        matchesDateFrom &&
        matchesDateTo

      row.classList.toggle("d-none", !show)

      if (show) visibleCount += 1
    })

    if (noResults) {
      noResults.classList.toggle("d-none", visibleCount > 0)
    }
  }
</script>