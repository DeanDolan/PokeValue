  "booster_bundle"           => "Booster Bundle",
  "booster_bundle_display"   => "Booster Bundle Display",
  "enhanced_booster_box"     => "Enhanced Booster Box",
  "ultra_premium_collection" => "Ultra Premium Collection",
  "upc"                      => "Ultra Premium Collection",
  "spc"                      => "Super Premium Collection",
  "collection_box"           => "Collection Box",
  "tin"                      => "Tin",
  "mini_tin"                 => "Mini Tin",
  "mini_tin_display"         => "Mini Tin Display",
  "blister_pack"             => "Blister Pack",
  "blister_pack_display"     => "Blister Pack Display"
}
inv_type_map  = type_map.invert
images_sealed = Rails.root.join("app", "assets", "images", "sealed")

# Checks whether a user is logged in so portfolio action buttons can either open their real modals or show the login pop-up
portfolio_logged_in = current_user.present?

# Uses controller-provided condition options where available
conditions_from_controller =
  if defined?(@conditions) && @conditions.is_a?(Array) && @conditions.any?
