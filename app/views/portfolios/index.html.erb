              <th class="col-qty">Quantity</th>
              <th class="col-money">Cost</th>
              <th class="col-money">Total Cost</th>
              <th class="col-money">Value</th>
              <th class="col-money">Total Value</th>
              <th class="col-pl">P/L</th>
