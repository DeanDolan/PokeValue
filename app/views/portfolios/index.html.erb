                  data-type="<%= h.product_type %>"
                  data-type-base="<%= base_type %>"
                  data-condition="<%= h.condition %>"
                  data-date="<%= (h.purchase_date || h.created_at&.to_date)&.strftime("%Y-%m-%d") %>"
                  data-cost="<%= h.cost_per_unit.to_f %>"
                  data-total-cost="<%= h.total_cost.to_f %>"
                  data-value="<%= h.value.to_f %>"
                  data-total-value="<%= h.total_value.to_f %>"
                  data-pl="<%= h.pl.to_f %>"
                  data-roi="<%= h.roi_pct.to_f %>"
                  data-search="<%= [h.era, h.set_name, h.product_type, meta && meta[:product_name], h.condition].join(" ").downcase %>">
                  <td>
                    <% if meta %>
                      <%= link_to meta[:href] do %>
                        <%= image_tag meta[:img_url], alt: h.product_type, class: "product-thumb" %>
                      <% end %>
                    <% elsif h.image.present? %>
                      <%= image_tag h.image, alt: h.product_type, class: "product-thumb" %>
                    <% else %>
                      <%= image_tag "pokevaluelogo.png", alt: h.product_type, class: "product-thumb" %>
                    <% end %>
                  </td>
                  <td><%= h.era %></td>
                  <td><%= h.set_name %></td>
                  <td><%= meta ? meta[:product_name] : h.product_type %></td>
                  <td><%= h.condition %></td>
                  <td><%= (h.purchase_date || h.created_at&.to_date)&.strftime("%d/%m/%Y") || "—" %></td>
                  <td><%= h.quantity %></td>
                  <td><%= number_to_currency(h.cost_per_unit, unit: "€") %></td>
                  <td><%= number_to_currency(h.total_cost, unit: "€") %></td>
                  <td><%= number_to_currency(h.value, unit: "€") %></td>
                  <td><%= number_to_currency(h.total_value, unit: "€") %></td>
                  <td class="text-nowrap"><%= number_to_currency(h.pl, unit: "€") %></td>
                  <td><%= "#{number_with_precision(h.roi_pct, precision: 2)}%" %></td>
                  <td>
                    <div class="holdings-actions d-inline-flex flex-nowrap">
                      <% if meta %>
                        <%= link_to "View", meta[:href], class: "btn btn-sm btn-outline-primary me-1" %>
                      <% else %>
                        <span class="btn btn-sm btn-outline-secondary disabled me-1">View</span>
                      <% end %>

                      <details class="summary-edit me-1">
                        <summary class="btn btn-sm btn-outline-secondary">Edit</summary>
                        <div class="border rounded p-2 mt-2 bg-white" style="min-width:240px;">
                          <%= form_with model: h, url: holding_path(h), method: :patch, local: true do |f| %>
                            <div class="mb-2">
                              <%= f.number_field :quantity, min: 1, step: 1, class: "form-control form-control-sm" %>
                            </div>
                            <div class="mb-2">
                              <%= f.number_field :cost_per_unit, min: 0, step: "0.01", class: "form-control form-control-sm" %>
                            </div>
                            <div class="mb-2">
                              <%= f.date_field :purchase_date, class: "form-control form-control-sm" %>
                            </div>
                            <div class="mb-2">
                              <%= f.select :condition, options_for_select(conditions_ordered, h.condition), {}, class: "form-select form-select-sm" %>
                            </div>
                            <div class="d-flex gap-2">
                              <%= f.submit "Save", class: "btn btn-sm btn-primary" %>
                              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="this.closest('details').removeAttribute('open')">Cancel</button>
                            </div>
                          <% end %>
                        </div>
                      </details>

                      <%= button_to "Remove",
                                    holding_path(h),
                                    method: :delete,
                                    form: {
                                      data: {
                                        portfolio_remove_form: "true",
                                        remove_quantity_max: h.quantity.to_i,
                                        remove_cost_per_unit: h.cost_per_unit.to_f,
                                        remove_product_name: (meta ? meta[:product_name] : h.product_type),
                                        custom_confirm_message: "Choose whether to remove this product from your portfolio or mark it as sold.",
                                        turbo: "false"
                                      }
                                    },
                                    class: "btn btn-sm btn-outline-danger" %>
                    </div>
                  </td>
                </tr>
              <% end %>
              <tr id="holdings-empty" class="d-none">
                <td colspan="14" class="text-center text-muted py-4">No matches.</td>
              </tr>
            <% else %>
              <tr>
                <td colspan="14" class="text-center text-muted py-4">No products within holdings.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex justify-content-end">
    <% if portfolio_logged_in %>
      <button class="btn btn-success btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#addHoldingModal">Add to Portfolio</button>
    <% else %>
      <%# Logged-out users see the login pop-up before they can add products to their portfolio %>
      <button class="btn btn-success btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#authModal" data-auth-title="Log in to add to portfolio">Add to Portfolio</button>
    <% end %>
  </div>
</div>

<% unless portfolio_logged_in %>
  <script>
    // Runs the logged-out portfolio auth modal title setup without creating global variables.
    (function(){
      // Sets the shared login/register modal title from the clicked portfolio button.
      function initPortfolioAuthModalTitles(){
        const authModal = document.getElementById("authModal")
        const authTitle = document.getElementById("authModalLabel")

        if(!authModal || !authTitle) return
        if(authModal.dataset.portfolioAuthTitleBound === "1") return
        authModal.dataset.portfolioAuthTitleBound = "1"

        // Changes the shared login modal title depending on which portfolio button opened it
        authModal.addEventListener("show.bs.modal", function(event){
          const button = event.relatedTarget
          const title = button ? button.getAttribute("data-auth-title") : ""
          authTitle.textContent = title || "Welcome"
        })
      }

      document.addEventListener("DOMContentLoaded", initPortfolioAuthModalTitles)
      document.addEventListener("turbo:load", initPortfolioAuthModalTitles)
    })()
  </script>
<% end %>

<% if portfolio_logged_in %>
  <div class="portfolio-remove-confirm-overlay" id="portfolioRemoveConfirmOverlay" aria-hidden="true">
