<%= stylesheet_link_tag "portfolios", "data-turbo-track": "reload" %>

<div class="container py-3">
  <h4 class="mb-3">Mark as Sold</h4>

  <div class="card">
    <div class="card-body">
      <div class="mb-3">
        <div class="fw-semibold"><%= @holding.product_type %></div>
        <div class="text-muted small"><%= @holding.era %> · <%= @holding.set_name %></div>
        <div class="text-muted small">Available Quantity: <%= @holding.quantity %></div>
      </div>

      <%= form_with url: mark_sold_holding_path(@holding), method: :post, local: true do %>
        <div class="row g-3">
          <div class="col-12 col-md-4">
            <%= label_tag :sold_quantity, "Quantity Sold", class: "form-label" %>
            <%= number_field_tag :sold_quantity, 1, min: 1, max: @holding.quantity, step: 1, class: "form-control" %>
          </div>

          <div class="col-12 col-md-4">
            <%= label_tag :sold_price, "Sold Per Unit (€)", class: "form-label" %>
            <%= number_field_tag :sold_price, nil, min: 0, step: "0.01", class: "form-control" %>
          </div>

          <div class="col-12 col-md-4">
            <%= label_tag :sale_date, "Sale Date", class: "form-label" %>
            <%= date_field_tag :sale_date, Date.current, class: "form-control" %>
          </div>

          <div class="col-12 d-flex justify-content-end gap-2">
            <%= link_to "Back", portfolio_path, class: "btn btn-outline-secondary btn-sm" %>
            <%= submit_tag "Mark Sold", class: "btn btn-success btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>