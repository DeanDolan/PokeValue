<%
# Keeps each raffle group safe even if the controller returns nil.
active_raffles = @active_raffles || []
active_mini_raffles = @active_mini_raffles || []
completed_raffles = @completed_raffles || []
incompleted_raffles = @incompleted_raffles || []

# Converts cents into a euro display.
money = ->(cents) { number_to_currency(cents.to_i / 100.0, unit: "€") }

# Chooses the badge colour based on raffle status.
status_badge = lambda do |status|
  {
    "active" => "admin-raffle-badge admin-raffle-badge-active",
    "completed" => "admin-raffle-badge admin-raffle-badge-completed",
    "incompleted" => "admin-raffle-badge admin-raffle-badge-incompleted"
  }[status.to_s] || "admin-raffle-badge"
end

# Defines each admin raffle table and the columns it should show.
sections = [
  { title: "Active Raffles", rows: active_raffles, columns: [ :images, :title, :host, :type, :ticket_price, :sold, :left, :paid, :created, :status, :actions ] },
  { title: "Active Mini Raffles", rows: active_mini_raffles, columns: [ :images, :title, :main_raffle, :host, :type, :ticket_price, :sold, :left, :paid, :created, :status, :actions ] },
  { title: "Completed Raffles", rows: completed_raffles, columns: [ :images, :title, :host, :type, :sold, :paid, :winner, :ticket, :completed, :status, :actions ] },
  { title: "Incompleted Raffles", rows: incompleted_raffles, columns: [ :images, :title, :host, :type, :sold, :left, :paid, :created, :ended, :status, :actions ] }
]

# Converts column keys into table headings.
headings = {
  images: "Images",
  title: "Title",
  main_raffle: "Main Raffle",
  host: "Host",
  type: "Type",
  ticket_price: "Ticket Price",
  sold: "Sold",
  left: "Left",
  paid: "Paid",
  created: "Created",
  completed: "Completed",
  ended: "Ended",
  winner: "Winner",
  ticket: "Ticket",
  status: "Status",
  actions: "Actions"
}

# Keeps column widths close to the original admin raffle page.
column_classes = {
  images: "col-img",
  title: "col-title",
  main_raffle: "col-title",
  host: "col-host",
  type: "col-type",
  ticket_price: "col-money",
  sold: "col-small",
  left: "col-small",
  paid: "col-money",
  created: "col-date",
  completed: "col-date",
  ended: "col-date",
  winner: "col-small",
  ticket: "col-small",
  status: "col-small",
  actions: "col-actions"
}
%>

<style>
  .admin-raffles-page{padding:12px 0 24px}
  .admin-raffles-header{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .admin-raffles-title{font-size:1.25rem;font-weight:800;margin:0}
  .admin-raffles-subtitle{font-size:.85rem;color:#6b7280;margin:2px 0 0}
  .admin-raffles-card{border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;margin-bottom:16px;background:#ffffff}
  .admin-raffles-card .card-head{background:#f8fafc;padding:10px 12px;font-weight:700;text-align:center}
  .admin-raffles-table{width:100%;font-size:.78rem;border-collapse:collapse}
  .admin-raffles-table thead th,.admin-raffles-table tbody td{vertical-align:middle;text-align:center;padding:.35rem .4rem;line-height:1.2}
  .admin-raffles-table thead th{font-size:.78rem;font-weight:700;white-space:nowrap}
  .admin-raffles-table .col-img{width:90px}
  .admin-raffles-table .col-title{width:220px}
  .admin-raffles-table .col-host{width:130px}
  .admin-raffles-table .col-type{width:100px}
  .admin-raffles-table .col-money{width:110px}
  .admin-raffles-table .col-small{width:90px}
  .admin-raffles-table .col-date{width:130px}
  .admin-raffles-table .col-actions{width:140px}
  .admin-raffle-thumb-stack{display:flex;justify-content:center;gap:4px;flex-wrap:wrap}
  .admin-raffle-thumb-stack img{height:36px;width:36px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb}
  .admin-raffle-badge{display:inline-flex;align-items:center;justify-content:center;padding:.22rem .55rem;border-radius:999px;font-size:.68rem;font-weight:800;border:1px solid #d1d5db;background:#ffffff;color:#111827}
  .admin-raffle-badge-active{color:#166534;border-color:#86efac;background:#f0fdf4}
  .admin-raffle-badge-completed{color:#1d4ed8;border-color:#93c5fd;background:#eff6ff}
  .admin-raffle-badge-incompleted{color:#991b1b;border-color:#fca5a5;background:#fef2f2}
  .admin-raffle-actions{display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:nowrap}
  .admin-raffle-actions form,.admin-raffle-actions .button_to{display:inline-flex;margin:0}
  .admin-raffle-actions .btn{font-size:.72rem;padding:.2rem .45rem;white-space:nowrap}
</style>

<div class="container admin-raffles-page">
  <%# Admin page heading and shortcut back to the public raffles page. %>
  <div class="admin-raffles-header">
    <div>
      <h1 class="admin-raffles-title">Admin Raffles</h1>
      <p class="admin-raffles-subtitle">Manage active raffles, mini raffles, completed raffles, and incompleted raffles.</p>
    </div>

    <%= link_to "View Raffles Page", raffles_path, class: "btn btn-outline-primary btn-sm" %>
  </div>

  <% sections.each do |section| %>
    <%# One reusable table layout is used for every raffle group. %>
    <div class="admin-raffles-card">
      <div class="card-head"><%= section[:title] %></div>

      <div class="table-responsive">
        <table class="table table-bordered admin-raffles-table mb-0">
          <thead class="table-light">
            <tr>
              <% section[:columns].each do |column| %>
                <th class="<%= column_classes[column] %>"><%= headings[column] %></th>
              <% end %>
            </tr>
          </thead>

          <tbody>
            <% if section[:rows].any? %>
              <% section[:rows].each do |raffle| %>
                <tr>
                  <% section[:columns].each do |column| %>
                    <td class="<%= column_classes[column] %>">
                      <% case column %>
                      <% when :images %>
                        <%# Shows up to four uploaded raffle images. %>
                        <div class="admin-raffle-thumb-stack">
                          <% if raffle.photos.attached? %>
                            <% raffle.photos.first(4).each do |photo| %>
                              <%= image_tag url_for(photo), alt: "" %>
                            <% end %>
                          <% else %>
                            <span class="text-muted">—</span>
                          <% end %>
                        </div>

                      <% when :title %>
                        <%= link_to raffle.title, raffle_path(raffle), class: "text-decoration-none fw-semibold" %>

                      <% when :main_raffle %>
                        <% if raffle.main_raffle.present? %>
                          <%= link_to raffle.main_raffle.title, raffle_path(raffle.main_raffle), class: "text-decoration-none" %>
                        <% else %>
                          —
                        <% end %>

                      <% when :host %>
                        <%= raffle.host&.username.to_s.presence || "User ##{raffle.host_id}" %>

                      <% when :type %>
                        <%= raffle.raffle_kind.to_s == "mini" ? "Mini Raffle" : "Raffle" %>

                      <% when :ticket_price %>
                        <%= money.call(raffle.ticket_price_cents) %>

                      <% when :sold %>
                        <%= raffle.sold_tickets_count %> / <%= raffle.total_tickets %>

                      <% when :left %>
                        <%= raffle.tickets_left %>

                      <% when :paid %>
                        <%= money.call(raffle.paid_amount_cents) %>

                      <% when :created %>
                        <%= raffle.created_at.present? ? raffle.created_at.strftime("%d/%m/%Y") : "—" %>

                      <% when :completed %>
                        <%= raffle.completed_at.present? ? raffle.completed_at.strftime("%d/%m/%Y") : "—" %>

                      <% when :ended %>
                        <%= raffle.ended_at.present? ? raffle.ended_at.strftime("%d/%m/%Y") : "—" %>

                      <% when :winner %>
                        <%= raffle.winner_name.presence || raffle.winner_user&.username.presence || "—" %>

                      <% when :ticket %>
                        <%= raffle.winner_number.present? ? "##{raffle.winner_number}" : "—" %>

                      <% when :status %>
                        <span class="<%= status_badge.call(raffle.status) %>"><%= raffle.status.to_s.capitalize %></span>

                      <% when :actions %>
                        <%# Admin can inspect or delete raffle records. %>
                        <div class="admin-raffle-actions">
                          <%= link_to "View", raffle_path(raffle), class: "btn btn-sm btn-outline-primary" %>
                          <%= button_to "Delete",
                                admin_raffle_path(raffle),
                                method: :delete,
                                params: { return_to: request.fullpath },
                                class: "btn btn-sm btn-outline-danger",
                                form: { data: { turbo_confirm: "Are you sure you want to delete this raffle?" } } %>
                        </div>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= section[:columns].size %>" class="text-center text-muted py-4">
                  No <%= section[:title].downcase %>.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>