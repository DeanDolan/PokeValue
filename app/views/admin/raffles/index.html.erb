<%
# Stores each raffle group safely, even if the controller sends nil
active_raffles = @active_raffles || []
active_mini_raffles = @active_mini_raffles || []
completed_raffles = @completed_raffles || []
incompleted_raffles = @incompleted_raffles || []

# Converts ticket price from cents into a euro display value
ticket_price = lambda do |raffle|
  number_to_currency(raffle.ticket_price_cents.to_i / 100.0, unit: "€")
end

# Calculates the amount marked as paid for this raffle
paid_amount = lambda do |raffle|
  amount =
    begin
      raffle.raffle_tickets.select(&:paid?).sum(&:amount_paid_cents)
    rescue
      0
    end

  number_to_currency(amount.to_i / 100.0, unit: "€")
end

# Chooses the correct badge class based on raffle status
status_badge = lambda do |status|
  case status.to_s
  when "active"
    "admin-raffle-badge admin-raffle-badge-active"
  when "completed"
    "admin-raffle-badge admin-raffle-badge-completed"
  when "incompleted"
    "admin-raffle-badge admin-raffle-badge-incompleted"
  else
    "admin-raffle-badge"
  end
end
%>

<style>
  .admin-raffles-page{padding:12px 0 24px}
  .admin-raffles-header{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .admin-raffles-title{font-size:1.25rem;font-weight:800;margin:0}
  .admin-raffles-subtitle{font-size:.85rem;color:#6b7280;margin:2px 0 0}
  .admin-raffles-card{border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;margin-bottom:16px;background:#ffffff}
  .admin-raffles-card .card-head{background:#f8fafc;padding:10px 12px;font-weight:700;text-align:center}
  .admin-raffles-table{width:100%;font-size:.78rem;border-collapse:collapse}
  .admin-raffles-table thead th,.admin-raffles-table tbody td{vertical-align:middle;text-align:center;padding:.35rem .4rem;line-height:1.2}
  .admin-raffles-table thead th{font-size:.78rem;font-weight:700;white-space:nowrap}
  .admin-raffles-table .col-img{width:90px}
  .admin-raffles-table .col-title{width:220px}
  .admin-raffles-table .col-host{width:130px}
  .admin-raffles-table .col-type{width:100px}
  .admin-raffles-table .col-money{width:110px}
  .admin-raffles-table .col-small{width:90px}
  .admin-raffles-table .col-date{width:130px}
  .admin-raffles-table .col-actions{width:140px}
  .admin-raffle-thumb-stack{display:flex;justify-content:center;gap:4px;flex-wrap:wrap}
  .admin-raffle-thumb-stack img{height:36px;width:36px;object-fit:cover;border-radius:8px;border:1px solid #e5e7eb}
  .admin-raffle-badge{display:inline-flex;align-items:center;justify-content:center;padding:.22rem .55rem;border-radius:999px;font-size:.68rem;font-weight:800;border:1px solid #d1d5db;background:#ffffff;color:#111827}
  .admin-raffle-badge-active{color:#166534;border-color:#86efac;background:#f0fdf4}
  .admin-raffle-badge-completed{color:#1d4ed8;border-color:#93c5fd;background:#eff6ff}
  .admin-raffle-badge-incompleted{color:#991b1b;border-color:#fca5a5;background:#fef2f2}
  .admin-raffle-actions{display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:nowrap}
  .admin-raffle-actions form,.admin-raffle-actions .button_to{display:inline-flex;margin:0}
  .admin-raffle-actions .btn{font-size:.72rem;padding:.2rem .45rem;white-space:nowrap}
</style>

<div class="container admin-raffles-page">
  <%# Admin page heading and shortcut back to the public raffles page %>
  <div class="admin-raffles-header">
    <div>
      <h1 class="admin-raffles-title">Admin Raffles</h1>
      <p class="admin-raffles-subtitle">Manage active raffles, mini raffles, completed raffles, and incompleted raffles.</p>
    </div>

    <%= link_to "View Raffles Page", raffles_path, class: "btn btn-outline-primary btn-sm" %>
  </div>

  <%# Main active raffles table %>
  <div class="admin-raffles-card">
    <div class="card-head">Active Raffles</div>

    <div class="table-responsive">
      <table class="table table-bordered admin-raffles-table mb-0">
        <thead class="table-light">
          <tr>
            <th class="col-img">Images</th>
            <th class="col-title">Title</th>
            <th class="col-host">Host</th>
            <th class="col-type">Type</th>
            <th class="col-money">Ticket Price</th>
            <th class="col-small">Sold</th>
            <th class="col-small">Left</th>
            <th class="col-money">Paid</th>
            <th class="col-date">Created</th>
            <th class="col-small">Status</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if active_raffles.any? %>
            <% active_raffles.each do |raffle| %>
              <tr>
                <td>
                  <%# Shows up to four uploaded raffle images %>
                  <div class="admin-raffle-thumb-stack">
                    <% if raffle.photos.attached? %>
                      <% raffle.photos.first(4).each do |photo| %>
                        <%= image_tag url_for(photo), alt: "" %>
                      <% end %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </div>
                </td>
                <td><%= link_to raffle.title, raffle_path(raffle), class: "text-decoration-none fw-semibold" %></td>
                <td><%= raffle.host&.username.to_s.presence || "User ##{raffle.host_id}" %></td>
                <td>Raffle</td>
                <td><%= ticket_price.call(raffle) %></td>
                <td><%= raffle.sold_tickets_count %> / <%= raffle.total_tickets %></td>
                <td><%= raffle.tickets_left %></td>
                <td><%= paid_amount.call(raffle) %></td>
                <td><%= raffle.created_at.present? ? raffle.created_at.strftime("%d/%m/%Y") : "—" %></td>
                <td><span class="<%= status_badge.call(raffle.status) %>"><%= raffle.status.to_s.capitalize %></span></td>
                <td>
                  <%# Admin can view or delete the raffle %>
                  <div class="admin-raffle-actions">
                    <%= link_to "View", raffle_path(raffle), class: "btn btn-sm btn-outline-primary" %>
                    <%= button_to "Delete", admin_raffle_path(raffle), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure you want to delete this raffle?" } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="11" class="text-center text-muted py-4">No active raffles.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Active mini raffles table %>
  <div class="admin-raffles-card">
    <div class="card-head">Active Mini Raffles</div>

    <div class="table-responsive">
      <table class="table table-bordered admin-raffles-table mb-0">
        <thead class="table-light">
          <tr>
            <th class="col-img">Images</th>
            <th class="col-title">Title</th>
            <th class="col-title">Main Raffle</th>
            <th class="col-host">Host</th>
            <th class="col-type">Type</th>
            <th class="col-money">Ticket Price</th>
            <th class="col-small">Sold</th>
            <th class="col-small">Left</th>
            <th class="col-money">Paid</th>
            <th class="col-date">Created</th>
            <th class="col-small">Status</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if active_mini_raffles.any? %>
            <% active_mini_raffles.each do |raffle| %>
              <tr>
                <td>
                  <%# Mini raffles also support up to four uploaded images %>
                  <div class="admin-raffle-thumb-stack">
                    <% if raffle.photos.attached? %>
                      <% raffle.photos.first(4).each do |photo| %>
                        <%= image_tag url_for(photo), alt: "" %>
                      <% end %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </div>
                </td>
                <td><%= link_to raffle.title, raffle_path(raffle), class: "text-decoration-none fw-semibold" %></td>
                <td>
                  <%# Links a mini raffle back to its parent/main raffle %>
                  <% if raffle.main_raffle.present? %>
                    <%= link_to raffle.main_raffle.title, raffle_path(raffle.main_raffle), class: "text-decoration-none" %>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td><%= raffle.host&.username.to_s.presence || "User ##{raffle.host_id}" %></td>
                <td>Mini Raffle</td>
                <td><%= ticket_price.call(raffle) %></td>
                <td><%= raffle.sold_tickets_count %> / <%= raffle.total_tickets %></td>
                <td><%= raffle.tickets_left %></td>
                <td><%= paid_amount.call(raffle) %></td>
                <td><%= raffle.created_at.present? ? raffle.created_at.strftime("%d/%m/%Y") : "—" %></td>
                <td><span class="<%= status_badge.call(raffle.status) %>"><%= raffle.status.to_s.capitalize %></span></td>
                <td>
                  <%# Admin can view or delete the mini raffle %>
                  <div class="admin-raffle-actions">
                    <%= link_to "View", raffle_path(raffle), class: "btn btn-sm btn-outline-primary" %>
                    <%= button_to "Delete", admin_raffle_path(raffle), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure you want to delete this raffle?" } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="12" class="text-center text-muted py-4">No active mini raffles.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Completed raffles table %>
  <div class="admin-raffles-card">
    <div class="card-head">Completed Raffles</div>

    <div class="table-responsive">
      <table class="table table-bordered admin-raffles-table mb-0">
        <thead class="table-light">
          <tr>
            <th class="col-img">Images</th>
            <th class="col-title">Title</th>
            <th class="col-host">Host</th>
            <th class="col-type">Type</th>
            <th class="col-small">Sold</th>
            <th class="col-money">Paid</th>
            <th class="col-small">Winner</th>
            <th class="col-small">Ticket</th>
            <th class="col-date">Completed</th>
            <th class="col-small">Status</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if completed_raffles.any? %>
            <% completed_raffles.each do |raffle| %>
              <tr>
                <td>
                  <%# Displays saved raffle images for completed raffles %>
                  <div class="admin-raffle-thumb-stack">
                    <% if raffle.photos.attached? %>
                      <% raffle.photos.first(4).each do |photo| %>
                        <%= image_tag url_for(photo), alt: "" %>
                      <% end %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </div>
                </td>
                <td><%= link_to raffle.title, raffle_path(raffle), class: "text-decoration-none fw-semibold" %></td>
                <td><%= raffle.host&.username.to_s.presence || "User ##{raffle.host_id}" %></td>
                <td><%= raffle.raffle_kind.to_s == "mini" ? "Mini Raffle" : "Raffle" %></td>
                <td><%= raffle.sold_tickets_count %> / <%= raffle.total_tickets %></td>
                <td><%= paid_amount.call(raffle) %></td>
                <td><%= raffle.winner_name.presence || raffle.winner_user&.username.presence || "—" %></td>
                <td><%= raffle.winner_number.present? ? "##{raffle.winner_number}" : "—" %></td>
                <td><%= raffle.completed_at.present? ? raffle.completed_at.strftime("%d/%m/%Y") : "—" %></td>
                <td><span class="<%= status_badge.call(raffle.status) %>"><%= raffle.status.to_s.capitalize %></span></td>
                <td>
                  <%# Admin can inspect or delete completed raffle records %>
                  <div class="admin-raffle-actions">
                    <%= link_to "View", raffle_path(raffle), class: "btn btn-sm btn-outline-primary" %>
                    <%= button_to "Delete", admin_raffle_path(raffle), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure you want to delete this raffle?" } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="11" class="text-center text-muted py-4">No completed raffles.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Incompleted raffles table %>
  <div class="admin-raffles-card">
    <div class="card-head">Incompleted Raffles</div>

    <div class="table-responsive">
      <table class="table table-bordered admin-raffles-table mb-0">
        <thead class="table-light">
          <tr>
            <th class="col-img">Images</th>
            <th class="col-title">Title</th>
            <th class="col-host">Host</th>
            <th class="col-type">Type</th>
            <th class="col-small">Sold</th>
            <th class="col-small">Left</th>
            <th class="col-money">Paid</th>
            <th class="col-date">Created</th>
            <th class="col-date">Ended</th>
            <th class="col-small">Status</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% if incompleted_raffles.any? %>
            <% incompleted_raffles.each do |raffle| %>
              <tr>
                <td>
                  <%# Displays saved raffle images for raffles ended before completion %>
                  <div class="admin-raffle-thumb-stack">
                    <% if raffle.photos.attached? %>
                      <% raffle.photos.first(4).each do |photo| %>
                        <%= image_tag url_for(photo), alt: "" %>
                      <% end %>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </div>
                </td>
                <td><%= link_to raffle.title, raffle_path(raffle), class: "text-decoration-none fw-semibold" %></td>
                <td><%= raffle.host&.username.to_s.presence || "User ##{raffle.host_id}" %></td>
                <td><%= raffle.raffle_kind.to_s == "mini" ? "Mini Raffle" : "Raffle" %></td>
                <td><%= raffle.sold_tickets_count %> / <%= raffle.total_tickets %></td>
                <td><%= raffle.tickets_left %></td>
                <td><%= paid_amount.call(raffle) %></td>
                <td><%= raffle.created_at.present? ? raffle.created_at.strftime("%d/%m/%Y") : "—" %></td>
                <td><%= raffle.ended_at.present? ? raffle.ended_at.strftime("%d/%m/%Y") : "—" %></td>
                <td><span class="<%= status_badge.call(raffle.status) %>"><%= raffle.status.to_s.capitalize %></span></td>
                <td>
                  <%# Admin can view or delete incompleted raffle records %>
                  <div class="admin-raffle-actions">
                    <%= link_to "View", raffle_path(raffle), class: "btn btn-sm btn-outline-primary" %>
                    <%= button_to "Delete", admin_raffle_path(raffle), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Are you sure you want to delete this raffle?" } } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="11" class="text-center text-muted py-4">No incompleted raffles.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>