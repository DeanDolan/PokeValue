<%# Admin product value update form. Values are grouped by sealed product type. %>
<%= form_with url: update_values_admin_products_path, method: :patch, local: true do %>
  <style>
    .admin-table{width:100%;font-size:.85rem}
    .admin-table th,.admin-table td{text-align:center;vertical-align:middle}
    .col-img{width:70px}
    .col-era{width:140px}
    .col-set{width:220px}
    .col-release{width:150px}
    .col-listings{width:90px}
    .col-value{width:160px}
    .product-thumb{height:42px;width:auto;object-fit:contain}
    .admin-update-values-wrap{padding-top:1rem;margin-bottom:1.5rem}
  </style>

  <% @groups.each do |type_name, rows| %>
    <%# Each table shows one product type, for example Booster Box or Elite Trainer Box. %>
    <div class="mt-3 mb-2 fw-semibold"><%= type_name %></div>

    <div class="table-responsive">
      <table class="table table-bordered admin-table mb-3">
        <thead class="table-light">
          <tr>
            <th class="col-img">Product</th>
            <th class="col-era">Era</th>
            <th class="col-set">Set</th>
            <th class="col-release">Release Date</th>
            <th class="col-listings">Listings</th>
            <th class="col-value">Estimated Value (€)</th>
          </tr>
        </thead>

        <tbody>
          <% rows.each do |product| %>
            <tr>
              <td>
                <%# Product image links to the same public product page users see. %>
                <%= link_to product[:href] do %>
                  <%= image_tag product[:img_url], alt: product[:product_name], class: "product-thumb" %>
                <% end %>

                <div class="small text-muted text-truncate" style="max-width:180px;margin:0 auto;">
                  <%= product[:product_name] %>
                </div>
              </td>

              <td><%= product[:era] %></td>
              <td><%= product[:set_name] %></td>
              <td><%= product[:release_date] %></td>
              <td><%= product[:listings].to_i %></td>

              <td>
                <%# Hidden fields keep the product metadata attached to the edited value. %>
                <%= hidden_field_tag "names[#{product[:sku]}]", product[:product_name] %>
                <%= hidden_field_tag "set_names[#{product[:sku]}]", product[:set_name] %>
                <%= hidden_field_tag "eras[#{product[:sku]}]", product[:era] %>
                <%= hidden_field_tag "product_type_names[#{product[:sku]}]", product[:type_name] %>
                <%= hidden_field_tag "route_types[#{product[:sku]}]", product[:route_type] %>
                <%= hidden_field_tag "image_urls[#{product[:sku]}]", product[:img_url] %>

                <%# Admin-entered value becomes the live estimated value for this product. %>
                <%= number_field_tag "values[#{product[:sku]}]",
                                     product[:value],
                                     step: "0.01",
                                     min: 0,
                                     class: "form-control form-control-sm text-center",
                                     style: "max-width:140px;margin:0 auto;" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# One submit saves every changed value from every product table. %>
  <div class="d-flex justify-content-end admin-update-values-wrap">
    <button type="submit" class="btn btn-primary">Update Values</button>
  </div>
<% end %>