<%= stylesheet_link_tag "admin_sets", "data-turbo-track": "reload" %>

<%# Admin set value update page. %>
<% groups = @groups || [] %>

<div class="container py-3">
  <%# Sends edited set totals to the admin controller. %>
  <%= form_with url: admin_update_set_values_path, method: :patch, local: true do %>
    <% groups.each do |era, rows| %>
      <% next if rows.blank? %>

      <%# Each card groups sets by era. %>
      <div class="admin-sets-card">
        <div class="card-head"><%= era %></div>

        <div class="table-responsive">
          <table class="table table-bordered admin-sets-table mb-0">
            <thead class="table-light">
              <tr>
                <th class="col-img">Set</th>
                <th class="col-name">Name</th>
                <th class="col-release">Release Date</th>
                <th class="col-total">Total Set Value</th>
              </tr>
            </thead>

            <tbody>
              <% rows.each do |set| %>
                <tr>
                  <td>
                    <%# Set image links to the public set page. %>
                    <%= link_to set_path(slug: set[:slug]) do %>
                      <%= image_tag set[:img_url], alt: set[:name], class: "thumb" %>
                    <% end %>
                  </td>

                  <td class="text-center">
                    <%= link_to set[:name], set_path(slug: set[:slug]), class: "text-decoration-none" %>
                  </td>

                  <td><%= set[:release_date].presence || set[:release_raw].presence || "—" %></td>

                  <td>
                    <%# Updates the visible total set value shown on set pages. %>
                    <input class="form-control form-control-sm text-center"
                           style="max-width:160px;margin:0 auto"
                           type="number"
                           min="0"
                           step="0.01"
                           name="total_values[<%= set[:slug] %>]"
                           value="<%= set[:total_value] %>">
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <%# One button saves all edited set rows. %>
    <div class="admin-sets-actions">
      <button class="btn btn-primary btn-sm" type="submit">Update Sets</button>
    </div>
  <% end %>
</div>