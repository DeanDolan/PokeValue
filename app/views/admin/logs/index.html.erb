<%
require "json"
require "yaml"

mode = @mode.to_s
mode = "marketplace" unless %w[marketplace auction raffle].include?(mode)

tab = @tab.to_s
if mode == "auction"
  tab = "auctions" unless %w[auctions ended sold deleted].include?(tab)
elsif mode == "raffle"
  tab = "current_raffles" unless %w[current_raffles mini_raffles incompleted completed deleted].include?(tab)
else
  tab = "listings" unless %w[listings sales refunds deleted].include?(tab)
end

sets_data =
  begin
    raw = File.read(Rails.root.join("config", "sets.json"), encoding: "bom|utf-8")
    JSON.parse(raw)
  rescue
    {}
  end

type_map = {
  "etb"                      => "Elite Trainer Box",
  "pc_etb"                   => "Pokemon Center Elite Trainer Box",
  "booster_box"              => "Booster Box",
  "booster_bundle"           => "Booster Bundle",
  "booster_bundle_display"   => "Booster Bundle Display",
  "enhanced_booster_box"     => "Enhanced Booster Box",
  "ultra_premium_collection" => "Ultra Premium Collection",
  "upc"                      => "Ultra Premium Collection",
  "spc"                      => "Super Premium Collection",
  "mini_tin"                 => "Mini Tin",
  "mini_tin_display"         => "Mini Tin Display"
}

titleize = lambda do |s|
  s.to_s.tr("_", " ").tr("-", " ").split.map(&:capitalize).join(" ")
end

era_for = lambda do |slug|
  s = sets_data[slug.to_s] || sets_data.values.find { |x| x["slug"].to_s == slug.to_s }
  s ? s["era"].to_s : ""
end

set_name_for = lambda do |slug|
  s = sets_data[slug.to_s] || sets_data.values.find { |x| x["slug"].to_s == slug.to_s }
  s ? s["name"].to_s : slug.to_s
end

split_type_variant = lambda do |t|
  s = t.to_s
  down = s.downcase
  idx = down.index("--v-")
  if idx
    base = s[0...idx].to_s
    raw = s[(idx + 4)..-1].to_s
    variant = raw.tr("_", " ").tr("-", " ").split.map(&:capitalize).join(" ")
    [base.to_s, variant.to_s]
  else
    [s.to_s, ""]
  end
end

product_type_display = lambda do |obj|
  raw =
    if obj.respond_to?(:route_type) && obj.route_type.to_s.present?
      obj.route_type.to_s
    elsif obj.respond_to?(:product_type_name) && obj.product_type_name.to_s.present?
      obj.product_type_name.to_s
    elsif obj.respond_to?(:product_sku) && obj.product_sku.to_s.present?
      obj.product_sku.to_s
    elsif obj.respond_to?(:sku) && obj.sku.to_s.present?
      obj.sku.to_s
    else
      ""
    end

  raw = raw.split(":", 2)[1].to_s if raw.include?(":")
  base, variant = split_type_variant.call(raw)
  base_key = base.to_s.strip.downcase.tr(" ", "_")
  tn = type_map[base_key].presence || titleize.call(base)
  vn = variant.to_s.strip

  if tn.to_s.downcase.include?("pokemon center") && vn.present?
    vn = vn.gsub(/\bpokemon\s+center\b/i, " ").strip
    vn = vn.gsub(/\s{2,}/, " ").strip
    tokens = vn.split
    if tokens.last && tokens.last.casecmp("o").zero?
      tokens.pop
      vn = tokens.join(" ").strip
    end
  end

  vn.present? ? "#{tn} (#{vn})" : tn
rescue
  "-"
end

parse_debug_context = lambda do |raw|
  return {} if raw.nil?
  s = raw.to_s.strip
  return {} if s.blank?

  begin
    v = JSON.parse(s)
    return v.is_a?(Hash) ? v : {}
  rescue
  end

  begin
    v = YAML.safe_load(s, permitted_classes: [Time, Date], aliases: true)
    return v.is_a?(Hash) ? v : {}
  rescue
  end

  if s.start_with?("{") && s.include?("=>")
    s2 = s.dup
    s2.gsub!(/:(\w+)\s*=>/, '"\1"=>')
    s2.gsub!("=>", ":")
    s2.gsub!(/\bnil\b/, "null")
    begin
      v = JSON.parse(s2)
      return v.is_a?(Hash) ? v : {}
    rescue
    end
  end

  {}
rescue
  {}
end

refund_note_for = lambda do |p|
  cols = p.class.column_names rescue []
  %w[refund_note seller_note note notes].each do |c|
    if cols.include?(c) && p.respond_to?(c)
      v = p.public_send(c) rescue nil
      return v.to_s if v.present?
    end
  end

  if cols.include?("debug_context") && p.respond_to?(:debug_context)
    h = parse_debug_context.call(p.debug_context)
    return h["refund_note"].to_s if h["refund_note"].present?
    return h["note"].to_s if h["note"].present?
    return h["notes"].to_s if h["notes"].present?
    if h["refund"].is_a?(Hash)
      r = h["refund"]
      return r["refund_note"].to_s if r["refund_note"].present?
      return r["note"].to_s if r["note"].present?
      return r["notes"].to_s if r["notes"].present?
    end
  end

  ""
rescue
  ""
end

refund_date_for = lambda do |p|
  cols = p.class.column_names rescue []

  if cols.include?("refunded_at") && p.respond_to?(:refunded_at) && p.refunded_at.present?
    p.refunded_at
  elsif cols.include?("debug_context") && p.respond_to?(:debug_context)
    h = parse_debug_context.call(p.debug_context)
    t = h["refunded_at"].presence || h["refund_at"].presence
    if t.blank? && h["refund"].is_a?(Hash)
      r = h["refund"]
      t = r["refunded_at"].presence || r["refund_at"].presence || r["at"].presence
    end
    if t.present?
      begin
        Time.zone.parse(t.to_s)
      rescue
        p.updated_at
      end
    else
      p.updated_at
    end
  else
    p.updated_at
  end
rescue
  p.updated_at
end

total_cents_for = lambda do |p|
  cols = p.class.column_names rescue []
  if cols.include?("total_cents") && p.respond_to?(:total_cents) && p.total_cents.to_i > 0
    p.total_cents.to_i
  elsif cols.include?("total_price_cents") && p.respond_to?(:total_price_cents) && p.total_price_cents.to_i > 0
    p.total_price_cents.to_i
  elsif cols.include?("unit_price_cents") && cols.include?("quantity") && p.respond_to?(:unit_price_cents) && p.respond_to?(:quantity)
    p.unit_price_cents.to_i * p.quantity.to_i
  elsif cols.include?("price_cents") && cols.include?("quantity") && p.respond_to?(:price_cents) && p.respond_to?(:quantity)
    p.price_cents.to_i * p.quantity.to_i
  else
    0
  end
rescue
  0
end

status_badge = lambda do |value|
  v = value.to_s.downcase
  text =
    case v
    when "deleted"
      "Deleted"
    when "sold"
      "Sold"
    when "ended"
      "Ended"
    when "completed", "complete"
      "Completed"
    when "incompleted", "incomplete"
      "Incompleted"
    else
      "Active"
    end

  css =
    case v
    when "deleted"
      "lg-status lg-status-deleted"
    when "sold"
      "lg-status lg-status-sold"
    when "ended"
      "lg-status lg-status-ended"
    when "completed", "complete"
      "lg-status lg-status-completed"
    when "incompleted", "incomplete"
      "lg-status lg-status-incompleted"
    else
      "lg-status lg-status-active"
    end

  %(<span class="#{css}">#{text}</span>).html_safe
end

listings = defined?(@listings) && @listings ? @listings : []
sales = defined?(@sales) && @sales ? @sales : []
refunds = defined?(@refunds) && @refunds ? @refunds : []
deleted_listings = defined?(@deleted_listings) && @deleted_listings ? @deleted_listings : []
auctions = defined?(@auctions) && @auctions ? @auctions : []
raffles = defined?(@raffles) && @raffles ? @raffles : []

marketplace_listing_row = lambda do |obj|
  defined?(MarketplaceListing) && obj.is_a?(MarketplaceListing)
end

purchase_listing_ids = []
Array(sales).each do |p|
  if p.respond_to?(:marketplace_listing_id) && p.marketplace_listing_id.present?
    purchase_listing_ids << p.marketplace_listing_id.to_i
  elsif p.respond_to?(:listing_id) && p.listing_id.present?
    purchase_listing_ids << p.listing_id.to_i
  elsif marketplace_listing_row.call(p)
    purchase_listing_ids << p.id.to_i
  end
end
Array(refunds).each do |p|
  if p.respond_to?(:marketplace_listing_id) && p.marketplace_listing_id.present?
    purchase_listing_ids << p.marketplace_listing_id.to_i
  elsif p.respond_to?(:listing_id) && p.listing_id.present?
    purchase_listing_ids << p.listing_id.to_i
  end
end
purchase_listing_ids.uniq!

listing_map = {}
if defined?(MarketplaceListing) && purchase_listing_ids.any?
  listing_map = MarketplaceListing.where(id: purchase_listing_ids).includes(:seller).index_by(&:id)
end

purchase_listing_for = lambda do |p|
  if p.respond_to?(:marketplace_listing_id) && p.marketplace_listing_id.present?
    listing_map[p.marketplace_listing_id.to_i]
  elsif p.respond_to?(:listing_id) && p.listing_id.present?
    listing_map[p.listing_id.to_i]
  elsif marketplace_listing_row.call(p)
    p
  else
    nil
  end
end

purchase_slug = lambda do |p, l|
  (p.respond_to?(:set_slug) ? p.set_slug.to_s : "").presence ||
    (l && l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || ""
end

purchase_set = lambda do |p, l|
  (p.respond_to?(:set_name) ? p.set_name.to_s : "").presence ||
    (l && l.respond_to?(:set_name) ? l.set_name.to_s : "").presence ||
    set_name_for.call(purchase_slug.call(p, l))
end

purchase_era = lambda do |p, l|
  (p.respond_to?(:era) ? p.era.to_s : "").presence || era_for.call(purchase_slug.call(p, l))
end

purchase_type = lambda do |p, l|
  t = product_type_display.call(p)
  return t if t.present? && t != "-"
  l ? product_type_display.call(l) : "-"
end

purchase_condition = lambda do |p, l|
  (p.respond_to?(:condition) ? p.condition.to_s : "").presence ||
    (l && l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-"
end

auction_top_bid = lambda do |a|
  if a.respond_to?(:winning_bid_cents) && a.winning_bid_cents.to_i > 0
    a.winning_bid_cents.to_i
  elsif a.respond_to?(:current_bid_cents) && a.current_bid_cents.to_i > 0
    a.current_bid_cents.to_i
  elsif a.respond_to?(:current_bid_cents_value) && a.current_bid_cents_value.to_i > 0
    a.current_bid_cents_value.to_i
  else
    0
  end
end

auction_bids_count = lambda do |a|
  if a.respond_to?(:bids_count)
    a.bids_count.to_i
  elsif a.respond_to?(:auction_bids)
    a.auction_bids.count
  else
    0
  end
rescue
  0
end

auction_length_label = lambda do |a|
  if a.respond_to?(:auction_length_label) && a.auction_length_label.present?
    a.auction_length_label.to_s
  elsif a.respond_to?(:auction_length_seconds) && a.auction_length_seconds.present?
    {
      60 => "1 min",
      3600 => "1 hour",
      10800 => "3 hours",
      21600 => "6 hours",
      43200 => "12 hours",
      86400 => "1 day",
      259200 => "3 days",
      604800 => "1 week"
    }[a.auction_length_seconds.to_i] || "-"
  else
    "-"
  end
end

auction_reserve_status = lambda do |a|
  if a.respond_to?(:reserve_status) && a.reserve_status.present?
    a.reserve_status.to_s
  elsif a.respond_to?(:reserve_enabled)
    a.reserve_enabled ? "Reserve" : "No Reserve"
  else
    "-"
  end
end

auction_time_remaining = lambda do |a|
  return "-" unless tab == "auctions"
  return "-" unless a.respond_to?(:ends_at)
  return "-" if a.ends_at.blank?

  diff = (a.ends_at.to_f - Time.current.to_f).to_i
  return "Ended" if diff <= 0

  days = diff / 86400
  hours = (diff % 86400) / 3600
  minutes = (diff % 3600) / 60
  seconds = diff % 60

  if days > 0
    "#{days}d #{hours}h #{minutes}m"
  elsif hours > 0
    "#{hours}h #{minutes}m #{seconds}s"
  else
    "#{minutes}m #{seconds}s"
  end
end

raffle_title_for = lambda do |r|
  cols = r.class.column_names rescue []
  %w[title name raffle_name product_name prize_name prize_title].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      return v.to_s if v.present?
    end
  end

  if r.respond_to?(:description) && r.description.present?
    return r.description.to_s.truncate(80)
  end

  "Raffle ##{r.respond_to?(:id) ? r.id : ""}"
rescue
  "-"
end

raffle_host_for = lambda do |r|
  %i[host seller user creator admin_user].each do |assoc|
    if r.respond_to?(assoc)
      u = r.public_send(assoc) rescue nil
      return u.username.to_s if u && u.respond_to?(:username) && u.username.present?
      return u.email.to_s if u && u.respond_to?(:email) && u.email.present?
    end
  end

  cols = r.class.column_names rescue []
  %w[host_username username].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      return v.to_s if v.present?
    end
  end

  %w[host_id seller_id user_id creator_id admin_user_id].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      user = User.find_by(id: v) rescue nil
      return user.username.to_s if user && user.respond_to?(:username) && user.username.present?
      return "User ##{v}" if v.present?
    end
  end

  "-"
rescue
  "-"
end

raffle_mini_for = lambda do |r|
  cols = r.class.column_names rescue []

  %w[mini is_mini mini_raffle is_mini_raffle].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      return true if v == true || v.to_s == "true" || v.to_s == "1"
    end
  end

  %w[raffle_type raffle_kind kind category mode].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c).to_s.downcase rescue ""
      return true if v.include?("mini")
    end
  end

  false
rescue
  false
end

raffle_type_for = lambda do |r|
  raffle_mini_for.call(r) ? "Mini Raffle" : "Raffle"
end

raffle_status_for = lambda do |r|
  if r.respond_to?(:status) && r.status.present?
    r.status.to_s
  elsif tab == "completed"
    "completed"
  elsif tab == "incompleted"
    "incompleted"
  elsif tab == "deleted"
    "deleted"
  else
    "active"
  end
rescue
  "active"
end

raffle_ticket_price_for = lambda do |r|
  cols = r.class.column_names rescue []
  cents = nil

  %w[ticket_price_cents price_cents entry_price_cents cost_cents].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      cents = v.to_i if v.present?
      break if cents
    end
  end

  if cents
    number_to_currency(cents / 100.0, unit: "€")
  elsif r.respond_to?(:ticket_price) && r.ticket_price.present?
    number_to_currency(r.ticket_price.to_f, unit: "€")
  elsif r.respond_to?(:price) && r.price.present?
    number_to_currency(r.price.to_f, unit: "€")
  else
    "-"
  end
rescue
  "-"
end

raffle_tickets_for = lambda do |r|
  cols = r.class.column_names rescue []

  sold = nil
  total = nil

  %w[tickets_sold sold_tickets purchased_tickets entries_count].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      sold = v.to_i if v.present?
      break if sold
    end
  end

  %w[total_tickets ticket_count tickets_count max_tickets quantity].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      total = v.to_i if v.present?
      break if total
    end
  end

  if sold && total
    "#{sold} / #{total}"
  elsif total
    total.to_s
  elsif sold
    sold.to_s
  else
    "-"
  end
rescue
  "-"
end

raffle_date_for = lambda do |r|
  cols = r.class.column_names rescue []

  %w[deleted_at completed_at ended_at updated_at created_at].each do |c|
    if cols.include?(c) && r.respond_to?(c)
      v = r.public_send(c) rescue nil
      return v.strftime("%d %b %Y") if v.respond_to?(:strftime) && v.present?
    end
  end

  "-"
rescue
  "-"
end
%>

<div class="container py-4">
  <style>
    .acc-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.08);margin-bottom:12px;overflow:hidden}
    .acc-tabs{display:flex;gap:8px;flex-wrap:wrap;margin:6px 0 12px}
    .acc-tabs a{font-size:.7rem;padding:.26rem .52rem;border-radius:999px;border:1px solid #e5e7eb;text-decoration:none;color:#111827;white-space:nowrap}
    .acc-tabs a.active{border-color:#111827;font-weight:900}
    .subhead{font-size:.95rem;font-weight:900;margin:0 0 10px}
    .mp-table{width:100%;border-collapse:separate;border-spacing:0;table-layout:fixed}
    .mp-table th{border-bottom:1px solid #eef2f7;padding:6px 6px;text-align:center;vertical-align:middle;font-size:.62rem;white-space:nowrap;overflow:hidden;text-overflow:clip}
    .mp-table td{border-bottom:1px solid #eef2f7;padding:6px 6px;text-align:center;vertical-align:top;font-size:.62rem;white-space:normal;overflow:visible;text-overflow:clip;overflow-wrap:anywhere;word-break:break-word;line-height:1.15}
    .mp-table th{font-weight:900;color:#111827;background:#fafafa}
    .mp-actions{display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:nowrap;white-space:nowrap}
    .mp-actions .btn{font-size:.6rem;padding:.12rem .32rem;line-height:1.05}
    .mp-empty{color:#6b7280;font-size:.85rem;text-align:center;padding:12px 0}
    .lg-status{display:inline-block;padding:.14rem .38rem;border-radius:999px;border:1px solid transparent;font-weight:900;font-size:.58rem;line-height:1}
    .lg-status-active{background:#ecfdf5;color:#166534;border-color:#22c55e}
    .lg-status-ended{background:#f3f4f6;color:#4b5563;border-color:#9ca3af}
    .lg-status-sold{background:#dc2626;color:#ffffff;border-color:#7f1d1d}
    .lg-status-deleted{background:#000000;color:#d4af37;border-color:#d4af37}
    .lg-status-completed{background:#ecfdf5;color:#166534;border-color:#22c55e}
    .lg-status-incompleted{background:#fef3c7;color:#92400e;border-color:#f59e0b}
    .w-id{width:4%}
    .w-seller{width:10%}
    .w-buyer{width:10%}
    .w-era{width:8%}
    .w-set{width:11%}
    .w-type{width:15%}
    .w-cond{width:10%}
    .w-price{width:8%}
    .w-qty{width:5%}
    .w-status{width:7%}
    .w-date{width:8%}
    .w-actions{width:6%}
    .w-total{width:9%}
    .w-note{width:8%}
    .w-desc{width:18%}
    .w-bids{width:6%}
    .w-length{width:8%}
    .w-time{width:10%}
    .w-reserve{width:8%}
    .w-title{width:20%}
    .w-raffle-type{width:10%}
    .w-ticket-price{width:9%}
    .w-tickets{width:9%}
  </style>

  <div class="acc-card">
    <div class="subhead">Logs</div>

    <div class="acc-tabs">
      <%= link_to "Marketplace Logs", admin_logs_path(mode: "marketplace", tab: (mode == "marketplace" ? tab : "listings")), class: ["", (mode == "marketplace" ? "active" : nil)].compact.join(" ") %>
      <%= link_to "Auction Logs", admin_logs_path(mode: "auction", tab: (mode == "auction" ? tab : "auctions")), class: ["", (mode == "auction" ? "active" : nil)].compact.join(" ") %>
      <%= link_to "Raffle Logs", admin_logs_path(mode: "raffle", tab: (mode == "raffle" ? tab : "current_raffles")), class: ["", (mode == "raffle" ? "active" : nil)].compact.join(" ") %>
    </div>

    <% if mode == "marketplace" %>
      <div class="acc-tabs">
        <%= link_to "Listings", admin_logs_path(mode: "marketplace", tab: "listings"), class: ["", (tab == "listings" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Sales", admin_logs_path(mode: "marketplace", tab: "sales"), class: ["", (tab == "sales" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Refunds", admin_logs_path(mode: "marketplace", tab: "refunds"), class: ["", (tab == "refunds" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Deleted", admin_logs_path(mode: "marketplace", tab: "deleted"), class: ["", (tab == "deleted" ? "active" : nil)].compact.join(" ") %>
      </div>

      <% if tab == "listings" %>
        <% if listings.any? %>
          <table class="mp-table">
            <thead>
              <tr>
                <th class="w-id">ID</th>
                <th class="w-seller">Seller</th>
                <th class="w-era">Era</th>
                <th class="w-set">Set</th>
                <th class="w-type">Product Type</th>
                <th class="w-cond">Condition</th>
                <th class="w-price">Price</th>
                <th class="w-qty">Qty</th>
                <th class="w-status">Status</th>
                <th class="w-date">Listed</th>
                <th class="w-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% listings.each do |l| %>
                <% seller = (l.respond_to?(:seller) ? l.seller : nil) %>
                <% slug = (l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || "" %>
                <tr>
                  <td class="w-id"><%= l.respond_to?(:id) ? l.id : "" %></td>
                  <td class="w-seller"><%= seller&.respond_to?(:username) ? seller.username : (l.respond_to?(:seller_id) ? "User ##{l.seller_id}" : "-") %></td>
                  <td class="w-era"><%= (l.respond_to?(:era) ? l.era.to_s : "").presence || era_for.call(slug).presence || "-" %></td>
                  <td class="w-set"><%= (l.respond_to?(:set_name) ? l.set_name.to_s : "").presence || set_name_for.call(slug).presence || "-" %></td>
                  <td class="w-type"><%= product_type_display.call(l) %></td>
                  <td class="w-cond"><%= (l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-" %></td>
                  <td class="w-price"><%= number_to_currency(l.respond_to?(:price_cents) ? (l.price_cents.to_i / 100.0) : 0, unit: "€") %></td>
                  <td class="w-qty"><%= l.respond_to?(:quantity) ? l.quantity.to_i : "-" %></td>
                  <td class="w-status"><%= status_badge.call(l.respond_to?(:status) ? l.status : "active") %></td>
                  <td class="w-date"><%= l.respond_to?(:created_at) && l.created_at ? l.created_at.strftime("%d %b %Y") : "" %></td>
                  <td class="w-actions">
                    <div class="mp-actions">
                      <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="mp-empty">No listings.</div>
        <% end %>

      <% elsif tab == "sales" %>
        <% if sales.any? %>
          <table class="mp-table">
            <thead>
              <tr>
                <th class="w-id">ID</th>
                <th class="w-seller">Seller</th>
                <th class="w-buyer">Buyer</th>
                <th class="w-era">Era</th>
                <th class="w-set">Set</th>
                <th class="w-type">Product Type</th>
                <th class="w-cond">Condition</th>
                <th class="w-qty">Qty</th>
                <th class="w-total">Total</th>
                <th class="w-status">Status</th>
                <th class="w-date">Sale Date</th>
                <th class="w-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% sales.each do |p| %>
                <% seller = (p.respond_to?(:seller_id) ? User.find_by(id: p.seller_id) : nil) %>
                <% buyer = (p.respond_to?(:buyer_id) ? User.find_by(id: p.buyer_id) : nil) %>
                <% l = purchase_listing_for.call(p) %>
                <% cents = total_cents_for.call(p) %>
                <tr>
                  <td class="w-id"><%= p.respond_to?(:id) ? p.id : "" %></td>
                  <td class="w-seller"><%= seller&.respond_to?(:username) ? seller.username : (p.respond_to?(:seller_id) ? "User ##{p.seller_id}" : "-") %></td>
                  <td class="w-buyer"><%= buyer&.respond_to?(:username) ? buyer.username : (p.respond_to?(:buyer_id) ? "User ##{p.buyer_id}" : "-") %></td>
                  <td class="w-era"><%= purchase_era.call(p, l).presence || "-" %></td>
                  <td class="w-set"><%= purchase_set.call(p, l).presence || "-" %></td>
                  <td class="w-type"><%= purchase_type.call(p, l).presence || "-" %></td>
                  <td class="w-cond"><%= purchase_condition.call(p, l).presence || "-" %></td>
                  <td class="w-qty"><%= p.respond_to?(:quantity) ? p.quantity.to_i : "-" %></td>
                  <td class="w-total"><%= number_to_currency(cents / 100.0, unit: "€") %></td>
                  <td class="w-status"><%= status_badge.call("sold") %></td>
                  <td class="w-date"><%= p.respond_to?(:created_at) && p.created_at ? p.created_at.strftime("%d %b %Y") : "" %></td>
                  <td class="w-actions">
                    <div class="mp-actions">
                      <% if l %>
                        <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                      <% else %>
                        <span class="text-muted">-</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="mp-empty">No sales.</div>
        <% end %>

      <% elsif tab == "refunds" %>
        <% if refunds.any? %>
          <table class="mp-table">
            <thead>
              <tr>
                <th class="w-id">ID</th>
                <th class="w-seller">Seller</th>
                <th class="w-buyer">Buyer</th>
                <th class="w-era">Era</th>
                <th class="w-set">Set</th>
                <th class="w-type">Product Type</th>
                <th class="w-cond">Condition</th>
                <th class="w-qty">Qty</th>
                <th class="w-total">Total</th>
                <th class="w-date">Refund Date</th>
                <th class="w-note">Note</th>
              </tr>
            </thead>
            <tbody>
              <% refunds.each do |p| %>
                <% seller = (p.respond_to?(:seller_id) ? User.find_by(id: p.seller_id) : nil) %>
                <% buyer = (p.respond_to?(:buyer_id) ? User.find_by(id: p.buyer_id) : nil) %>
                <% l = purchase_listing_for.call(p) %>
                <% cents = total_cents_for.call(p) %>
                <% note = refund_note_for.call(p).to_s %>
                <% rdate = refund_date_for.call(p) %>
                <tr>
                  <td class="w-id"><%= p.respond_to?(:id) ? p.id : "" %></td>
                  <td class="w-seller"><%= seller&.respond_to?(:username) ? seller.username : (p.respond_to?(:seller_id) ? "User ##{p.seller_id}" : "-") %></td>
                  <td class="w-buyer"><%= buyer&.respond_to?(:username) ? buyer.username : (p.respond_to?(:buyer_id) ? "User ##{p.buyer_id}" : "-") %></td>
                  <td class="w-era"><%= purchase_era.call(p, l).presence || "-" %></td>
                  <td class="w-set"><%= purchase_set.call(p, l).presence || "-" %></td>
                  <td class="w-type"><%= purchase_type.call(p, l).presence || "-" %></td>
                  <td class="w-cond"><%= purchase_condition.call(p, l).presence || "-" %></td>
                  <td class="w-qty"><%= p.respond_to?(:quantity) ? p.quantity.to_i : "-" %></td>
                  <td class="w-total"><%= number_to_currency(cents / 100.0, unit: "€") %></td>
                  <td class="w-date"><%= rdate ? rdate.strftime("%d %b %Y") : "" %></td>
                  <td class="w-note">
                    <% if note.present? %>
                      <div class="mp-actions">
                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#adminNote-<%= p.id %>">View</button>
                      </div>
                      <div class="modal fade" id="adminNote-<%= p.id %>" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                          <div class="modal-content">
                            <div class="modal-header">
                              <h5 class="modal-title">Refund Note</h5>
                              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body" style="white-space:pre-wrap"><%= note %></div>
                          </div>
                        </div>
                      </div>
                    <% else %>
                      <span class="text-muted">No note</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="mp-empty">No refunds.</div>
        <% end %>

      <% else %>
        <% if deleted_listings.any? %>
          <table class="mp-table">
            <thead>
              <tr>
                <th class="w-id">ID</th>
                <th class="w-seller">Seller</th>
                <th class="w-era">Era</th>
                <th class="w-set">Set</th>
                <th class="w-type">Product Type</th>
                <th class="w-cond">Condition</th>
                <th class="w-price">Price</th>
                <th class="w-status">Status</th>
                <th class="w-date">Deleted</th>
                <th class="w-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% deleted_listings.each do |l| %>
                <% seller = (l.respond_to?(:seller) ? l.seller : nil) %>
                <% slug = (l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || "" %>
                <tr>
                  <td class="w-id"><%= l.respond_to?(:id) ? l.id : "" %></td>
                  <td class="w-seller"><%= seller&.respond_to?(:username) ? seller.username : (l.respond_to?(:seller_id) ? "User ##{l.seller_id}" : "-") %></td>
                  <td class="w-era"><%= (l.respond_to?(:era) ? l.era.to_s : "").presence || era_for.call(slug).presence || "-" %></td>
                  <td class="w-set"><%= (l.respond_to?(:set_name) ? l.set_name.to_s : "").presence || set_name_for.call(slug).presence || "-" %></td>
                  <td class="w-type"><%= product_type_display.call(l) %></td>
                  <td class="w-cond"><%= (l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-" %></td>
                  <td class="w-price"><%= number_to_currency(l.respond_to?(:price_cents) ? (l.price_cents.to_i / 100.0) : 0, unit: "€") %></td>
                  <td class="w-status"><%= status_badge.call("deleted") %></td>
                  <td class="w-date"><%= l.respond_to?(:updated_at) && l.updated_at ? l.updated_at.strftime("%d %b %Y") : "" %></td>
                  <td class="w-actions">
                    <div class="mp-actions">
                      <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="mp-empty">No deleted listings.</div>
        <% end %>
      <% end %>

    <% elsif mode == "auction" %>
      <div class="acc-tabs">
        <%= link_to "Auctions", admin_logs_path(mode: "auction", tab: "auctions"), class: ["", (tab == "auctions" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Ended", admin_logs_path(mode: "auction", tab: "ended"), class: ["", (tab == "ended" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Sold", admin_logs_path(mode: "auction", tab: "sold"), class: ["", (tab == "sold" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Deleted", admin_logs_path(mode: "auction", tab: "deleted"), class: ["", (tab == "deleted" ? "active" : nil)].compact.join(" ") %>
      </div>

      <% if auctions.any? %>
        <table class="mp-table">
          <thead>
            <tr>
              <th class="w-id">ID</th>
              <th class="w-seller">Seller</th>
              <th class="w-desc">Description</th>
              <th class="w-cond">Condition</th>
              <th class="w-bids">Bids</th>
              <th class="w-price">Top Bid</th>
              <th class="w-reserve">Reserve Status</th>
              <th class="w-length">Length</th>
              <% if tab == "auctions" %>
                <th class="w-time">Time Remaining</th>
              <% end %>
              <th class="w-status">Status</th>
              <th class="w-date">Updated</th>
              <th class="w-actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% auctions.each do |a| %>
              <% seller = (a.respond_to?(:seller) ? a.seller : nil) %>
              <tr>
                <td class="w-id"><%= a.respond_to?(:id) ? a.id : "" %></td>
                <td class="w-seller"><%= seller&.respond_to?(:username) ? seller.username : (a.respond_to?(:seller_id) ? "User ##{a.seller_id}" : "-") %></td>
                <td class="w-desc"><%= a.respond_to?(:auction_description) ? a.auction_description.to_s : "-" %></td>
                <td class="w-cond"><%= a.respond_to?(:condition) ? a.condition.to_s.presence || "-" : "-" %></td>
                <td class="w-bids"><%= auction_bids_count.call(a) %></td>
                <td class="w-price"><%= number_to_currency(auction_top_bid.call(a) / 100.0, unit: "€") %></td>
                <td class="w-reserve"><%= auction_reserve_status.call(a) %></td>
                <td class="w-length"><%= auction_length_label.call(a) %></td>
                <% if tab == "auctions" %>
                  <td class="w-time"><%= auction_time_remaining.call(a) %></td>
                <% end %>
                <td class="w-status"><%= status_badge.call(a.respond_to?(:status) ? a.status : "active") %></td>
                <td class="w-date"><%= a.respond_to?(:updated_at) && a.updated_at ? a.updated_at.strftime("%d %b %Y") : "" %></td>
                <td class="w-actions">
                  <div class="mp-actions">
                    <%= link_to "View", auction_listing_path(a), class: "btn btn-outline-primary btn-sm" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="mp-empty">No auction logs for this section.</div>
      <% end %>

    <% else %>
      <div class="acc-tabs">
        <%= link_to "Current Raffles", admin_logs_path(mode: "raffle", tab: "current_raffles"), class: ["", (tab == "current_raffles" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Mini Raffles", admin_logs_path(mode: "raffle", tab: "mini_raffles"), class: ["", (tab == "mini_raffles" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Incompleted", admin_logs_path(mode: "raffle", tab: "incompleted"), class: ["", (tab == "incompleted" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Completed", admin_logs_path(mode: "raffle", tab: "completed"), class: ["", (tab == "completed" ? "active" : nil)].compact.join(" ") %>
        <%= link_to "Deleted", admin_logs_path(mode: "raffle", tab: "deleted"), class: ["", (tab == "deleted" ? "active" : nil)].compact.join(" ") %>
      </div>

      <% if raffles.any? %>
        <table class="mp-table">
          <thead>
            <tr>
              <th class="w-id">ID</th>
              <th class="w-seller">Host</th>
              <th class="w-title">Raffle</th>
              <th class="w-raffle-type">Type</th>
              <th class="w-ticket-price">Ticket Price</th>
              <th class="w-tickets">Tickets</th>
              <th class="w-status">Status</th>
              <th class="w-date">Updated</th>
              <th class="w-actions">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% raffles.each do |r| %>
              <% view_href = (raffle_path(r) rescue nil) %>
              <tr>
                <td class="w-id"><%= r.respond_to?(:id) ? r.id : "" %></td>
                <td class="w-seller"><%= raffle_host_for.call(r) %></td>
                <td class="w-title"><%= raffle_title_for.call(r) %></td>
                <td class="w-raffle-type"><%= raffle_type_for.call(r) %></td>
                <td class="w-ticket-price"><%= raffle_ticket_price_for.call(r) %></td>
                <td class="w-tickets"><%= raffle_tickets_for.call(r) %></td>
                <td class="w-status"><%= status_badge.call(raffle_status_for.call(r)) %></td>
                <td class="w-date"><%= raffle_date_for.call(r) %></td>
                <td class="w-actions">
                  <div class="mp-actions">
                    <% if view_href.present? %>
                      <%= link_to "View", view_href, class: "btn btn-outline-primary btn-sm" %>
                    <% else %>
                      <span class="text-muted">-</span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="mp-empty">No raffle logs for this section.</div>
      <% end %>
    <% end %>
  </div>
</div>