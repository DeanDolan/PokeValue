    .au-hidden-tag.revealed{background:#111827;color:#fff}
    .pv-au-rating-stars{display:inline-flex !important;align-items:center !important;gap:1px !important;white-space:nowrap !important;line-height:1 !important;vertical-align:middle !important;color:#d4a017 !important}
    .pv-au-rating-star{display:inline-block !important;position:static !important;width:auto !important;height:auto !important;overflow:visible !important;color:#d4a017 !important;line-height:1 !important;text-shadow:none !important}
    .pv-au-rating-half{display:inline-block !important;position:static !important;width:auto !important;height:auto !important;overflow:visible !important;color:#d4a017 !important;line-height:1 !important;font-weight:900 !important;font-size:.8em !important;text-shadow:none !important}
    .au-review-form-wrap{display:none;max-width:460px;margin:8px 0 14px}
    .au-confirm-backdrop{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;z-index:99999;padding:16px}
    .au-confirm-box{width:100%;max-width:430px;border-radius:18px;border:1px solid #000000;background:#ffffff;color:#000000;box-shadow:0 24px 70px rgba(0,0,0,.32);padding:20px;text-align:center}
    .au-confirm-text{color:#000000;font-size:.96rem;font-weight:800;line-height:1.45;margin:0 0 18px}
    .au-confirm-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
    .au-confirm-yes,.au-confirm-no{min-width:86px;border-radius:999px;font-weight:800;font-size:.86rem;padding:.42rem .9rem;border:1px solid #000000 !important;transition:background-color .12s ease,color .12s ease,border-color .12s ease,box-shadow .12s ease !important}
    .au-confirm-yes{background:#000000 !important;color:#ffffff !important}
    .au-confirm-no{background:#ffffff !important;color:#000000 !important}
    .au-confirm-yes:hover,.au-confirm-yes:focus,.au-confirm-yes:active,.au-confirm-no:hover,.au-confirm-no:focus,.au-confirm-no:active{background:#d4af37 !important;color:#000000 !important;border-color:#d4af37 !important;box-shadow:0 0 0 .16rem rgba(212,175,55,.25) !important}
