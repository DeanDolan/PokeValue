<%#
References:
- Rails Action View helpers:
  https://guides.rubyonrails.org/action_view_helpers.html
- Rails Active Storage display helpers:
  https://guides.rubyonrails.org/active_storage_overview.html
- Rails form helpers:
  https://api.rubyonrails.org/classes/ActionView/Helpers/FormHelper.html
- Bootstrap modals and buttons:
  https://getbootstrap.com/docs/5.3/components/modal/
  https://getbootstrap.com/docs/5.3/components/buttons/
- MDN DOM events, dataset and timers:
  https://developer.mozilla.org/en-US/docs/Web/API/EventTarget/addEventListener
  https://developer.mozilla.org/en-US/docs/Web/API/HTMLElement/dataset
  https://developer.mozilla.org/en-US/docs/Web/API/setInterval
%>

<%
# Main auction object loaded by the controller.
auction = @auction
seller = auction.seller
seller_name = seller&.username.to_s.presence || "User ##{auction.seller_id}"
seller_badges = auction_badges_for(seller)
seller_stats = @seller_stats || { avg: 0.0, count: 0 }

country_code = seller&.country_code.to_s.upcase
reserve_label = auction.no_reserve? ? "No Reserve" : "Reserve"
status_label = auction_status_label(auction)
status_badge_class = auction_status_badge_class(auction)
status_key = auction.status.to_s
images = auction_images_for(auction)

winning_bidder = auction.winning_bidder
current_user_id = current_user&.id.to_i
is_host = current_user_id.present? && current_user_id == auction.seller_id.to_i
is_winner = current_user_id.present? && winning_bidder && current_user_id == winning_bidder.id.to_i
can_bid_now = auction.running? && !is_host
owner_can_end = current_user && auction.can_end_early_by?(current_user)
admin_can_delete = auction_admin_user?(current_user)

highest_bid_display = auction.current_bid_cents_value.to_i.positive? ? number_to_currency(auction.current_bid_cents_value.to_i / 100.0, unit: "€") : "No bids yet"
reviews = @reviews || []
can_give_review = @can_give_review || false
review_form_id = "auction-review-form-#{auction.id}"
host_revolut_tag = auction.host_revolut_tag.to_s
winner_revolut_tag = auction.winner_revolut_tag.to_s

remaining_text =
  case status_key
  when "payment_pending"
    "Awaiting Payment"
  when "paid"
    "Awaiting Host Verification"
  when "sold"
    "Sold"
  else
    auction_time_left_text(auction)
  end
%>

<div class="container py-4">
  <style>
    .au-show{display:flex;gap:18px;align-items:flex-start;flex-wrap:wrap}
    .au-left{flex:1;min-width:320px}
    .au-right{width:420px;max-width:100%}
    .au-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.08)}
    .au-section{margin-top:14px}
    .au-title{font-size:1.2rem;margin:0 0 6px}
    .au-sub{color:#6b7280;font-size:.85rem;margin:0 0 14px}
    .au-line{font-size:.88rem;margin:6px 0}
    .au-line strong{font-weight:700}
    .au-desc{white-space:pre-wrap;word-break:break-word}
    .au-actions{margin-top:10px;display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .au-btn{padding:6px 10px;font-size:.85rem}
    .au-thumbs{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
    .au-thumb{width:100%;height:160px;object-fit:cover;border-radius:12px;border:1px solid #e5e7eb;cursor:pointer;transition:transform .12s ease}
    .au-thumb:hover{transform:scale(1.03)}
    .au-badges{display:inline-flex;gap:6px;align-items:center;flex-wrap:wrap}
    .au-badges img{height:22px;width:22px;object-fit:contain}
    .au-pay{margin-top:12px;border:1px solid #e5e7eb;border-radius:14px;padding:12px;background:#f9fafb}
    .au-hidden-tag{display:inline-flex;align-items:center;justify-content:center;min-width:150px;height:30px;background:#000;color:#000;border-radius:8px;padding:0 10px;font-weight:800;letter-spacing:.04em;user-select:none}
    .au-hidden-tag.revealed{background:#111827;color:#fff}
    .pv-au-rating-stars{display:inline-flex;align-items:center;gap:1px;white-space:nowrap;color:#d4a017;line-height:1}
    .pv-au-rating-star,.pv-au-rating-half{display:inline-block;color:#d4a017;line-height:1}
    .pv-au-rating-half{font-weight:900;font-size:.8em}
    .au-review-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:12px;margin-bottom:8px}
    .au-review-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;flex-wrap:wrap}
    .au-review-name{font-weight:900;font-size:.9rem}
    .au-review-stars{display:flex;align-items:center;gap:6px;white-space:nowrap}
    .au-review-body{margin-top:6px;color:#111827;font-size:.9rem;white-space:pre-wrap}
    .au-review-meta{color:#6b7280;font-size:.8rem}
    .au-review-form{display:none;max-width:460px;margin:8px 0 14px}
    .au-confirm{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;z-index:99999;padding:16px}
    .au-confirm-box{width:100%;max-width:430px;border-radius:18px;border:1px solid #000;background:#fff;color:#000;box-shadow:0 24px 70px rgba(0,0,0,.32);padding:20px;text-align:center}
    .au-confirm-text{font-size:.96rem;font-weight:800;line-height:1.45;margin:0 0 18px}
    .au-confirm-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
    .au-confirm-yes,.au-confirm-no{min-width:86px;border-radius:999px;font-weight:800;font-size:.86rem;padding:.42rem .9rem;border:1px solid #000}
    .au-confirm-yes{background:#000;color:#fff}
    .au-confirm-no{background:#fff;color:#000}
    .au-confirm-yes:hover,.au-confirm-no:hover{background:#d4af37;color:#000;border-color:#d4af37}
  </style>

  <div class="mb-3">
    <%= link_to "← Back to Auction", auction_path, class: "btn btn-link p-0" %>
  </div>

  <div class="au-show">
    <div class="au-left">
      <div class="au-card" id="auctionInfoCard">
        <h1 class="au-title">Auction Information:</h1>
        <p class="au-sub">Auction listing details</p>

        <div class="au-line"><strong>Seller:</strong> <%= link_to seller_name, user_path(auction.seller_id), class: "text-decoration-none" %></div>

        <div class="au-line">
          <strong>Location:</strong>
          <% if country_code.present? %>
            <span title="<%= auction_country_name(country_code) %>"><%= auction_flag(country_code) %></span>
          <% else %>
            <span class="text-muted">-</span>
          <% end %>
        </div>

        <div class="au-line">
          <strong>Reviews:</strong>
          <span title="<%= "#{seller_stats[:avg].round(1)}/5 (#{seller_stats[:count]})" %>">
            <%= auction_star_rating(seller_stats[:avg], prefix: "pv-au-rating") %> (<%= seller_stats[:count] %>)
          </span>
        </div>

        <div class="au-line">
          <strong>Badges:</strong>
          <% if seller_badges.any? %>
            <span class="au-badges">
              <% seller_badges.each do |badge| %>
                <%= image_tag badge, alt: "Badge" %>
              <% end %>
            </span>
          <% else %>
            <span class="text-muted">None</span>
          <% end %>
        </div>

        <div class="au-line">
          <strong>Auction Description:</strong>
          <div class="au-desc mt-1"><%= auction.auction_description %></div>
        </div>

        <div class="au-line"><strong>Condition:</strong> <%= auction.condition %></div>
        <div class="au-line"><strong>Reserve Status:</strong> <%= reserve_label %></div>
        <div class="au-line"><strong>Length:</strong> <%= auction_length_label(auction) %></div>
        <div class="au-line"><strong>Highest Bid:</strong> <%= highest_bid_display %></div>
        <div class="au-line"><strong>Bids:</strong> <%= auction.bids_count.to_i %></div>
        <div class="au-line">
          <strong>Time Remaining:</strong>
          <span id="auctionShowTimer" data-status="<%= status_key %>" data-end-timestamp="<%= auction.ends_at.present? ? (auction.ends_at.to_f * 1000).to_i : 0 %>"><%= remaining_text %></span>
        </div>
        <div class="au-line"><strong>Status:</strong> <span id="auctionShowStatus" class="badge <%= status_badge_class %>"><%= status_label %></span></div>

        <% if winning_bidder.present? && %w[payment_pending paid sold].include?(status_key) %>
          <div class="au-line"><strong>Winning Bidder:</strong> <%= winning_bidder.username.to_s.presence || "User ##{winning_bidder.id}" %></div>
          <div class="au-line"><strong>Winning Bid:</strong> <%= number_to_currency(auction.winning_bid_cents.to_i / 100.0, unit: "€") %></div>
        <% end %>

        <% if status_key == "payment_pending" && is_winner %>
          <div class="au-pay">
            <div class="fw-semibold mb-2">You won this auction. Confirm payment after sending payment through Revolut.</div>
            <div class="au-line">
              <strong>Host Revolut Tag:</strong>
              <span class="au-hidden-tag" data-secret-tag="<%= host_revolut_tag %>">████████</span>
              <button type="button" class="btn btn-outline-dark btn-sm" data-reveal-tag="true">Reveal</button>
            </div>
            <%= button_to "Confirm Payment",
                          confirm_auction_payment_path(auction),
                          method: :post,
                          class: "btn btn-primary btn-sm mt-2",
                          form: { data: { confirm_modal: "Do you want to confirm payment?" } } %>
          </div>
        <% elsif status_key == "payment_pending" && is_host %>
          <div class="au-pay">
            <div class="fw-semibold">Waiting for auction winner to confirm payment.</div>
            <div class="text-muted small mt-1">You will only see the winner’s Revolut tag after they confirm payment.</div>
          </div>
        <% elsif status_key == "paid" && is_host %>
          <div class="au-pay">
            <div class="fw-semibold mb-2">Winner has confirmed payment. Verify it after checking your Revolut.</div>
            <div class="au-line">
              <strong>Winner Revolut Tag:</strong>
              <span class="au-hidden-tag" data-secret-tag="<%= winner_revolut_tag %>">████████</span>
              <button type="button" class="btn btn-outline-dark btn-sm" data-reveal-tag="true">Reveal</button>
            </div>
            <div class="au-line"><strong>Send To:</strong> <%= auction.winning_address_text.to_s.presence || "-" %></div>
            <%= button_to "Verify Payment",
                          verify_auction_payment_path(auction),
                          method: :post,
                          class: "btn btn-success btn-sm mt-2",
                          form: { data: { confirm_modal: "Do you want to verify this payment?" } } %>
          </div>
        <% elsif status_key == "paid" && is_winner %>
          <div class="au-pay">
            <div class="fw-semibold">Payment confirmation sent.</div>
            <div class="text-muted small mt-1">Waiting for the auction host to verify payment.</div>
          </div>
        <% elsif status_key == "sold" && winning_bidder.present? %>
          <div class="au-pay">
            <div class="fw-semibold">Payment verified. Auction sold.</div>
            <% if is_host %>
              <div class="au-line"><strong>Send To:</strong> <%= auction.winning_address_text.to_s.presence || "-" %></div>
            <% end %>
          </div>
        <% end %>

        <div class="au-actions">
          <% if can_bid_now %>
            <%= link_to "Bid", bid_auction_path(auction), class: "btn btn-primary au-btn" %>
          <% elsif is_host %>
            <button type="button" class="btn btn-secondary au-btn" disabled>Host Cannot Bid</button>
          <% else %>
            <button type="button" class="btn btn-secondary au-btn" disabled>Bid</button>
          <% end %>

          <% if owner_can_end %>
            <%= button_to "End",
                          end_auction_path(auction),
                          method: :post,
                          class: "btn btn-outline-danger au-btn",
                          form: { data: { confirm_modal: "Are you sure you want to end this auction?" } } %>
          <% end %>

          <% if admin_can_delete %>
            <%= button_to "Delete",
                          delete_auction_path(auction),
                          method: :delete,
                          class: "btn btn-outline-danger au-btn",
                          form: { data: { confirm_modal: "Are you sure you want to delete this auction?", turbo: "false" } } %>
          <% end %>
        </div>
      </div>

      <div class="au-card au-section">
        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
          <h3 class="au-title">Reviews</h3>

          <% if can_give_review %>
            <button type="button" class="btn btn-outline-primary btn-sm" data-toggle-review="<%= review_form_id %>">Give Review</button>
          <% end %>
        </div>

        <% if can_give_review %>
          <div id="<%= review_form_id %>" class="au-review-form">
            <%= form_with url: reviews_path, method: :post, local: true do %>
              <%= hidden_field_tag "review[seller_id]", auction.seller_id %>

              <div class="mb-2">
                <label class="form-label mb-1 small">Rating (0 to 5)</label>
                <%= number_field_tag "review[rating]", "", min: 0, max: 5, step: 0.1, class: "form-control form-control-sm", required: true %>
              </div>

              <div class="mb-2">
                <label class="form-label mb-1 small">Comment</label>
                <%= text_area_tag "review[comment]", "", class: "form-control form-control-sm", rows: 3, maxlength: 1000 %>
              </div>

              <div class="d-flex justify-content-end">
                <%= submit_tag "Submit Review", class: "btn btn-primary btn-sm" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if reviews.any? %>
          <% reviews.each do |review| %>
            <% reviewer = review.respond_to?(:reviewer) ? review.reviewer : nil %>
            <% reviewer_name = reviewer&.username.to_s.presence || "User ##{review.reviewer_id}" %>

            <div class="au-review-card">
              <div class="au-review-top">
                <div>
                  <div class="au-review-name"><%= reviewer_name %></div>
                  <div class="au-review-stars">
                    <%= auction_star_rating(review.rating, prefix: "pv-au-rating") %>
                    <strong><%= number_with_precision(review.rating.to_f, precision: 1) %>/5</strong>
                  </div>
                </div>

                <div class="au-review-meta"><%= review.created_at.strftime("%d %b %Y") if review.respond_to?(:created_at) %></div>
              </div>

              <% if review.comment.to_s.present? %>
                <div class="au-review-body"><%= review.comment %></div>
              <% else %>
                <div class="au-review-body text-muted">No comment left.</div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-muted">No reviews yet.</div>
        <% end %>
      </div>
    </div>

    <div class="au-right">
      <div class="au-card" id="auctionImagesCard">
        <div class="fw-semibold mb-2">Auction Image(s):</div>

        <% if images.any? %>
          <div class="au-thumbs">
            <% images.each_with_index do |image, index| %>
              <%= image_tag url_for(image),
                            class: "au-thumb",
                            alt: "Auction image #{index + 1}",
                            data: { bs_toggle: "modal", bs_target: "#auctionImageModal", full_src: url_for(image) } %>
            <% end %>
          </div>
        <% else %>
          <div class="text-muted">No images uploaded.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="auctionImageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body d-flex justify-content-center">
        <img id="auctionImageModalEl" src="" alt="" style="max-width:100%;max-height:78vh;object-fit:contain;">
      </div>
    </div>
  </div>
</div>

<div class="au-confirm" id="auctionConfirmModal">
  <div class="au-confirm-box">
    <p class="au-confirm-text" id="auctionConfirmText">Do you want to confirm this action?</p>
    <div class="au-confirm-actions">
      <button type="button" class="au-confirm-yes" id="auctionConfirmYes">Yes</button>
      <button type="button" class="au-confirm-no" id="auctionConfirmNo">No</button>
    </div>
  </div>
</div>

<script>
  (() => {
    let pendingForm = null

    function formatRemaining(ms) {
      if (ms <= 0) return "Ended"

      const total = Math.floor(ms / 1000)
      const days = Math.floor(total / 86400)
      const hours = Math.floor((total % 86400) / 3600)
      const minutes = Math.floor((total % 3600) / 60)
      const seconds = total % 60

      if (days > 0) return `${days}d ${hours}h ${minutes}m`
      if (hours > 0) return `${hours}h ${minutes}m ${seconds}s`
      return `${minutes}m ${seconds}s`
    }

    function initAuctionShow() {
      const imageModal = document.getElementById("auctionImageModalEl")
      const timer = document.getElementById("auctionShowTimer")
      const status = document.getElementById("auctionShowStatus")
      const confirmModal = document.getElementById("auctionConfirmModal")
      const confirmText = document.getElementById("auctionConfirmText")
      const confirmYes = document.getElementById("auctionConfirmYes")
      const confirmNo = document.getElementById("auctionConfirmNo")

      document.addEventListener("click", (event) => {
        const image = event.target.closest("img[data-bs-target='#auctionImageModal']")
        if (imageModal && image) imageModal.src = image.dataset.fullSrc || ""

        const reveal = event.target.closest("[data-reveal-tag='true']")
        if (reveal) {
          const tag = reveal.parentElement?.querySelector("[data-secret-tag]")
          if (!tag) return

          tag.textContent = tag.dataset.secretTag || "No tag"
          tag.classList.add("revealed")
          reveal.disabled = true

          setTimeout(() => {
            tag.textContent = "████████"
            tag.classList.remove("revealed")
            reveal.disabled = false
          }, 10000)
        }

        const reviewToggle = event.target.closest("[data-toggle-review]")
        if (reviewToggle) {
          const wrap = document.getElementById(reviewToggle.dataset.toggleReview)
          if (wrap) wrap.style.display = wrap.style.display === "block" ? "none" : "block"
        }
      })

      document.addEventListener("submit", (event) => {
        const form = event.target.closest("form[data-confirm-modal]")
        if (!form || form.dataset.confirmed === "true") return

        event.preventDefault()
        pendingForm = form
        if (confirmText) confirmText.textContent = form.dataset.confirmModal || "Do you want to confirm this action?"
        if (confirmModal) confirmModal.style.display = "flex"
      })

      confirmNo?.addEventListener("click", () => {
        pendingForm = null
        if (confirmModal) confirmModal.style.display = "none"
      })

      confirmYes?.addEventListener("click", () => {
        if (!pendingForm) return

        pendingForm.dataset.confirmed = "true"
        if (confirmModal) confirmModal.style.display = "none"
        pendingForm.requestSubmit()
      })

      confirmModal?.addEventListener("click", (event) => {
        if (event.target !== confirmModal) return

        pendingForm = null
        confirmModal.style.display = "none"
      })

      function updateTimer() {
        if (!timer) return

        const currentStatus = timer.dataset.status || ""

        if (currentStatus === "payment_pending") {
          timer.textContent = "Awaiting Payment"
          return
        }

        if (currentStatus === "paid") {
          timer.textContent = "Awaiting Host Verification"
          return
        }

        if (currentStatus === "sold") {
          timer.textContent = "Sold"
          return
        }

        const end = parseInt(timer.dataset.endTimestamp || "0", 10)
        if (!end) return

        const left = end - Date.now()

        if (left <= 0) {
          timer.textContent = "Ended"

          if (status && status.textContent.trim() === "Running") {
            status.textContent = "Ended"
            status.classList.remove("bg-success", "bg-danger", "bg-warning", "text-dark", "bg-primary")
            status.classList.add("bg-secondary")
          }

          return
        }

        timer.textContent = formatRemaining(left)
      }

      function syncCardHeights() {
        const info = document.getElementById("auctionInfoCard")
        const images = document.getElementById("auctionImagesCard")
        if (!info || !images) return

        images.style.minHeight = ""
        if (window.innerWidth >= 992) images.style.minHeight = `${info.offsetHeight}px`
      }

      updateTimer()
      syncCardHeights()

      if (window.auctionShowTimerId) clearInterval(window.auctionShowTimerId)
      window.auctionShowTimerId = setInterval(updateTimer, 1000)
      window.addEventListener("resize", syncCardHeights)
    }

    document.addEventListener("DOMContentLoaded", initAuctionShow)
    document.addEventListener("turbo:load", initAuctionShow)
  })()
</script>