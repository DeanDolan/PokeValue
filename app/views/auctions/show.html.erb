<%
# Main auction object loaded by the controller.
auction = @auction

# Builds a simple non-overlapping star display from an average score.
stars = lambda do |avg|
  value = avg.to_f
  value = 0.0 if value < 0
  value = 5.0 if value > 5

  rounded = ((value * 2).round / 2.0)
  full = rounded.floor
  half = (rounded - full) >= 0.5

  parts = []
  full.times { parts << '<span class="pv-au-rating-star">★</span>' }
  parts << '<span class="pv-au-rating-half">½</span>' if half

  %(<span class="pv-au-rating-stars">#{parts.join}</span>).html_safe
end

admin_badge_asset = "badges/adminbadge.png"

# Adds badge images for special seller statuses.
badge_imgs_for = lambda do |user|
  out = []
  if user && ((user.respond_to?(:admin?) && user.admin?) || (user.respond_to?(:admin) && !!user.admin))
    out << admin_badge_asset
  end
  out
end

seller = auction.seller
seller_name = seller&.username.to_s.presence || "User ##{auction.seller_id}"
seller_badges = badge_imgs_for.call(seller)

country_code =
  if seller && seller.respond_to?(:country_code) && seller.country_code.present?
    seller.country_code.to_s
  else
    ""
  end

reserve_label = auction.reserve_status.to_s.downcase.include?("no") ? "No Reserve" : "Reserve"

# Converts internal auction status into text for the page.
status_key = auction.status.to_s
status_label =
  case status_key
  when "sold"
    "Sold"
  when "paid"
    "Payment Confirmed"
  when "payment_pending"
    "Awaiting Winner Payment"
  when "ended"
    "Ended"
  else
    auction.ends_at.present? && auction.ends_at <= Time.current ? "Ended" : "Running"
  end

# Sets Bootstrap badge colour by status.
status_badge_class =
  case status_key
  when "sold"
    "bg-danger"
  when "paid"
    "bg-primary"
  when "payment_pending"
    "bg-warning text-dark"
  when "ended"
    "bg-secondary"
  else
    "bg-success"
  end

# Builds the initial time remaining text before JavaScript starts updating it.
remaining_text =
  if status_key == "payment_pending"
    "Awaiting Payment"
  elsif status_key == "paid"
    "Awaiting Host Verification"
  elsif status_key == "sold"
    "Sold"
  elsif status_key == "ended"
    "Ended"
  elsif auction.ends_at.blank?
    "-"
  else
    diff = (auction.ends_at.to_f - Time.current.to_f).to_i
    if diff <= 0
      "Ended"
    else
      days = diff / 86_400
      hours = (diff % 86_400) / 3_600
      minutes = (diff % 3_600) / 60
      seconds = diff % 60

      if days > 0
        "#{days}d #{hours}h #{minutes}m"
      elsif hours > 0
        "#{hours}h #{minutes}m #{seconds}s"
      else
        "#{minutes}m #{seconds}s"
      end
    end
  end

# Page state and permission checks.
images = auction.photos.attached? ? auction.photos.first(4) : []
owner_can_end = defined?(current_user) && current_user && auction.can_end_early_by?(current_user)
winning_bidder = auction.winning_bidder
current_user_id = defined?(current_user) && current_user ? current_user.id.to_i : nil
is_host = current_user_id.present? && current_user_id == auction.seller_id.to_i
is_winner = current_user_id.present? && winning_bidder && current_user_id == winning_bidder.id.to_i
can_bid_now = auction.running? && !is_host
highest_bid_display = auction.current_bid_cents_value.to_i > 0 ? number_to_currency(auction.current_bid_cents_value.to_i / 100.0, unit: "€") : "No bids yet"
host_revolut_tag = auction.host_revolut_tag.to_s
winner_revolut_tag = auction.winner_revolut_tag.to_s
reviews = defined?(@reviews) && @reviews ? @reviews : []
can_give_review = defined?(@can_give_review) ? @can_give_review : false
review_form_id = "auction-give-review-form-#{auction.id}"

admin_can_delete =
  begin
    current_user.present? && (
      (current_user.respond_to?(:admin?) && current_user.admin?) ||
      (current_user.respond_to?(:admin) && !!current_user.admin)
    )
  rescue
    false
  end
%>

<div class="container py-4">
