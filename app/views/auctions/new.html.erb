<%#
References:
- Rails form helpers:
  https://api.rubyonrails.org/classes/ActionView/Helpers/FormHelper.html
- Rails Active Storage file uploads:
  https://guides.rubyonrails.org/active_storage_overview.html
- Bootstrap forms and grid:
  https://getbootstrap.com/docs/5.3/forms/overview/
  https://getbootstrap.com/docs/5.3/layout/grid/
- MDN DOM events:
  https://developer.mozilla.org/en-US/docs/Web/API/EventTarget/addEventListener
%>

<div class="container py-4">
  <style>
    .au-new-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.06)}
    .au-new-title{font-size:1.2rem;margin:0 0 10px}
    .au-new-muted{color:#6b7280;font-size:.9rem}
    .au-new-label{font-size:.85rem}
    .au-new-img-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .au-new-note{font-size:.78rem;color:#6b7280;line-height:1.35}
    .au-new-count{text-align:right;font-size:.78rem;color:#6b7280;margin-top:4px}
  </style>

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <div class="au-new-title">Create Auction</div>
      <div class="au-new-muted">Add the auction details, choose reserve status, and upload up to 4 images.</div>
    </div>

    <%= link_to "← Back to Auction", auction_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <div class="au-new-card">
    <%# Multipart form allows up to four uploaded images. %>
    <%= form_with url: auctions_path, method: :post, local: true, html: { multipart: true, id: "auction-form" } do %>
      <div class="row g-2 mb-3">
        <div class="col-12">
          <label class="form-label mb-1 au-new-label" for="auction-description">Auction Description</label>
          <%= text_area_tag :auction_description,
                            "",
                            rows: 4,
                            maxlength: 250,
                            class: "form-control",
                            placeholder: "Describe exactly what is being auctioned...",
                            required: true,
                            id: "auction-description" %>
          <div id="auction-description-count" class="au-new-count">0 / 250</div>
        </div>
      </div>

      <div class="row g-2 mb-1">
        <div class="col-12 col-lg-3">
          <label class="form-label mb-1 au-new-label" for="auction-condition">Condition</label>
          <%= select_tag :condition,
                         options_for_select(auction_conditions),
                         include_blank: true,
                         class: "form-select",
                         id: "auction-condition",
                         required: true %>
        </div>

        <div class="col-12 col-lg-3">
          <label class="form-label mb-1 au-new-label" for="auction-reserve-status">Reserve Status</label>
          <%= select_tag :reserve_status,
                         options_for_select(Auction::RESERVE_STATUSES),
                         include_blank: true,
                         class: "form-select",
                         id: "auction-reserve-status",
                         required: true %>
        </div>

        <div class="col-12 col-lg-3">
          <label class="form-label mb-1 au-new-label" for="auction-duration">Auction Time Length</label>
          <%= select_tag :auction_duration,
                         options_for_select(auction_duration_select_options),
                         include_blank: true,
                         class: "form-select",
                         id: "auction-duration",
                         required: true %>
        </div>

        <div class="col-12 col-lg-3">
          <label class="form-label mb-1 au-new-label" for="auction-reserve-price">Reserve Price (€)</label>
          <%= text_field_tag :reserve_price,
                             "",
                             class: "form-control",
                             inputmode: "decimal",
                             placeholder: "e.g. 100.00",
                             id: "auction-reserve-price" %>
        </div>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-12">
          <div id="auction-reserve-note" class="au-new-note">Select a reserve status to continue.</div>
        </div>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-12">
          <label class="form-label mb-1 au-new-label">Images (up to 4)</label>

          <div class="au-new-img-grid">
            <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
            <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
            <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
            <input class="form-control" type="file" name="photos[]" accept="image/png,image/jpeg">
          </div>

          <div class="small text-muted mt-1">PNG/JPG only.</div>
        </div>
      </div>

      <div class="d-flex gap-2 justify-content-end flex-wrap">
        <%= submit_tag "Create Auction", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <script>
    (() => {
      function initAuctionForm() {
        const reserveStatus = document.getElementById("auction-reserve-status")
        const reservePrice = document.getElementById("auction-reserve-price")
        const reserveNote = document.getElementById("auction-reserve-note")
        const description = document.getElementById("auction-description")
        const count = document.getElementById("auction-description-count")

        if (description && count && description.dataset.bound !== "1") {
          description.dataset.bound = "1"

          const syncCount = () => {
            count.textContent = `${description.value.length} / 250`
          }

          description.addEventListener("input", syncCount)
          syncCount()
        }

        if (!reserveStatus || !reservePrice || !reserveNote || reserveStatus.dataset.bound === "1") return
        reserveStatus.dataset.bound = "1"

        const syncReserve = () => {
          const reserve = reserveStatus.value === "Reserve"

          reservePrice.disabled = !reserve
          reservePrice.required = reserve
          if (!reserve) reservePrice.value = ""

          if (reserveStatus.value === "Reserve") {
            reserveNote.textContent = "Reserve selected. The auction can only be ended early if the reserve price has not been met."
          } else if (reserveStatus.value === "No Reserve") {
            reserveNote.textContent = "No Reserve selected. Reserve price is disabled. The highest final bid wins, regardless of amount."
          } else {
            reserveNote.textContent = "Select a reserve status to continue."
          }
        }

        reserveStatus.addEventListener("change", syncReserve)
        syncReserve()
      }

      document.addEventListener("DOMContentLoaded", initAuctionForm)
      document.addEventListener("turbo:load", initAuctionForm)
    })()
  </script>
</div>