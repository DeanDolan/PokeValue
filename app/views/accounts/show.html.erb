    begin
      auction_cols = Auction.column_names
      if auction_cols.include?("winning_bidder_id")
        scope = Auction.where(winning_bidder_id: u.id)
        scope = scope.where(status: "sold") if auction_cols.include?("status")
        scope.order(updated_at: :desc).to_a
      else
        []
      end
    rescue
      []
    end
  else
    []
  end

selected_auctions =
  if auction_tab == "ended"
    ended_auctions
  elsif auction_tab == "sold"
    sold_auctions
  elsif auction_tab == "won" && is_self
    won_auctions
  else
    current_auctions
  end

# Groups raffles into current or ended states
raffle_status_key = lambda do |raffle|
  status = raffle.respond_to?(:status) ? raffle.status.to_s.downcase : ""
  ended_at = raffle.respond_to?(:ended_at) ? raffle.ended_at : nil
  completed_at = raffle.respond_to?(:completed_at) ? raffle.completed_at : nil

  if status.include?("complete") || status.include?("ended") || status.include?("sold") || completed_at.present? || ended_at.present?
    "ended"
  else
    "current"
  end
end

user_raffles =
  if defined?(Raffle) && u
    Raffle.where(host_id: u.id).order(created_at: :desc).to_a
  else
    []
  end

current_raffles = user_raffles.select { |r| raffle_status_key.call(r) == "current" }
ended_raffles = user_raffles.select { |r| raffle_status_key.call(r) == "ended" }

# Shows raffles won by the current user on their own account only
won_raffles =
  if is_self && defined?(Raffle) && u
    begin
      raffle_cols = Raffle.column_names
      if raffle_cols.include?("winner_user_id")
        Raffle.where(winner_user_id: u.id).order(updated_at: :desc).to_a
      else
        []
      end
    rescue
      []
    end
  else
    []
  end

selected_raffles =
  if raffle_tab == "ended"
    ended_raffles
  elsif raffle_tab == "won" && is_self
    won_raffles
  else
    current_raffles
