<%
require "json"

# Refreshes auction statuses before showing account auction data
if defined?(Auction)
  begin
    Auction.refresh_all_statuses!
  rescue
  end
end

# Loads set/product metadata from config/sets.json for account tables
sets_data =
  begin
    raw = File.read(Rails.root.join("config", "sets.json"), encoding: "bom|utf-8")
    JSON.parse(raw)
  rescue
    {}
  end

type_map = {
  "etb"                      => "Elite Trainer Box",
  "pc_etb"                   => "Pokemon Center Elite Trainer Box",
  "booster_box"              => "Booster Box",
  "booster_bundle"           => "Booster Bundle",
  "booster_bundle_display"   => "Booster Bundle Display",
  "enhanced_booster_box"     => "Enhanced Booster Box",
  "ultra_premium_collection" => "Ultra Premium Collection",
  "upc"                      => "Ultra Premium Collection",
  "spc"                      => "Super Premium Collection",
  "mini_tin"                 => "Mini Tin",
  "mini_tin_display"         => "Mini Tin Display"
}

# Converts internal codes into readable labels
titleize = lambda do |s|
  s.to_s.tr("_", " ").tr("-", " ").split.map(&:capitalize).join(" ")
end

# Finds the era for a set slug
era_for = lambda do |slug|
  s = sets_data[slug.to_s] || sets_data.values.find { |x| x["slug"].to_s == slug.to_s }
  s ? s["era"].to_s : ""
end

# Finds the set name for a set slug
set_name_for = lambda do |slug|
  s = sets_data[slug.to_s] || sets_data.values.find { |x| x["slug"].to_s == slug.to_s }
  s ? s["name"].to_s : slug.to_s
end

# Splits product route types such as etb--v-lucario into base type and variant
split_type_variant = lambda do |t|
  s = t.to_s
  down = s.downcase
  idx = down.index("--v-")
  if idx
    base = s[0...idx].to_s
    raw = s[(idx + 4)..-1].to_s
    variant = raw.tr("_", " ").tr("-", " ").split.map(&:capitalize).join(" ")
    [base.to_s, variant.to_s]
  else
    [s.to_s, ""]
  end
end

# Builds the product type label shown in account marketplace tables
product_type_display = lambda do |obj|
  raw =
    if obj.respond_to?(:route_type) && obj.route_type.to_s.present?
      obj.route_type.to_s
    elsif obj.respond_to?(:product_type_name) && obj.product_type_name.to_s.present?
      obj.product_type_name.to_s
    elsif obj.respond_to?(:product_name) && obj.product_name.to_s.present?
      obj.product_name.to_s
    elsif obj.respond_to?(:product_sku) && obj.product_sku.to_s.present?
      obj.product_sku.to_s
    elsif obj.respond_to?(:sku) && obj.sku.to_s.present?
      obj.sku.to_s
    else
      ""
    end

  raw = raw.split(":", 2)[1].to_s if raw.include?(":")
  base, variant = split_type_variant.call(raw)
  base_key = base.to_s.strip.downcase.tr(" ", "_")
  tn = type_map[base_key].presence || titleize.call(base)
  vn = variant.to_s.strip

  if tn.to_s.downcase.include?("pokemon center") && vn.present?
    vn = vn.gsub(/\bpokemon\s+center\b/i, " ").strip
    vn = vn.gsub(/\s{2,}/, " ").strip
    tokens = vn.split
    if tokens.last && tokens.last.casecmp("o").zero?
      tokens.pop
      vn = tokens.join(" ").strip
    end
  end

  vn.present? ? "#{tn} (#{vn})" : tn
rescue
  "-"
end

# Calculates total cents from whichever purchase price columns exist
total_cents_for = lambda do |p|
  cols = p.class.column_names rescue []
  if cols.include?("total_cents") && p.respond_to?(:total_cents) && p.total_cents.to_i > 0
    p.total_cents.to_i
  elsif cols.include?("total_price_cents") && p.respond_to?(:total_price_cents) && p.total_price_cents.to_i > 0
    p.total_price_cents.to_i
  elsif cols.include?("unit_price_cents") && cols.include?("quantity") && p.respond_to?(:unit_price_cents) && p.respond_to?(:quantity)
    p.unit_price_cents.to_i * p.quantity.to_i
  elsif cols.include?("price_cents") && cols.include?("quantity") && p.respond_to?(:price_cents) && p.respond_to?(:quantity)
    p.price_cents.to_i * p.quantity.to_i
  else
    0
  end
rescue
  0
end

# Converts listing status values into display text
listing_status_label = lambda do |l|
  s = l.respond_to?(:status) ? l.status.to_s : ""
  s = "active" if s.blank?
  down = s.downcase
  return "Deleted" if down.include?("deleted")
  return "Cancelled" if down.include?("cancel")
  return "Active" if down == "active"
  titleize.call(down)
end

images_sealed = Rails.root.join("app", "assets", "images", "sealed")
admin_badge_asset = "badges/adminbadge.png"

u = @user
is_self = defined?(@is_self) ? !!@is_self : false

# Keeps the selected marketplace, auction and raffle account tabs safe
tab = params[:tab].to_s.presence || (defined?(@tab) && @tab.present? ? @tab.to_s : "current")
tab = "current" unless %w[current sold bought].include?(tab)

auction_tab = params[:auction_tab].to_s.presence || (defined?(@auction_tab) && @auction_tab.present? ? @auction_tab.to_s : "current")
auction_tab = "current" unless %w[current ended sold won].include?(auction_tab)

raffle_tab = params[:raffle_tab].to_s.presence || (defined?(@raffle_tab) && @raffle_tab.present? ? @raffle_tab.to_s : "current")
raffle_tab = "current" unless %w[current ended won].include?(raffle_tab)

# Loads watchlist items only for the account owner
items =
  if is_self && defined?(@watchlist_items) && @watchlist_items
    @watchlist_items
  elsif is_self && u && u.respond_to?(:watchlist_items)
    u.watchlist_items
  elsif is_self && u && u.respond_to?(:watchlists)
    u.watchlists
  else
    []
  end

# Builds display data for each watchlist item
meta_for = lambda do |item|
  sku =
    if item.respond_to?(:sku)
      item.sku.to_s
    elsif item.respond_to?(:product_sku)
      item.product_sku.to_s
    else
      ""
    end

  slug =
    if item.respond_to?(:set_slug)
      item.set_slug.to_s
    else
      sku.split(":", 2)[0].to_s
    end

  type_code =
    if item.respond_to?(:route_type)
      item.route_type.to_s
    else
      sku.split(":", 2)[1].to_s
    end

  s = sets_data[slug] || sets_data.values.find { |x| x["slug"].to_s == slug }
  era = s ? s["era"].to_s : ""
  set_name = s ? s["name"].to_s : slug.to_s
  product_type_name = type_map[type_code] || titleize.call(type_code)

  prod =
    if s
      Array(s["products"] || s["sealed"]).find { |p| (p["type"] || p[:type]).to_s == type_code }
    end

  img_base = File.basename((prod && (prod["img"] || prod[:img])).to_s) rescue nil
  img_url =
    if img_base.present? && File.exist?(images_sealed.join(img_base))
      asset_path("sealed/#{img_base}")
    else
      asset_path("pokevaluelogo.png")
    end

  href = set_product_path(slug: slug, type: type_code)
  label = [era.presence, set_name.presence, product_type_name.presence].compact.join(" · ")
  { sku: sku, href: href, img_url: img_url, label: label }
end

is_admin =
  u && ((u.respond_to?(:admin?) && u.admin?) || (u.respond_to?(:admin) && !!u.admin))

# Loads the user's current marketplace listings
current_listings =
  if defined?(@current_listings)
    @current_listings
  elsif defined?(MarketplaceListing) && u
    if MarketplaceListing.respond_to?(:active)
      MarketplaceListing.active.where(seller_id: u.id).order(created_at: :desc)
    else
      MarketplaceListing.where(seller_id: u.id, status: "active").order(created_at: :desc)
    end
  else
    []
  end

# Loads sold listings for the public seller account view
sold_listings =
  if defined?(MarketplaceListing) && u
    MarketplaceListing.where(seller_id: u.id, status: "sold").order(updated_at: :desc).to_a
  else
    []
  end

# Finds confirmed offers for sold listings so the sold value can show the final accepted price
sold_offer_map = {}
if defined?(MarketplaceOffer) && sold_listings.any?
  begin
    sold_offer_map =
      MarketplaceOffer
        .where(marketplace_listing_id: sold_listings.map(&:id))
        .where(status: "confirmed_paid")
        .order(updated_at: :desc)
        .to_a
        .group_by(&:marketplace_listing_id)
        .transform_values(&:first)
  rescue
    sold_offer_map = {}
  end
end

sold_total_cents_for = lambda do |listing|
  offer = sold_offer_map[listing.id] rescue nil
  if offer && offer.respond_to?(:offer_cents) && offer.offer_cents.to_i > 0
    offer.offer_cents.to_i
  elsif listing.respond_to?(:price_cents) && listing.respond_to?(:quantity) && listing.price_cents.to_i > 0 && listing.quantity.to_i > 0
    listing.price_cents.to_i * listing.quantity.to_i
  elsif listing.respond_to?(:price_cents) && listing.price_cents.to_i > 0
    listing.price_cents.to_i
  else
    0
  end
end

sold_qty_for = lambda do |listing|
  q = listing.respond_to?(:quantity) ? listing.quantity.to_i : 0
  q > 0 ? q : 1
end

# Loads purchases made by the logged-in user
bought_purchases =
  if is_self
    if defined?(MarketplacePurchase)
      begin
        purchase_cols = MarketplacePurchase.column_names
        if purchase_cols.include?("buyer_id")
          scope = MarketplacePurchase.where(buyer_id: u.id)
          scope = scope.where(status: "sold") if purchase_cols.include?("status")
          scope.order(created_at: :desc).to_a
        else
          []
        end
      rescue
        []
      end
    elsif defined?(MarketplaceListing) && MarketplaceListing.column_names.include?("buyer_id")
      MarketplaceListing.where(buyer_id: u.id, status: "sold").order(updated_at: :desc).to_a
    else
      []
    end
  else
    []
  end

# Preloads related listings for bought purchase rows
purchase_listing_ids = []
Array(bought_purchases).each do |p|
  if p.respond_to?(:marketplace_listing_id) && p.marketplace_listing_id.present?
    purchase_listing_ids << p.marketplace_listing_id.to_i
  elsif p.respond_to?(:listing_id) && p.listing_id.present?
    purchase_listing_ids << p.listing_id.to_i
  elsif defined?(MarketplaceListing) && p.is_a?(MarketplaceListing)
    purchase_listing_ids << p.id.to_i
  end
end
purchase_listing_ids.concat(sold_listings.map(&:id))
purchase_listing_ids.uniq!

listing_map = {}
if defined?(MarketplaceListing) && purchase_listing_ids.any?
  listing_map = MarketplaceListing.where(id: purchase_listing_ids).index_by(&:id)
end

purchase_listing_for = lambda do |p|
  if p.respond_to?(:marketplace_listing_id) && p.marketplace_listing_id.present?
    listing_map[p.marketplace_listing_id.to_i]
  elsif p.respond_to?(:listing_id) && p.listing_id.present?
    listing_map[p.listing_id.to_i]
  elsif defined?(MarketplaceListing) && p.is_a?(MarketplaceListing)
    p
  else
    nil
  end
end

purchase_slug = lambda do |p, l|
  (p.respond_to?(:set_slug) ? p.set_slug.to_s : "").presence ||
    (l && l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || ""
end

purchase_set = lambda do |p, l|
  (p.respond_to?(:set_name) ? p.set_name.to_s : "").presence ||
    (l && l.respond_to?(:set_name) ? l.set_name.to_s : "").presence ||
    set_name_for.call(purchase_slug.call(p, l))
end

purchase_type = lambda do |p, l|
  t = product_type_display.call(p)
  return t if t.present? && t != "-"
  l ? product_type_display.call(l) : "-"
end

purchase_condition = lambda do |p, l|
  (p.respond_to?(:condition) ? p.condition.to_s : "").presence ||
    (l && l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-"
end

# Keeps account tab links anchored to the working area after reloads
account_base_path = lambda do |extra = {}|
  extra = extra.merge(anchor: "account-work-area")
  if is_self
    account_path(extra)
  elsif u
    user_path(u.id, extra)
  else
    "#"
  end
end

# Groups auctions into current, ended and sold states
auction_status_key = lambda do |auction|
  explicit_status =
    if auction.respond_to?(:status) && auction.status.present?
      auction.status.to_s.downcase
    else
      ""
    end

  end_time =
    if auction.respond_to?(:ends_at) && auction.ends_at.present?
      auction.ends_at
    elsif auction.respond_to?(:end_at) && auction.end_at.present?
      auction.end_at
    elsif auction.respond_to?(:end_time) && auction.end_time.present?
      auction.end_time
    elsif auction.respond_to?(:expires_at) && auction.expires_at.present?
      auction.expires_at
    end

  if explicit_status == "sold"
    "sold"
  elsif explicit_status == "ended"
    "ended"
  elsif end_time.present? && end_time <= Time.current
    "ended"
  else
    "running"
  end
end

auction_length_label_for = lambda do |auction|
  label =
    if auction.respond_to?(:auction_length_label) && auction.auction_length_label.present?
      auction.auction_length_label.to_s
    else
      ""
    end
  return label if label.present?

  seconds =
    if auction.respond_to?(:auction_length_seconds) && auction.auction_length_seconds.present?
      auction.auction_length_seconds.to_i
    else
      0
    end

  {
    1.minute.to_i => "1 min",
    1.hour.to_i => "1 hour",
    3.hours.to_i => "3 hours",
    6.hours.to_i => "6 hours",
    12.hours.to_i => "12 hours",
    1.day.to_i => "1 day",
    3.days.to_i => "3 days",
    1.week.to_i => "1 week"
  }[seconds.to_i] || "-"
end

auction_remaining_text = lambda do |auction|
  end_time = auction.respond_to?(:ends_at) ? auction.ends_at : nil
  status_key = auction_status_key.call(auction)
  return "Sold" if status_key == "sold"
  return "0s" if status_key == "ended"
  return "-" if end_time.blank?

  diff = (end_time.to_f - Time.current.to_f).to_i
  return "0s" if diff <= 0

  days = diff / 86_400
  hours = (diff % 86_400) / 3_600
  minutes = (diff % 3_600) / 60
  seconds = diff % 60

  if days > 0
    "#{days}d #{hours}h #{minutes}m"
  elsif hours > 0
    "#{hours}h #{minutes}m #{seconds}s"
  elsif minutes > 0
    "#{minutes}m #{seconds}s"
  else
    "#{seconds}s"
  end
end

user_auctions =
  if defined?(Auction) && u
    Auction.where(seller_id: u.id).order(created_at: :desc).to_a
  else
    []
  end

current_auctions = user_auctions.select { |a| auction_status_key.call(a) == "running" }
ended_auctions = user_auctions.select { |a| auction_status_key.call(a) == "ended" }
sold_auctions = user_auctions.select { |a| auction_status_key.call(a) == "sold" }

# Shows auctions won by the current user on their own account only
won_auctions =
