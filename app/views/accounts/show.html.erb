    .w-ra-tickets{width:12%}
    .w-ra-status{width:12%}
    .w-ra-date{width:12%}
    .w-ra-actions{width:14%}
    .acc-au-desc{display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;line-clamp:2;overflow:hidden;text-overflow:ellipsis;white-space:normal;word-break:break-word;line-height:1.2;max-height:2.4em;text-align:left}
    .acc-address-grid{display:grid;gap:10px}
    .acc-address-item{border:1px solid #e5e7eb;border-radius:12px;padding:10px}
    .acc-address-line{font-size:.82rem;line-height:1.25}
  </style>

  <div id="account-work-area" class="acc-wrap">
    <div class="acc-left">
      <div class="acc-card">
        <div class="acc-top">
          <div class="acc-meta">
            <%# Main account header and seller profile information %>
            <div class="acc-title"><%= is_self ? "My Account" : (u&.respond_to?(:username) ? u.username : "User") %></div>
            <p>Username: <strong><%= u&.respond_to?(:username) ? u.username : "-" %></strong></p>

            <p>
              Country:
              <span style="font-size:1.05rem;line-height:1;display:inline-block;position:relative;top:2px;" title="<%= (defined?(country_name) && u&.respond_to?(:country_code)) ? country_name(u.country_code) : "" %>">
                <%= (defined?(flag_emoji) && u&.respond_to?(:country_code)) ? flag_emoji(u.country_code) : (u&.respond_to?(:country_code) ? u.country_code.to_s : "") %>
              </span>
            </p>

            <p class="acc-badges">
              Badges:
              <% if is_admin %>
                <span title="Admin"><%= image_tag admin_badge_asset, alt: "Admin" %></span>
              <% else %>
                <span class="text-muted">N/A</span>
              <% end %>
            </p>
          </div>
        </div>
      </div>

      <% if is_self %>
        <div class="acc-card">
          <div class="subhead">Addresses</div>

          <% if saved_addresses.any? %>
            <div class="acc-address-grid mb-3">
              <% saved_addresses.each do |address| %>
                <% edit_wrap_id = "acc-edit-address-#{address.id}" %>
                <div class="acc-address-item">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                      <div class="fw-semibold"><%= address.respond_to?(:display_label) ? address.display_label : (address.respond_to?(:label) && address.label.present? ? address.label : "Saved Address") %></div>
                      <div class="acc-address-line"><%= address.respond_to?(:single_line) ? address.single_line : [address.try(:line1), address.try(:line2).presence, address.try(:city), address.try(:postcode).presence, address.try(:country_code)].compact.join(", ") %></div>
                    </div>

                    <div class="d-flex gap-2">
                      <button
                        type="button"
                        class="btn btn-sm btn-outline-primary"
                        onclick="var wrap=document.getElementById('<%= edit_wrap_id %>'); if(!wrap){return false;} wrap.style.display=(wrap.style.display==='none'||wrap.style.display==='')?'block':'none';">
                        Edit
                      </button>
                      <%= button_to "Remove", saved_address_path(address), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { preserve_scroll: true } } %>
                    </div>
                  </div>

                  <div id="<%= edit_wrap_id %>" style="display:none;" class="mt-3">
                    <%= form_with url: saved_addresses_path, method: :post, local: true, data: { preserve_scroll: true } do %>
                      <%= hidden_field_tag "saved_address[id]", address.id %>

                      <div class="row g-2">
                        <div class="col-12">
                          <label class="form-label mb-1 small">Address Name</label>
                          <%= text_field_tag "saved_address[label]", (address.respond_to?(:label) ? address.label.to_s : ""), class: "form-control form-control-sm", placeholder: "e.g. Home" %>
                        </div>

                        <div class="col-12">
                          <label class="form-label mb-1 small">Address Line 1</label>
                          <%= text_field_tag "saved_address[line1]", address.try(:line1).to_s, class: "form-control form-control-sm", required: true %>
                        </div>

                        <div class="col-12">
                          <label class="form-label mb-1 small">Address Line 2 (Optional)</label>
                          <%= text_field_tag "saved_address[line2]", address.try(:line2).to_s, class: "form-control form-control-sm" %>
                        </div>

                        <div class="col-12 col-md-4">
                          <label class="form-label mb-1 small">Town/City</label>
                          <%= text_field_tag "saved_address[city]", address.try(:city).to_s, class: "form-control form-control-sm", required: true %>
                        </div>

                        <div class="col-12 col-md-4">
                          <label class="form-label mb-1 small">Eircode</label>
                          <%= text_field_tag "saved_address[postcode]", address.try(:postcode).to_s, class: "form-control form-control-sm" %>
                        </div>

                        <div class="col-12 col-md-4">
                          <label class="form-label mb-1 small">Country</label>
                          <%= select_tag "saved_address[country_code]", options_for_select(eu_countries.map { |name, flag| ["#{flag} #{name}", name] }, address.try(:country_code).to_s.presence || "Ireland"), class: "form-select form-select-sm", required: true %>
                        </div>
                      </div>

                      <div class="d-flex justify-content-end mt-3">
                        <%= submit_tag "Save Changes", class: "btn btn-primary btn-sm" %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="mp-empty">No saved addresses yet.</div>
          <% end %>

          <% if saved_addresses.count < 5 %>
            <div class="d-flex justify-content-end mb-3">
              <button
                type="button"
                class="btn btn-primary btn-sm"
                onclick="var wrap=document.getElementById('acc-add-address-wrap'); if(!wrap){return false;} var hidden=(wrap.style.display==='none'||wrap.style.display===''); wrap.style.display=hidden?'block':'none'; this.textContent=hidden?'Hide Address Form':'Add Address';">
                Add Address
              </button>
            </div>

            <div id="acc-add-address-wrap" style="display:none;">
              <%= form_with model: SavedAddress.new, url: saved_addresses_path, method: :post, local: true, data: { preserve_scroll: true } do |f| %>
                <div class="row g-2">
                  <div class="col-12">
                    <label class="form-label mb-1 small">Address Name</label>
                    <%= f.text_field :label, class: "form-control form-control-sm", placeholder: "e.g. Home" %>
                  </div>

                  <div class="col-12">
                    <label class="form-label mb-1 small">Address Line 1</label>
                    <%= f.text_field :line1, class: "form-control form-control-sm", required: true %>
                  </div>

                  <div class="col-12">
                    <label class="form-label mb-1 small">Address Line 2 (Optional)</label>
                    <%= f.text_field :line2, class: "form-control form-control-sm" %>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label mb-1 small">Town/City</label>
                    <%= f.text_field :city, class: "form-control form-control-sm", required: true %>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label mb-1 small">Eircode</label>
                    <%= f.text_field :postcode, class: "form-control form-control-sm" %>
                  </div>

                  <div class="col-12 col-md-4">
                    <label class="form-label mb-1 small">Country</label>
                    <%= f.select :country_code, options_for_select(eu_countries.map { |name, flag| ["#{flag} #{name}", name] }, "Ireland"), {}, class: "form-select form-select-sm", required: true %>
                  </div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                  <%= f.submit "Save Address", class: "btn btn-primary btn-sm" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="small text-muted">Maximum of 5 saved addresses reached.</div>
          <% end %>
        </div>
      <% end %>

      <div class="acc-card">
        <div class="subhead">Marketplace Listings</div>

        <div class="acc-tabs">
          <%= link_to "Current Listings", account_base_path.call(tab: "current", auction_tab: auction_tab, raffle_tab: raffle_tab), class: ["", (tab == "current" ? "active" : nil)].compact.join(" ") %>
          <%= link_to "Sold Listings", account_base_path.call(tab: "sold", auction_tab: auction_tab, raffle_tab: raffle_tab), class: ["", (tab == "sold" ? "active" : nil)].compact.join(" ") %>
          <% if is_self %>
            <%= link_to "Bought Listings", account_base_path.call(tab: "bought", auction_tab: auction_tab, raffle_tab: raffle_tab), class: ["", (tab == "bought" ? "active" : nil)].compact.join(" ") %>
          <% end %>
        </div>

        <% if tab == "sold" %>
          <% if sold_listings.any? %>
            <div class="table-responsive">
              <table class="mp-table">
                <thead>
                  <tr>
                    <th class="w-era">Era</th>
                    <th class="w-set">Set</th>
                    <th class="w-type">Product Type</th>
                    <th class="w-cond">Condition</th>
                    <th class="w-qty">Qty</th>
                    <th class="w-total">Total</th>
                    <th class="w-date">Sale Date</th>
                    <th class="w-actions">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% sold_listings.each do |l| %>
                    <% slug = (l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || "" %>
                    <% cents = sold_total_cents_for.call(l) %>
                    <% qty_value = sold_qty_for.call(l) %>
                    <tr>
                      <td class="w-era"><%= (l.respond_to?(:era) ? l.era.to_s : "").presence || era_for.call(slug).presence || "-" %></td>
                      <td class="w-set"><%= (l.respond_to?(:set_name) ? l.set_name.to_s : "").presence || set_name_for.call(slug).presence || "-" %></td>
                      <td class="w-type"><%= product_type_display.call(l) %></td>
                      <td class="w-cond"><%= (l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-" %></td>
                      <td class="w-qty"><%= qty_value %></td>
                      <td class="w-total"><%= number_to_currency(cents / 100.0, unit: "€") %></td>
                      <td class="w-date"><%= l.respond_to?(:updated_at) && l.updated_at ? l.updated_at.strftime("%d %b %Y") : "" %></td>
                      <td class="w-actions">
                        <div class="mp-actions">
                          <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="mp-empty">No sold listings.</div>
          <% end %>

        <% elsif tab == "bought" && is_self %>
          <% if bought_purchases.any? %>
            <div class="table-responsive">
              <table class="mp-table">
                <thead>
                  <tr>
                    <th class="w-seller">Seller</th>
                    <th class="w-set">Set</th>
                    <th class="w-type">Product Type</th>
                    <th class="w-cond">Condition</th>
                    <th class="w-qty">Qty</th>
                    <th class="w-total">Total</th>
                    <th class="w-date">Bought</th>
                    <th class="w-actions">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% bought_purchases.each do |p| %>
                    <% l = purchase_listing_for.call(p) %>
                    <% seller_id = (p.respond_to?(:seller_id) ? p.seller_id : nil).presence || (l && l.respond_to?(:seller_id) ? l.seller_id : nil) %>
                    <% seller_name = if seller_id.present? && defined?(User) then (User.find_by(id: seller_id)&.username.presence || "User ##{seller_id}") else "-" end %>
                    <% qty_value = p.respond_to?(:quantity) ? p.quantity.to_i : (l && l.respond_to?(:quantity) ? l.quantity.to_i : "-") %>
                    <% cents = total_cents_for.call(p) %>
                    <% cents = (l.price_cents.to_i * qty_value.to_i) if cents.to_i <= 0 && l && l.respond_to?(:price_cents) && qty_value.to_s =~ /\A\d+\z/ %>
                    <% bought_date = if p.respond_to?(:created_at) && p.created_at then p.created_at else (l && l.respond_to?(:updated_at) ? l.updated_at : nil) end %>
                    <tr>
                      <td class="w-seller">
                        <% if seller_id.present? %>
                          <%= link_to seller_name, user_path(seller_id), class: "text-decoration-none" %>
                        <% else %>
                          -
                        <% end %>
                      </td>
                      <td class="w-set"><%= purchase_set.call(p, l).presence || "-" %></td>
                      <td class="w-type"><%= purchase_type.call(p, l).presence || "-" %></td>
                      <td class="w-cond"><%= purchase_condition.call(p, l).presence || "-" %></td>
                      <td class="w-qty"><%= qty_value %></td>
                      <td class="w-total"><%= number_to_currency(cents.to_i / 100.0, unit: "€") %></td>
                      <td class="w-date"><%= bought_date ? bought_date.strftime("%d %b %Y") : "" %></td>
                      <td class="w-actions">
                        <div class="mp-actions">
                          <% if l %>
                            <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                          <% else %>
                            <span class="text-muted">-</span>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="mp-empty">No bought listings.</div>
          <% end %>

        <% else %>
          <% if current_listings.any? %>
            <div class="table-responsive">
              <table class="mp-table">
                <thead>
                  <tr>
                    <th class="w-era">Era</th>
                    <th class="w-set">Set</th>
                    <th class="w-type">Product Type</th>
                    <th class="w-cond">Condition</th>
                    <th class="w-price">Price</th>
                    <th class="w-qty">Qty</th>
                    <th class="w-status">Status</th>
                    <th class="w-date">Listed</th>
                    <th class="w-actions">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% current_listings.each do |l| %>
                    <% slug = (l.respond_to?(:set_slug) ? l.set_slug.to_s : "").presence || "" %>
                    <tr>
                      <td class="w-era"><%= (l.respond_to?(:era) ? l.era.to_s : "").presence || era_for.call(slug).presence || "-" %></td>
                      <td class="w-set"><%= (l.respond_to?(:set_name) ? l.set_name.to_s : "").presence || set_name_for.call(slug).presence || "-" %></td>
                      <td class="w-type"><%= product_type_display.call(l) %></td>
                      <td class="w-cond"><%= (l.respond_to?(:condition) ? l.condition.to_s : "").presence || "-" %></td>
                      <td class="w-price"><%= number_to_currency(l.respond_to?(:price_cents) ? (l.price_cents.to_i / 100.0) : 0, unit: "€") %></td>
                      <td class="w-qty"><%= l.respond_to?(:quantity) ? l.quantity.to_i : "-" %></td>
                      <td class="w-status"><%= listing_status_label.call(l) %></td>
                      <td class="w-date"><%= l.respond_to?(:created_at) && l.created_at ? l.created_at.strftime("%d %b %Y") : "" %></td>
                      <td class="w-actions">
                        <div class="mp-actions">
                          <%= link_to "View", marketplace_listing_path(l), class: "btn btn-outline-primary btn-sm" %>
                          <% if is_self && l.respond_to?(:status) && l.status.to_s == "active" %>
                            <%= button_to "Cancel", cancel_marketplace_listing_path(l), method: :post, class: "btn btn-outline-danger btn-sm", form: { data: { preserve_scroll: true } } %>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="mp-empty">No active listings.</div>
          <% end %>
        <% end %>
      </div>

      <div class="acc-card">
        <div class="subhead">Auctions</div>

        <div class="acc-tabs">
          <%= link_to "Current Auctions", account_base_path.call(tab: tab, auction_tab: "current", raffle_tab: raffle_tab), class: ["", (auction_tab == "current" ? "active" : nil)].compact.join(" ") %>
          <%= link_to "Ended Auctions", account_base_path.call(tab: tab, auction_tab: "ended", raffle_tab: raffle_tab), class: ["", (auction_tab == "ended" ? "active" : nil)].compact.join(" ") %>
          <%= link_to "Sold Auctions", account_base_path.call(tab: tab, auction_tab: "sold", raffle_tab: raffle_tab), class: ["", (auction_tab == "sold" ? "active" : nil)].compact.join(" ") %>
          <% if is_self %>
            <%= link_to "Auctions Won", account_base_path.call(tab: tab, auction_tab: "won", raffle_tab: raffle_tab), class: ["", (auction_tab == "won" ? "active" : nil)].compact.join(" ") %>
          <% end %>
        </div>

        <% if auction_tab == "won" && is_self %>
          <% if won_auctions.any? %>
            <div class="table-responsive">
              <table class="mp-table">
                <thead>
                  <tr>
                    <th class="w-seller">Seller</th>
                    <th class="w-au-desc">Auction Description</th>
                    <th class="w-au-bid">Winning Bid</th>
                    <th class="w-au-length">Length</th>
                    <th class="w-au-date">Sold Date</th>
                    <th class="w-au-actions">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% won_auctions.each do |auction_item| %>
                    <tr>
                      <td class="w-seller">
                        <% if auction_item.respond_to?(:seller_id) && auction_item.seller_id.present? %>
                          <%= link_to (auction_item.seller&.respond_to?(:username) && auction_item.seller.username.present? ? auction_item.seller.username : "User ##{auction_item.seller_id}"), user_path(auction_item.seller_id), class: "text-decoration-none" %>
                        <% else %>
                          -
                        <% end %>
                      </td>
                      <td class="w-au-desc">
                        <div class="acc-au-desc" title="<%= auction_item.auction_description.to_s %>"><%= auction_item.auction_description.to_s %></div>
                      </td>
                      <td class="w-au-bid"><%= number_to_currency(auction_item.respond_to?(:winning_bid_cents) ? (auction_item.winning_bid_cents.to_i / 100.0) : 0, unit: "€") %></td>
                      <td class="w-au-length"><%= auction_length_label_for.call(auction_item) %></td>
                      <td class="w-au-date"><%= auction_item.updated_at ? auction_item.updated_at.strftime("%d %b %Y") : "" %></td>
                      <td class="w-au-actions">
                        <div class="mp-actions">
                          <%= link_to "View", auction_listing_path(auction_item), class: "btn btn-outline-primary btn-sm" %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="mp-empty">No auctions won.</div>
          <% end %>

        <% elsif selected_auctions.any? %>
          <div class="table-responsive">
            <table class="mp-table">
              <thead>
                <tr>
                  <th class="w-au-desc">Auction Description</th>
                  <th class="w-au-cond">Condition</th>
                  <th class="w-au-bids">Bids</th>
                  <th class="w-au-length">Length</th>
                  <th class="w-au-time">Time Remaining</th>
                  <th class="w-au-date">Listed</th>
                  <th class="w-au-actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% selected_auctions.each do |auction_item| %>
                  <tr>
                    <td class="w-au-desc">
                      <div class="acc-au-desc" title="<%= auction_item.auction_description.to_s %>"><%= auction_item.auction_description.to_s %></div>
                    </td>
                    <td class="w-au-cond"><%= auction_item.condition.to_s.presence || "-" %></td>
                    <td class="w-au-bids"><%= auction_item.bids_count.to_i %></td>
                    <td class="w-au-length"><%= auction_length_label_for.call(auction_item) %></td>
                    <td class="w-au-time"><%= auction_remaining_text.call(auction_item) %></td>
                    <td class="w-au-date"><%= auction_item.created_at ? auction_item.created_at.strftime("%d %b %Y") : "" %></td>
                    <td class="w-au-actions">
                      <div class="mp-actions">
                        <%= link_to "View", auction_listing_path(auction_item), class: "btn btn-outline-primary btn-sm" %>
                        <% if auction_tab == "current" && defined?(current_user) && current_user && auction_item.can_end_early_by?(current_user) %>
                          <%= button_to "End", end_auction_path(auction_item), method: :post, class: "btn btn-outline-danger btn-sm", form: { class: "d-inline", data: { turbo_confirm: "Are you sure you want to end this auction?", preserve_scroll: true } } %>
                        <% end %>
                      </div>
                    </td>
                  </tr>

                  <% if auction_tab == "sold" && auction_item.winning_bidder.present? && defined?(current_user) && current_user && current_user.id.to_i == auction_item.seller_id.to_i %>
                    <tr>
                      <td colspan="7" style="text-align:left;">
                        <strong>Winning Bidder:</strong> <%= auction_item.winning_bidder.username.to_s.presence || "User ##{auction_item.winning_bidder.id}" %>
                        ·
                        <strong>Send To:</strong> <%= auction_item.winning_address_text.to_s.presence || "-" %>
                      </td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="mp-empty">
            <%= auction_tab == "ended" ? "No ended auctions." : (auction_tab == "sold" ? "No sold auctions." : (auction_tab == "won" ? "No auctions won." : "No current auctions.")) %>
          </div>
        <% end %>
      </div>

      <div class="acc-card">
        <div class="subhead">Raffles</div>

        <div class="acc-tabs">
          <%= link_to "Current Raffles", account_base_path.call(tab: tab, auction_tab: auction_tab, raffle_tab: "current"), class: ["", (raffle_tab == "current" ? "active" : nil)].compact.join(" ") %>
          <%= link_to "Ended Raffles", account_base_path.call(tab: tab, auction_tab: auction_tab, raffle_tab: "ended"), class: ["", (raffle_tab == "ended" ? "active" : nil)].compact.join(" ") %>
          <% if is_self %>
            <%= link_to "Raffles Won", account_base_path.call(tab: tab, auction_tab: auction_tab, raffle_tab: "won"), class: ["", (raffle_tab == "won" ? "active" : nil)].compact.join(" ") %>
          <% end %>
        </div>

        <% if selected_raffles.any? %>
          <div class="table-responsive">
            <table class="mp-table">
              <thead>
                <tr>
                  <% if raffle_tab == "won" && is_self %>
                    <th class="w-seller">Host</th>
                  <% end %>
                  <th class="w-ra-title">Title</th>
                  <th class="w-ra-kind">Type</th>
                  <th class="w-ra-price">Ticket Price</th>
                  <th class="w-ra-tickets">Tickets</th>
                  <th class="w-ra-status">Status</th>
                  <th class="w-ra-date"><%= raffle_tab == "current" ? "Created" : "Ended" %></th>
                  <th class="w-ra-actions">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% selected_raffles.each do |raffle_item| %>
                  <% host = defined?(User) && raffle_item.respond_to?(:host_id) ? User.find_by(id: raffle_item.host_id) : nil %>
                  <% sold_tickets = raffle_tickets_sold.call(raffle_item) %>
                  <% total_tickets = raffle_item.respond_to?(:total_tickets) ? raffle_item.total_tickets.to_i : 0 %>
                  <% ticket_price = raffle_item.respond_to?(:ticket_price_cents) ? raffle_item.ticket_price_cents.to_i : 0 %>
                  <% date_value = if raffle_tab == "current" then raffle_item.created_at else (raffle_item.respond_to?(:ended_at) && raffle_item.ended_at.present? ? raffle_item.ended_at : raffle_item.updated_at) end %>
                  <tr>
                    <% if raffle_tab == "won" && is_self %>
                      <td class="w-seller">
                        <% if host %>
                          <%= link_to host.username.to_s.presence || "User ##{host.id}", user_path(host.id), class: "text-decoration-none" %>
                        <% elsif raffle_item.respond_to?(:host_id) && raffle_item.host_id.present? %>
                          <%= link_to "User ##{raffle_item.host_id}", user_path(raffle_item.host_id), class: "text-decoration-none" %>
                        <% else %>
                          -
                        <% end %>
                      </td>
                    <% end %>
                    <td class="w-ra-title"><%= raffle_item.respond_to?(:title) ? raffle_item.title.to_s : "-" %></td>
                    <td class="w-ra-kind"><%= raffle_kind_label.call(raffle_item) %></td>
                    <td class="w-ra-price"><%= number_to_currency(ticket_price / 100.0, unit: "€") %></td>
                    <td class="w-ra-tickets"><%= "#{sold_tickets}/#{total_tickets}" %></td>
                    <td class="w-ra-status"><%= raffle_status_label.call(raffle_item) %></td>
                    <td class="w-ra-date"><%= date_value ? date_value.strftime("%d %b %Y") : "" %></td>
                    <td class="w-ra-actions">
                      <div class="mp-actions">
                        <% if respond_to?(:raffle_path) %>
                          <%= link_to "View", raffle_path(raffle_item), class: "btn btn-outline-primary btn-sm" %>
                        <% else %>
                          <span class="text-muted">-</span>
                        <% end %>
                      </div>
                    </td>
                  </tr>

                  <% if raffle_tab != "current" && raffle_item.respond_to?(:winner_user_id) && raffle_item.winner_user_id.present? && defined?(current_user) && current_user && current_user.id.to_i == raffle_item.host_id.to_i %>
                    <tr>
                      <td colspan="<%= raffle_tab == "won" && is_self ? 8 : 7 %>" style="text-align:left;">
                        <strong>Winner:</strong>
                        <% winner = defined?(User) ? User.find_by(id: raffle_item.winner_user_id) : nil %>
                        <%= winner&.username.to_s.presence || raffle_item.winner_name.to_s.presence || "User ##{raffle_item.winner_user_id}" %>
                      </td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="mp-empty">
            <%= raffle_tab == "ended" ? "No ended raffles." : (raffle_tab == "won" ? "No raffles won." : "No current raffles.") %>
          </div>
        <% end %>
      </div>

      <% if is_self %>
        <div class="acc-card">
          <div class="subhead">Watchlist</div>

          <% if items.any? %>
            <div class="list-group list-group-flush">
              <% items.each do |it| %>
                <% m = meta_for.call(it) %>
                <div class="list-group-item">
                  <div class="d-flex align-items-center gap-3">
                    <%= link_to m[:href], class: "d-inline-flex align-items-center text-decoration-none" do %>
                      <%= image_tag m[:img_url], alt: m[:label], style: "height:44px;width:auto;object-fit:contain;" %>
                    <% end %>

                    <div class="flex-grow-1">
                      <%= link_to m[:label], m[:href], class: "text-decoration-none text-body fw-semibold" %>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                      <%= link_to "View", m[:href], class: "btn btn-sm btn-outline-primary" %>
                      <%= button_to "Remove", remove_watchlist_path(sku: m[:sku]), method: :delete, params: { return_to: request.fullpath }, class: "btn btn-sm btn-outline-danger", form: { data: { preserve_scroll: true } } %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="mp-empty">Your watchlist is empty.</div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  (function () {
    const key = "pokevalue_account_scroll_y";

    function saveScroll() {
      try {
        sessionStorage.setItem(key, String(window.scrollY || window.pageYOffset || 0));
      } catch (e) {}
    }

    function restoreScroll() {
      let raw = null;

      try {
        raw = sessionStorage.getItem(key);
      } catch (e) {}

      if (raw === null) return;

      const y = parseInt(raw, 10);

      try {
        sessionStorage.removeItem(key);
      } catch (e) {}

      if (Number.isNaN(y)) return;

      requestAnimationFrame(function () {
        window.scrollTo(0, y);
        setTimeout(function () { window.scrollTo(0, y); }, 25);
        setTimeout(function () { window.scrollTo(0, y); }, 75);
        setTimeout(function () { window.scrollTo(0, y); }, 150);
        setTimeout(function () { window.scrollTo(0, y); }, 300);
      });
    }

    document.addEventListener("click", function (event) {
      const clickable = event.target.closest("a, button, input[type='submit']");
      if (!clickable) return;

      const opensModal = clickable.hasAttribute("data-bs-toggle");
      const closesModal = clickable.hasAttribute("data-bs-dismiss");
      const inlineButton = clickable.getAttribute("type") === "button" && clickable.getAttribute("onclick");

      if (opensModal || closesModal || inlineButton) return;

      saveScroll();
    }, true);

    document.addEventListener("submit", function () {
      saveScroll();
    }, true);

    window.addEventListener("beforeunload", saveScroll);
    window.addEventListener("pageshow", restoreScroll);

    document.addEventListener("turbo:before-visit", saveScroll);
    document.addEventListener("turbo:submit-start", saveScroll);
    document.addEventListener("turbo:load", restoreScroll);
    document.addEventListener("DOMContentLoaded", restoreScroll);
  })();
</script>