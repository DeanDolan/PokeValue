  <style>
    .acc-wrap{display:flex;gap:16px;flex-wrap:wrap;align-items:flex-start}
    .acc-left{flex:1;min-width:320px}
    .acc-title{font-size:1.15rem;margin:0 0 14px}
    .acc-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:14px;box-shadow:0 10px 25px rgba(15,23,42,.08);margin-bottom:12px;overflow:hidden}
    .acc-top{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .acc-meta p{margin:0 0 6px;font-size:.85rem}
    .acc-badges img{height:20px;width:20px;object-fit:contain;display:inline-block;vertical-align:middle}
