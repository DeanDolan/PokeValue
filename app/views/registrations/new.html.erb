<%# Registration page wrapper %>
<div class="container py-4 register-page">
  <div class="register-hero mb-4">
    <div>
      <p class="register-eyebrow mb-1">Create your PokeValue account</p>
      <h1 class="mb-2">Register</h1>
      <p class="register-hero-text mb-0">
        Create a private account for tracking your portfolio, joining the marketplace, hosting auctions and joining raffles.
      </p>
    </div>
  </div>

  <div class="row g-4 justify-content-center">
    <div class="col-lg-7">
      <%= render "registrations/form" %>
    </div>
  </div>
</div>