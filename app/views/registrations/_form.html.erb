<%= form_with url: register_path, method: :post, local: true, class: "register-form-card", html: { autocomplete: "off" } do %>
  <%# Username field submitted as params[:username]. %>
  <div class="mb-3">
    <label class="form-label">Username</label>
    <%= text_field_tag :username, nil, class: "form-control", autocomplete: "off" %>
    <div class="form-text">
      Username must be 5-15 characters. Do not use your real name. Use letters, numbers, dots, underscores or dashes only.
    </div>
  </div>

  <%# Country dropdown submitted as params[:country_code]. %>
  <div class="mb-3">
    <label class="form-label">Country</label>
    <%# Loops through each country from countries_helper.rb, shows "country flag + country name"
    <%# Only saves the country code %>
    <%= select_tag :country_code,
      options_for_select(eu_countries.map { |c| ["#{c[:flag]} #{c[:name]}", c[:code]] }),
      include_blank: "Select country",
      class: "form-select" %>
    <div class="form-text">
      Choose the country in which you are located.
    </div>
  </div>

  <%# Revolut tag field submitted as params[:revolut_tag]. %>
  <div class="mb-3">
    <label class="form-label">Revolut Tag</label>
    <%= text_field_tag :revolut_tag, nil, class: "form-control", placeholder: "@yourtag", autocomplete: "off" %>
    <div class="form-text">
      Your Revolut tag is encrypted in storage, but it will be shown later to buyers, winning bidders or raffle ticket buyers when payment is required.
    </div>
  </div>

  <%# Password field submitted as params[:password]. %>
  <div class="mb-3">
    <label class="form-label">Password</label>
    <%= password_field_tag :password, nil, class: "form-control", autocomplete: "off", data: { lpignore: "true", one_password_ignore: "true" } %>
    <div class="form-text">
      Password must be 12-20 characters and include uppercase, lowercase, number and symbol. Do not use your real name or username.
    </div>
  </div>

  <%# Confirmation field submitted as params[:password_confirmation]. %>
  <div class="mb-3">
    <label class="form-label">Confirm Password</label>
    <%= password_field_tag :password_confirmation, nil, class: "form-control", autocomplete: "off", data: { lpignore: "true", one_password_ignore: "true" } %>
  </div>

  <%# Submit button that triggers RegistrationsController#create. %>
  <div class="d-grid">
    <%= submit_tag "Register", class: "btn btn-success btn-lg" %>
  </div>
<% end %>