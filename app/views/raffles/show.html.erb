<%
# I use this to check if the logged-in user is the person who created/hosted this raffle.
# This is important because only the host should be able to run the raffle, assign tickets, verify payments, etc.
is_host = current_user && @raffle.host_id.to_i == current_user.id.to_i

# I use this to check if the raffle has already finished and has a winner.
is_completed = @raffle.completed?

# I use this to check if the raffle is still active, meaning tickets can still be bought or assigned.
is_active = @raffle.active?

# I use this so the page can automatically spin/reveal the winner if the URL has auto_spin=1 or reveal=1.
auto_spin = params[:auto_spin].to_s == "1" || params[:reveal].to_s == "1"

# I use this to check if the controller has given admin permission to manage raffles.
admin_can_manage_raffles = defined?(@admin_can_manage_raffles) && @admin_can_manage_raffles

# I use this to decide if the Delete Raffle button should be available.
# The raffle can only be deleted by the host or by an admin.
can_delete_raffle = current_user.present? && (is_host || admin_can_manage_raffles)

# I store the current user's id so the winner reveal can be saved separately for each user in localStorage.
current_user_id_for_reveal = current_user&.id.to_i

# I use this to hide the completed raffle winner until the wheel reveal has happened.
winner_reveal_required = is_completed && current_user.present?

# I use this to decide if the Reveal Winner button should be shown.
can_spin_reveal_winner = is_completed && current_user.present?

# I limit long names so they do not break the ticket chips or the wheel labels.
max_name_length = 24

# I convert all sold tickets into a smaller format that JavaScript can use for the wheel.
# Each ticket gets its number, shortened name, display label and user id.
ticket_items = @tickets.sort_by(&:ticket_number).map do |ticket|
  short_name = ticket.display_name.to_s[0, max_name_length]
  {
    number: ticket.ticket_number.to_i,
    name: short_name,
    label: "##{ticket.ticket_number} #{short_name}",
    user_id: ticket.user_id.to_i
  }
end

# I find all ticket numbers that belong to the current user.
# These are shown later in the "Your Tickets" section.
user_ticket_numbers =
  if current_user
    @tickets.select { |ticket| ticket.user_id.to_i == current_user.id.to_i }.map(&:ticket_number).sort
  else
    []
  end

# I keep the available ticket numbers here so the user can pick exact numbers to buy.
available_numbers = @available_numbers || []

# I check if the current user has tickets and if all of their tickets are marked as paid.
my_paid_all = @my_tickets.any? && @my_tickets.all?(&:paid?)

# I store the winning person's display name.
# Safe navigation is used because there may not be a winner yet.
winning_name = @winning_ticket&.display_name.to_s

# I store the winning ticket number.
winning_number = @winning_ticket&.ticket_number.to_i

# I check if the current user is an entrant in the raffle.
entrant_viewer = current_user.present? && @tickets.any? { |ticket| ticket.user_id.to_i == current_user.id.to_i }

# I get the current user's Revolut tag from their account.
my_revolut_tag = current_user&.revolut_tag.to_s

# I get the host's Revolut tag so entrants can reveal it when they need to pay.
host_revolut_tag = @raffle.revolut_tag.to_s

# These are the options the host can choose from when assigning tickets manually.
assignment_reason_options = ["Mini Raffle", "Free Ticket(s)"]

# I use this to check if the person viewing the page is the raffle winner.
viewer_is_raffle_winner =
  current_user.present? &&
  is_completed &&
  @raffle.winner_user_id.to_i == current_user.id.to_i &&
  @raffle.host_id.to_i != current_user.id.to_i
%>

