        <% end %>
      </section>
    <% end %>

    <% if current_user && user_ticket_numbers.any? && is_active %>
      <section class="rf-card">
        <h2 class="h5 mb-3">Your Tickets</h2>
        <div class="mb-3">
          <% user_ticket_numbers.each do |number| %>
            <span class="rf-number-chip rf-number-chip-self">#<%= number %></span>
          <% end %>
        </div>

        <%= form_with url: return_tickets_raffle_path(@raffle), method: :post, local: true do %>
          <div class="mb-3">
            <label class="form-label">Return Selected Tickets</label>
            <%= select_tag "ticket_numbers[]",
                  options_for_select(user_ticket_numbers.map { |number| ["##{number}", number] }),
                  multiple: true,
                  size: [ user_ticket_numbers.size, 8 ].min,
                  class: "form-select" %>
          </div>
          <%= submit_tag("Return Tickets", class: "btn btn-outline-danger btn-sm") %>
        <% end %>
      </section>

      <% unless is_host %>
        <section class="rf-card">
          <h2 class="h5 mb-3">Pay For Tickets</h2>

          <div class="rf-tag-card mb-3">
            <div class="rf-tag-label">Host Revolut Tag</div>
            <div>
              <span class="rf-tag-hidden" id="host_tag_hidden">Revolut Tag Hidden</span>
              <span class="rf-tag-value" id="host_tag_value" style="display:none;"><%= host_revolut_tag %></span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <button type="button" class="btn btn-sm btn-outline-dark" id="revealHostTagButton" <%= "disabled" if host_revolut_tag.blank? %>>Pay For Tickets</button>
            </div>
          </div>

          <%= form_with url: toggle_paid_raffle_path(@raffle), method: :post, local: true do %>
            <div class="mb-3">
              <label class="form-label">Your Revolut Tag</label>
              <%= text_field_tag :revolut_tag,
                    my_revolut_tag.presence,
                    class: "form-control",
                    placeholder: "@yourtag",
                    maxlength: 80,
                    required: true,
                    readonly: true %>
              <div class="rf-form-note">This Revolut Tag is taken from your account and cannot be changed here.</div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <%= submit_tag(my_paid_all ? "Mark All Unpaid" : "Mark All Paid", class: "btn btn-sm #{my_paid_all ? 'btn-outline-secondary' : 'btn-success'}") %>
            </div>
          <% end %>
