                <div class="rf-form-note">Optional. Leave blank if choosing exact numbers or buying all remaining tickets.</div>
              </div>

              <div class="rf-purchase-actions">
                <%= submit_tag((is_host ? "Assign Ticket(s)" : "Buy Ticket(s)"), class: "btn btn-primary btn-sm") %>
                <%= button_tag((is_host ? "Assign All Available" : "Buy All Available"), type: "submit", name: "buy_all_available", value: "1", class: "btn btn-outline-primary btn-sm") %>
              </div>
            </div>
          <% end %>
        <% else %>
