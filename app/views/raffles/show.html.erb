    <% if is_completed %>
      <section class="rf-card">
        <h2 class="h5 mb-3">Winner</h2>
        <div class="rf-winner-box">
          <% if entrant_viewer %>
            <div id="winnerBoxMasked">
              Winner:
              <span class="rf-blackout">#<%= winning_number %> <%= winning_name.to_s[0, max_name_length] %></span>
            </div>
            <div id="winnerBoxRevealed" style="display:none;">
              Winner: #<%= winning_number %> - <%= winning_name %>
            </div>
          <% else %>
            <div id="winnerBoxMasked" style="display:none;"></div>
            <div id="winnerBoxRevealed">
              Winner: #<%= winning_number %> - <%= winning_name %>
            </div>
          <% end %>
