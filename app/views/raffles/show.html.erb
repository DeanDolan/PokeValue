    body[data-bs-theme="dark"] .rf-delete-confirm-yes:focus,
    body[data-bs-theme="dark"] .rf-delete-confirm-yes:active,
    body[data-bs-theme="dark"] .rf-delete-confirm-no:hover,
    body[data-bs-theme="dark"] .rf-delete-confirm-no:focus,
    body[data-bs-theme="dark"] .rf-delete-confirm-no:active,
    html[data-theme="dark"] .rf-delete-confirm-yes:hover,
    html[data-theme="dark"] .rf-delete-confirm-yes:focus,
    html[data-theme="dark"] .rf-delete-confirm-yes:active,
    html[data-theme="dark"] .rf-delete-confirm-no:hover,
    html[data-theme="dark"] .rf-delete-confirm-no:focus,
    html[data-theme="dark"] .rf-delete-confirm-no:active,
    body[data-theme="dark"] .rf-delete-confirm-yes:hover,
    body[data-theme="dark"] .rf-delete-confirm-yes:focus,
    body[data-theme="dark"] .rf-delete-confirm-yes:active,
    body[data-theme="dark"] .rf-delete-confirm-no:hover,
    body[data-theme="dark"] .rf-delete-confirm-no:focus,
    body[data-theme="dark"] .rf-delete-confirm-no:active,
    html.dark .rf-delete-confirm-yes:hover,
    html.dark .rf-delete-confirm-yes:focus,
    html.dark .rf-delete-confirm-yes:active,
    html.dark .rf-delete-confirm-no:hover,
    html.dark .rf-delete-confirm-no:focus,
    html.dark .rf-delete-confirm-no:active,
    body.dark .rf-delete-confirm-yes:hover,
    body.dark .rf-delete-confirm-yes:focus,
    body.dark .rf-delete-confirm-yes:active,
    body.dark .rf-delete-confirm-no:hover,
    body.dark .rf-delete-confirm-no:focus,
    body.dark .rf-delete-confirm-no:active,
    html.dark-mode .rf-delete-confirm-yes:hover,
    html.dark-mode .rf-delete-confirm-yes:focus,
    html.dark-mode .rf-delete-confirm-yes:active,
    html.dark-mode .rf-delete-confirm-no:hover,
    html.dark-mode .rf-delete-confirm-no:focus,
    html.dark-mode .rf-delete-confirm-no:active,
    body.dark-mode .rf-delete-confirm-yes:hover,
    body.dark-mode .rf-delete-confirm-yes:focus,
    body.dark-mode .rf-delete-confirm-yes:active,
    body.dark-mode .rf-delete-confirm-no:hover,
    body.dark-mode .rf-delete-confirm-no:focus,
    body.dark-mode .rf-delete-confirm-no:active,
    body:has(.navbar-dark) .rf-delete-confirm-yes:hover,
    body:has(.navbar-dark) .rf-delete-confirm-yes:focus,
    body:has(.navbar-dark) .rf-delete-confirm-yes:active,
    body:has(.navbar-dark) .rf-delete-confirm-no:hover,
    body:has(.navbar-dark) .rf-delete-confirm-no:focus,
    body:has(.navbar-dark) .rf-delete-confirm-no:active{
      background:#d4af37 !important;
      color:#000000 !important;
      border-color:#d4af37 !important;
      box-shadow:0 0 0 .16rem rgba(212,175,55,.25) !important;
    }

    /* Dark mode wheel stage styling. */
    :root[data-pv-theme="dark"] .rf-wheel-stage{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#d4af37 !important;
    }

    /* Dark mode wheel canvas background. */
    :root[data-pv-theme="dark"] .rf-wheel-canvas{
      background:#000000 !important;
      background-color:#000000 !important;
    }

    /* Keeps confetti transparent in dark mode too. */
    :root[data-pv-theme="dark"] .rf-confetti,
    :root[data-pv-theme="dark"] #raffleConfetti{
      background:transparent !important;
      background-color:transparent !important;
    }

    /* Dark mode wheel pointer styling. */
    :root[data-pv-theme="dark"] .rf-wheel-pointer{
      top:10px !important;
      left:50% !important;
      transform:translateX(-50%) !important;
      width:0 !important;
      height:0 !important;
      background:transparent !important;
      background-color:transparent !important;
      border-left:18px solid transparent !important;
      border-right:18px solid transparent !important;
      border-top:32px solid #d4af37 !important;
      border-bottom:0 !important;
      border-radius:0 !important;
      filter:drop-shadow(0 2px 3px rgba(212,175,55,0.35)) !important;
    }

    /* Makes sure no pseudo-element appears on the dark mode pointer. */
    :root[data-pv-theme="dark"] .rf-wheel-pointer::after{
      display:none !important;
      content:none !important;
    }

    /* Dark mode countdown overlay styling. */
    :root[data-pv-theme="dark"] .rf-wheel-countdown{
      color:#d4af37 !important;
      background:rgba(42,42,42,0.84) !important;
      background-color:rgba(42,42,42,0.84) !important;
    }

    /* Dark mode winner overlay box. */
    :root[data-pv-theme="dark"] .rf-winner-overlay-box{
      background:rgba(0,0,0,0.94) !important;
      color:#d4af37 !important;
      border:1px solid #d4af37 !important;
    }

    /* Makes all text inside the dark mode winner overlay gold. */
    :root[data-pv-theme="dark"] .rf-winner-overlay-box *{
      color:#d4af37 !important;
    }

    /* Dark mode ticket picker container. */
    :root[data-pv-theme="dark"] .rf-ticket-select{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#d4af37 !important;
    }

    /* Dark mode available ticket option base style. */
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option{
      background:#d4af37 !important;
      background-color:#d4af37 !important;
      color:#000000 !important;
      border-color:#d4af37 !important;
      box-shadow:none !important;
    }

    /* Dark mode ticket option text. */
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option span{
      color:#000000 !important;
      background:transparent !important;
    }

    /* Dark mode selected/hover/focus ticket option styling. */
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:not(.is-selected):hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:focus,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:active,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:focus,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:active{
      background:#000000 !important;
      background-color:#000000 !important;
      color:#d4af37 !important;
      border-color:#d4af37 !important;
      box-shadow:none !important;
      filter:none !important;
    }

    /* Dark mode selected/hover/focus ticket text styling. */
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:not(.is-selected):hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:focus span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:active span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:focus span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:active span{
      color:#d4af37 !important;
      background:transparent !important;
    }

    /* Mobile/tablet layout changes. */
    @media (max-width: 992px){
      .rf-stat-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
      .rf-wheel-stage{
        width:90%;
        max-width:90%;
      }
    }
  </style>

  <div class="rf-page-stack">
    <%# This is the top card with the raffle title, host, status buttons and stats. %>
    <section class="rf-card">
      <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
          <%# Shows the raffle title. %>
          <h1 class="rf-title"><%= @raffle.title %></h1>

          <%# Shows small raffle details like type, host and created date. %>
          <div class="rf-sub">
            <%# Shows either Mini Raffle or Raffle depending on the raffle kind. %>
            <%= @raffle.raffle_kind == "mini" ? "Mini Raffle" : "Raffle" %>

            <%# If this is a mini raffle linked to a main raffle, show the main raffle title too. %>
            <% if @raffle.raffle_kind == "mini" && @raffle.main_raffle.present? %>
              · Main Raffle: <%= @raffle.main_raffle.title %>
            <% end %>

            · Hosted by

            <%# If the viewer won the raffle, the host name can later turn into a clickable profile link after reveal. %>
            <% if viewer_is_raffle_winner %>
              <span id="raffleHostNamePlain"><%= @raffle.host.username %></span>
              <%= link_to @raffle.host.username, user_path(@raffle.host_id), class: "rf-host-link text-decoration-none", id: "raffleHostNameLink", style: "display:none;" %>
            <% else %>
              <%= @raffle.host.username %>
            <% end %>

            <%# Shows how long ago the raffle was created. %>
            · Created <%= time_ago_in_words(@raffle.created_at) %> ago
          </div>
        </div>

        <%# Buttons on the top right of the card. %>
        <div class="d-flex gap-2 flex-wrap">
          <%# Takes the user back to the raffles index page. %>
          <%= link_to "Back", raffles_path, class: "btn btn-outline-secondary btn-sm" %>

          <%# The host can only run the raffle if it is active and sold out. %>
          <% if is_host && is_active && @raffle.sold_out? %>
            <%= button_to "Run Raffle", run_raffle_raffle_path(@raffle), method: :post, class: "btn btn-success btn-sm", form: { class: "rf-run-raffle-form" } %>
          <% end %>

          <%# The delete button only appears for the host or admin. %>
          <% if can_delete_raffle %>
            <%= button_to "Delete Raffle",
                  raffle_path(@raffle),
                  method: :delete,
                  class: "btn btn-outline-danger btn-sm",
                  form: { class: "d-inline mb-0 rf-delete-confirm-form", data: { turbo: "false" } } %>
          <% end %>
        </div>
      </div>

      <%# These boxes summarise the raffle quickly. %>
      <div class="rf-stat-grid">
        <div class="rf-stat">
          <div class="rf-stat-label">Ticket Price</div>
          <div class="rf-stat-value"><%= number_to_currency(@raffle.ticket_price_eur, unit: "€") %></div>
        </div>

        <div class="rf-stat">
          <div class="rf-stat-label">Sold</div>
          <div class="rf-stat-value"><%= @raffle.sold_tickets_count %> / <%= @raffle.total_tickets %></div>
        </div>

        <div class="rf-stat">
          <div class="rf-stat-label">Tickets Left</div>
          <div class="rf-stat-value"><%= @raffle.tickets_left %></div>
        </div>

        <div class="rf-stat">
          <div class="rf-stat-label">Amount Paid</div>
          <div class="rf-stat-value"><%= number_to_currency(@paid_amount_cents.to_i / 100.0, unit: "€") %></div>
        </div>

        <div class="rf-stat">
          <div class="rf-stat-label">Status</div>
          <div class="rf-stat-value"><%= @raffle.status.capitalize %></div>
        </div>
      </div>

      <%# Shows up to 4 uploaded raffle images if the raffle has photos attached. %>
      <% if @raffle.photos.attached? %>
        <div class="rf-gallery">
          <% @raffle.photos.first(4).each do |photo| %>
            <%= image_tag url_for(photo), alt: "" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <%# This card shows all raffle participants, their tickets, payment status and host actions. %>
    <section class="rf-card">
      <h2 class="h5 mb-3">Participants</h2>

      <div class="rf-table-wrap">
        <table class="rf-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Tickets</th>
              <th>Numbers</th>

              <%# Only the host can see why tickets were assigned. %>
              <% if is_host %>
                <th>Reason</th>
              <% end %>

              <th>Paid</th>
              <th>Verified</th>
              <th>Paid Amount</th>
              <th>Total Amount</th>

              <%# Host sees Revolut tags and verify actions. Normal users only see a basic actions column while active. %>
              <% if is_host %>
                <th>Revolut Tag</th>
                <th>Actions</th>
              <% elsif is_active %>
                <th>Actions</th>
              <% end %>
            </tr>
          </thead>

          <tbody>
            <%# If there are participant rows, loop through and display each person. %>
            <% if @participant_rows.any? %>
              <% @participant_rows.each do |row| %>
                <%# Checks if this row belongs to the logged-in user so I can highlight it. %>
                <% is_self_row = current_user && row[:user_id].to_i == current_user.id.to_i %>

                <tr class="<%= 'rf-row-self' if is_self_row %>">
                  <td class="<%= 'rf-name-self' if is_self_row %>"><%= row[:display_name] %></td>
                  <td><%= row[:ticket_count] %></td>
                  <td><%= row[:ticket_numbers].map { |n| "##{n}" }.join(", ") %></td>

                  <%# Host-only reason column. %>
                  <% if is_host %>
                    <td><%= row[:assignment_reason].presence || "-" %></td>
                  <% end %>

                  <%# Shows whether all of this participant's tickets are marked as paid. %>
                  <td>
                    <% if row[:paid_all] %>
                      <span class="rf-paid-badge">Paid</span>
                    <% else %>
                      <span class="rf-muted">No</span>
                    <% end %>
                  </td>

                  <%# Shows whether the host has verified the participant's payment. %>
                  <td>
                    <% if row[:verified_all] %>
                      <span class="rf-verified-badge">Verified</span>
                    <% else %>
                      <span class="rf-muted">No</span>
                    <% end %>
                  </td>

                  <%# Shows how much this participant has marked as paid. %>
                  <td><%= number_to_currency(row[:paid_amount_cents].to_i / 100.0, unit: "€") %></td>

                  <%# Shows the participant's total amount owed. %>
                  <td><%= number_to_currency(row[:total_amount_cents].to_i / 100.0, unit: "€") %></td>

                  <%# Host-only Revolut tag and verify controls. %>
                  <% if is_host %>
                    <td>
                      <%# If the entrant has a Revolut tag, hide it until the host clicks Reveal. %>
                      <% if row[:revolut_tag].present? %>
                        <div class="rf-tag-label mb-1">Revolut Tag</div>
                        <div>
                          <span class="rf-tag-hidden" id="entrant_tag_hidden_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>">Hidden</span>
                          <span class="rf-tag-value" id="entrant_tag_value_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>" style="display:none;"><%= row[:revolut_tag] %></span>
                        </div>
                      <% else %>
                        <span class="rf-muted">None</span>
                      <% end %>
                    </td>

                    <td class="d-flex gap-2 justify-content-center flex-wrap">
                      <%# Reveal button only appears if there is actually a Revolut tag to show. %>
                      <% if row[:revolut_tag].present? %>
                        <button
                          type="button"
                          class="btn btn-sm btn-outline-dark rf-reveal-entrant-tag-btn"
                          data-hidden-id="entrant_tag_hidden_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>"
                          data-value-id="entrant_tag_value_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>">
                          Reveal
                        </button>
                      <% end %>

                      <%# Host can verify or unverify this participant's payment. %>
                      <%= button_to(row[:verified_all] ? "Unverify" : "Verify",
                            verify_payment_raffle_path(@raffle),
                            method: :post,
                            params: { user_id: row[:user_id], display_name: row[:display_name] },
                            class: "btn btn-sm #{row[:verified_all] ? 'btn-outline-secondary' : 'btn-primary'}") %>
                    </td>
                  <% elsif is_active %>
                    <%# Non-host users only get told to use the payment section below if it is their own row. %>
                    <td>
                      <% if is_self_row %>
                        <span class="rf-muted">Use the payment section below</span>
                      <% else %>
                        <span class="rf-muted">-</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <%# Empty state if nobody has joined the raffle yet. %>
              <tr>
                <td colspan="<%= is_host ? 10 : (is_active ? 8 : 7) %>" class="rf-muted">No participants yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <%# This shows every ticket number already bought or assigned. %>
    <section class="rf-card">
      <h2 class="h5 mb-3">All Ticket Numbers</h2>
      <div class="rf-ticket-box">
        <% if @tickets.any? %>
          <% @tickets.sort_by(&:ticket_number).each do |ticket| %>
            <span class="rf-number-chip <%= 'rf-number-chip-self' if current_user && ticket.user_id.to_i == current_user.id.to_i %>">#<%= ticket.ticket_number %> <%= ticket.display_name.to_s[0, max_name_length] %></span>
          <% end %>
        <% else %>
          <div class="rf-muted">No tickets assigned yet.</div>
        <% end %>
      </div>
    </section>

    <%# This section lets users buy tickets, or lets the host assign tickets manually. %>
    <% if current_user && is_active %>
      <section class="rf-card">
        <h2 class="h5 mb-3"><%= is_host ? "Assign Ticket(s)" : "Buy Ticket(s)" %></h2>

        <% if available_numbers.any? %>
          <%= form_with url: purchase_tickets_raffle_path(@raffle), method: :post, local: true do %>
            <div class="rf-purchase-grid">
              <%# Host-only fields for assigning tickets to a name and giving a reason. %>
              <% if is_host %>
                <div>
                  <label class="form-label">Assign Name</label>
                  <%= text_field_tag :assigned_name, nil, class: "form-control", placeholder: "Type any name" %>
                  <div class="rf-form-note">A name is always required when assigning tickets. Hosts cannot assign tickets to themselves.</div>
                </div>

                <div>
                  <label class="form-label">Reason:</label>
                  <%= select_tag :assignment_reason,
                        options_for_select([["", ""]] + assignment_reason_options.map { |reason| [reason, reason] }),
                        class: "form-select",
                        required: true %>
                </div>
              <% end %>

              <%# Exact ticket number picker. %>
              <div>
                <label class="form-label">Choose Ticket Numbers</label>
                <div class="rf-ticket-select" id="availableTicketPicker">
                  <% available_numbers.each do |number| %>
                    <label class="rf-ticket-option" data-ticket-option>
                      <input type="checkbox" name="ticket_numbers[]" value="<%= number %>">
                      <span>#<%= number %></span>
                    </label>
                  <% end %>
                </div>
                <div class="rf-form-note">You can click individual numbers, drag across numbers, or mix both methods.</div>
              </div>

              <%# Random quantity option if the user does not care which exact ticket numbers they get. %>
              <div>
                <label class="form-label">Or Random Quantity</label>
                <%= number_field_tag :random_quantity, nil, min: 1, max: @raffle.tickets_left, class: "form-control", placeholder: "e.g. 3" %>
                <div class="rf-form-note">Optional. Leave blank if choosing exact numbers or buying all remaining tickets.</div>
              </div>

              <%# Submit buttons for buying/assigning selected tickets or all remaining tickets. %>
              <div class="rf-purchase-actions">
                <%= submit_tag((is_host ? "Assign Ticket(s)" : "Buy Ticket(s)"), class: "btn btn-primary btn-sm") %>
                <%= button_tag((is_host ? "Assign All Available" : "Buy All Available"), type: "submit", name: "buy_all_available", value: "1", class: "btn btn-outline-primary btn-sm") %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="rf-muted">No tickets left to buy.</div>
        <% end %>
      </section>
    <% end %>

    <%# This section appears if the logged-in user owns tickets in an active raffle. %>
    <% if current_user && user_ticket_numbers.any? && is_active %>
      <section class="rf-card">
        <h2 class="h5 mb-3">Your Tickets</h2>

        <%# Shows the user's current ticket numbers. %>
        <div class="mb-3">
          <% user_ticket_numbers.each do |number| %>
            <span class="rf-number-chip rf-number-chip-self">#<%= number %></span>
          <% end %>
        </div>

        <%# Lets the user return selected tickets before the raffle is completed. %>
        <%= form_with url: return_tickets_raffle_path(@raffle), method: :post, local: true do %>
          <div class="mb-3">
            <label class="form-label">Return Selected Tickets</label>
            <%= select_tag "ticket_numbers[]",
                  options_for_select(user_ticket_numbers.map { |number| ["##{number}", number] }),
                  multiple: true,
                  size: [ user_ticket_numbers.size, 8 ].min,
                  class: "form-select" %>
          </div>
          <%= submit_tag("Return Tickets", class: "btn btn-outline-danger btn-sm") %>
        <% end %>
      </section>

      <%# The host does not need to pay themselves, so this only appears for entrants. %>
      <% unless is_host %>
        <section class="rf-card">
          <h2 class="h5 mb-3">Pay For Tickets</h2>

          <%# Host Revolut tag is hidden until the entrant clicks Pay For Tickets. %>
          <div class="rf-tag-card mb-3">
            <div class="rf-tag-label">Host Revolut Tag</div>
            <div>
              <span class="rf-tag-hidden" id="host_tag_hidden">Revolut Tag Hidden</span>
              <span class="rf-tag-value" id="host_tag_value" style="display:none;"><%= host_revolut_tag %></span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <button type="button" class="btn btn-sm btn-outline-dark" id="revealHostTagButton" <%= "disabled" if host_revolut_tag.blank? %>>Pay For Tickets</button>
            </div>
          </div>

          <%# Lets the entrant mark all their tickets as paid or unpaid. %>
          <%= form_with url: toggle_paid_raffle_path(@raffle), method: :post, local: true do %>
            <div class="mb-3">
              <label class="form-label">Your Revolut Tag</label>
              <%= text_field_tag :revolut_tag,
                    my_revolut_tag.presence,
                    class: "form-control",
                    placeholder: "@yourtag",
                    maxlength: 80,
                    required: true,
                    readonly: true %>
              <div class="rf-form-note">This Revolut Tag is taken from your account and cannot be changed here.</div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
              <%= submit_tag(my_paid_all ? "Mark All Unpaid" : "Mark All Paid", class: "btn btn-sm #{my_paid_all ? 'btn-outline-secondary' : 'btn-success'}") %>
            </div>
          <% end %>
        </section>
      <% end %>
    <% end %>

    <%# This section shows the winner if the raffle is completed, or an ended message if it was not completed. %>
    <% if is_completed %>
      <section class="rf-card">
        <h2 class="h5 mb-3">Winner</h2>
        <div class="rf-winner-box">
          <% if winner_reveal_required %>
            <%# Hidden winner state before reveal. %>
            <div id="winnerBoxMasked">
              Winner:
              <span class="rf-blackout">Hidden</span>
            </div>

            <%# Actual winner details, hidden until JavaScript reveals it. %>
            <div id="winnerBoxRevealed" style="display:none;">
              Winner: #<%= winning_number %> - <%= winning_name %>
            </div>
          <% else %>
            <%# If no reveal is required, show winner immediately. %>
            <div id="winnerBoxMasked" style="display:none;"></div>
            <div id="winnerBoxRevealed">
              Winner: #<%= winning_number %> - <%= winning_name %>
            </div>
          <% end %>
        </div>
      </section>
    <% elsif @raffle.incompleted? %>
      <section class="rf-card">
        <h2 class="h5 mb-3">Raffle Ended</h2>
        <div class="rf-ended-box">
          This raffle ended without completion.
        </div>
      </section>
    <% end %>

    <%# This is the interactive wheel section. %>
    <section class="rf-card rf-wheel-card" id="raffleWheelCard">
      <div class="rf-wheel-controls">
        <h2 class="h5 mb-0">Wheel</h2>

        <%# Wheel tool buttons. %>
        <div class="rf-wheel-tools">
          <button type="button" class="rf-icon-btn" id="focusWinnerButton" title="Show Winner Position" aria-label="Show Winner Position">◎</button>
          <button type="button" class="rf-icon-btn" id="wheelReset" title="Reset" aria-label="Reset">↺</button>
        </div>
      </div>

      <%# This holds the wheel canvas, pointer, countdown, confetti and winner overlay. %>
      <div class="rf-wheel-stage" id="raffleWheelStage">
        <div class="rf-wheel-pointer"></div>
        <canvas id="raffleWheelCanvas" class="rf-wheel-canvas"></canvas>
        <div class="rf-wheel-countdown" id="raffleWheelCountdown"></div>
        <canvas id="raffleConfetti" class="rf-confetti"></canvas>

        <%# Winner overlay shown after the wheel finishes spinning. %>
        <div class="rf-winner-overlay" id="raffleWinnerOverlay">
          <div class="rf-winner-overlay-box">
            <div class="rf-winner-overlay-title">Winner</div>
            <div class="rf-winner-overlay-main" id="raffleWinnerOverlayText"></div>
          </div>
        </div>
      </div>

      <%# Reveal button and winning ticket text below the wheel. %>
      <div class="rf-wheel-reveal">
        <% if can_spin_reveal_winner %>
          <button type="button" class="btn btn-primary btn-sm" id="revealWinnerButton">Reveal Winner</button>
        <% end %>

        <% if is_completed && winner_reveal_required %>
          <div class="rf-wheel-result" id="winnerResultMasked">
            Winning Ticket:
            <span class="rf-blackout">Hidden</span>
          </div>

          <div class="rf-wheel-result" id="winnerResultRevealed" style="display:none;">
            Winning Ticket:
            <span class="rf-wheel-result-number">#<%= winning_number %></span>
            -
            <span><%= winning_name %></span>
          </div>
        <% elsif is_completed %>
          <div class="rf-wheel-result" id="winnerResultMasked" style="display:none;"></div>
          <div class="rf-wheel-result" id="winnerResultRevealed">
            Winning Ticket:
            <span class="rf-wheel-result-number">#<%= winning_number %></span>
            -
            <span><%= winning_name %></span>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <%# This custom popup appears before the host actually runs the raffle. %>
  <div class="rf-confirm-overlay" id="runRaffleConfirm">
    <div class="rf-confirm-box">
      <div class="rf-confirm-title">Run Raffle</div>
      <div class="rf-confirm-text">Have you made sure to collect all the money?</div>
      <div class="rf-confirm-actions">
        <button type="button" class="btn btn-outline-secondary" id="runRaffleCancel">No - Cancel</button>
        <button type="button" class="btn btn-success" id="runRaffleConfirmBtn">Yes - Run Raffle!</button>
      </div>
    </div>
  </div>

  <%# This custom popup appears before deleting a raffle. %>
  <div class="rf-delete-confirm-overlay" id="raffleDeleteConfirmOverlay" aria-hidden="true">
    <div class="rf-delete-confirm-box">
      <div class="rf-delete-confirm-text">Are you sure you want to delete this raffle?</div>
      <div class="rf-delete-confirm-actions">
        <button type="button" class="rf-delete-confirm-yes" id="raffleDeleteConfirmYes">Yes</button>
        <button type="button" class="rf-delete-confirm-no" id="raffleDeleteConfirmNo">No</button>
      </div>
    </div>
  </div>

  <script>
    ;(function () {
      // I wrap everything in this function so the raffle page JavaScript does not leak variables into the global scope.

      // This object brings Rails data into JavaScript.
      // Most of the wheel and reveal logic uses this instead of trying to read the page again.
      const data = {
        raffleId: <%= @raffle.id %>,
        viewerUserId: <%= current_user_id_for_reveal.to_i %>,
        tickets: <%= raw(ticket_items.to_json) %>,
        winningNumber: <%= raw(winning_number.to_json) %>,
        winningName: <%= raw(winning_name.to_json) %>,
        completed: <%= is_completed ? "true" : "false" %>,
        active: <%= is_active ? "true" : "false" %>,
        autoSpin: <%= auto_spin ? "true" : "false" %>,
        entrantViewer: <%= entrant_viewer ? "true" : "false" %>,
        winnerRevealRequired: <%= winner_reveal_required ? "true" : "false" %>,
        viewerIsRaffleWinner: <%= viewer_is_raffle_winner ? "true" : "false" %>
      }

      // Main wheel canvas and its drawing context.
      const wheelCanvas = document.getElementById("raffleWheelCanvas")
      const wheelCtx = wheelCanvas.getContext("2d")

      // Main wheel stage/container.
      const stage = document.getElementById("raffleWheelStage")

      // Countdown overlay shown before the wheel starts spinning.
      const countdownEl = document.getElementById("raffleWheelCountdown")

      // Reveal button and winner result elements.
      const revealButton = document.getElementById("revealWinnerButton")
      const winnerResultMasked = document.getElementById("winnerResultMasked")
      const winnerResultRevealed = document.getElementById("winnerResultRevealed")
      const winnerBoxMasked = document.getElementById("winnerBoxMasked")
      const winnerBoxRevealed = document.getElementById("winnerBoxRevealed")

      // Host name elements. These are used so the winner can later click the host profile after reveal.
      const hostNamePlain = document.getElementById("raffleHostNamePlain")
      const hostNameLink = document.getElementById("raffleHostNameLink")

      // Winner overlay shown on top of the wheel after the spin.
      const overlay = document.getElementById("raffleWinnerOverlay")
      const overlayText = document.getElementById("raffleWinnerOverlayText")

      // Confetti canvas.
      const confettiCanvas = document.getElementById("raffleConfetti")

      // Wheel tool buttons.
      const resetButton = document.getElementById("wheelReset")
      const focusWinnerButton = document.getElementById("focusWinnerButton")

      // Wheel card used for scrolling to the wheel before the spin.
      const wheelCard = document.getElementById("raffleWheelCard")

      // Run raffle confirmation popup elements.
      const confirmOverlay = document.getElementById("runRaffleConfirm")
      const confirmCancel = document.getElementById("runRaffleCancel")
      const confirmRun = document.getElementById("runRaffleConfirmBtn")
      const runForm = document.querySelector(".rf-run-raffle-form")

      // Host Revolut tag reveal elements.
      const revealHostTagButton = document.getElementById("revealHostTagButton")
      const hostTagHidden = document.getElementById("host_tag_hidden")
      const hostTagValue = document.getElementById("host_tag_value")

      // Delete confirmation popup elements.
      const deleteOverlay = document.getElementById("raffleDeleteConfirmOverlay")
      const deleteYes = document.getElementById("raffleDeleteConfirmYes")
      const deleteNo = document.getElementById("raffleDeleteConfirmNo")

      // localStorage/sessionStorage keys.
      // These include the raffle id and user id so each user has their own reveal state.
      const revealedKey = "raffle_revealed_" + data.raffleId + "_user_" + data.viewerUserId
      const quickRevealedKey = "raffle_quick_reveal_" + data.raffleId + "_user_" + data.viewerUserId
      const autoSpinKey = "raffle_auto_spin_done_" + data.raffleId + "_user_" + data.viewerUserId

      // Audio variables for spin/win sounds.
      let audioContext = null
      let masterGain = null

      // Used to remember which delete form is waiting for confirmation.
      let pendingDeleteForm = null

      // Makes sure tickets is always an array.
      const tickets = Array.isArray(data.tickets) ? data.tickets : []

      // Number of tickets on the wheel.
      const ticketCount = tickets.length

      // I draw the wheel in a large "world" size and scale it down to the visible canvas.
      // This makes zooming and panning easier.
      const world = {
        size: 30000,
        center: 15000,
        outer: 12000,
        inner: 10800
      }

      // This is the fixed pointer angle at the top of the wheel.
      const pointerAngle = -Math.PI / 2

      // This calculates how much angle each ticket slice gets.
      const anglePer = ticketCount > 0 ? ((Math.PI * 2) / ticketCount) : (Math.PI * 2)

      // Finds where the winning ticket is in the ticket array.
      let winningIndex = findWinningIndex()

      // Calculates the final rotation needed so the winning ticket lands under the pointer.
      let desiredRotation = calculateDesiredRotation()

      // Current wheel rotation.
      let currentRotation = 0

      // Stops multiple spins happening at once.
      let spinning = false

      // Stores a function that can stop the spin sound.
      let spinSoundStop = null

      // This controls what part of the large wheel world is currently visible.
      const view = {
        x: 0,
        y: 0,
        w: world.size,
        h: world.size
      }

      // Finds the index of the winning ticket in the tickets array.
      function findWinningIndex() {
        return tickets.findIndex(function (ticket) {
          return Number(ticket.number) === Number(data.winningNumber)
        })
      }

      // Works out how far the wheel needs to rotate so the winning slice is under the top pointer.
      function calculateDesiredRotation() {
        if (winningIndex < 0) return 0

        const winningSliceMiddle = (-Math.PI / 2) + (winningIndex * anglePer) + (anglePer / 2)
        return pointerAngle - winningSliceMiddle
      }

      // Recalculates the winning index and desired rotation after the raffle is run by fetch.
      function refreshWinnerPosition() {
        winningIndex = findWinningIndex()
        desiredRotation = calculateDesiredRotation()
      }

      // Checks if my custom page theme is currently dark mode.
      function isDarkTheme() {
        return document.documentElement.getAttribute("data-pv-theme") === "dark"
      }

      // Resizes the wheel canvas and confetti canvas to match the visible stage size.
      // devicePixelRatio is used so the canvas is not blurry on high-resolution screens.
      function resizeCanvases() {
        const rect = stage.getBoundingClientRect()
        const dpr = window.devicePixelRatio || 1

        wheelCanvas.width = Math.max(1, Math.floor(rect.width * dpr))
        wheelCanvas.height = Math.max(1, Math.floor(rect.height * dpr))
        wheelCanvas.style.width = rect.width + "px"
        wheelCanvas.style.height = rect.height + "px"

        confettiCanvas.width = Math.max(1, Math.floor(rect.width * dpr))
        confettiCanvas.height = Math.max(1, Math.floor(rect.height * dpr))
        confettiCanvas.style.width = rect.width + "px"
        confettiCanvas.style.height = rect.height + "px"
        confettiCanvas.style.background = "transparent"
        confettiCanvas.style.backgroundColor = "transparent"

        renderWheel(currentRotation)
      }

      // Applies the zoom/pan transform so the big wheel world fits into the visible canvas.
      function applyWorldTransform(ctx) {
        const sx = wheelCanvas.width / view.w
        const sy = wheelCanvas.height / view.h
        ctx.setTransform(sx, 0, 0, sy, -view.x * sx, -view.y * sy)
      }

      // Resets zoom and pan back to the full wheel.
      function resetView() {
        view.x = 0
        view.y = 0
        view.w = world.size
        view.h = world.size
        renderWheel(currentRotation)
      }

      // Stops the zoomed/panned view from going outside the wheel world.
      function clampView() {
        if (view.x < 0) view.x = 0
        if (view.y < 0) view.y = 0
        if (view.x + view.w > world.size) view.x = world.size - view.w
        if (view.y + view.h > world.size) view.y = world.size - view.h
      }

      // Zooms in or out around the mouse position.
      function zoomAt(factor, clientX, clientY) {
        const rect = stage.getBoundingClientRect()
        const px = rect.width ? ((clientX - rect.left) / rect.width) : 0.5
        const py = rect.height ? ((clientY - rect.top) / rect.height) : 0.5

        const worldX = view.x + (view.w * px)
        const worldY = view.y + (view.h * py)

        const nextW = Math.max(world.size * 0.02, Math.min(world.size, view.w * factor))
        const nextH = Math.max(world.size * 0.02, Math.min(world.size, view.h * factor))

        view.x = worldX - (nextW * px)
        view.y = worldY - (nextH * py)
        view.w = nextW
        view.h = nextH
        clampView()
        renderWheel(currentRotation)
      }

      // Zooms into the winning slice so it is easier to see where the winner is on the wheel.
      function focusWinnerSlice() {
        if (winningIndex < 0) return

        const mid = (-Math.PI / 2) + (winningIndex * anglePer) + (anglePer / 2) + currentRotation
        const radius = world.inner + ((world.outer - world.inner) * 0.5)
        const pointX = world.center + Math.cos(mid) * radius
        const pointY = world.center + Math.sin(mid) * radius
        const size = Math.max(world.size * 0.08, Math.min(world.size * 0.18, 3600))

        view.w = size
        view.h = size
        view.x = pointX - (size / 2)
        view.y = pointY - (size / 2)

        clampView()
        renderWheel(currentRotation)
      }

      // Browsers often block audio until the user interacts with the page.
      // This prepares/unlocks the audio context after a click or pointerdown.
      function ensureAudioUnlocked() {
        if (!window.AudioContext && !window.webkitAudioContext) return null

        if (!audioContext) {
          audioContext = new (window.AudioContext || window.webkitAudioContext)()
          masterGain = audioContext.createGain()
          masterGain.gain.value = 0.18
          masterGain.connect(audioContext.destination)
        }

        if (audioContext.state === "suspended") {
          audioContext.resume()
        }

        const silent = audioContext.createOscillator()
        const gain = audioContext.createGain()

        gain.gain.value = 0.00001
        silent.connect(gain)
        gain.connect(masterGain)
        silent.start()
        silent.stop(audioContext.currentTime + 0.02)

        return audioContext
      }

      // Plays the wheel spinning sound.
      // It uses the Web Audio API instead of needing an audio file.
      function playSpinSound() {
        const ctx = ensureAudioUnlocked()
        if (!ctx || !masterGain) return function () {}

        const oscillator = ctx.createOscillator()
        const gain = ctx.createGain()

        oscillator.type = "sawtooth"
        oscillator.frequency.setValueAtTime(240, ctx.currentTime)
        oscillator.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 7)

        gain.gain.setValueAtTime(0.00001, ctx.currentTime)
        gain.gain.exponentialRampToValueAtTime(0.12, ctx.currentTime + 0.05)
        gain.gain.exponentialRampToValueAtTime(0.00001, ctx.currentTime + 7)

        oscillator.connect(gain)
        gain.connect(masterGain)

        oscillator.start(ctx.currentTime)
        oscillator.stop(ctx.currentTime + 7.02)

        return function () {
          try {
            gain.gain.cancelScheduledValues(ctx.currentTime)
            gain.gain.setValueAtTime(0.00001, ctx.currentTime)
          } catch (e) {
          }
        }
      }

      // Plays a short winning sound after the wheel lands.
      function playWinSound() {
        const ctx = ensureAudioUnlocked()
        if (!ctx || !masterGain) return

        ;[
          { t: 0.00, f: 880 },
          { t: 0.07, f: 1100 },
          { t: 0.14, f: 1320 },
          { t: 0.21, f: 1760 }
        ].forEach(function (note) {
          const oscillator = ctx.createOscillator()
          const gain = ctx.createGain()

          oscillator.type = "square"
          oscillator.frequency.setValueAtTime(note.f, ctx.currentTime + note.t)

          gain.gain.setValueAtTime(0.00001, ctx.currentTime + note.t)
          gain.gain.exponentialRampToValueAtTime(0.14, ctx.currentTime + note.t + 0.02)
          gain.gain.exponentialRampToValueAtTime(0.00001, ctx.currentTime + note.t + 0.22)

          oscillator.connect(gain)
          gain.connect(masterGain)

          oscillator.start(ctx.currentTime + note.t)
          oscillator.stop(ctx.currentTime + note.t + 0.24)
        })
      }

      // Shows the host's account link after the winner reveal.
      function showHostAccountLink() {
        if (!data.viewerIsRaffleWinner) return
        if (!hostNamePlain || !hostNameLink) return

        hostNamePlain.style.display = "none"
        hostNameLink.style.display = ""
      }

      // Hides the host account link again before reveal.
      function hideHostAccountLink() {
        if (!data.viewerIsRaffleWinner) return
        if (!hostNamePlain || !hostNameLink) return

        hostNamePlain.style.display = ""
        hostNameLink.style.display = "none"
      }

      // Reveals all winner information straight away.
      // This is used after the spin finishes or when the user has already revealed before.
      function showWinnerInfoImmediate() {
        if (data.winnerRevealRequired) {
          localStorage.setItem(revealedKey, "1")
          localStorage.setItem(quickRevealedKey, "1")
        }

        showHostAccountLink()

        if (revealButton) revealButton.style.display = "none"
        if (winnerResultMasked) winnerResultMasked.style.display = "none"
        if (winnerResultRevealed) winnerResultRevealed.style.display = ""
        if (winnerBoxMasked) winnerBoxMasked.style.display = "none"
        if (winnerBoxRevealed) winnerBoxRevealed.style.display = ""
      }

      // Hides winner information before the reveal spin happens.
      function hideWinnerInfo() {
        hideHostAccountLink()

        if (revealButton && data.completed) revealButton.style.display = ""
        if (winnerResultMasked && data.completed) winnerResultMasked.style.display = ""
        if (winnerResultRevealed) winnerResultRevealed.style.display = "none"
        if (winnerBoxMasked) winnerBoxMasked.style.display = ""
        if (winnerBoxRevealed) winnerBoxRevealed.style.display = "none"
      }

      // Shows a hidden Revolut tag temporarily, then hides it again after 10 seconds.
      function revealTemporarily(hiddenEl, valueEl) {
        if (!hiddenEl || !valueEl) return

        hiddenEl.style.display = "none"
        valueEl.style.display = ""

        setTimeout(function () {
          hiddenEl.style.display = ""
          valueEl.style.display = "none"
        }, 10000)
      }

      // Runs the confetti animation on the confetti canvas.
      function runConfetti() {
        const ctx = confettiCanvas.getContext("2d")
        const width = confettiCanvas.width
        const height = confettiCanvas.height

        const pieces = []

        // Creates all the confetti pieces with random movement, size, rotation and colour.
        for (let i = 0; i < 180; i += 1) {
          pieces.push({
            x: width / 2,
            y: height * 0.28,
            vx: (Math.random() - 0.5) * 18,
            vy: (Math.random() * -14) - 5,
            size: (Math.random() * 10) + 5,
            rotation: Math.random() * Math.PI,
            vr: (Math.random() - 0.5) * 0.35,
            life: 120 + Math.random() * 35,
            color: ["#ef4444", "#22c55e", "#3b82f6", "#eab308", "#a855f7", "#ec4899"][Math.floor(Math.random() * 6)]
          })
        }

        let frame = 0

        // Draws and moves the confetti each animation frame.
        function step() {
          frame += 1
          ctx.clearRect(0, 0, width, height)

          pieces.forEach(function (piece) {
            piece.x += piece.vx
            piece.y += piece.vy
            piece.vy += 0.24
            piece.rotation += piece.vr
            piece.life -= 1

            ctx.save()
            ctx.translate(piece.x, piece.y)
            ctx.rotate(piece.rotation)
            ctx.fillStyle = piece.color
            ctx.fillRect(-piece.size / 2, -piece.size / 2, piece.size, piece.size * 0.6)
            ctx.restore()
          })

          // Removes dead confetti pieces so the animation can finish.
          for (let i = pieces.length - 1; i >= 0; i -= 1) {
            if (pieces[i].life <= 0 || pieces[i].y > height + 40) {
              pieces.splice(i, 1)
            }
          }

          if (frame < 180 && pieces.length) {
            requestAnimationFrame(step)
          } else {
            ctx.clearRect(0, 0, width, height)
          }
        }

        step()
        playWinSound()
      }

      // Shows the winner overlay on top of the wheel for 5 seconds.
      function showWinnerOverlay() {
        if (!overlay || !overlayText) return

        overlayText.textContent = "#" + data.winningNumber + " " + data.winningName
        overlay.style.display = "flex"

        setTimeout(function () {
          overlay.style.display = "none"
        }, 5000)
      }

      // Smoothly scrolls to the wheel before the spin starts.
      function scrollToWheel() {
        if (!wheelCard) return
        wheelCard.scrollIntoView({ behavior: "smooth", block: "start" })
      }

      // Shows a countdown before spinning the wheel.
      // It returns a Promise so the spin only starts after the countdown finishes.
      function beginCountdown(seconds) {
        return new Promise(function (resolve) {
          let remaining = seconds

          countdownEl.style.display = "flex"
          countdownEl.textContent = String(remaining)

          const timer = setInterval(function () {
            remaining -= 1

            if (remaining > 0) {
              countdownEl.textContent = String(remaining)
            } else {
              clearInterval(timer)
              countdownEl.style.display = "none"
              resolve()
            }
          }, 1000)
        })
      }

      // Measures the text width for a wheel slice label.
      function measureLabelWidth(text, fontSize) {
        wheelCtx.save()
        wheelCtx.font = "900 " + fontSize + "px Arial"
        const width = wheelCtx.measureText(text).width
        wheelCtx.restore()
        return width
      }

      // Finds the biggest font size that fits inside the slice.
      function fitSliceFontSize(text, radialSpace, tangentialSpace) {
        const maxRadial = Math.max(120, radialSpace * 0.9)
        const maxTangential = Math.max(80, tangentialSpace * 0.82)

        let low = 12
        let high = Math.floor(Math.min(520, maxTangential, maxRadial))
        let best = 12

        while (low <= high) {
          const mid = Math.floor((low + high) / 2)
          const width = measureLabelWidth(text, mid)

          if (width <= maxRadial && mid <= maxTangential) {
            best = mid
            low = mid + 1
          } else {
            high = mid - 1
          }
        }

        return Math.max(12, best)
      }

      // Draws the entire wheel on the canvas.
      function renderWheel(rotation) {
        // Theme colours used by the wheel.
        const darkTheme = isDarkTheme()
        const backgroundColor = darkTheme ? "#000000" : "#ffffff"
        const emptyFillColor = darkTheme ? "#000000" : "#f8fafc"
        const borderColor = darkTheme ? "#d4af37" : "#d1d5db"
        const sliceStrokeColor = darkTheme ? "#000000" : "#ffffff"
        const sliceTextColor = "#000000"
        const sliceTextStrokeColor = darkTheme ? "#000000" : "#ffffff"
        const centerFillColor = "#000000"
        const centerStrokeColor = darkTheme ? "#d4af37" : "#ffffff"
        const centerTextColor = darkTheme ? "#d4af37" : "#ffffff"

        // Clears the canvas before redrawing.
        wheelCtx.save()
        wheelCtx.setTransform(1, 0, 0, 1, 0, 0)
        wheelCtx.clearRect(0, 0, wheelCanvas.width, wheelCanvas.height)
        wheelCtx.restore()

        // Applies zoom and pan transform.
        applyWorldTransform(wheelCtx)

        // Draws the background.
        wheelCtx.fillStyle = backgroundColor
        wheelCtx.fillRect(0, 0, world.size, world.size)

        // If there are no tickets, draw an empty wheel message.
        if (!ticketCount) {
          wheelCtx.beginPath()
          wheelCtx.arc(world.center, world.center, 7000, 0, Math.PI * 2)
          wheelCtx.fillStyle = emptyFillColor
          wheelCtx.fill()
          wheelCtx.strokeStyle = borderColor
          wheelCtx.lineWidth = 60
          wheelCtx.stroke()

          wheelCtx.fillStyle = darkTheme ? "#d4af37" : "#111827"
          wheelCtx.font = "700 800px Arial"
          wheelCtx.textAlign = "center"
          wheelCtx.textBaseline = "middle"
          wheelCtx.fillText("No tickets yet", world.center, world.center)
          return
        }

        // Colours used for wheel slices.
        const colors = darkTheme ? [
          "#d4af37"
        ] : [
          "#dbeafe",
          "#dcfce7",
          "#fee2e2",
          "#fef3c7",
          "#ede9fe",
          "#fce7f3",
          "#cffafe",
          "#e5e7eb"
        ]

        // Small gap between slices.
        const inset = Math.min(anglePer * 0.04, 0.04)

        // Thickness of the ring where ticket slices are drawn.
        const bandThickness = world.outer - world.inner

        // Draws each ticket slice and its label.
        tickets.forEach(function (ticket, index) {
          const start = (-Math.PI / 2) + (index * anglePer) + inset + rotation
          const end = (-Math.PI / 2) + ((index + 1) * anglePer) - inset + rotation
          const mid = (start + end) / 2
          const midRadius = world.inner + (bandThickness * 0.5)
          const tangentialSpace = Math.max(30, (end - start) * midRadius)
          const radialSpace = Math.max(120, bandThickness - 110)
          const fontSize = fitSliceFontSize(ticket.label, radialSpace, tangentialSpace)
          const centerRadius = world.inner + (bandThickness * 0.5)

          // Draws the slice shape as a ring segment.
          wheelCtx.beginPath()
          wheelCtx.moveTo(world.center + Math.cos(start) * world.inner, world.center + Math.sin(start) * world.inner)
          wheelCtx.arc(world.center, world.center, world.outer, start, end)
          wheelCtx.lineTo(world.center + Math.cos(end) * world.inner, world.center + Math.sin(end) * world.inner)
          wheelCtx.arc(world.center, world.center, world.inner, end, start, true)
          wheelCtx.closePath()

          wheelCtx.fillStyle = colors[index % colors.length]
          wheelCtx.fill()
          wheelCtx.strokeStyle = sliceStrokeColor
          wheelCtx.lineWidth = darkTheme ? 34 : 24
          wheelCtx.stroke()

          // Clips the label so it stays inside the slice.
          wheelCtx.save()
          wheelCtx.beginPath()
          wheelCtx.moveTo(world.center + Math.cos(start) * world.inner, world.center + Math.sin(start) * world.inner)
          wheelCtx.arc(world.center, world.center, world.outer, start, end)
          wheelCtx.lineTo(world.center + Math.cos(end) * world.inner, world.center + Math.sin(end) * world.inner)
          wheelCtx.arc(world.center, world.center, world.inner, end, start, true)
          wheelCtx.closePath()
          wheelCtx.clip()

          // Rotates and places the label inside the slice.
          wheelCtx.translate(world.center, world.center)
          wheelCtx.rotate(mid)
          wheelCtx.fillStyle = sliceTextColor
          wheelCtx.strokeStyle = sliceTextStrokeColor
          wheelCtx.lineWidth = Math.max(2, fontSize * 0.035)
          wheelCtx.font = "900 " + fontSize + "px Arial"
          wheelCtx.textAlign = "center"
          wheelCtx.textBaseline = "middle"
          wheelCtx.strokeText(ticket.label, centerRadius, 0)
          wheelCtx.fillText(ticket.label, centerRadius, 0)
          wheelCtx.restore()
        })

        // Draws the black centre circle.
        wheelCtx.beginPath()
        wheelCtx.arc(world.center, world.center, world.inner, 0, Math.PI * 2)
        wheelCtx.fillStyle = centerFillColor
        wheelCtx.fill()
        wheelCtx.strokeStyle = centerStrokeColor
        wheelCtx.lineWidth = 80
        wheelCtx.stroke()

        // Draws the RAFFLE text in the centre.
        wheelCtx.fillStyle = centerTextColor
        wheelCtx.font = "800 1500px Arial"
        wheelCtx.textAlign = "center"
        wheelCtx.textBaseline = "middle"
        wheelCtx.fillText("RAFFLE", world.center, world.center)
      }

      // Easing function used so the wheel slows down smoothly instead of stopping suddenly.
      function easeOutCubic(t) {
        return 1 - Math.pow(1 - t, 3)
      }

      // Spins the wheel to the winning ticket.
      function spinToWinner() {
        if (!data.completed || winningIndex < 0 || spinning) return

        spinning = true
        resetView()
        scrollToWheel()
        ensureAudioUnlocked()
        hideWinnerInfo()

        beginCountdown(5).then(function () {
          spinSoundStop = playSpinSound()

          const extraTurns = 10
          const startRotation = currentRotation
          const endRotation = desiredRotation + ((Math.PI * 2) * extraTurns)
          const duration = 7000
          const startTime = performance.now()

          // This animation loop rotates the wheel until it reaches the desired winner position.
          function animate(now) {
            const elapsed = now - startTime
            const progress = Math.min(1, elapsed / duration)
            const eased = easeOutCubic(progress)

            currentRotation = startRotation + ((endRotation - startRotation) * eased)
            renderWheel(currentRotation)

            if (progress < 1) {
              requestAnimationFrame(animate)
            } else {
              currentRotation = desiredRotation
              renderWheel(currentRotation)
              spinning = false

              if (typeof spinSoundStop === "function") spinSoundStop()

              showWinnerInfoImmediate()
              showWinnerOverlay()
              runConfetti()
            }
          }

          requestAnimationFrame(animate)
        })
      }

      // Sets up the page when the raffle is already completed.
      function initializeCompletedState() {
        const alreadyRevealed = localStorage.getItem(revealedKey) === "1" || localStorage.getItem(quickRevealedKey) === "1"

        // If this user already revealed the winner before, show it straight away.
        if (alreadyRevealed && data.winnerRevealRequired) {
          currentRotation = desiredRotation
          renderWheel(currentRotation)
          showWinnerInfoImmediate()
        } else {
          currentRotation = 0
          renderWheel(currentRotation)

          if (data.winnerRevealRequired) {
            hideWinnerInfo()
          }
        }

        // If the page loaded with auto spin, remove the URL flag and spin once.
        if (data.autoSpin) {
          history.replaceState({}, document.title, window.location.pathname)

          if (sessionStorage.getItem(autoSpinKey) !== "1") {
            sessionStorage.setItem(autoSpinKey, "1")

            setTimeout(function () {
              spinToWinner()
            }, 0)
          }
        }
      }

      // Sets up the wheel when the raffle is still active.
      function initializeActiveState() {
        currentRotation = 0
        renderWheel(currentRotation)
      }

      // Adds zoom, pan, reset and focus winner controls to the wheel.
      function wireZoomPan() {
        if (resetButton) {
          resetButton.addEventListener("click", function () {
            resetView()
          })
        }

        if (focusWinnerButton) {
          focusWinnerButton.addEventListener("click", function () {
            focusWinnerSlice()
          })
        }

        // Mouse wheel zoom.
        wheelCanvas.addEventListener("wheel", function (event) {
          event.preventDefault()

          const factor = event.deltaY < 0 ? 0.88 : 1.14
          zoomAt(factor, event.clientX, event.clientY)
        }, { passive: false })

        // Click zoom.
        wheelCanvas.addEventListener("click", function (event) {
          if (spinning) return
          zoomAt(0.65, event.clientX, event.clientY)
        })

        // Drag/pan variables.
        let dragging = false
        let dragStart = null
        let dragOrigin = null

        // Starts dragging.
        wheelCanvas.addEventListener("mousedown", function (event) {
          dragging = true
          wheelCanvas.classList.add("rf-dragging")
          dragStart = { x: event.clientX, y: event.clientY }
          dragOrigin = { x: view.x, y: view.y }
        })

        // Moves the view while dragging.
        window.addEventListener("mousemove", function (event) {
          if (!dragging) return

          const rect = stage.getBoundingClientRect()
          const dx = ((event.clientX - dragStart.x) / rect.width) * view.w
          const dy = ((event.clientY - dragStart.y) / rect.height) * view.h

          view.x = dragOrigin.x - dx
          view.y = dragOrigin.y - dy

          clampView()
          renderWheel(currentRotation)
        })

        // Stops dragging.
        window.addEventListener("mouseup", function () {
          dragging = false
          wheelCanvas.classList.remove("rf-dragging")
        })
      }

      // Adds click behaviour to the Reveal Winner button.
      function wireReveal() {
        if (!revealButton) return

        revealButton.addEventListener("click", function () {
          if (spinning) return

          ensureAudioUnlocked()
          localStorage.removeItem(revealedKey)
          localStorage.removeItem(quickRevealedKey)
          sessionStorage.removeItem(autoSpinKey)
          hideWinnerInfo()
          currentRotation = 0
          renderWheel(currentRotation)
          spinToWinner()
        })
      }

      // Handles the custom "Run Raffle" confirmation popup and AJAX request.
      function wireRunConfirm() {
        if (!runForm || !confirmOverlay || !confirmCancel || !confirmRun) return

        // Stops the form submitting immediately and shows my custom confirmation instead.
        runForm.addEventListener("submit", function (event) {
          event.preventDefault()
          confirmOverlay.style.display = "flex"
        })

        // Cancels the run raffle popup.
        confirmCancel.addEventListener("click", function () {
          confirmOverlay.style.display = "none"
        })

        // Runs the raffle after the host confirms.
        confirmRun.addEventListener("click", function () {
          ensureAudioUnlocked()
          confirmOverlay.style.display = "none"

          const token = document.querySelector('meta[name="csrf-token"]')?.content

          fetch(runForm.action, {
            method: "POST",
            headers: {
              "X-CSRF-Token": token,
              "Accept": "application/json"
            },
            credentials: "same-origin"
          })
            .then(function (response) {
              return response.json()
            })
            .then(function (json) {
              if (!json.ok) {
                alert(json.message || "Unable to run raffle.")
                return
              }

              // Updates the JavaScript state using the winner returned from the Rails controller.
              data.completed = true
              data.active = false
              data.autoSpin = true
              data.winnerRevealRequired = true
              data.winningNumber = json.winning_number
              data.winningName = json.winning_name

              // Clears reveal state so the new winner can be revealed properly.
              localStorage.removeItem(revealedKey)
              localStorage.removeItem(quickRevealedKey)
              sessionStorage.removeItem(autoSpinKey)

              refreshWinnerPosition()
              hideWinnerInfo()
              currentRotation = 0
              renderWheel(currentRotation)
              spinToWinner()
            })
            .catch(function () {
              alert("Unable to run raffle.")
            })
        })

        // Lets the user close the popup by clicking the dark background.
        confirmOverlay.addEventListener("click", function (event) {
          if (event.target === confirmOverlay) {
            confirmOverlay.style.display = "none"
          }
        })
      }

      // Handles the custom delete confirmation popup.
      function wireDeleteConfirm() {
        if (!deleteOverlay || !deleteYes || !deleteNo) return

        // Intercepts delete form submission before it reaches Rails.
        document.addEventListener("submit", function (event) {
          const form = event.target.closest(".rf-delete-confirm-form")
          if (!form) return
          if (form.dataset.confirmedDelete === "1") return

          event.preventDefault()
          pendingDeleteForm = form
          deleteOverlay.style.display = "flex"
          deleteOverlay.setAttribute("aria-hidden", "false")
        })

        // User clicked No, so cancel deletion.
        deleteNo.addEventListener("click", function () {
          pendingDeleteForm = null
          deleteOverlay.style.display = "none"
          deleteOverlay.setAttribute("aria-hidden", "true")
        })

        // User clicked Yes, so submit the delete form for real.
        deleteYes.addEventListener("click", function () {
          if (!pendingDeleteForm) return

          const form = pendingDeleteForm
          pendingDeleteForm = null

          deleteOverlay.style.display = "none"
          deleteOverlay.setAttribute("aria-hidden", "true")
          form.dataset.confirmedDelete = "1"

          if (form.requestSubmit) {
            form.requestSubmit()
          } else {
            form.submit()
          }
        })

        // Clicking the dark overlay also cancels the delete action.
        deleteOverlay.addEventListener("click", function (event) {
          if (event.target !== deleteOverlay) return

          pendingDeleteForm = null
          deleteOverlay.style.display = "none"
          deleteOverlay.setAttribute("aria-hidden", "true")
        })
      }

      // Adds reveal behaviour for host and entrant Revolut tags.
      function wireHostAndEntrantTagReveal() {
        if (revealHostTagButton && hostTagHidden && hostTagValue) {
          revealHostTagButton.addEventListener("click", function () {
            revealTemporarily(hostTagHidden, hostTagValue)
          })
        }

        // Adds reveal buttons for entrant tags in the participant table.
        document.querySelectorAll(".rf-reveal-entrant-tag-btn").forEach(function (button) {
          button.addEventListener("click", function () {
            const hiddenId = button.getAttribute("data-hidden-id")
            const valueId = button.getAttribute("data-value-id")
            const hiddenEl = document.getElementById(hiddenId)
            const valueEl = document.getElementById(valueId)

            revealTemporarily(hiddenEl, valueEl)
          })
        })
      }

      // Handles the exact ticket number picker.
      function wireTicketPicker() {
        const picker = document.getElementById("availableTicketPicker")
        if (!picker) return

        let pointerDown = false

        // Makes the visual selected style match whether the hidden checkbox is checked.
        function syncVisual(label) {
          const input = label.querySelector("input[type='checkbox']")
          if (!input) return

          if (input.checked) {
            label.classList.add("is-selected")
          } else {
            label.classList.remove("is-selected")
          }
        }

        // Adds click and drag-to-select behaviour to every ticket option.
        picker.querySelectorAll("[data-ticket-option]").forEach(function (label) {
          const input = label.querySelector("input[type='checkbox']")

          syncVisual(label)

          // Clicking/tapping a ticket toggles it.
          label.addEventListener("mousedown", function () {
            pointerDown = true
            input.checked = !input.checked
            syncVisual(label)
          })

          // Dragging over tickets selects them.
          label.addEventListener("mouseenter", function () {
            if (!pointerDown) return

            input.checked = true
            syncVisual(label)
          })

          // Prevents the browser's normal label click from double toggling the checkbox.
          label.addEventListener("click", function (event) {
            event.preventDefault()
          })

          // Keeps the styling synced if the input changes another way.
          input.addEventListener("change", function () {
            syncVisual(label)
          })
        })

        // Stops drag selection when the mouse is released.
        window.addEventListener("mouseup", function () {
          pointerDown = false
        })
      }

      // Unlocks audio after the first click.
      document.addEventListener("click", function () {
        ensureAudioUnlocked()
      }, { once: true })

      // Unlocks audio after the first pointer interaction.
      document.addEventListener("pointerdown", function () {
        ensureAudioUnlocked()
      }, { once: true })

      // Resizes the canvas whenever the browser window changes size.
      window.addEventListener("resize", resizeCanvases)

      // Watches for theme changes so the wheel redraws in the correct light/dark colours.
      const themeObserver = new MutationObserver(function () {
        renderWheel(currentRotation)
      })

      themeObserver.observe(document.documentElement, {
        attributes:true,
        attributeFilter:["data-pv-theme"]
      })

      // Connects all page interactions.
      wireZoomPan()
      wireReveal()
      wireRunConfirm()
      wireDeleteConfirm()
      wireHostAndEntrantTagReveal()
      wireTicketPicker()

      // Sets up canvas size and default view.
      resizeCanvases()
      resetView()

      // Decides whether the page should start in completed mode or active mode.
      if (data.completed) {
        initializeCompletedState()
      } else {
        initializeActiveState()
      }
    })()
  </script>
</div>