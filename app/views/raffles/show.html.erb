<% 
is_host = current_user && @raffle.host_id.to_i == current_user.id.to_i
is_completed = @raffle.completed?
is_active = @raffle.active?
auto_spin = params[:auto_spin].to_s == "1" || params[:reveal].to_s == "1"
max_name_length = 24
ticket_items = @tickets.sort_by(&:ticket_number).map do |ticket|
  short_name = ticket.display_name.to_s[0, max_name_length]
  {
    number: ticket.ticket_number.to_i,
    name: short_name,
    label: "##{ticket.ticket_number} #{short_name}",
    user_id: ticket.user_id.to_i
  }
end
user_ticket_numbers =
  if current_user
    @tickets.select { |ticket| ticket.user_id.to_i == current_user.id.to_i }.map(&:ticket_number).sort
  else
    []
  end
available_numbers = @available_numbers || []
my_paid_all = @my_tickets.any? && @my_tickets.all?(&:paid?)
winning_name = @winning_ticket&.display_name.to_s
winning_number = @winning_ticket&.ticket_number.to_i
entrant_viewer = current_user.present? && @tickets.any? { |ticket| ticket.user_id.to_i == current_user.id.to_i }
my_revolut_tag = current_user&.revolut_tag.to_s
host_revolut_tag = @raffle.revolut_tag.to_s
assignment_reason_options = ["Mini Raffle", "Free Ticket(s)"]
%>

<div class="container-fluid py-3">
  <style>
    .rf-page-stack{
      display:flex;
      flex-direction:column;
      gap:16px;
    }
    .rf-card{
      background:#ffffff;
      border-radius:1rem;
      border:1px solid #d4d4d8;
      box-shadow:0 10px 25px rgba(15,23,42,0.08);
      padding:16px;
    }
    .rf-title{
      margin:0;
      font-size:1.45rem;
      font-weight:700;
    }
    .rf-sub{
      color:#6b7280;
      font-size:.88rem;
      margin-top:4px;
    }
    .rf-stat-grid{
      display:grid;
      grid-template-columns:repeat(5,minmax(0,1fr));
      gap:10px;
      margin-top:14px;
    }
    .rf-stat{
      border:1px solid #e5e7eb;
      border-radius:12px;
      padding:12px;
      text-align:center;
      background:#fafafa;
    }
    .rf-stat-label{
      font-size:.72rem;
      color:#6b7280;
      margin-bottom:4px;
    }
    .rf-stat-value{
      font-size:1rem;
      font-weight:700;
      color:#111827;
    }
    .rf-gallery{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
      margin-top:14px;
    }
    .rf-gallery img{
      width:100%;
      height:220px;
      object-fit:cover;
      border-radius:12px;
      border:1px solid #e5e7eb;
    }
    .rf-table-wrap{
      overflow-x:auto;
    }
    .rf-table{
      width:100%;
      border-collapse:collapse;
      min-width:1120px;
      font-size:.8rem;
    }
    .rf-table thead th{
      background:#f9fafb;
      font-weight:700;
      text-align:center;
      font-size:.75rem;
      color:#374151;
      padding:9px 10px;
      border-bottom:1px solid #e5e7eb;
      white-space:nowrap;
    }
    .rf-table tbody td{
      padding:9px 10px;
      border-bottom:1px solid #f1f5f9;
      text-align:center;
      vertical-align:middle;
      color:#111827;
    }
    .rf-row-self{
      background:#eff6ff;
    }
    .rf-name-self{
      font-weight:700;
      color:#1d4ed8;
    }
    .rf-muted{
      color:#6b7280;
    }
    .rf-ticket-box{
      max-height:240px;
      overflow:auto;
      border:1px solid #e5e7eb;
      border-radius:12px;
      padding:10px;
      background:#fafafa;
    }
    .rf-number-chip{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:48px;
      padding:.35rem .6rem;
      border-radius:999px;
      border:1px solid #d1d5db;
      background:#fff;
      font-size:.72rem;
      margin:0 6px 6px 0;
      font-weight:700;
      color:#111827;
    }
    .rf-number-chip-self{
      background:#dbeafe;
      border-color:#93c5fd;
      color:#1d4ed8;
    }
    .rf-form-note{
      color:#6b7280;
      font-size:.78rem;
      margin-top:4px;
    }
    .rf-purchase-grid{
      display:grid;
      grid-template-columns:1fr;
      gap:10px;
    }
    .rf-purchase-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }
    .rf-winner-box{
      border:1px solid #dcfce7;
      background:#f0fdf4;
      color:#166534;
      border-radius:12px;
      padding:12px;
      font-weight:700;
    }
    .rf-ended-box{
      border:1px solid #fee2e2;
      background:#fef2f2;
      color:#991b1b;
      border-radius:12px;
      padding:12px;
      font-weight:700;
    }
    .rf-blackout{
      display:inline-block;
      background:#111827;
      color:#111827;
      border-radius:6px;
      padding:.15rem .45rem;
      min-width:130px;
      user-select:none;
    }
    .rf-wheel-card{
      display:flex;
      flex-direction:column;
    }
    .rf-wheel-controls{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:12px;
    }
    .rf-wheel-tools{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }
    .rf-wheel-stage{
      position:relative;
      width:50%;
      max-width:50%;
      aspect-ratio:1 / 1;
      margin:0 auto;
      border-radius:16px;
      border:1px solid #d1d5db;
      background:#f8fafc;
      overflow:hidden;
    }
    .rf-wheel-canvas{
      width:100%;
      height:100%;
      display:block;
      cursor:grab;
      background:#ffffff;
    }
    .rf-wheel-canvas.rf-dragging{
      cursor:grabbing;
    }
    .rf-wheel-pointer{
      position:absolute;
      top:10px;
      left:50%;
      transform:translateX(-50%);
      width:0;
      height:0;
      border-left:18px solid transparent;
      border-right:18px solid transparent;
      border-top:32px solid #dc2626;
      z-index:6;
      filter:drop-shadow(0 2px 3px rgba(0,0,0,0.25));
    }
    .rf-wheel-countdown{
      position:absolute;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      font-size:5rem;
      font-weight:800;
      color:#111827;
      background:rgba(255,255,255,0.72);
      z-index:7;
    }
    .rf-wheel-reveal{
      margin-top:12px;
      display:flex;
      flex-direction:column;
      gap:10px;
      align-items:center;
      text-align:center;
    }
    .rf-wheel-result{
      font-weight:800;
      font-size:1.02rem;
      color:#111827;
    }
    .rf-wheel-result-number{
      color:#111827;
      font-weight:800;
    }
    .rf-winner-overlay{
      position:absolute;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      z-index:8;
      pointer-events:none;
    }
    .rf-winner-overlay-box{
      background:rgba(17,24,39,0.92);
      color:#ffffff;
      border-radius:16px;
      padding:20px 24px;
      text-align:center;
      box-shadow:0 18px 40px rgba(0,0,0,0.25);
      min-width:300px;
      max-width:80%;
    }
    .rf-winner-overlay-title{
      font-size:1rem;
      margin-bottom:8px;
      opacity:.95;
    }
    .rf-winner-overlay-main{
      font-size:1.7rem;
      font-weight:800;
      line-height:1.2;
      word-break:break-word;
    }
    .rf-confetti{
      position:absolute;
      inset:0;
      pointer-events:none;
      z-index:9;
      background:transparent !important;
      background-color:transparent !important;
    }
    #raffleConfetti{
      background:transparent !important;
      background-color:transparent !important;
    }
    .rf-ticket-select{
      width:100%;
      min-height:220px;
      border:1px solid #d1d5db;
      border-radius:12px;
      background:#fff;
      overflow:auto;
      padding:10px;
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      align-content:flex-start;
    }
    .rf-ticket-option{
      position:relative;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:64px;
      padding:.48rem .7rem;
      border-radius:999px;
      border:1px solid #d1d5db;
      background:#ffffff;
      color:#000000;
      font-size:.76rem;
      font-weight:700;
      cursor:pointer;
      user-select:none;
      transition:all .12s ease;
    }
    .rf-ticket-option span{
      color:inherit !important;
      background:transparent !important;
    }
    .rf-ticket-option:hover{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#000000 !important;
      color:#ffffff !important;
      box-shadow:none !important;
    }
    .rf-ticket-option:hover span{
      color:#ffffff !important;
      background:transparent !important;
    }
    .rf-ticket-option input{
      position:absolute;
      opacity:0;
      pointer-events:none;
    }
    .rf-ticket-option.is-selected{
      background:#ffffff;
      border-color:#000000;
      color:#000000;
      box-shadow:0 0 0 1px rgba(0,0,0,0.12) inset;
    }
    .rf-ticket-option.is-selected:hover{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#000000 !important;
      color:#ffffff !important;
      box-shadow:none !important;
    }
    .rf-ticket-option.is-selected:hover span{
      color:#ffffff !important;
      background:transparent !important;
    }
    .rf-icon-btn{
      width:34px;
      height:34px;
      border-radius:999px;
      border:1px solid #d1d5db;
      background:#ffffff;
      color:#111827;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      font-size:1.15rem;
      font-weight:800;
      line-height:1;
      cursor:pointer;
      transition:all .12s ease;
    }
    .rf-icon-btn:hover{
      background:#f3f4f6;
      border-color:#9ca3af;
    }
    .rf-confirm-overlay{
      position:fixed;
      inset:0;
      background:rgba(15,23,42,0.45);
      display:none;
      align-items:center;
      justify-content:center;
      z-index:2000;
      padding:16px;
    }
    .rf-confirm-box{
      width:100%;
      max-width:430px;
      background:#ffffff;
      border-radius:18px;
      border:1px solid #d1d5db;
      box-shadow:0 24px 60px rgba(15,23,42,0.28);
      padding:20px;
      text-align:center;
    }
    .rf-confirm-title{
      font-size:1.1rem;
      font-weight:800;
      color:#111827;
      margin-bottom:10px;
    }
    .rf-confirm-text{
      color:#4b5563;
      font-size:.92rem;
      margin-bottom:16px;
    }
    .rf-confirm-actions{
      display:flex;
      gap:10px;
      justify-content:center;
      flex-wrap:wrap;
    }
    .rf-tag-card{
      border:1px solid #e5e7eb;
      border-radius:12px;
      padding:14px;
      background:#fafafa;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .rf-tag-label{
      font-size:.78rem;
      color:#6b7280;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.04em;
    }
    .rf-tag-value{
      font-size:1rem;
      font-weight:800;
      color:#111827;
    }
    .rf-tag-hidden{
      display:inline-block;
      background:#111827;
      color:#111827;
      border-radius:6px;
      padding:.18rem .55rem;
      min-width:170px;
      user-select:none;
    }
    .rf-verified-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:.25rem .55rem;
      border-radius:999px;
      background:#2563eb;
      border:1px solid #1d4ed8;
      color:#ffffff;
      font-size:.68rem;
      font-weight:800;
      white-space:nowrap;
    }
    .rf-paid-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:.25rem .55rem;
      border-radius:999px;
      background:#f0fdf4;
      border:1px solid #86efac;
      color:#166534;
      font-size:.68rem;
      font-weight:800;
      white-space:nowrap;
    }
    :root[data-pv-theme="dark"] .rf-wheel-stage{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#d4af37 !important;
    }
    :root[data-pv-theme="dark"] .rf-wheel-canvas{
      background:#000000 !important;
      background-color:#000000 !important;
    }
    :root[data-pv-theme="dark"] .rf-confetti,
    :root[data-pv-theme="dark"] #raffleConfetti{
      background:transparent !important;
      background-color:transparent !important;
    }
    :root[data-pv-theme="dark"] .rf-wheel-pointer{
      top:10px !important;
      left:50% !important;
      transform:translateX(-50%) !important;
      width:0 !important;
      height:0 !important;
      background:transparent !important;
      background-color:transparent !important;
      border-left:18px solid transparent !important;
      border-right:18px solid transparent !important;
      border-top:32px solid #d4af37 !important;
      border-bottom:0 !important;
      border-radius:0 !important;
      filter:drop-shadow(0 2px 3px rgba(212,175,55,0.35)) !important;
    }
    :root[data-pv-theme="dark"] .rf-wheel-pointer::after{
      display:none !important;
      content:none !important;
    }
    :root[data-pv-theme="dark"] .rf-wheel-countdown{
      color:#d4af37 !important;
      background:rgba(42,42,42,0.84) !important;
      background-color:rgba(42,42,42,0.84) !important;
    }
    :root[data-pv-theme="dark"] .rf-winner-overlay-box{
      background:rgba(0,0,0,0.94) !important;
      color:#d4af37 !important;
      border:1px solid #d4af37 !important;
    }
    :root[data-pv-theme="dark"] .rf-winner-overlay-box *{
      color:#d4af37 !important;
    }
    :root[data-pv-theme="dark"] .rf-ticket-select{
      background:#000000 !important;
      background-color:#000000 !important;
      border-color:#d4af37 !important;
    }
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option{
      background:#d4af37 !important;
      background-color:#d4af37 !important;
      color:#000000 !important;
      border-color:#d4af37 !important;
      box-shadow:none !important;
    }
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option span{
      color:#000000 !important;
      background:transparent !important;
    }
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:not(.is-selected):hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:focus,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:active,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:hover,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:focus,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:active{
      background:#000000 !important;
      background-color:#000000 !important;
      color:#d4af37 !important;
      border-color:#d4af37 !important;
      box-shadow:none !important;
      filter:none !important;
    }
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:not(.is-selected):hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:focus span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option:active span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:hover span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:focus span,
    :root[data-pv-theme="dark"] .rf-ticket-select .rf-ticket-option.is-selected:active span{
      color:#d4af37 !important;
      background:transparent !important;
    }
    @media (max-width: 992px){
      .rf-stat-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
      .rf-wheel-stage{
        width:90%;
        max-width:90%;
      }
    }
  </style>

  <div class="rf-page-stack">
    <section class="rf-card">
      <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
          <h1 class="rf-title"><%= @raffle.title %></h1>
          <div class="rf-sub">
            <%= @raffle.raffle_kind == "mini" ? "Mini Raffle" : "Raffle" %>
            <% if @raffle.raffle_kind == "mini" && @raffle.main_raffle.present? %>
              · Main Raffle: <%= @raffle.main_raffle.title %>
            <% end %>
            · Hosted by <%= @raffle.host.username %>
            · Created <%= time_ago_in_words(@raffle.created_at) %> ago
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <%= link_to "Back", raffles_path, class: "btn btn-outline-secondary btn-sm" %>

          <% if is_host && is_active %>
            <%= button_to "End Raffle", end_raffle_raffle_path(@raffle), method: :post, class: "btn btn-outline-danger btn-sm", form: { data: { turbo_confirm: "Are you sure you want to end this raffle?" } } %>
          <% end %>

          <% if is_host && is_active && @raffle.sold_out? %>
            <%= button_to "Run Raffle", run_raffle_raffle_path(@raffle), method: :post, class: "btn btn-success btn-sm", form: { class: "rf-run-raffle-form" } %>
          <% end %>
        </div>
      </div>

      <div class="rf-stat-grid">
        <div class="rf-stat">
          <div class="rf-stat-label">Ticket Price</div>
          <div class="rf-stat-value"><%= number_to_currency(@raffle.ticket_price_eur, unit: "€") %></div>
        </div>
        <div class="rf-stat">
          <div class="rf-stat-label">Sold</div>
          <div class="rf-stat-value"><%= @raffle.sold_tickets_count %> / <%= @raffle.total_tickets %></div>
        </div>
        <div class="rf-stat">
          <div class="rf-stat-label">Tickets Left</div>
          <div class="rf-stat-value"><%= @raffle.tickets_left %></div>
        </div>
        <div class="rf-stat">
          <div class="rf-stat-label">Amount Paid</div>
          <div class="rf-stat-value"><%= number_to_currency(@paid_amount_cents.to_i / 100.0, unit: "€") %></div>
        </div>
        <div class="rf-stat">
          <div class="rf-stat-label">Status</div>
          <div class="rf-stat-value"><%= @raffle.status.capitalize %></div>
        </div>
      </div>

      <% if @raffle.photos.attached? %>
        <div class="rf-gallery">
          <% @raffle.photos.first(4).each do |photo| %>
            <%= image_tag url_for(photo), alt: "" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="rf-card">
      <h2 class="h5 mb-3">Participants</h2>
      <div class="rf-table-wrap">
        <table class="rf-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Tickets</th>
              <th>Numbers</th>
              <% if is_host %>
                <th>Reason</th>
              <% end %>
              <th>Paid</th>
              <th>Verified</th>
              <th>Paid Amount</th>
              <th>Total Amount</th>
              <% if is_host %>
                <th>Revolut Tag</th>
                <th>Actions</th>
              <% elsif is_active %>
                <th>Actions</th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% if @participant_rows.any? %>
              <% @participant_rows.each do |row| %>
                <% is_self_row = current_user && row[:user_id].to_i == current_user.id.to_i %>
                <tr class="<%= 'rf-row-self' if is_self_row %>">
                  <td class="<%= 'rf-name-self' if is_self_row %>"><%= row[:display_name] %></td>
                  <td><%= row[:ticket_count] %></td>
                  <td><%= row[:ticket_numbers].map { |n| "##{n}" }.join(", ") %></td>

                  <% if is_host %>
                    <td><%= row[:assignment_reason].presence || "-" %></td>
                  <% end %>

                  <td>
                    <% if row[:paid_all] %>
                      <span class="rf-paid-badge">Paid</span>
                    <% else %>
                      <span class="rf-muted">No</span>
                    <% end %>
                  </td>
                  <td>
                    <% if row[:verified_all] %>
                      <span class="rf-verified-badge">Verified</span>
                    <% else %>
                      <span class="rf-muted">No</span>
                    <% end %>
                  </td>
                  <td><%= number_to_currency(row[:paid_amount_cents].to_i / 100.0, unit: "€") %></td>
                  <td><%= number_to_currency(row[:total_amount_cents].to_i / 100.0, unit: "€") %></td>

                  <% if is_host %>
                    <td>
                      <% if row[:revolut_tag].present? %>
                        <div class="rf-tag-label mb-1">Revolut Tag</div>
                        <div>
                          <span class="rf-tag-hidden" id="entrant_tag_hidden_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>">Hidden</span>
                          <span class="rf-tag-value" id="entrant_tag_value_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>" style="display:none;"><%= row[:revolut_tag] %></span>
                        </div>
                      <% else %>
                        <span class="rf-muted">None</span>
                      <% end %>
                    </td>
                    <td class="d-flex gap-2 justify-content-center flex-wrap">
                      <% if row[:revolut_tag].present? %>
                        <button
                          type="button"
                          class="btn btn-sm btn-outline-dark rf-reveal-entrant-tag-btn"
                          data-hidden-id="entrant_tag_hidden_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>"
                          data-value-id="entrant_tag_value_<%= "#{row[:user_id]}_#{row[:display_name].parameterize}" %>">
