<%
# Main page permissions and state flags
is_host = current_user && @raffle.host_id.to_i == current_user.id.to_i
is_completed = @raffle.completed?
is_active = @raffle.active?
auto_spin = params[:auto_spin].to_s == "1" || params[:reveal].to_s == "1"
admin_can_manage_raffles = defined?(@admin_can_manage_raffles) && @admin_can_manage_raffles
can_delete_raffle = current_user.present? && (is_host || admin_can_manage_raffles)

# Stores the current user id so completed raffle reveal state can be unique per user
current_user_id_for_reveal = current_user&.id.to_i

# Controls whether completed raffle winner details should be hidden until the wheel reveal finishes
winner_reveal_required = is_completed && current_user.present?
can_spin_reveal_winner = is_completed && current_user.present?

# Limits long participant names inside wheel and ticket chips
max_name_length = 24

# Converts sold tickets into compact wheel entries
ticket_items = @tickets.sort_by(&:ticket_number).map do |ticket|
  short_name = ticket.display_name.to_s[0, max_name_length]
  {
    number: ticket.ticket_number.to_i,
    name: short_name,
    label: "##{ticket.ticket_number} #{short_name}",
    user_id: ticket.user_id.to_i
  }
end

# Finds the current user's ticket numbers for the "Your Tickets" section
user_ticket_numbers =
  if current_user
    @tickets.select { |ticket| ticket.user_id.to_i == current_user.id.to_i }.map(&:ticket_number).sort
  else
    []
  end

# Core ticket and payment display data
available_numbers = @available_numbers || []
my_paid_all = @my_tickets.any? && @my_tickets.all?(&:paid?)
winning_name = @winning_ticket&.display_name.to_s
winning_number = @winning_ticket&.ticket_number.to_i
entrant_viewer = current_user.present? && @tickets.any? { |ticket| ticket.user_id.to_i == current_user.id.to_i }
my_revolut_tag = current_user&.revolut_tag.to_s
host_revolut_tag = @raffle.revolut_tag.to_s
assignment_reason_options = ["Mini Raffle", "Free Ticket(s)"]

# Builds a simple non-overlapping star display from an average score.
stars = lambda do |avg|
  value = avg.to_f
  value = 0.0 if value < 0
  value = 5.0 if value > 5

  rounded = ((value * 2).round / 2.0)
  full = rounded.floor
  half = (rounded - full) >= 0.5

  parts = []
  full.times { parts << '<span class="pv-rf-rating-star">★</span>' }
  parts << '<span class="pv-rf-rating-half">½</span>' if half

  %(<span class="pv-rf-rating-stars">#{parts.join}</span>).html_safe
end

host_stats = defined?(@host_stats) && @host_stats ? @host_stats : { avg: 0.0, count: 0 }
reviews = defined?(@reviews) && @reviews ? @reviews : []
can_give_review = defined?(@can_give_review) ? @can_give_review : false
already_reviewed_host = defined?(@already_reviewed_host) ? @already_reviewed_host : false
viewer_is_raffle_winner = defined?(@viewer_is_raffle_winner) ? @viewer_is_raffle_winner : false
review_form_id = "raffle-give-review-form-#{@raffle.id}"
