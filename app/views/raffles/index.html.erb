  <%# Custom confirmation pop-up used before deleting raffles %>
  <div class="rf-delete-confirm-overlay" id="raffleDeleteConfirmOverlay" aria-hidden="true">
    <div class="rf-delete-confirm-box">
      <div class="rf-delete-confirm-text">Are you sure you want to delete this raffle?</div>
      <div class="rf-delete-confirm-actions">
        <button type="button" class="rf-delete-confirm-yes" id="raffleDeleteConfirmYes">Yes</button>
        <button type="button" class="rf-delete-confirm-no" id="raffleDeleteConfirmNo">No</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      let pendingRaffleDeleteForm = null

      function initRaffleTabs() {
        const buttons = Array.from(document.querySelectorAll("[data-rf-tab-target]"));
        const panels = Array.from(document.querySelectorAll("[data-rf-tab-panel]"));
        if (!buttons.length || !panels.length) return;

        buttons.forEach(function (button) {
          if (button.dataset.rfBound === "1") return;
          button.dataset.rfBound = "1";

          button.addEventListener("click", function () {
            const target = button.getAttribute("data-rf-tab-target");

            buttons.forEach(function (btn) {
              btn.classList.remove("active", "pv-tab-locked");
              btn.setAttribute("aria-pressed", "false");
            });

            panels.forEach(function (panel) {
              panel.classList.remove("active");
            });

            button.classList.add("active", "pv-tab-locked");
            button.setAttribute("aria-pressed", "true");

            const panel = document.querySelector('[data-rf-tab-panel="' + target + '"]');
            if (panel) panel.classList.add("active");
          });
        });
      }

      function applyRevealState(row) {
        const entrantHide = row.getAttribute("data-entrant-hide") === "1";
        const revealKey = row.getAttribute("data-reveal-key");
        const revealed = revealKey && localStorage.getItem(revealKey) === "1";

        const winnerHidden = row.querySelector(".rf-winner-hidden");
        const winnerShown = row.querySelector(".rf-winner-shown");
        const ticketHidden = row.querySelector(".rf-ticket-hidden");
        const ticketShown = row.querySelector(".rf-ticket-shown");
        const revealButton = row.querySelector(".rf-reveal-index-btn");
        const hostPlain = row.querySelector(".rf-host-plain");
        const hostLink = row.querySelector(".rf-host-link");

        if (!entrantHide) {
          if (winnerHidden) winnerHidden.style.display = "none";
          if (winnerShown) winnerShown.style.display = "";
          if (ticketHidden) ticketHidden.style.display = "none";
          if (ticketShown) ticketShown.style.display = "";
          if (revealButton) revealButton.style.display = "none";
          if (hostPlain) hostPlain.style.display = "";
          if (hostLink) hostLink.style.display = "none";
          return;
        }

        if (revealed) {
          if (winnerHidden) winnerHidden.style.display = "none";
          if (winnerShown) winnerShown.style.display = "";
          if (ticketHidden) ticketHidden.style.display = "none";
          if (ticketShown) ticketShown.style.display = "";
          if (revealButton) revealButton.style.display = "none";
          if (hostPlain) hostPlain.style.display = "none";
          if (hostLink) hostLink.style.display = "";
        } else {
          if (winnerHidden) winnerHidden.style.display = "";
          if (winnerShown) winnerShown.style.display = "none";
          if (ticketHidden) ticketHidden.style.display = "";
          if (ticketShown) ticketShown.style.display = "none";
          if (revealButton) revealButton.style.display = "";
          if (hostPlain) hostPlain.style.display = "";
          if (hostLink) hostLink.style.display = "none";
        }
      }

      function initCompletedRevealState() {
        document.querySelectorAll("[data-raffle-row-id]").forEach(function (row) {
          applyRevealState(row);
        });

        document.querySelectorAll(".rf-reveal-index-btn").forEach(function (button) {
          if (button.dataset.revealBound === "1") return;
          button.dataset.revealBound = "1";

          button.addEventListener("click", function () {
            const raffleId = button.getAttribute("data-raffle-id");
            if (!raffleId) return;

            const row = button.closest("[data-raffle-row-id]");
            if (!row) return;

            const revealKey = row.getAttribute("data-reveal-key");
            if (!revealKey) return;

            localStorage.setItem(revealKey, "1");
            applyRevealState(row);
          });
        });
      }

      function closeRaffleDeleteConfirm() {
        pendingRaffleDeleteForm = null

        const overlay = document.getElementById("raffleDeleteConfirmOverlay")
        if (!overlay) return

        overlay.style.display = "none"
        overlay.setAttribute("aria-hidden", "true")
      }

      function initRaffleDeleteConfirm() {
        const overlay = document.getElementById("raffleDeleteConfirmOverlay")
        const yesButton = document.getElementById("raffleDeleteConfirmYes")
        const noButton = document.getElementById("raffleDeleteConfirmNo")

        if (!overlay || !yesButton || !noButton) return
        if (overlay.dataset.bound === "1") return

        overlay.dataset.bound = "1"

        document.addEventListener("submit", function (event) {
          const form = event.target.closest(".rf-delete-confirm-form")
          if (!form) return
          if (form.dataset.confirmedDelete === "1") return

          event.preventDefault()

          pendingRaffleDeleteForm = form
          overlay.style.display = "flex"
          overlay.setAttribute("aria-hidden", "false")
        })

        noButton.addEventListener("click", function () {
          closeRaffleDeleteConfirm()
        })

        yesButton.addEventListener("click", function () {
          if (!pendingRaffleDeleteForm) return

          const form = pendingRaffleDeleteForm
          pendingRaffleDeleteForm = null

          overlay.style.display = "none"
          overlay.setAttribute("aria-hidden", "true")
          form.dataset.confirmedDelete = "1"

          if (form.requestSubmit) {
            form.requestSubmit()
          } else {
            form.submit()
          }
        })

        overlay.addEventListener("click", function (event) {
          if (event.target !== overlay) return

          closeRaffleDeleteConfirm()
        })
      }

