  <div class="rf-page-header">
    <div>
      <h1 class="rf-page-title">Raffles</h1>
      <p class="rf-subtitle mb-0">Host raffles, buy ticket numbers, and run completed raffles.</p>
    </div>

    <%# Shows the Host Raffle page for logged-in users, or a login pop-up for guests %>
    <% if raffle_logged_in %>
      <%= link_to "Host Raffle", new_raffle_path, class: "btn btn-success" %>
    <% else %>
      <%# Logged-out users see a login pop-up instead of being sent to the protected Host Raffle page %>
      <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#raffleHostLoginModal">
        Host Raffle
      </button>
    <% end %>
  </div>

  <%# Login modal shown when a logged-out user clicks Host Raffle %>
  <% unless raffle_logged_in %>
    <div class="modal fade" id="raffleHostLoginModal" tabindex="-1" aria-labelledby="raffleHostLoginModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="raffleHostLoginModalLabel">Log in to host raffle</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cancel"></button>
          </div>

          <div class="modal-body">
            <%= form_with url: login_path, method: :post, local: true do %>
              <div class="mb-3">
                <label class="form-label" for="raffle_host_login_username">Username</label>
                <%= text_field_tag :username, nil, class: "form-control", id: "raffle_host_login_username", required: true, autocomplete: "username" %>
              </div>

              <div class="mb-3">
                <label class="form-label" for="raffle_host_login_password">Password</label>
                <%= password_field_tag :password, nil, class: "form-control", id: "raffle_host_login_password", required: true, autocomplete: "current-password" %>
              </div>

              <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <%= submit_tag "Log in", class: "btn btn-primary" %>
              </div>
            <% end %>

            <hr class="my-3">

            <div class="text-center small">
              Don't have an account?
              <%= link_to "Register", register_path, class: "btn btn-link btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Filter form used to narrow down raffles by title, price, ticket count and ticket status %>
  <section class="rf-filter-card">
    <%= form_with url: raffles_path, method: :get, local: true do %>
      <div class="rf-filter-title">Filters</div>

      <div class="rf-filter-grid">
        <div>
          <label class="rf-filter-label">Search</label>
          <%= text_field_tag :q, filters[:q], class: "form-control form-control-sm", placeholder: "Title, host, raffle..." %>
        </div>

        <div>
          <label class="rf-filter-label">Min Ticket Price (€)</label>
          <%= number_field_tag :min_ticket_price, filters[:min_ticket_price], step: "0.01", min: 0, class: "form-control form-control-sm" %>
        </div>

        <div>
          <label class="rf-filter-label">Max Ticket Price (€)</label>
          <%= number_field_tag :max_ticket_price, filters[:max_ticket_price], step: "0.01", min: 0, class: "form-control form-control-sm" %>
        </div>

        <div>
          <label class="rf-filter-label">Min Tickets</label>
          <%= number_field_tag :min_tickets, filters[:min_tickets], step: 1, min: 0, class: "form-control form-control-sm" %>
        </div>

        <div>
