<%
# Collects the raffle groups prepared by the controller
main_active = @active_raffles || []
mini_active = @active_mini_raffles || []
completed = @completed_raffles || []
incompleted = @incompleted_raffles || []

# Stores the current user id so completed raffle reveal state can be unique per user
current_user_id_for_reveal = current_user&.id.to_i

# Stores the active filter values so the form keeps the user's selected filters
filters = @raffle_filters || {}

# Checks whether a user is logged in so the Host Raffle button can either open the form or show the login pop-up
raffle_logged_in = current_user.present?

# Checks whether the current viewer can delete raffles from the normal raffle pages
admin_can_manage_raffles = defined?(@admin_can_manage_raffles) && @admin_can_manage_raffles

# Loads review totals for raffle hosts so the Reviews column can match the marketplace and auction style
all_raffles_for_host_stats = main_active + mini_active + completed + incompleted
host_ids_for_stats = all_raffles_for_host_stats.map { |raffle| raffle.host_id.to_i }.reject(&:zero?).uniq

review_counts_by_seller_id =
  if defined?(Review) && host_ids_for_stats.any?
    Review.where(seller_id: host_ids_for_stats).group(:seller_id).count
  else
    {}
  end

review_avgs_by_seller_id =
  if defined?(Review) && host_ids_for_stats.any?
    Review.where(seller_id: host_ids_for_stats).group(:seller_id).average(:rating)
  else
    {}
  end

stars = lambda do |avg|
  value = avg.to_f
  value = 0.0 if value < 0
  value = 5.0 if value > 5

  rounded = ((value * 2).round / 2.0)
  full = rounded.floor
  half = (rounded - full) >= 0.5

  parts = []
  full.times { parts << '<span class="pv-acc-rating-star">★</span>' }
  parts << '<span class="pv-acc-rating-half">½</span>' if half

  %(<span class="pv-acc-rating-stars">#{parts.join}</span>).html_safe
end

# Builds the compact review text shown in the Reviews column
review_data_for = lambda do |user|
  next { avg: 0.0, count: 0 } unless user

  avg = review_avgs_by_seller_id[user.id].to_f
  count = review_counts_by_seller_id[user.id].to_i

  { avg: avg, count: count }
end

# Builds the compact location text shown in the Location column
location_text_for = lambda do |user|
  next "-" unless user && user.respond_to?(:country_code)

  code = user.country_code.to_s.strip
  next "-" if code.blank?

  if defined?(flag_emoji)
    flag_emoji(code)
  else
    code
  end
end

# Builds the hover title for the Location column
location_title_for = lambda do |user|
  next "" unless user && user.respond_to?(:country_code)

  code = user.country_code.to_s.strip
  next "" if code.blank?

  if defined?(country_name)
    country_name(code)
  else
    code
  end
end

# Checks whether the host has badges that should be displayed beside their raffle
host_admin_badge_for = lambda do |user|
  user && ((user.respond_to?(:admin?) && user.admin?) || (user.respond_to?(:admin) && !!user.admin))
end

# Builds a compact "time ago" label for raffle table rows
precise_time_ago = lambda do |time|
  next "-" if time.blank?

  seconds = (Time.current - time).to_i
  seconds = 0 if seconds < 0

  if seconds < 60
    "#{seconds}s ago"
  elsif seconds < 3600
    minutes = seconds / 60
    "#{minutes}m ago"
  elsif seconds < 86_400
    hours = seconds / 3600
    minutes = (seconds % 3600) / 60
    minutes.positive? ? "#{hours}h #{minutes}m ago" : "#{hours}h ago"
  elsif seconds < 2_592_000
    days = seconds / 86_400
    "#{days}d ago"
  elsif seconds < 31_536_000
    months = seconds / 2_592_000
    "#{months}mo ago"
  else
    years = seconds / 31_536_000
    "#{years}y ago"
  end
end
%>

