<%
require "json"

sets_data =
  begin
    raw = File.read(Rails.root.join("config", "sets.json"), encoding: "bom|utf-8")
    JSON.parse(raw)
  rescue
    {}
  end

type_map = {
  "etb" => "Elite Trainer Box",
  "pc_etb" => "Pokemon Center Elite Trainer Box",
  "booster_box" => "Booster Box",
  "booster_bundle" => "Booster Bundle",
  "booster_bundle_display" => "Booster Bundle Display",
  "enhanced_booster_box" => "Enhanced Booster Box",
  "ultra_premium_collection" => "Ultra Premium Collection",
  "upc" => "Ultra Premium Collection",
  "spc" => "Super Premium Collection",
  "mini_tin" => "Mini Tin",
  "mini_tin_display" => "Mini Tin Display"
}

titleize = lambda do |s|
  s.to_s.tr("_"," ").tr("-"," ").split.map(&:capitalize).join(" ")
end

split_type_variant = lambda do |t|
  s = t.to_s
  down = s.downcase
  idx = down.index("--v-")
  if idx
    base = s[0...idx].to_s
    raw = s[(idx + 4)..-1].to_s
    variant = raw.tr("_"," ").tr("-"," ").split.map(&:capitalize).join(" ")
    [base.to_s, variant.to_s]
  else
    [s.to_s, ""]
  end
end

display_type = lambda do |listing|
  src = listing.respond_to?(:route_type) ? listing.route_type.to_s : ""
  src = listing.respond_to?(:product_type_name) ? listing.product_type_name.to_s : src if src.blank?
  base, variant = split_type_variant.call(src)
  base_key = base.to_s.downcase
  base_name = type_map[base_key].presence || titleize.call(base)
  variant = variant.to_s.strip
  variant.present? ? "#{base_name} (#{variant})" : base_name
end

era_for = lambda do |slug|
  s = sets_data[slug.to_s] || sets_data.values.find { |x| x["slug"].to_s == slug.to_s }
  s ? s["era"].to_s : ""
end

admin_badge_asset = "badges/adminbadge.png"
is_admin = defined?(@is_admin) ? !!@is_admin : (@user.respond_to?(:admin) && !!@user.admin)

listings =
  if defined?(@listings) && @listings
    @listings
  else
    []
  end

listings = listings.select { |l| l.respond_to?(:status) ? l.status.to_s == "active" : true }
%>

<div class="container py-4">
  <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
    <div>
      <h2 class="mb-2"><%= @user.username %></h2>

      <p class="mb-2">
        Country:
        <span style="font-size: 1.2rem; line-height: 1; display:inline-block; position:relative; top:3px;" title="<%= country_name(@user.country_code) %>">
          <%= flag_emoji(@user.country_code) %>
        </span>
      </p>

      <p class="mb-0">
        Badges:
        <% if is_admin %>
          <span title="Admin" aria-label="Admin" style="display:inline-block; position:relative; top:2px;">
            <%= image_tag admin_badge_asset, alt: "Admin", title: "Admin", style: "height:22px;width:22px;display:inline-block;object-fit:contain;" %>
          </span>
        <% else %>
          <span class="text-muted">None</span>
        <% end %>
      </p>
    </div>

    <div class="text-end">
      <div class="badge bg-light text-dark border mb-1">
        Reviews: <%= number_with_precision(@reviews_avg.to_f, precision: 1) %>/5 (<%= @reviews_count.to_i %>)
      </div>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-between mb-2">
    <h5 class="mb-0">Marketplace Listings</h5>
    <div class="small text-muted"><%= listings.size %> listing<%= listings.size == 1 ? "" : "s" %></div>
  </div>

  <% if listings.any? %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-sm mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Era</th>
              <th>Set</th>
              <th>Product Type</th>
              <th>Condition</th>
              <th>Price</th>
              <th>Quantity</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% listings.each do |l| %>
              <tr>
                <td><%= era_for.call(l.set_slug).presence || "-" %></td>
                <td><%= l.set_name.presence || l.set_slug.presence || "-" %></td>
                <td><%= display_type.call(l) %></td>
                <td><%= l.condition %></td>
                <td><%= number_to_currency(l.price_cents.to_i / 100.0, unit: "€") %></td>
                <td><%= l.quantity %></td>
                <td class="text-end">
                  <%= link_to "View", marketplace_listing_path(l), class: "btn btn-sm btn-outline-primary" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card">
      <div class="card-body t