<%# Edit page for an existing community post. Only the owner or an admin can reach this page through the controller. %>
<%
  selected_channel_value = @community_post.channel.presence || CommunityPost::CHANNELS.first
%>

<div class="container py-4" style="max-width:820px;">
  <style>
    .community-edit-card{background:#fff;border:1px solid #e5e7eb;border-radius:1.25rem;box-shadow:0 12px 30px rgba(15,23,42,.06);padding:1rem}
    .community-edit-title{margin:0 0 .35rem;font-size:1.45rem;font-weight:800}
    .community-edit-subtitle{margin:0 0 1rem;color:#6b7280;font-size:.9rem}
    .community-edit-label{font-size:.8rem;font-weight:700;color:#4b5563;margin-bottom:.45rem}
    .community-edit-textarea{width:100%;min-height:140px;border:1px solid #d1d5db;border-radius:1rem;padding:.9rem 1rem;font-size:.98rem;resize:vertical;outline:none}
    .community-edit-textarea:focus{border-color:#111827;box-shadow:0 0 0 3px rgba(17,24,39,.08)}
    .community-edit-select{border-radius:1rem}
    .community-edit-images{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:.75rem;margin-top:.75rem}
    .community-edit-image-card{border:1px solid #e5e7eb;border-radius:1rem;overflow:hidden;background:#f8fafc}
    .community-edit-image{width:100%;height:120px;object-fit:cover;display:block}
    .community-edit-remove{padding:.55rem;font-size:.78rem}
    .community-edit-actions{display:flex;justify-content:flex-end;gap:.5rem;flex-wrap:wrap;margin-top:1rem}
  </style>

  <div class="mb-3">
    <%= link_to "← Back to Community", community_path(channel: selected_channel_value, anchor: "community-post-#{@community_post.id}"), class: "btn btn-link p-0" %>
  </div>

  <section class="community-edit-card">
    <h1 class="community-edit-title">Edit Community Post</h1>
    <p class="community-edit-subtitle">Update your post text, move it to another channel, add images, or remove existing images.</p>

    <%= form_with model: @community_post, url: community_post_path(@community_post), method: :patch, local: true do |f| %>
      <div class="mb-3">
        <div class="community-edit-label">Channel</div>
        <%= f.select :channel,
              options_for_select(CommunityPost::CHANNEL_LABELS.map { |value, label| [label, value] }, selected_channel_value),
              {},
              class: "form-select community-edit-select" %>
      </div>

      <div class="mb-3">
        <div class="community-edit-label">Post Body</div>
        <%= f.text_area :body,
              class: "community-edit-textarea",
              maxlength: CommunityPost::MAX_BODY_LENGTH,
              rows: 6,
              placeholder: "Update your community post..." %>
        <div class="form-text">Max 2000 characters.</div>
      </div>

      <%# Existing images can be kept or removed one by one. %>
      <% if @community_post.images.attached? %>
        <div class="mb-3">
          <div class="community-edit-label">Current Images</div>
          <div class="community-edit-images">
            <% @community_post.images.attachments.each do |attachment| %>
              <div class="community-edit-image-card">
                <%= image_tag url_for(attachment), class: "community-edit-image", alt: "Community post image" %>
                <div class="community-edit-remove">
                  <div class="form-check">
                    <%= check_box_tag "community_post[remove_image_ids][]", attachment.id, false, class: "form-check-input", id: "remove_community_image_#{attachment.id}" %>
                    <label class="form-check-label" for="remove_community_image_<%= attachment.id %>">Remove image</label>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# New images are added to the post without automatically deleting the existing images. %>
      <div class="mb-3">
        <div class="community-edit-label">Add More Images</div>
        <%= f.file_field :images,
              multiple: true,
              accept: "image/png,image/jpeg,image/jpg,image/webp,image/gif",
              class: "form-control" %>
        <div class="form-text">You can have up to 10 images total.</div>
      </div>

      <div class="community-edit-actions">
        <%= link_to "Cancel", community_path(channel: selected_channel_value, anchor: "community-post-#{@community_post.id}"), class: "btn btn-outline-secondary" %>
        <%= f.submit "Save Changes", class: "btn btn-dark" %>
      </div>
    <% end %>
  </section>
</div>